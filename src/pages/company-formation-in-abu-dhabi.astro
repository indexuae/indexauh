---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+973", label: "BH +973" },
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1", label: "US +1" },
]

const purposes = [
  {
    title: "Market Entry",
    body: "Entrepreneurs and investors are attracted to Abu Dhabi's thriving economy and strategic location. Establishing a company here is a gateway to accessing the UAE and wider Gulf markets.",
  },
  {
    title: "Legal Compliance",
    body: "Registering your business ensures that it complies with UAE laws and regulations. This includes obtaining the necessary permits and licenses to operate legally within Abu Dhabi.",
  },
  {
    title: "Access to Investment Opportunities",
    body: "Abu Dhabi offers various incentives and investment opportunities, such as free zones and tax benefits, which can be leveraged through proper company formation.",
  },
  {
    title: "Enhanced Credibility",
    body: "A registered business demonstrates professionalism and commitment, instilling trust in customers, partners, and investors. It also allows you to build a solid business reputation.",
  },
]

const whyIndex = [
  {
    title: "Expert Guidance",
    body: "Index Office Services boasts extensive experience and expertise in company formation in Abu Dhabi. Their team of professionals can guide you through every step of the process, ensuring compliance with local regulations.",
  },
  {
    title: "Efficiency with Regard to Time",
    body: "In the corporate world, time equals money. Index Office Services streamlines the setup process, reducing administrative delays, and allowing you to start your operations sooner.",
  },
  {
    title: "Comprehensive Services",
    body: "Index Office Services offers a one-stop solution for all your business setup needs. From initial registration to obtaining permits and licenses, they handle it all, saving you the hassle of dealing with multiple authorities.",
  },
  {
    title: "Customized Solutions",
    body: "Every business is unique, and Index Office Services tailors their services to your specific requirements. This ensures that you receive a personalized approach that meets your business objectives.",
  },
  {
    title: "Local Knowledge",
    body: "Having a partner with local knowledge is invaluable. Index Office Services has familiarity with Abu Dhabi's business landscape ensures that you benefit from insider insights and connections.",
  },
  {
    title: "Transparency",
    body: "Index Office Services places a premium on transparency, ensuring that you understand every step of the process, including costs and timelines.",
  },
  {
    title: "Ongoing Support",
    body: "Beyond the initial setup, Index Office Services offers ongoing support, including accounting, tax, and administrative services, to help your business thrive in Abu Dhabi.",
  },
]

const faqs = [
  { q: "How can Indexauh help me set up a mainland company in Abu Dhabi?", a: "Indexauh guides clients through the entire process of establishing a mainland company in Abu Dhabi. This includes selecting the right business activity, preparing required documents, submitting applications to the Department of Economic Development, and ensuring compliance with local regulations. Clients can rely on Indexauh to handle all procedural steps efficiently." },
  { q: "Can Indexauh assist with choosing between a Free Zone and mainland company in Abu Dhabi?", a: "Yes. Indexauh evaluates your business goals, trade scope, and target markets to recommend the most suitable option. Free Zone companies are ideal for international trade and specific activities, while mainland companies allow unrestricted access to the UAE market. Indexauh explains these distinctions clearly to help you make the best decision." },
  { q: "Does Indexauh handle all document preparation for Abu Dhabi company formation?", a: "Indexauh prepares and organizes all documents required for company registration. This includes identity verification, corporate agreements, Memorandum of Association, and lease or office documents. The team ensures accuracy and completeness to avoid delays in approvals." },
  { q: "How does Indexauh guide clients through Abu Dhabi license approvals and registration?", a: "Indexauh manages communication with government authorities, submits license applications, tracks progress, and ensures all requirements are met. Clients benefit from a streamlined process with fewer administrative hurdles, reducing the time and effort needed for registration." },
  { q: "Can Indexauh help foreign investors understand 100% ownership rules in Abu Dhabi?", a: "Yes. Indexauh advises investors on the sectors and activities that allow full foreign ownership under current laws. This guidance ensures investors understand their rights, capital requirements, and regulatory obligations before starting a business." },
  { q: "Does Indexauh assist with securing a physical office or registered address for company registration?", a: "Yes. Indexauh helps clients find suitable office space that meets the legal requirements for company registration in Abu Dhabi. This ensures the company has a compliant registered address for licensing and official communications." },
  { q: "How can Indexauh support opening a corporate bank account in Abu Dhabi?", a: "Indexauh assists clients in selecting a suitable bank, preparing the required documentation, and coordinating appointments. This support ensures the bank account setup aligns with local regulations and business needs." },
  { q: "Can Indexauh help with PRO services and visas after company registration?", a: "Yes. Indexauh provides full PRO services, including employee and investor visa processing, labor approvals, and government correspondence. Clients can rely on these services for smooth post-registration operations in Abu Dhabi." },
  { q: "Does Indexauh provide guidance on Abu Dhabi business compliance and post-registration requirements?", a: "Indexauh advises on ongoing compliance, such as labor law requirements, visa renewals, license renewal, and other legal obligations. This ensures your company operates in full compliance with Abu Dhabi regulations." },
  { q: "How does Indexauh support startups and small businesses in choosing the right company structure in Abu Dhabi?", a: "Indexauh evaluates each client's business plan, goals, and resources to recommend the optimal structure, such as LLC, branch, or Free Zone entity. The team also guides startups through cost estimation, license selection, and process management, making setup simpler and faster." },
]
---

<BaseLayout
  title="Company Formation in Abu Dhabi | Business Setup Services"
  description="Start your company formation in Abu Dhabi with Indexauh. Our experienced team ensures smooth documentation and quick setup to help you setup your business."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .company-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 24px; transition: all 0.25s; }
  .company-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 300px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .three-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-9.webp"
    alt="Company Formation in Abu Dhabi"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      COMPANY FORMATION<br/>IN ABU DHABI
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      Company formation in Abu Dhabi, also known as business registration or business establishment, is a crucial process for entrepreneurs and businesses looking to thrive in this dynamic emirate. By choosing Index Office Services as your partner, you can navigate the complexities of business registration with ease, giving your venture the best chance for success in this vibrant and dynamic emirate.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ PURPOSE OF COMPANY FORMATION ════ -->
