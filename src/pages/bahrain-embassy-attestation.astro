  { step: "03", title: "We Process Everything", desc: "We process them through UAE MOFA and Bahrain Embassy attestation on your behalf." },
  { step: "04", title: "Receive Attested Docs", desc: "Receive your fully attested documents safely — no multiple visits needed." },
]

const whyChoose = [
  { title: "25+ Years of Experience", desc: "More than 25 years handling certificate attestation and embassy procedures across the UAE with proven expertise." },
  { title: "MOFA & Embassy Coordination", desc: "We directly coordinate Bahrain Embassy attestation and MOFA attestation Bahrain procedures on your behalf." },
  { title: "Pre-Submission Document Review", desc: "Our experts review all documents before submission to identify and resolve issues before they cause rejection." },
  { title: "Translation Coordination", desc: "We assist with approved Arabic and English translation services to ensure full compliance with Bahrain authorities." },
  { title: "Pickup and Delivery Support", desc: "Convenient document pickup and delivery service available across the UAE for a hassle-free experience." },
