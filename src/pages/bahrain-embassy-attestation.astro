const processStepsInbound = [
  { step: "01", title: "Ministry of Foreign Affairs Bahrain Attestation", desc: "The Bahrain Ministry of Foreign Affairs authenticates the document at the source." },
  { step: "02", title: "Bahrain Embassy Verification", desc: "The Bahrain Embassy reviews the document for UAE acceptance." },
  { step: "03", title: "UAE MOFA Attestation", desc: "After completion, the documents become legally accepted in the UAE." },
