---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whenNeeded = [
  "Employment visa",
  "Professional license",
  "Family visa",
  "Higher education",
  "Business setup",
  "Equivalency approval",
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Marriage certificate attestation",
      "Birth certificate attestation",
      "German Divorce Certificate Attestation",
      "German Death Certificate Attestation",
      "Police Clearance Certificate Attestation",
      "Good Conduct Certificate Attestation",
      "Single Status Certificate Attestation",
      "Experience Certificate Attestation",
      "Salary Certificate Attestation",
      "Affidavit Attestation",
    ],
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "German Degree attestation for UAE",
      "German Diploma certificate Attestation",
      "German PhD Certificate Attestation",
      "German Engineering Certificate Attestation",
      "German Nursing Certificate Attestation",
      "German Medical Certificate Attestation",
      "German Technical Certificate Attestation",
      "German School Leaving Certificate Attestation",
      "German Higher Secondary Certificate Attestation",
    ],
  },
  {
    category: "Commercial Documents",
    icon: "⚖️",
    docs: [
      "Power of Attorney Attestation",
      "Memorandum of Association Attestation",
      "Articles of Association Attestation",
      "Commercial Invoice Attestation",
      "Board Resolution Attestation",
      "Certificate of Incorporation Attestation",
      "Trade License Attestation",
      "Company Registration Certificate Attestation",
      "Commercial License",
    ],
  },
]

const processSteps = [
  { step: "01", title: "Notary Attestation in Germany", desc: "The document gets notarized by authorized authorities in Germany." },
  { step: "02", title: "State or Regional Authentication", desc: "The concerned government department verifies the document." },
  { step: "03", title: "Germany Embassy Attestation in UAE", desc: "The German Embassy confirms the document for UAE use." },
  { step: "04", title: "MOFA Attestation in UAE", desc: "The UAE Ministry of Foreign Affairs gives the final stamp." },
]

const docsRequired = [
  "Original certificate",
  "Passport copy",
  "Visa copy",
  "Authorization letter",
]

const timingFactors = [
  "Type of document submitted",
  "Issuing authority or state in Germany",
  "Requirement for Germany certificate verification",
  "Germany Embassy processing time in UAE",
  "UAE MOFA processing time",
  "Public holidays in Germany or UAE",
]

const feeFactors = [
  "Type of document",
  "Number of certificates",
  "Embassy fees",
  "MOFA fees",
  "Legal Translation requirement",
  "Urgent processing request",
]

const challenges = [
  "Submitting laminated certificates",
  "Sending unclear copies",
  "Ignoring translation requirements",
  "Skipping required steps",
  "Not confirming employer requirements",
]

const getStartedSteps = [
  { step: "01", title: "Contact Our Team", desc: "Reach out by phone or chat online. A team member will get back to you promptly." },
  { step: "02", title: "Document Review", desc: "We check your certificate and confirm the required process with a clear timeline and cost estimate." },
  { step: "03", title: "Secure Processing", desc: "Our team handles the complete document attestation for Germany, coordinating with the embassy and MOFA." },
  { step: "04", title: "Final Delivery", desc: "Once completed, collect your document or request delivery across the UAE." },
]

const whyChoose = [
  { title: "25+ Years of Experience", desc: "Extensive experience in certificate attestation across 100+ countries including Germany." },
  { title: "Clear Step-by-Step Guidance", desc: "We explain the process clearly before starting, so you always know what to expect." },
  { title: "Transparent Pricing", desc: "Full cost breakdown is provided before we begin — no hidden charges." },
  { title: "Quick Response & Updates", desc: "Fast replies and regular updates so you are never left wondering about your documents." },
  { title: "Careful Document Handling", desc: "Strict protocols ensure your original documents are handled and tracked securely." },
  { title: "UAE-Wide Service Support", desc: "We provide service support across all emirates for Germany certificate attestation." },
]

const faqs = [
  { q: "Can I complete certificate attestation in Germany without the original document?", a: "Original documents are generally required for embassy processing." },
  { q: "How is German certificate verification different from attestation?", a: "Verification confirms authenticity. Attestation confirms legal acceptance in the UAE." },
  { q: "How long does document attestation for Germany take?", a: "Time varies based on document type and authority approval. Our team gives you a clear estimate before starting." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Germany Certificate Attestation in UAE | Indexauh"
  description="Germany certificate attestation in UAE with 25+ years of experience. Fast, clear process for certificate attestation Germany and document verification."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr 1fr !important; }
    .get-started-grid { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-97.webp"
    alt="Germany Certificate Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Germany Attestation</span>
      <span class="idx-pill">25 Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      GERMANY CERTIFICATE ATTESTATION<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Germany certificate attestation confirms that your German document is legally accepted in the UAE. IndexAUH has over 25 years of experience handling the full process — from embassy coordination to final MOFA approval.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What is Germany Certificate Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Germany certificate attestation confirms that your German document is legally accepted in the UAE. It is an official approval from the concerned authorities.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        IndexAUH has over 25 years of experience in handling Germany certificate attestation across the UAE. Our team understands embassy and MOFA procedures clearly and manages the process without confusion. Get your documents processed correctly the first time with expert support you can trust.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Key Insight — Verification vs Attestation</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          German certificate verification confirms authenticity. Attestation confirms legal acceptance in the UAE. Both serve different purposes — we help you understand exactly which one you need.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/germany-flag.webp" alt="Germany document attestation UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Notary · State Auth · German Embassy · MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Germany attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHEN DO YOU NEED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-11.webp" alt="When to get Germany certificate attestation" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">When You Need Attestation</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Visa · Business · Education · Family</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Key Situations</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Purpose of German Certificate Attestation in the UAE</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          UAE authorities need proof that your German document is original and approved by the right government departments. Without proper Germany certificate attestation, your visa or job process can stop. You may need it for:
        </p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {whenNeeded.map(item => (
            <div style="display:flex;align-items:flex-start;gap:12px;background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:14px 18px;">
              <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:2px;">→</span>
              <p style="font-size:0.9rem;color:#374151;line-height:1.6;margin:0;">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our German Certificate Attestation Services in UAE"
  description="We handle attestation for a wide range of document categories. Always check with the requesting authority to confirm exactly what form of attestation they require."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Germany attestation"
  docTypes={docTypes}
  country="germany"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Germany attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Process of German Documents Attestation for UAE</h2>
      </div>
    </div>

    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;">
      <div style="display:flex;flex-direction:column;gap:14px;">
        {processSteps.map(s => (
          <div class="step-card">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}
        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:14px;padding:18px;margin-top:4px;">
          <h3 style="color:#1A202C;font-size:0.88rem;font-weight:700;margin:0 0 6px;">Germany Certificate Verification</h3>
          <p style="font-size:0.88rem;color:#4B5563;line-height:1.7;margin:0;">German certificate verification is different from attestation. Verification confirms that your certificate is issued by a recognized institution. Attestation makes your certificate legally valid in the UAE. We help you understand the exact requirement so you avoid delays.</p>
        </div>
      </div>

      <div style="display:flex;flex-direction:column;gap:20px;">
        <!-- Documents Required -->
        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Our team reviews your documents before starting to avoid rejection. You usually need:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {docsRequired.map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{d}
              </div>
            ))}
          </div>
        </div>

        <!-- Timing -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">How Long Does German Attestation Take?</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Certificate attestation Germany usually takes several working days. The timeline depends on:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {timingFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>

        <!-- Fees -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Germany Certificate Attestation Cost in UAE</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">German Attestation involves multiple authorities, so pricing varies case by case. We explain the full breakdown clearly before proceeding. Cost depends on:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {feeFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ CHALLENGES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="two-col" style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What to Watch For</p>
        <h2 style="font-size:1.8rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Common Mistakes That Cause Delays</h2>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:24px;">
          Many applicants face delays due to small errors. Proper guidance helps prevent rejection. Our team checks documents carefully before submission.
        </p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {challenges.map(c => (
            <div style="display:flex;align-items:center;gap:12px;background:#FFF5F5;border:1px solid #FED7D7;border-radius:10px;padding:12px 16px;">
              <span style="color:#E53E3E;font-weight:bold;font-size:1rem;flex-shrink:0;">!</span>
              <p style="font-size:0.88rem;color:#4B5563;line-height:1.5;margin:0;">{c}</p>
            </div>
          ))}
        </div>
      </div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-16.webp" alt="Common mistakes in Germany attestation" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">Avoid Delays</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">We check everything before submission</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ GET STARTED ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;text-align:center;">
    <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Simple Process</p>
    <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">How to Get Your Germany Attestation Done with IndexAUH?</h2>
    <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0 auto 44px;max-width:560px;">
      Getting Germany certificate attestation through IndexAUH is simple. Follow these steps to begin.
    </p>

    <div class="get-started-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:18px;text-align:left;">
