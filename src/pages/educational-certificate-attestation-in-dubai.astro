  { step: "04", title: "National Level Attestation", desc: "The foreign affairs authority approves the document. They verify all previous steps. Therefore, your certificate becomes valid for international use." },
  { step: "05", title: "<a href='/embassy-attestation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>UAE Embassy Attestation</a>", desc: "The UAE Embassy reviews and attests the document. This aligns it with UAE requirements. Hence, accuracy in earlier stages is important." },
