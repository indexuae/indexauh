  { step: "07", title: "Certified Translation", desc: "Translation is required for documents not in English or Arabic. For example, <a href='/legal-translation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>certified translators in the UAE</a> handle this step for smooth processing." }
