<!-- ════ SCRIPTS ════ -->
<script>
(function(){
  // ── Country tabs ──
  const tabBtns = document.querySelectorAll('.country-tab-btn');
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const target = (btn as HTMLElement).dataset.tab;
      
      // Hide all panels, show matching one
      ['india','uk','usa','phil','pak'].forEach(id => {
        const el = document.getElementById('country-' + id) as HTMLElement;
        if(el) {
          el.style.display = id === target ? 'block' : 'none';
        }
      });
    });
  });

  // ── FAQ accordion ──
  document.querySelectorAll('.faq-item').forEach(item => {
    item.querySelector('.faq-q')?.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(x => {
        x.classList.remove('open');
        (x.querySelector('.faq-a') as HTMLElement).classList.remove('open');
      });
      if (!isOpen) {
        item.classList.add('open');
        (item.querySelector('.faq-a') as HTMLElement).classList.add('open');
      }
    });
  });
})();
</script>

