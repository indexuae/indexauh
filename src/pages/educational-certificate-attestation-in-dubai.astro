    name: "Philippines",
    steps: [
      "DFA (Department of Foreign Affairs) authentication",
      "UAE Embassy attestation in the Philippines",
      "MOFA attestation in UAE"
    ],
    desc: "Additional verification may be required for healthcare and regulated professions."
  },
  {
    id: "pak",
    name: "Pakistan",
    steps: [
      "IBCC verification (for school documents)",
      "HEC attestation (for degree certificates)",
      "Ministry of Foreign Affairs attestation",
      "UAE Embassy attestation in Pakistan",
      "MOFA attestation in UAE"
    ],
    desc: "Document verification may depend on university and degree type."
  }
]

const commonDocs = [
  { title: "Original Educational Certificate", desc: "Degrees, diplomas, or mark sheets must be original, intact, and unlaminated for verification." },
  { title: "Valid Passport Copy", desc: "Clear copy of the passport’s photo page and personal details page." },
  { title: "Authorization Letter", desc: "Required if a third-party representative or service provider is submitting the documents on your behalf." }
]

const specificDocs = [
  { title: "Academic Transcripts", desc: "May be required depending on the university, employer, or licensing authority for detailed academic verification." },
  { title: "Emirates ID & UAE Visa Copy", desc: "Required mainly for applicants already residing in the UAE or when processing is handled locally." },
  { title: "University Verification Letter", desc: "May be requested in certain cases such as professional licensing (DHA, MOH, DOH), DataFlow verification, or when additional authentication is required by authorities." }
]

const employmentProfessions = [
  "Engineers", "Teachers", "Nurses", "Doctors", "Accountants", "Managers", "Skilled professionals", "Government sector employees"
]

const equivalencySteps = [
  "Educational certificate attestation", "UAE Embassy attestation", "MOFA attestation", "DataFlow verification", "University verification", "Additional educational assessments"
]

const purposes = [
  { title: "Verification of Authenticity", desc: "Dubai authorities use the attestation process to confirm the authenticity of educational certificates and documents. This helps in maintaining the integrity and credibility of the education system within the country." },
  { title: "Compliance with Regulations", desc: "It is a legal requirement for individuals to have their educational documents attested when applying for jobs, pursuing higher education, or securing a residence permit in Dubai. The attestation process ensures compliance with the UAE’s regulations and laws." },
  { title: "Standardization of Credentials", desc: "Attestation aligns foreign educational credentials with the standards set by the UAE, providing a uniform and recognizable format for evaluating educational qualifications." },
  { title: "Prevention of Fraud", desc: "Educational certificate attestation helps in preventing document fraud by validating the legitimacy of academic records presented by individuals seeking opportunities in Dubai." }
]

const benefits = [
  { title: "Expertise and Experience", desc: "Index Office Services possesses extensive experience and expertise in handling the <a href='/certificate-attestation-in-the-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>certificate attestation in UAE</a> process for educational certificates. Their professionals are well-versed in the intricacies of the attestation procedure in Dubai, ensuring a smooth and efficient process." },
  { title: "Comprehensive Service", desc: "Index Office Services provides end-to-end services for educational certificate attestation, covering all necessary steps, from document collection to final attestation. This ensures a hassle-free experience for clients, saving them time and effort." },
  { title: "Knowledge of Local Regulations", desc: "Understanding the local laws and regulations governing educational certificate attestation is crucial. Index Office Services is well-acquainted with the specific requirements set by Dubai authorities, guaranteeing accurate and compliant attestation services." },
  { title: "Timely Processing", desc: "Index Office Services prioritizes timely processing of educational certificate attestation, enabling clients to meet deadlines for job applications, academic pursuits, or other professional endeavours in Dubai." },
  { title: "Customer Support", desc: "Index Office Services offers excellent customer support, addressing queries and concerns promptly. Our dedicated team is available to assist clients throughout the attestation process, ensuring a high level of satisfaction." }
]

const rejectionReasons = [
  "Minor spelling differences on document vs. passport",
  "Missing embassy authentication from the issuing country",
  "Missing MOFA UAE approval at the final stage",
  "Incorrect attestation order from home country to UAE",
  "Faded seals, tears, or laminated documents that reduce clarity",
  "Certificates from unverified or unrecognized institutions",
  "Name or date mismatch during state-level authentication",
  "Absence of transcripts or additional university proof when requested"
]

const faqs = [
  { q: "How long does educational certificate attestation take in UAE?", a: "Processing time varies based on the issuing country and verification steps. Some cases finish quickly within a few days, while others take longer due to embassy or institutional checks." },
  { q: "Is the original educational certificate required for attestation?", a: "Yes. The original degree, diploma, or certificate is mandatory. Copies cannot be attested at the primary level because authorities must verify stamp validity and paper authenticity." },
  { q: "Do all certificates need UAE Embassy attestation?", a: "Yes. To be accepted for MOFA attestation inside the UAE, the document must first be authenticated by the UAE Embassy located in the country of origin." },
  { q: "Can online or distance degrees be attested?", a: "Online and distance learning degrees can be attested if the issuing institution is fully recognized by the home country’s education board, and if they comply with the UAE Ministry of Education's equivalency guidelines." },
  { q: "Can someone submit documents on my behalf?", a: "Yes, you do not need to travel. A registered agency like Index Office Services can handle all steps securely on your behalf with a standard authorization letter." }
]
---

<BaseLayout title="Educational Certificate Attestation in Dubai — Index Office Services" 
description="Educational certificate attestation in Dubai with 25+ years of experience. Fast UAE document support from Index Office Services. Call today."
>

<style>
  .sec-inner { position: relative; z-index: 1; }

  /* pills */
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }

  /* form */
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }

  /* document type card */
  .doc-type-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; transition: all 0.25s; }
  .doc-type-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.06); transform: translateY(-3px); }

  /* steps cards */
  .step-card { display: flex; align-items: flex-start; gap: 18px; padding: 20px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }

  /* tabs countries */
  .country-tab-btn { padding: 10px 22px; border-radius: 9999px; font-size: 0.85rem; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s; }
  .country-tab-btn.active { background: #2D3748; color: #fff; }
  .country-tab-btn:not(.active) { background: #F0FFFE; color: #2D3748; border: 1px solid #B2F5EA; }

  /* list items */
  .check-item { display: flex; align-items: flex-start; gap: 10px; padding: 12px 16px; background: #fff; border: 1px solid #e0e7ef; border-radius: 10px; font-size: 0.85rem; color: #1A202C; font-weight: 500; }
  
  /* warning item */
  .warning-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px; background: #FFF5F5; border: 1px solid #FEB2B2; border-radius: 10px; font-size: 0.82rem; color: #9B2C2C; font-weight: 500; }

  /* FAQ */
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 200px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

 @media(max-width:768px){
  .about-hero-title { font-size: 2rem !important; }
  .about-hero-desc { font-size: 0.88rem !important; }
  .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
  .benefits-grid { grid-template-columns: 1fr !important; }
  .offices-flex { flex-direction: column !important; }
  .step-sticky { position: static !important; }
}
</style>

<!-- ════════════ HERO — image bg, centered text ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <!-- Background image -->
  <img
    src="/images/img-16.webp"
    alt="Educational Certificate Attestation"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <!-- Dark overlay -->
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.88) 0%,rgba(45,55,72,0.82) 100%);"></div>
  <!-- Dot pattern -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="about-hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      EDUCATIONAL CERTIFICATE ATTESTATION<br/>IN DUBAI
    </h1>
    <p class="about-hero-desc" style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:640px;">
      Educational certificate attestation in Dubai is required for work, study, migration, and professional licensing in the UAE. Most people understand its importance only when an authority requests verified academic documents.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>
  
<div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:start;">
  <!-- Left Text -->
  <div>
    <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
      <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
    </p>
    <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Why is Educational Certificate Attestation Important?</h2>
    
    <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
      The process confirms that your educational certificate is genuine and accepted for official use in the UAE. It supports employment visas, higher education, family sponsorship, DHA licensing, and UAE equivalency applications.
    </p>
    <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
      At Index Office Services, we handle attestation with over 25 years of experience in document authentication and embassy procedures. Our team manages each step with careful handling, clear guidance, and consistent updates across different countries and authorities.
    </p>

    <div style="background:#FFF5F5;border:1px solid #FEB2B2;border-radius:12px;padding:18px;margin-bottom:16px;">
      <h3 style="color:#9B2C2C;font-size:0.95rem;font-weight:700;margin:0 0 10px;">⚠ Without proper attestation, your documents may not be accepted for:</h3>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:6px;">
        {["Employment visa approvals","Professional licensing","Salary classification","Higher education admission","Immigration applications","Equivalency certification","Government sector jobs"].map(item => (
          <div style="font-size:0.82rem;color:#9B2C2C;display:flex;align-items:center;gap:6px;">
            <span style="font-weight:bold;">•</span> {item}
          </div>
        ))}
      </div>
    </div>

    <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
      Many applicants only realize the importance of educational certificate attestation when their employment visa, professional licensing, or university application gets delayed due to incomplete document verification. UAE authorities carefully verify academic qualifications before approving official applications.
    </p>

    <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;margin-bottom:24px;">
      <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">What is Educational Certificate Attestation?</h3>
      <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
        Educational certificate attestation is the process of verifying the authenticity of academic documents issued by schools, colleges, universities, or educational institutions. The attestation process confirms that the certificate is genuine and accepted for official use in the UAE.
      </p>
    </div>
  </div>

  <!-- Right side: image + Commonly Required For -->
  <div style="display:flex;flex-direction:column;gap:24px;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
      <img src="/images/img-16.webp" alt="Educational Attestation documents" style="width:100%;height:340px;object-fit:cover;" />
      <div style="position:absolute;bottom:20px;left:-16px;background:#2D3748;color:#fff;padding:12px 18px;border-radius:12px;font-size:0.9rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
        25+ Years Experience
      </div>
    </div>

    <div>
      <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 12px;">Commonly Required For:</h3>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px;">
        {["Employment visa processing","UAE work permit applications","Higher education admissions","Professional licensing","DHA, HAAD, MOH licensing","UAE equivalency certificate","Family visa applications","Immigration purposes","Government-related procedures"].map(item => (
          <div style="display:flex;align-items:center;gap:8px;font-size:0.82rem;color:#4B5563;background:#F0FFFE;border:1px solid #B2F5EA;padding:8px 12px;border-radius:8px;">
            <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span> {item}
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
  </div>
</section>

<!-- ════ CERTIFICATES THAT REQUIRE ATTESTATION ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>
  
  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1.6fr;gap:52px;align-items:center;margin-bottom:52px;" class="split-grid">
      <!-- Left image -->
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.1);">
        <img src="/images/img-52.webp" alt="University graduation certificates" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.6) 100%);"></div>
        <div style="position:absolute;bottom:18px;left:18px;right:18px;">
          <p style="color:#fff;font-size:0.98rem;font-weight:700;margin:0;line-height:1.4;">Degrees · Diplomas · Transcripts · Nursing &amp; Medical</p>
        </div>
      </div>
      <!-- Right text -->
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Education Types</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 16px;">Educational Certificates That Require Attestation</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">Different academic qualifications require attestation for different purposes in the UAE — from employment visas to DHA licensing. Below are the most commonly requested types.</p>
       <div style="display:flex;flex-direction:column;gap:14px;">
  {requiredAttestationDocs.map(d => (
    <div style="display:flex;align-items:flex-start;gap:14px;background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:16px;">
      <span style="font-size:1.6rem;flex-shrink:0;">{d.icon}</span>
      <div>
        <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 4px;" set:html={d.title}></h3>
        <p style="font-size:0.9rem;color:#4B5563;line-height:1.6;margin:0;">{d.desc}</p>
      </div>
    </div>
  ))}
</div>
      </div>
    </div>
  </div>
</section>

<!-- ════ STEP BY STEP PROCESS ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Authentication Workflow</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">Steps For Educational Certificate Attestation</h2>
      <p style="color:#6B7280;font-size:1.05rem;max-width:560px;margin:0 auto;">A clear process saves time and prevents rejection. Follow these steps to complete attestation smoothly.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;" class="split-grid">
      <!-- Steps list -->
      <div style="display:flex;flex-direction:column;gap:14px;">
