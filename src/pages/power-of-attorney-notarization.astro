---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const attestationConfirms = [
  "The document is real",
  "The signatures are verified",
  "The issuing authority is officially recognized",
  "The document can be used legally in the UAE",
]

const poaTypes = [
  {
    category: "General Power of Attorney",
    icon: "📋",
    desc: "A General Power of Attorney gives broad authority to an appointed person to manage multiple legal, financial, and administrative matters on your behalf. It is commonly used when someone needs ongoing assistance while living abroad or is unable to handle important responsibilities personally.",
    listIntro: "A General POA may be used for:",
    items: [
      "Managing bank accounts",
      "Signing contracts",
      "Handling government formalities",
      "Representing the principal before authorities",
      "Managing personal assets",
    ],
  },
  {
    category: "Special Power of Attorney",
    icon: "🎯",
    desc: "A Special Power of Attorney is created for one specific purpose. The authority is limited to the task mentioned in the document and cannot be used for unrelated matters.",
    listIntro: "It is commonly issued for:",
    items: [
      "Selling or purchasing a property",
      "Completing a specific banking transaction",
      "Representing someone in a particular legal matter",
      "Signing a defined agreement",
      "Collecting official documents",
    ],
  },
  {
    category: "Property Power of Attorney",
    icon: "🏠",
    desc: "A Property Power of Attorney allows another person to manage real estate transactions on behalf of the property owner. This type is often used by people living outside the UAE or those unable to attend property procedures personally.",
    listIntro: "It may be used for:",
    items: [
      "Buying or selling property",
      "Leasing residential or commercial units",
      "Property registration",
      "Mortgage-related formalities",
      "Property management and maintenance",
    ],
  },
  {
    category: "Corporate Power of Attorney",
    icon: "🏢",
    desc: "A Corporate Power of Attorney allows a company to authorize an individual to act on its behalf for business and legal matters. The powers granted depend on the company's requirements and internal approvals. Many organisations also require Power of Attorney legal services when appointing representatives for commercial transactions or regulatory procedures.",
    listIntro: "It is commonly used for:",
    items: [
      "Signing commercial agreements",
      "Representing the company before government departments",
      "Managing licensing procedures",
      "Handling corporate documentation",
      "Share transfers and company resolutions",
    ],
  },
  {
    category: "Financial Power of Attorney",
    icon: "💰",
    desc: "A Financial Power of Attorney gives someone authority to handle financial matters without giving them broader legal powers. It is suitable when the principal only wants assistance with money-related responsibilities.",
    listIntro: "It may include:",
    items: [
      "Operating bank accounts",
      "Paying bills and financial obligations",
      "Managing investments",
      "Handling insurance matters",
      "Collecting payments",
    ],
  },
  {
    category: "Personal and Family Power of Attorney",
    icon: "👨‍👩‍👧",
    desc: "This type of POA is used for personal matters involving family responsibilities or individual affairs. It allows a trusted person to manage specific personal obligations when the principal cannot be present.",
    listIntro: "It is commonly used for:",
    items: [
      "Child travel authorizations",
      "Sponsorship-related formalities",
      "Managing personal affairs during overseas travel",
      "Family-related legal documentation",
      "Collecting personal records and certificates",
    ],
  },
  {
    category: "Vehicle Power of Attorney",
    icon: "🚗",
    desc: "A Vehicle Power of Attorney authorizes another person to complete vehicle-related procedures on behalf of the owner. It is useful when buying, selling, transferring, or exporting a vehicle.",
    listIntro: "Common purposes include:",
    items: [
      "Vehicle sale or purchase",
      "Ownership transfer",
      "Vehicle registration",
      "Vehicle export",
      "Related RTA formalities",
    ],
  },
  {
    category: "Limited Power of Attorney",
    icon: "📝",
    desc: "A Limited Power of Attorney grants authority for a specific responsibility and for a defined period. Once the assigned task is completed or the validity period ends, the authority automatically comes to an end.",
    listIntro: "",
    items: [],
  },
  {
    category: "Durable Power of Attorney",
    icon: "🛡️",
    desc: "A Durable Power of Attorney is recognised in certain countries and continues to remain effective even if the person granting the authority later becomes unable to manage their own affairs. The acceptance of this type depends on the laws of both the issuing country and the country where it will be used.",
    listIntro: "",
    items: [],
  },
  {
    category: "Medical Power of Attorney",
    icon: "🏥",
    desc: "A Medical Power of Attorney allows an appointed individual to make healthcare decisions on behalf of another person when permitted under the applicable laws. The availability and legal recognition of this type of POA vary between jurisdictions and may not apply in every country.",
    listIntro: "",
    items: [],
  },
]

const outsideSteps = [
  { step: "01", title: "Notarization", desc: "The document is signed before a Notary Public in the country where the POA is issued." },
  { step: "02", title: "Home Country Ministry of Foreign Affairs", desc: "The document is authenticated by the Ministry of Foreign Affairs or the equivalent authority in the issuing country." },
  { step: "03", title: "UAE Embassy or Consulate", desc: "The UAE Embassy or Consulate verifies the previous attestations and legalizes the document for use in the UAE." },
  { step: "04", title: "UAE MOFA Attestation", desc: "After the document arrives in the UAE, it must receive final attestation from the UAE Ministry of Foreign Affairs. Once this stage is completed, the Power of Attorney Attestation Dubai process is generally complete." },
  { step: "05", title: "Legal Translation", desc: "When the document is prepared in a language other than Arabic, it should be translated by a legal translator approved by the UAE Ministry of Justice before submission to many authorities." },
]

const outsideSituations = [
  "Property transactions while living abroad",
  "Business representation",
  "Family or inheritance matters",
  "Banking authorizations",
  "Court-related procedures",
]

const insideSteps = [
  { step: "01", title: "Drafting", desc: "The document is prepared according to its intended legal purpose." },
  { step: "02", title: "Notary or Embassy", desc: "UAE residents generally complete notarization through Dubai Courts or the Abu Dhabi Judicial Department. For a Power of Attorney Abu Dhabi, the document follows the procedures established by the Abu Dhabi Judicial Department. Foreign nationals may also prepare certain POAs through their embassy or consulate, depending on their country's requirements." },
  { step: "03", title: "Electronic Notarization", desc: "Several UAE authorities now offer electronic notarization, allowing eligible documents to be signed and verified remotely. The exact process for a POA in UAE depends on the authority where the document will be submitted." },
  { step: "04", title: "MOFA Attestation", desc: "When the document will be used outside the UAE, additional MOFA attestation may be required before overseas acceptance." },
]

const insideUses = [
  "Property transactions",
  "Court representation",
  "Company matters",
  "Personal legal affairs",
]

const docsIndividual = [
  "Original passport and passport copy",
  "Emirates ID for UAE residents",
  "Valid UAE residence visa, where applicable",
  "Passport copy of the attorney (the person receiving authority)",
  "Draft Power of Attorney document",
  "Passport-size photographs, when requested by the authority",
  "Any supporting documents related to the purpose of the POA",
]

const docsCompany = [
  "Valid trade licence",
  "Memorandum of Association (MOA)",
  "Articles of Association (AOA), where applicable",
  "Board Resolution authorizing the POA",
  "Passport and Emirates ID of the authorized signatory",
  "Company stamp, when required",
  "Supporting commercial documents depending on the transaction",
]

const additionalByType = [
  { cat: "Property Power of Attorney", icon: "🏠", items: ["Title deed or property purchase agreement", "Property details", "Mortgage documents, when applicable"] },
  { cat: "Vehicle Power of Attorney", icon: "🚗", items: ["Vehicle registration card", "Emirates Vehicle Gate or RTA documents, where required"] },
  { cat: "Financial Power of Attorney", icon: "💰", items: ["Bank account details", "Supporting financial documents requested by the bank"] },
  { cat: "Corporate or Commercial Power of Attorney", icon: "🏢", items: ["Commercial agreements", "Share transfer documents", "Company licences or approvals"] },
]

const docsOutsideUAE = [
  "Original Power of Attorney",
  "Notary Public certification",
  "Home country's Ministry of Foreign Affairs attestation",
  "UAE Embassy or Consulate attestation",
  "UAE MOFA attestation after arrival in the UAE",
  "Certified Arabic translation, when required",
]

const docsInsideUAE = [
  "Emirates ID or passport",
  "Draft Power of Attorney",
  "Passport details of the attorney",
  "Supporting documents related to the transaction",
  "Additional approvals for corporate or property matters, where applicable",
]

const rejectionReasons = [
  "Passport names that do not match the POA",
  "Expired identification documents",
  "Missing embassy or MOFA stamps",
  "Incorrect or incomplete legal translation",
  "Missing supporting documents",
  "Unsigned or improperly notarized POA",
  "Using an outdated document format",
]

const whyChooseHelp = [
  "Clear explanation of what your documents actually need, no guessing",
  "Handling full multi-step legalization and attestation flow",
  "Support for both personal and corporate POA services",
  "Helping avoid delays caused by missing or incorrect paperwork",
  "Coordinating cross-border approvals for smooth processing of power of attorney uae cases",
]

const faqs = [
  { q: "Can a Power of Attorney holder sell property?", a: "Yes, but only when the document clearly gives that authority. If it's a general POA, it may or may not include property rights. It really depends on how it was written." },
  { q: "What are Special Power of Attorney requirements?", a: "It should clearly mention the exact job the person is allowed to do. Nothing vague. Depending on where it's made, you may also need notarization and attestation before it can be used in the UAE." },
  { q: "Can I cancel a Power of Attorney after it is issued?", a: "Yes, you can revoke it. You'll need to follow the same legal channel where it was issued so it gets officially cancelled and no longer valid." },
  { q: "Does a Power of Attorney expire?", a: "Sometimes yes, sometimes no. Some are linked to a time period or specific task, and others stay active until they are cancelled. It depends on how the document is drafted." },
  { q: "Can one person hold more than one Power of Attorney?", a: "Yes, that's allowed. A single person can act under multiple POAs as long as each one is for a different purpose or different person." },
  { q: "Can more than one attorney be appointed in a single POA?", a: "Yes. You can name more than one person. The document should also say clearly whether they can act separately or need to act together." },
  { q: "Is a witness always required for a Power of Attorney?", a: "Not always. Some authorities ask for witnesses, some don't. It changes based on the country and the type of POA you are making." },
]
---

<BaseLayout
  title="Power of Attorney Attestation Services in UAE | Index Office Services"
  description="Power of attorney attestation services in UAE including POA drafting, attestation, and legal support. 25+ years experience. Contact us now!"
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .poa-type-card { background: #F8FAFF; border: 1px solid #eef0f6; border-radius: 16px; padding: 26px; transition: all 0.25s; }
  .poa-type-card:hover { border-color: #B2F5EA; box-shadow: 0 8px 24px rgba(56,178,172,0.08); }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 320px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .four-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr !important; }
    .img-first { order: -1 !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
    .get-started-grid { grid-template-columns: 1fr 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Power of Attorney Attestation Services in UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      Power of Attorney Attestation Services in UAE | Index Office Services
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 20px;max-width:660px;">
      A Power of Attorney is basically a legal way of letting someone act on your behalf. It could be for property, banking, business, court work, or even personal matters. Once this document is involved in UAE procedures, things like notarization and power of attorney attestation become important so it's accepted by banks, courts, and government offices without issues.
    </p>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Index Office Services has been working for 25 years in the UAE handling Power of Attorney drafting, processing, attestation, and document support for individuals and businesses across 100+ countries. The process isn't the same for everyone. It changes depending on where the POA is made and how it will be used in the UAE.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-btns">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Request POA Services &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ WHY ATTESTATION MATTERS ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Power of Attorney Dubai: Why Attestation Matters?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        When people search for Power of Attorney Dubai or POA Dubai, most of them are actually trying to figure out how to make their document valid for use here without running into rejection.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        A Power of Attorney in UAE is not automatically accepted unless it goes through the proper checks. If it's made outside the country, it almost always needs full legalization before UAE authorities will look at it.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:18px;">
        There's often confusion between drafting, notarization, legalization, and POA services in general. Each step does something different, and missing one can slow everything down.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">Attestation simply confirms a few key things:</p>
      <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;">
        {attestationConfirms.map(item => (
          <div style="display:flex;align-items:flex-start;gap:12px;background:#F8FAFF;border:1px solid #eef0f6;border-radius:10px;padding:12px 16px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:2px;">→</span>
            <p style="font-size:0.9rem;color:#374151;line-height:1.6;margin:0;">{item}</p>
          </div>
        ))}
      </div>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.75;margin:0;">
          That's where power of attorney attestation becomes the deciding step before anything gets accepted in courts or government departments.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-11.webp" alt="Power of Attorney notarization and attestation UAE" style="width:100%;height:460px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Draft · Notarize · Attest · Deliver</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete POA process handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:84px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          100+ Countries Covered
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ TYPES OF POA ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:48px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Our POA Services</p>
      <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Types of Power of Attorney in UAE</h2>
      <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;max-width:700px;margin:0 auto;">
        A Power of Attorney in UAE can be prepared in different formats depending on the authority you want to give another person. Some POAs provide broad legal powers, while others are limited to a single task. Choosing the correct type helps ensure the document serves its intended purpose.
      </p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;" class="three-col">
      {poaTypes.map(t => (
        <div class="poa-type-card">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
            <span style="font-size:1.5rem;">{t.icon}</span>
            <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0;">{t.category}</h3>
          </div>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">{t.desc}</p>
          {t.listIntro && <p style="font-size:0.85rem;color:#374151;font-weight:600;margin:0 0 8px;">{t.listIntro}</p>}
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;">
            {t.items.map(d => (
              <li style="display:flex;align-items:flex-start;gap:8px;font-size:0.88rem;color:#4B5563;line-height:1.5;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;margin-top:2px;">•</span>{d}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ POA DRAFTED OUTSIDE THE UAE ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:40px;">
      <img src="/images/img-7.webp" alt="POA drafted outside the UAE" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">POA Drafted Outside the UAE</h2>
      </div>
    </div>

    <p style="color:#4B5563;font-size:0.95rem;line-height:1.8;margin:0 0 8px;">
      When a Power of Attorney is prepared outside the UAE, it normally requires legalization before it can be accepted by UAE authorities.
    </p>
    <p style="color:#4B5563;font-size:0.95rem;line-height:1.8;margin:0 0 24px;">
      The process generally follows these steps.
    </p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:32px;" class="two-col">
      {outsideSteps.map(s => (
        <div class="step-card">
          <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
          <div>
            <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
            <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div style="background:#fff;border:1px solid #B2F5EA;border-radius:14px;padding:22px 26px;">
      <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 12px;">Common situations for overseas POAs</h3>
