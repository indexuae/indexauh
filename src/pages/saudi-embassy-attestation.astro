---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whoNeeds = [
  "Applying for a work visa or employment in Saudi Arabia",
  "Sending family or dependent visa applications",
  "Studying at a Saudi university",
  "Setting up a business or legal entity in Saudi Arabia",
  "Using documents for courts or government procedures",
]

const mandatory = [
  "Educational certificates",
  "Personal documents like birth and marriage certificates",
  "Commercial papers like contracts",
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Marriage certificate attestation for Saudi Arabia",
      "Saudi Police Clearance Certificate",
      "Birth certificate attestation in Saudi Arabia",
      "Saudi Divorce Certificate Attestation",
      "Death Certificate Attestation",
      "Transfer Certificate Attestation",
      "Medical Certificate Attestation",
      "Affidavit",
    ],
  },
  {
    category: "Educational Certificate Attestation",
    icon: "🎓",
    docs: [
      "Saudi Attestation for Degree Certificate",
      "Diploma Certificate Attestation for Saudi",
      "School leaving certificates",
      "Nursing Degree Certificate Attestation",
      "Master Degree Certificate Attestation Saudi",
      "Engineering Degree Certificate Attestation",
    ],
  },
  {
    category: "Commercial Documents Attestation",
    icon: "⚖️",
    docs: [
      "Memorandum of Association (MOA)",
      "Articles of Association (AOA)",
      "Certificate of Incorporation",
      "Board Resolutions",
      "Commercial Invoices",
      "Power of Attorney",
      "Business contracts and invoices",
      "Commercial License",
    ],
  },
]

const processRoutes = [
  {
    step: "01",
    title: "For Using UAE or Other Foreign Documents in Saudi Arabia",
    desc: "This applies to documents issued in the UAE or abroad and required for use in Saudi Arabia.",
    steps: [
      "Check and notarize your certificate. Make sure all details are correct, then get it notarized in the UAE, or in the country of issue if it's from elsewhere",
      "Get attestation from MOFA UAE or the local attestation office, confirming your certificate is real",
      "Submit to the Saudi embassy in Abu Dhabi or the Saudi consulate in Dubai for review and stamping",
      "Some documents, like degrees, may need translation into Arabic or Cultural Attache approval before they are ready to use in Saudi Arabia",
    ],
  },
  {
    step: "02",
    title: "For Using Saudi Issued Documents in the UAE",
    desc: "This applies to documents issued in Saudi Arabia and required for use in the UAE.",
    steps: [
      "Verify your documents in Saudi Arabia, checking that all details are correct with the proper authorities",
      "Get MOFA UAE attestation to confirm your documents are valid for use in the UAE",
      "Submit to the Saudi embassy in the UAE if additional approval is required for your documents",
      "Receive your fully attested documents, which can be delivered to your home",
    ],
  },
]

const timingFactors = [
  "Educational certificates like degrees or diplomas usually take a few days to a couple of weeks",
  "Personal documents like birth or marriage certificates can be faster or slightly longer depending on verification",
  "Commercial documents like contracts or company papers may take extra time if multiple approvals are needed",
]

const feeFactors = [
  "The type of document (degree, certificate, or commercial paper)",
  "The number of documents you need attested",
  "MOFA UAE fees for verification",
  "Saudi embassy fees",
  "Optional costs like translation or courier service",
]

const challenges = [
  "Missing MOFA UAE attestation",
  "Incorrect order of documents",
  "Name mismatches or incomplete details",
  "Non certified translations",
  "Using expired certificates or documents",
  "Missing supporting documents",
  "Trying to handle everything without guidance",
  "Not tracking your documents",
]

const requiredDocs = [
  "Original certificate or degree",
  "Passport copy",
  "Visa copy if required",
  "Authorization letter if someone submits on your behalf",
  "Supporting documents depending on type",
]

const getStartedSteps = [
  { step: "01", title: "Contact Indexauh", desc: "Reach out to us. Our team explains the requirements and guides you clearly." },
  { step: "02", title: "Submit Your Documents", desc: "Send your certificates safely. We ensure secure handling at every stage." },
  { step: "03", title: "Processing by Experts", desc: "Our team manages all steps with MOFA UAE and the Saudi embassy." },
  { step: "04", title: "Receive Attested Certificates", desc: "Your fully attested documents are delivered to your doorstep." },
]

const whyChoose = [
  { title: "25+ Years of Experience", desc: "Over 25 years of experience in UAE attestation services." },
  { title: "Accurate Processing", desc: "Accurate processing at every step of your Saudi embassy attestation." },
  { title: "Pickup & Delivery", desc: "Complete service including free pickup and delivery." },
  { title: "GCC-Wide Coverage", desc: "Services across UAE and GCC, with guidance for certificate attestation in Dubai and other types of documents." },
  { title: "Degree & Legal Translation Support", desc: "Support with degree attestation and legal translation." },
  { title: "Transparent & Reliable", desc: "Transparent fee breakdown, clear updates at every step, and peace of mind with no repeated submissions." },
]

const faqs = [
  { q: "Is Arabic translation required?", a: "Yes. Many documents, especially educational certificates and degrees, must be translated into Arabic before submission. The translation must be certified." },
  { q: "Can someone submit documents on my behalf?", a: "Yes. You can authorize a representative to submit your documents. They will need an authorization letter along with copies of your ID or passport." },
  { q: "What is the Saudi embassy attestation time for degrees?", a: "Processing time depends on the type of document. Degrees usually take a few days to a couple of weeks, depending on verification and embassy workload." },
  { q: "Do all degrees need Cultural Attache approval?", a: "Not all degrees require Cultural Attache verification. Only some educational certificates need this extra step, depending on the university and country of issue." },
  { q: "Can documents be submitted online?", a: "No, most documents need to be submitted physically to MOFA UAE and the Saudi embassy or consulate. Some initial guidance or tracking can be done online through services like Indexauh." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Saudi Embassy Attestation Services | Indexauh"
  description="Saudi Embassy Attestation in UAE backed by 25 years of proven experience. Hassle-free MOFA & embassy approval you can trust. Get started today."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .route-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; transition: all 0.25s; }
  .route-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .four-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Saudi Embassy Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Saudi Attestation</span>
      <span class="idx-pill">Embassy Attestation</span>
      <span class="idx-pill">25 Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      SAUDI EMBASSY ATTESTATION<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Attesting your documents with the Saudi embassy is important if you plan to study, work, or do business in Saudi Arabia. The Saudi embassy attestation in UAE confirms your certificates are genuine and accepted officially. At Indexauh, we have over 25 years of experience helping people complete attestation without delays. Our team manages every step, from MOFA UAE attestation to submission at the Saudi embassy in Abu Dhabi or the consulate in Dubai.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-btns">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW / WHAT IS IT ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is Saudi Embassy Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:18px;">
        Saudi embassy attestation is the process of getting your documents verified so that Saudi authorities accept them. The attestation involves two main steps: first, verification by MOFA UAE, then approval by the Saudi Arabia embassy. This makes your documents legally valid in Saudi Arabia. Whether your certificates are from the UAE or abroad, we guide you through the correct process so there are no mistakes.
      </p>
      <p style="color:#2D3748;font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px;">This is needed for:</p>
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px;">
        {mandatory.map(item => (
          <div style="display:flex;align-items:center;gap:12px;background:#F8FAFF;border:1px solid #eef0f6;border-radius:10px;padding:10px 14px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;">→</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">{item}</p>
          </div>
        ))}
      </div>
      <p style="color:#2D3748;font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px;">When you need this service:</p>
      <div style="display:flex;flex-direction:column;gap:8px;">
        {whoNeeds.map(item => (
          <div style="display:flex;align-items:flex-start;gap:12px;background:#F0FFFE;border:1px solid #B2F5EA;border-radius:10px;padding:10px 14px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:1px;">✓</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">{item}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/saudi-flag.webp" alt="Saudi embassy attestation UAE" style="width:100%;height:480px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Saudi Embassy · MOFA UAE · Full Legalization</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Saudi attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:90px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Saudi Attestation Services"
  description="It is needed for educational certificates, personal documents like birth and marriage certificates, and commercial papers like contracts."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Saudi attestation"
  docTypes={docTypes}
  country="saudi"
/>

<!-- ════ PROCESS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Saudi embassy attestation process" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Saudi Embassy Attestation Procedure</h2>
      </div>
    </div>

    <!-- Two routes side by side -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px;" class="two-col">
      {processRoutes.map(route => (
        <div class="route-card">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{route.step}</div>
            <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0;">{route.title}</h3>
          </div>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">{route.desc}</p>
          <p style="font-size:0.78rem;font-weight:700;color:#38B2AC;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 10px;">Steps Involved</p>
          <div style="display:flex;flex-direction:column;gap:8px;">
            {route.steps.map((s, idx) => (
              <div style="display:flex;align-items:flex-start;gap:10px;">
                <span style="background:#F0FFFE;border:1px solid #B2F5EA;color:#2D3748;font-weight:800;font-size:0.72rem;width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;">{idx + 1}</span>
                <p style="font-size:0.88rem;color:#4B5563;line-height:1.5;margin:0;">{s}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Required Documents -->
    <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;margin-bottom:24px;">
      <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required for Saudi Embassy Attestation</h3>
      <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">To avoid delays, you need:</p>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:9px;" class="two-col">
        {requiredDocs.map(f => (
          <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
            <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
          </div>
        ))}
      </div>
    </div>

    <!-- Timing & Fees -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;" class="two-col">
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Saudi Embassy Attestation Time</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">The time it takes to complete Saudi embassy attestation depends on the type of document and where it comes from:</p>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {timingFactors.map(f => (
            <div style="display:flex;align-items:flex-start;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
            </div>
          ))}
        </div>
      </div>
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Saudi Embassy Attestation Fees</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">The cost of Saudi attestation depends on:</p>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {feeFactors.map(f => (
            <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
            </div>
          ))}
        </div>
        <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">At Indexauh, we give you a clear cost breakdown before you start. You know exactly how much you will pay. There are no surprises, and you can choose the services you need.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ CHALLENGES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;" class="two-col">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What to Watch For</p>
        <h2 style="font-size:1.8rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Common Mistakes to Avoid</h2>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:24px;">
          Many applications face delays due to small but important errors. Our experience helps avoid these issues and ensures smooth attestation in Saudi Arabia without repeated submissions.
        </p>
        <div style="position:relative;border-radius:16px;overflow:hidden;box-shadow:0 12px 32px rgba(0,0,0,0.1);">
          <img
            src="/images/img-40.webp"
            alt="Common mistakes in Saudi document attestation"
            style="width:100%;height:320px;object-fit:cover;display:block;"
          />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
          <div style="position:absolute;bottom:16px;left:16px;right:16px;">
            <p style="color:#fff;font-size:0.88rem;font-weight:700;margin:0;">Avoid these mistakes for a smooth attestation process</p>
          </div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {challenges.map(c => (
          <div style="display:flex;align-items:center;gap:12px;background:#FFF5F5;border:1px solid #FED7D7;border-radius:10px;padding:14px 16px;">
            <span style="color:#E53E3E;font-weight:bold;font-size:1rem;flex-shrink:0;">!</span>
            <p style="font-size:0.9rem;color:#4B5563;line-height:1.5;margin:0;">{c}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ════ GET STARTED ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;text-align:center;">
