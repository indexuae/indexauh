---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whoNeeds = [
  "Employment visa processing",
  "Labour card and work permit",
  "Family visa or spouse sponsorship",
  "Higher education admissions",
  "Professional license applications",
  "Business registration and commercial approvals",
]

const mandatory = [
  "UAE government departments ask for attested documents to confirm they are genuine",
  "This protects the country from fake certificates",
  "Final approval from the Ministry of Foreign Affairs in the UAE makes your certificate officially valid",
]

const docTypes = [
  {
    category: "Personal Documents Attestation",
    icon: "👤",
    docs: [
      "Marriage certificate attestation",
      "Birth certificate attestation",
      "Divorce Certificate Attestation",
      "Death Certificate Attestation",
      "Police Clearance Certificate Attestation",
      "Medical Certificate Attestation",
      "Single Status Certificate Attestation",
      "Affidavit",
    ],
  },
  {
    category: "Educational Certificate Attestation",
    icon: "🎓",
    docs: [
      "Degree Certificate Attestation",
      "Diploma Certificate Attestation",
      "School Certificate Attestation",
      "Mark Sheets Attestation",
      "Technical Certificate Attestation",
      "Nursing Certificate Attestation",
      "Engineering Certificate Attestation",
      "Transcript Attestation",
    ],
  },
  {
    category: "Commercial Documents Attestation",
    icon: "⚖️",
    docs: [
      "Power of Attorney Attestation",
      "Company Incorporation Documents Attestation",
      "Memorandum of Association Attestation",
      "Articles of Association Attestation",
      "Board Resolution Attestation",
      "Commercial Invoice Attestation",
      "Commercial License",
    ],
  },
]

const processRoutes = [
  {
    step: "01",
    title: "Notary & Singapore Authentication",
    desc: "Your document must first receive local verification in Singapore before it can move on to embassy and UAE stages.",
    steps: [
      "Notary or initial verification in Singapore, confirming the authenticity of the certificate",
      "Singapore Academy of Law authentication, an important step in attestation of documents in Singapore",
    ],
  },
  {
    step: "02",
    title: "UAE Embassy & MOFA Attestation",
    desc: "Once authenticated in Singapore, your document is verified for use in the UAE and given final approval.",
    steps: [
      "UAE Embassy attestation in Singapore, where the document is verified for use in the UAE",
      "UAE Ministry of Foreign Affairs attestation once the document reaches the UAE, giving final approval so you can use your certificate officially",
    ],
  },
]

const emirates = [
  "Dubai",
  "Abu Dhabi",
  "Sharjah",
  "Ajman",
  "Ras Al Khaimah",
  "Fujairah",
]

const timingFactors = [
  "Normal processing may take several working days",
  "Express service is available for urgent cases",
  "Educational certificates can take slightly longer due to verification requirements in Singapore",
]

const feeFactors = [
  "Type of document",
  "Number of certificates",
  "Embassy charges",
  "MOFA fees",
  "Urgency of processing",
]

const challenges = [
  "Incorrect notarisation",
  "Missing authentication from Singapore authorities",
  "Embassy rejection due to incomplete documents",
  "Delay at MOFA stage",
]

const getStartedSteps = [
  { step: "01", title: "Contact Us", desc: "Call or send a copy of your certificate through WhatsApp or email." },
  { step: "02", title: "Document Review", desc: "Our experts check your document and confirm the exact process for Singapore Certificate Attestation." },
  { step: "03", title: "Processing and Updates", desc: "We handle every stage including authentication, embassy approval, and MOFA attestation. You receive regular updates." },
  { step: "04", title: "Safe Delivery", desc: "We return your completed document securely to your location in the UAE." },
]

const whyChoose = [
  { title: "25+ Years of Expertise", desc: "Over 25+ years of expertise in handling Singapore Certificate Attestation and other international documents." },
  { title: "Deep Procedural Knowledge", desc: "Deep knowledge of Singapore and UAE procedures." },
  { title: "Clear Communication", desc: "Clear communication at every stage of your attestation." },
  { title: "Fast Processing Support", desc: "Fast processing support to keep your timeline on track." },
  { title: "Dedicated Team Assistance", desc: "Dedicated team assistance throughout your case." },
  { title: "Offices in Dubai & Abu Dhabi", desc: "Offices in Dubai and Abu Dhabi for convenient access." },
]

const faqs = [
  { q: "Is Apostille enough for UAE use?", a: "No. UAE requires full attestation including embassy and MOFA approval." },
  { q: "Do I need original documents?", a: "Yes. Authorities require the original certificate." },
  { q: "Can someone else submit my documents?", a: "Yes. Our team can handle the complete process on your behalf." },
  { q: "Can I track my document status?", a: "Yes. We provide regular updates until completion." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Singapore Certificate Attestation in UAE | Index Office Services"
  description="Singapore Certificate Attestation in UAE by Index office services with 25+ years of experience. Fast, secure process with clear guidance."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .route-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; transition: all 0.25s; }
  .route-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  .emirate-pill { background: #F0FFFE; border: 1px solid #B2F5EA; color: #1A202C; font-weight: 700; font-size: 0.85rem; padding: 10px 18px; border-radius: 9999px; }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .four-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Singapore Certificate Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Singapore Attestation</span>
      <span class="idx-pill">MOFA Attestation</span>
      <span class="idx-pill">25 Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      SINGAPORE CERTIFICATE<br/>ATTESTATION IN UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Moving to the UAE for a job, family visa, higher studies, or business setup requires proper document approval. Singapore Certificate Attestation is the legal process that makes your Singapore-issued documents valid in the UAE. Without this approval, authorities will not accept your certificate. We are proud to be one of the best attestation service providers in the UAE with over 25+ years of experience.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-btns">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW / WHAT IS IT ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Situations That Require Singapore Certificate Attestation</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:18px;">
        UAE government departments ask for attested documents to confirm they are genuine. This protects the country from fake certificates. Singapore Certificate Attestation confirms that your document is real and legally accepted. UAE authorities check every stage carefully. Without proper attestation, your application can face rejection or delay.
      </p>
      <p style="color:#2D3748;font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px;">Important to know:</p>
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px;">
        {mandatory.map(item => (
          <div style="display:flex;align-items:center;gap:12px;background:#F8FAFF;border:1px solid #eef0f6;border-radius:10px;padding:10px 14px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;">→</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">{item}</p>
          </div>
        ))}
      </div>
      <p style="color:#2D3748;font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px;">You may need this service for:</p>
      <div style="display:flex;flex-direction:column;gap:8px;">
        {whoNeeds.map(item => (
          <div style="display:flex;align-items:flex-start;gap:12px;background:#F0FFFE;border:1px solid #B2F5EA;border-radius:10px;padding:10px 14px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:1px;">✓</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">{item}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/singapore-flag.webp" alt="Singapore certificate attestation UAE" style="width:100%;height:480px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Singapore Academy of Law · UAE Embassy · MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Singapore attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:90px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Singaporean Document Attestation Services"
  description="We handle attestation for a wide range of document categories across personal, educational, and commercial needs for use in the UAE."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Singapore attestation"
  docTypes={docTypes}
  country="singapore"
/>

<!-- ════ PROCESS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Singapore certificate attestation process" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Complete Process of Singapore Certificate Attestation for UAE</h2>
      </div>
    </div>

    <!-- Two routes side by side -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px;" class="two-col">
      {processRoutes.map(route => (
        <div class="route-card">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{route.step}</div>
            <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0;">{route.title}</h3>
          </div>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">{route.desc}</p>
          <p style="font-size:0.78rem;font-weight:700;color:#38B2AC;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 10px;">Steps Involved</p>
          <div style="display:flex;flex-direction:column;gap:8px;">
            {route.steps.map((s, idx) => (
              <div style="display:flex;align-items:flex-start;gap:10px;">
                <span style="background:#F0FFFE;border:1px solid #B2F5EA;color:#2D3748;font-weight:800;font-size:0.72rem;width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;">{idx + 1}</span>
                <p style="font-size:0.88rem;color:#4B5563;line-height:1.5;margin:0;">{s}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Emirates Coverage -->
    <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;margin-bottom:24px;">
      <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Singapore Certificate Attestation Across UAE</h3>
      <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 16px;">We provide services across all Emirates including:</p>
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:14px;">
        {emirates.map(e => (
          <span class="emirate-pill">{e}</span>
        ))}
      </div>
      <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">Your final attested document is accepted across the UAE once MOFA approval is completed.</p>
    </div>

    <!-- Timing & Fees -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;" class="two-col">
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">How Long Does It Take?</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">The time required depends on document type and authority approvals:</p>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {timingFactors.map(f => (
            <div style="display:flex;align-items:flex-start;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
            </div>
          ))}
        </div>
        <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">Our team guides you clearly about the timeline before starting your Singapore Certificate Attestation. We keep you informed throughout the process.</p>
      </div>
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">What Affects the Cost</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">The cost of Singapore Certificate Attestation depends on:</p>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {feeFactors.map(f => (
            <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
            </div>
          ))}
        </div>
        <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">Each case is different. We explain the full cost in advance so you know what to expect. There are no hidden surprises.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ CHALLENGES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;" class="two-col">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What to Watch For</p>
        <h2 style="font-size:1.8rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Common Challenges During Singapore Document Attestation</h2>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:24px;">
          Many people face problems due to lack of guidance. Professional support helps you avoid these mistakes. Our experience in attestation of documents in Singapore ensures smooth approval.
        </p>
        <div style="position:relative;border-radius:16px;overflow:hidden;box-shadow:0 12px 32px rgba(0,0,0,0.1);">
          <img
            src="/images/img-40.webp"
            alt="Common mistakes in Singapore document attestation"
            style="width:100%;height:320px;object-fit:cover;display:block;"
          />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
          <div style="position:absolute;bottom:16px;left:16px;right:16px;">
            <p style="color:#fff;font-size:0.88rem;font-weight:700;margin:0;">Avoid these mistakes for a smooth attestation process</p>
          </div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {challenges.map(c => (
          <div style="display:flex;align-items:center;gap:12px;background:#FFF5F5;border:1px solid #FED7D7;border-radius:10px;padding:14px 16px;">
            <span style="color:#E53E3E;font-weight:bold;font-size:1rem;flex-shrink:0;">!</span>
            <p style="font-size:0.9rem;color:#4B5563;line-height:1.5;margin:0;">{c}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ════ GET STARTED ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;text-align:center;">
    <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Simple Process</p>
    <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">How to Begin with Singapore Certificate Attestation?</h2>
    <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0 auto 44px;max-width:560px;">
      Starting is easy. You focus on your career or family plans. We handle the paperwork.
    </p>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;text-align:left;" class="four-col">
      {getStartedSteps.map(s => (
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:22px;position:relative;">
