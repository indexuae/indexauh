---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+973", label: "BH +973" },
  { code: "+91",  label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44",  label: "GB +44" },
  { code: "+1",   label: "US +1" },
]

const documents = [
  { title: "Valid Passport", body: "A copy of your passport, including all relevant pages, such as personal information, entry/exit stamps, and residency permit pages." },
  { title: "Resident ID Card", body: "If you hold a Kuwaiti resident ID card, a copy of it may be required as part of the application." },
  { title: "Application Form", body: "The completed application form for the PCC can be obtained from the Kuwaiti Ministry of Interior or the relevant police department." },
  { title: "Recent Passport-Sized Photographs", body: "Usually, two or three passport-sized photographs are required for the application." },
  { title: "Authorization Letter", body: "If you authorize someone else to apply for the PCC on your behalf, an authorization letter signed by you, along with copies of your ID and the authorized person's ID, will be necessary." },
]

const faqs = [
  { q: "How can Indexauh help me get a Kuwait Police Clearance Certificate if I am currently outside Kuwait?", a: "Indexauh manages the entire process remotely by guiding you on the required documents, assisting with fingerprint card preparation, and coordinating with Kuwait authorities so you can obtain your PCC without traveling back." },
  { q: "Does Indexauh assist with the fingerprint process required for a Kuwait PCC?", a: "Yes. Indexauh helps you complete the fingerprinting step correctly by advising where to get your fingerprints taken, how to attest the fingerprint card, and how to send it for processing in Kuwait." },
  { q: "Can Indexauh handle Kuwait PCC applications for former Kuwait residents whose Civil ID has expired?", a: "Indexauh can support applicants who no longer hold an active Civil ID by working with the available passport and residency records to initiate the PCC request through the appropriate authority." },
  { q: "How does Indexauh ensure my documents meet Kuwait Ministry of Interior requirements?", a: "Before submission, Indexauh checks every document for format, clarity, attestation, and validity to ensure they align with Kuwait MOI guidelines, preventing delays or rejections." },
  { q: "Can Indexauh apply for a Kuwait PCC on my behalf without me traveling?", a: "Yes. Indexauh can act on your behalf through authorized documentation, allowing the PCC process to be completed while you remain in your current country of residence." },
  { q: "Does Indexauh help with Kuwait PCC applications submitted through the Sahel app?", a: "Indexauh can guide you on how the Sahel application works, what documents are needed, and when alternative submission methods are required if Sahel access is not available." },
  { q: "Can Indexauh assist if my Kuwait PCC request was rejected previously?", a: "Indexauh reviews the reason for rejection, identifies missing or incorrect information, and helps you reapply with the proper documentation to avoid repeated issues." },
  { q: "What documents should I share with Indexauh to start the Kuwait PCC process?", a: "Typically, you should provide your passport copy, previous Kuwait residency information, photographs, and any old Civil ID details. Indexauh will review these and confirm any additional requirements." },
  { q: "How long does Indexauh usually take to complete the Kuwait PCC procedure?", a: "Processing time depends on your location and document readiness, but Indexauh aims to complete each stage quickly by handling coordination, verification, and follow-up on your behalf." },
  { q: "Does Indexauh offer Kuwait PCC services for immigration, employment, or visa processing?", a: "Yes. Whether you need the PCC for migration, job applications, further studies, or visa submissions, Indexauh provides tailored support to ensure your certificate is accepted by the requesting authority." },
]
---

<BaseLayout
  title="Police Clearance Certificate Kuwait | Kuwait PCC- Index Attestation"
  description="Need a Police Clearance Certificate Kuwait? Let Indexauh handle it quickly and securely. Get your Kuwait PCC or Good Standing Certificate hassle-free today!"
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .doc-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 24px; transition: all 0.25s; }
  .doc-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 300px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-47.webp"
    alt="Police Clearance Certificate in Kuwait"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      POLICE CLEARANCE<br/>CERTIFICATE IN KUWAIT
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      Looking for PCC in Kuwait? Let the Index guide you. We specialize in helping individuals obtain their Police Clearance Certificate efficiently, whether you are based in Kuwait or applying from abroad.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is a Police Clearance Certificate in Kuwait?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
        A Police Clearance Certificate (PCC) in Kuwait is an official document issued by the Kuwaiti authorities that verifies an individual's criminal record or the absence of any criminal activities in the country.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
        It serves as proof that the applicant has a clean criminal history and is often required for various purposes, such as employment, immigration, higher education, or obtaining a residence visa in Kuwait.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Specialist Service Provider</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          Index is a specialist service provider, focusing on police clearance certificates and other international individual and business services. With 25+ years of expertise, we deliver professional and timely police clearance certificates authorised by police departments and concerned authorities in various countries.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/kuwait-flag.webp" alt="Police Clearance Certificate Kuwait" style="width:100%;height:440px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Professional Kuwait PCC Assistance</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">End-to-end support by Index Office Services</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY IMPORTANT ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
