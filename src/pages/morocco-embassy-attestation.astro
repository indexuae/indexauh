---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whenNeeded = [
  "Employment in Morocco",
  "Family visa processing",
  "Marriage registration",
  "Birth certificate submission",
  "Higher education admission",
  "Business set up in UAE or expansion",
  "Commercial agreements",
  "Power of attorney use",
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Morocco Marriage certificate attestation",
      "Morocco Birth certificate attestation",
      "Divorce Certificate Attestation",
      "Death Certificate Attestation",
      "Transfer Certificate Attestation",
      "Police Clearance Certificate (PCC)",
      "Affidavit Attestation",
      "Singleness Certificate Attestation",
      "Medical Certificate Attestation",
      "Adoption Certificate Attestation",
    ],
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Morocco Degree Certificate Attestation",
      "Master Degree Certificate Attestation",
      "Engineering Degree Certificate Attestation",
      "Diploma Certificate Attestation",
      "Degree Certificate Attestation",
      "Nursing Certificate Attestation",
      "Transcripts and Mark Sheets Attestation",
      "Professional Qualification Certificates Attestation",
      "Certificate of Experience Attestation",
      "Vocational and Technical Certificates",
    ],
  },
  {
    category: "Commercial Documents",
    icon: "⚖️",
    docs: [
      "Memorandum of Association",
      "Articles of Association",
      "Certificate of Incumbency",
      "Power of Attorney",
      "Commercial Invoices",
      "Certificate of Incorporation",
      "Certificate of Good Standing",
      "Board Resolution",
      "Shareholder Resolution",
      "Agency Agreement",
    ],
  },
]

const processToMorocco = [
  { step: "01", title: "Notary Attestation in UAE", desc: "The document is first verified by a notary public in the UAE." },
  { step: "02", title: "Ministry of Foreign Affairs UAE Approval", desc: "The UAE Ministry of Foreign Affairs stamps the document to confirm authenticity." },
  { step: "03", title: "Submission to Morocco Embassy", desc: "The document is submitted to the Morocco Embassy in Abu Dhabi or the Moroccan Consulate Dubai based on jurisdiction." },
  { step: "04", title: "Embassy Stamping", desc: "After the embassy stamp, the document becomes legally valid for use in Morocco." },
]

const processToUAE = [
  { step: "01", title: "Local Authority Verification in Morocco", desc: "The document is verified by the concerned local authority in Morocco." },
  { step: "02", title: "Moroccan Ministry of Foreign Affairs Approval", desc: "The Moroccan Ministry of Foreign Affairs attests the document." },
  { step: "03", title: "UAE Embassy Approval in Morocco", desc: "The UAE Embassy in Morocco provides legalization." },
  { step: "04", title: "UAE Ministry of Foreign Affairs Final Attestation", desc: "Once the document reaches the UAE, the Ministry of Foreign Affairs gives the final stamp for legal use." },
]

const docsRequired = [
  "Original certificate",
  "Passport copy",
  "Visa copy",
  "Emirates ID copy",
  "Authorization letter for submission",
  "Trade license copy for company documents",
]

const timingFactors = [
  "Document type",
  "Issuing country",
  "Embassy workload",
  "Translation requirements",
]

const getStartedSteps = [
  { step: "01", title: "Contact Our Team", desc: "Call us or send us a message. Share a clear copy of your document for initial review." },
  { step: "02", title: "Document Review", desc: "Our experts check your certificate and confirm the exact process required for Morocco Embassy Attestation." },
  { step: "03", title: "Confirm the Procedure and Timeline", desc: "We explain the steps, required approvals, and expected processing time clearly." },
  { step: "04", title: "Document Collection", desc: "We arrange secure document collection anywhere in the UAE for your convenience." },
  { step: "05", title: "Attestation Processing", desc: "Our team handles each stage carefully, including ministry approvals and submission to the Morocco Embassy in Abu Dhabi or the Moroccan Consulate Dubai." },
  { step: "06", title: "Regular Updates", desc: "We keep you informed about the progress at every stage." },
  { step: "07", title: "Safe Delivery", desc: "Once the Morocco Embassy Attestation is completed, we return your document safely to your location." },
]

const whyChoose = [
  { title: "25+ Years of Experience", desc: "With over 25 years in the UAE, we have handled thousands of embassy cases." },
  { title: "Deep Procedural Understanding", desc: "Deep understanding of Morocco Embassy procedures." },
  { title: "Clear Document Verification", desc: "Clear document verification before submission." },
  { title: "Support Across All Emirates", desc: "Support across all Emirates for your convenience." },
  { title: "Secure Handling", desc: "Secure handling of original certificates." },
  { title: "Transparent Guidance", desc: "Transparent guidance at every stage of the process." },
]

const faqs = [
  { q: "Is Morocco part of the Hague Convention?", a: "No. Embassy legalization is required." },
  { q: "Do Moroccan documents need fresh issuance?", a: "In many cases, recently issued civil documents are preferred." },
  { q: "Is translation mandatory?", a: "Some documents need Arabic or French translation based on requirement." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Morocco Embassy Attestation in UAE | Indexauh"
  description="Morocco Embassy Attestation in UAE with 25+ years expertise. Fast, reliable process via IndexAUH. Contact us today for secure document legalization."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .four-col { display: grid !important; }
  .five-col { display: grid !important; }
  .seven-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr 1fr !important; }
    .five-col { grid-template-columns: 1fr 1fr !important; }
    .seven-col { grid-template-columns:  1fr !important; }
    .img-first { order: -1 !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
    .process-split { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Morocco Embassy Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Morocco Attestation Services</span>
      <span class="idx-pill">25 Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      MOROCCO EMBASSY ATTESTATION<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Morocco Embassy Attestation is needed when your document must be accepted in Morocco or in the UAE. This process confirms that your certificate is genuine and approved by the right authorities. With over 25 years of experience in the UAE, Indexauh handles Morocco Embassy Attestation with clear planning and proper documentation.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ WHEN DO YOU NEED ════ -->
<section id="details" style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;" class="split-grid">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/morocco-flag.webp" alt="When to get Morocco embassy attestation" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">When You Need Attestation</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Work · Education · Family · Business</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Key Situations</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">When Do You Need Morocco Embassy Attestation?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          You may need Morocco Embassy Attestation for many reasons:
        </p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {whenNeeded.map(item => (
            <div style="display:flex;align-items:flex-start;gap:12px;background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:14px 18px;">
              <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:2px;">→</span>
              <p style="font-size:0.9rem;color:#374151;line-height:1.6;margin:0;">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Morocco Embassy Attestation Services"
  description="We handle attestation for a wide range of document categories across personal, educational, and commercial needs."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Morocco attestation"
  docTypes={docTypes}
  country="morocco"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Morocco attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:520px;line-height:1.25;">Morocco Certificate Attestation Process in the UAE</h2>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px;" class="process-split two-col">
      <div>
        <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 14px;">For UAE Documents to Be Used in Morocco</h3>
        <div style="display:flex;flex-direction:column;gap:14px;">
          {processToMorocco.map(s => (
            <div class="step-card">
              <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
              <div>
                <p style="font-size:0.95rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
                <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 14px;">For Moroccan Documents to Be Used in UAE</h3>
        <div style="display:flex;flex-direction:column;gap:14px;">
          {processToUAE.map(s => (
            <div class="step-card">
              <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
              <div>
                <p style="font-size:0.95rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
                <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Embassy/Consulate Info -->
    <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:28px;margin-bottom:24px;">
      <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 16px;">Morocco Embassy and Consulate in UAE</h3>
      <p style="color:#4B5563;font-size:0.88rem;line-height:1.75;margin:0 0 14px;">Understanding the correct authority is important.</p>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div>
          <p style="font-size:0.9rem;font-weight:700;color:#1A202C;margin:0 0 4px;">Morocco Embassy in Abu Dhabi</p>
          <p style="font-size:0.86rem;color:#6B7280;line-height:1.65;margin:0;">The Morocco Embassy in Abu Dhabi handles official diplomatic services. Many UAE issued documents require approval from this embassy before they are accepted in Morocco.</p>
        </div>
        <div>
          <p style="font-size:0.9rem;font-weight:700;color:#1A202C;margin:0 0 4px;">Général Consulate of the Kingdom of Morocco in Dubaï</p>
          <p style="font-size:0.86rem;color:#6B7280;line-height:1.65;margin:0;">The général consulate of the kingdom of Morocco in Dubaï serves Moroccan nationals and residents in Dubai and Northern Emirates, and also processes document legalization based on jurisdiction.</p>
        </div>
        <div>
          <p style="font-size:0.9rem;font-weight:700;color:#1A202C;margin:0 0 4px;">Morocco Embassy in Dubai</p>
          <p style="font-size:0.86rem;color:#6B7280;line-height:1.65;margin:0;">In practice, consular services in Dubai are handled by the Moroccan Consulate. Knowing the correct office avoids delay. Our team guides you to the correct authority based on your document type and location.</p>
        </div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;" class="two-col">
      <!-- Documents Required -->
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Basic requirements include:</p>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {docsRequired.map(d => (
            <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{d}
            </div>
          ))}
        </div>
        <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">Some documents require Arabic or French translation. Our team checks everything before submission for the Morocco Embassy Attestation.</p>
      </div>

      <!-- Timing -->
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">How Long Does It Take?</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Processing time depends on:</p>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {timingFactors.map(f => (
            <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
            </div>
          ))}
        </div>
        <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">On average, the timeline ranges from a few working days to a couple of weeks. We always explain the expected timeframe before starting.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ GET STARTED ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;text-align:center;">
    <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Simple Process</p>
    <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">How to Get Started with Morocco Embassy Attestation?</h2>
    <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0 auto 44px;max-width:560px;">
      Starting is simple. Follow these easy steps.
    </p>

    <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:14px;text-align:left;" class="seven-col">
      {getStartedSteps.map(s => (
        <div style="background:#F8FAFF;border:1px solid #eef0f6;border-radius:16px;padding:18px;position:relative;">
          <div style="font-size:2.2rem;font-weight:900;color:#B2F5EA;line-height:1;margin-bottom:10px;">{s.step}</div>
          <h3 style="font-size:0.82rem;font-weight:800;color:#1A202C;margin:0 0 6px;">{s.title}</h3>
          <p style="font-size:0.74rem;color:#6B7280;line-height:1.55;margin:0;">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE INDEX ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;" class="split-grid">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
        <img src="/images/img-3.webp" alt="IndexAUH Morocco attestation team" style="width:100%;height:340px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">IndexAUH</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Abu Dhabi · Dubai · Global Network</p>
        </div>
      </div>
      <div>
        <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Why Choose Us</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.2;margin:0 0 16px;">Why Choose Us?</h2>
        <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;">
          Experience matters in attestation work. With over 25 years in the UAE, we have handled thousands of embassy cases.
        </p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;" class="three-col">
      {whyChoose.map(b => (
        <div class="benefit-card">
          <h3 style="font-size:0.92rem;font-weight:800;color:#fff;margin:0 0 8px;border-bottom:1px solid rgba(56,178,172,0.3);padding-bottom:8px;">{b.title}</h3>
          <p style="font-size:0.9rem;color:#CBD5E0;line-height:1.65;margin:0;">{b.desc}</p>
        </div>
      ))}
    </div>
  </div>
