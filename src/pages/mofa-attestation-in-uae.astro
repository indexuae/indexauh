---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1", label: "US +1" },
  { code: "+973", label: "BH +973" },
]

const documentTypes = [
  {
    title: "Educational Documents",
    desc: "Educational certificates are required for employment, higher education, professional licensing, and visa purposes.",
    items: ["Degree Certificates", "Diploma Certificates", "Mark Sheets & Transcripts", "School Leaving Certificates", "Professional Qualification Certificates"],
    use: "Employment visa, Golden Visa (skilled professionals), equivalency certificates."
  },
  {
    title: "Personal Documents",
    desc: "Personal documents establish identity, family relationships, and civil status.",
    items: ["Birth Certificate", "Marriage Certificate", "Divorce Certificate", "Death Certificate", "Police Clearance Certificate (PCC)", "Medical Certificates"],
    use: "Family visa, spouse sponsorship, dependent visa, legal matters."
  },
  {
    title: "Commercial Documents",
    desc: "Commercial documents are required for business operations, trade, and corporate compliance.",
    items: ["Power of Attorney (POA)", "Memorandum of Association (MOA)", "Articles of Association (AOA)", "Commercial License", "Commercial Invoices", "Board Resolutions", "Company Agreements"],
    use: "<a href='/business-setup-in-the-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>Business setup UAE</a>, trade licensing, bank approvals, legal transactions."
  }
]

const outsideUAESteps = [
  { step: "01", title: "Issuing Country Attestation", desc: "Attestation from the relevant authorities in the country where the document was issued." },
  { step: "02", title: "Foreign Affairs Attestation", desc: "Attestation from that country's Ministry of Foreign Affairs." },
  { step: "03", title: "UAE Embassy Attestation", desc: "UAE Embassy attestation in the issuing country." },
  { step: "04", title: "Final MOFA Attestation", desc: "Final MOFA attestation completed inside the UAE." }
]

const insideUAESteps = [
  { step: "01", title: "Initial UAE Authority Attestation", desc: "Initial attestation from the relevant UAE authority that issued or holds the document." },
  { step: "02", title: "Direct MOFA Attestation", desc: "Direct MOFA attestation completed without the need for embassy-level steps." }
]

const whyNeeded = [
  "Employment in the UAE",
  "Golden Visa applications",
  "Residence visa processing",
  "Family visa & spouse sponsorship",
  "Higher education admissions",
  "Business setup and trade licensing",
  "Legal and court-related matters"
]

const importancePoints = [
  "Confirms document authenticity",
  "Ensures acceptance by UAE government bodies",
  "Prevents fraud and document misuse",
  "Mandatory for immigration and visa approvals",
  "Required for legal, academic, and commercial recognition"
]

const digitalFeatures = [
  "Tamper-proof digital certificate",
  "Online verification using QR code or reference number",
  "Faster processing time",
  "No physical stamping required",
  "Accepted by UAE government entities and international institutions"
]

const verifySteps = [
  { step: "01", title: "Visit the Portal", desc: "Visiting the official MOFA UAE verification portal." },
  { step: "02", title: "Enter Reference", desc: "Entering the attestation reference number or scanning the QR code." },
  { step: "03", title: "View Status", desc: "Viewing real-time authentication status." }
]

const supportServices = [
  { title: "MOFA Attestation Services", items: ["Educational, personal & commercial documents", "UAE & foreign-issued certificates", "Fast-track and normal processing"] },
  { title: "Golden Visa Assistance", items: ["Skilled professionals", "Investors & entrepreneurs", "Property owners & special talent categories"] },
  { title: "Certified Translation Services", items: ["Legal & technical translations", "MOFA & embassy-approved formats", "Arabic ↔ English and other languages"] },
  { title: "Typing Services", items: ["Visa applications", "Immigration forms", "Government submissions"] }
]

const whyChooseUs = [
  "Experienced attestation consultants",
  "Transparent process & pricing",
  "End-to-end handling",
  "Time-saving & hassle-free service",
  "Trusted across UAE"
]

const coverageAreas = ["Abu Dhabi", "Dubai", "Sharjah", "Ajman", "Ras Al Khaimah", "Fujairah"]

const faqs = [
  { q: "Is MOFA attestation mandatory in the UAE?", a: "Yes, MOFA attestation is very much mandatory for documents used for official purposes in the UAE. Documents may not be accepted by UAE government departments, employers, immigration authorities, or courts without MOFA Attestation." },
  { q: "How long does MOFA attestation take in the UAE?", a: "MOFA attestation timelines vary based on document type and origin. Normally 1 to 3 working days will be required for completion of MOFA Attestation in UAE once all prior attestations are completed." },
  { q: "Is it possible to do MOFA attestation online in the United Arab Emirates?", a: "Indeed. Digital MOFA attestation, in which documents are electronically certified and issued with a verifiable digital certificate, is provided by the UAE Ministry of Foreign Affairs. For the majority of documents, physical stamping is no longer necessary." },
  { q: "What documents are required for MOFA attestation?", a: "Typically, you need the original document, prior attestations (if the document is issued outside the UAE), and a copy of the passport. Requirements may vary depending on whether the document is educational, personal, or commercial." },
  { q: "Is MOFA attestation required for Golden Visa applications?", a: "Yes. MOFA attestation is often required for educational certificates, marriage certificates, and professional documents submitted for UAE Golden Visa applications, depending on the visa category." }
]
---

<BaseLayout title="MOFA Attestation in UAE | Certificate Attestation Services UAE" 
description="Indexauh offers trusted MOFA attestation in UAE with 25+ years of experience. Contact us today for a free consultation."
>

<style>
  .sec-inner { position: relative; z-index: 1; }

  /* pills */
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }

  /* form */
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }

  /* document type card */
  .doc-type-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; transition: all 0.25s; }
  .doc-type-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.06); transform: translateY(-3px); }

  /* steps cards */
  .step-card { display: flex; align-items: flex-start; gap: 18px; padding: 20px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }

  /* list items */
  .check-item { display: flex; align-items: flex-start; gap: 10px; padding: 12px 16px; background: #fff; border: 1px solid #e0e7ef; border-radius: 10px; font-size: 0.85rem; color: #1A202C; font-weight: 500; }

  /* FAQ */
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 200px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  /* mofa tabs */
  .mofa-tab-btn { padding: 10px 22px; border-radius: 9999px; font-size: 0.85rem; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s; }
  .mofa-tab-btn.active { background: #2D3748; color: #fff; }
  .mofa-tab-btn:not(.active) { background: #F0FFFE; color: #2D3748; border: 1px solid #B2F5EA; }

 @media(max-width:768px){
  .about-hero-title { font-size: 2rem !important; }
  .about-hero-desc { font-size: 0.88rem !important; }
  .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
  .benefits-grid { grid-template-columns: 1fr !important; }
  .offices-flex { flex-direction: column !important; }
  .step-sticky { position: static !important; }
  .doctype-grid { grid-template-columns: 1fr !important; }
}
</style>

<!-- ════════════ HERO — image bg, centered text ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <!-- Background image -->
  <img
    src="/images/img-16.webp"
    alt="MOFA Attestation in UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <!-- Dark overlay -->
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.88) 0%,rgba(45,55,72,0.82) 100%);"></div>
  <!-- Dot pattern -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">UAE-Wide Coverage</span>
      <span class="idx-pill">Trusted Services</span>
      <span class="idx-pill">Transparent Pricing</span>
    </div>
    <h1 class="about-hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      MOFA ATTESTATION<br/>IN UAE
    </h1>
    <p class="about-hero-desc" style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:640px;">
      MOFA Attestation in the UAE verifies that your documents are authentic and approved for official use. It is mandatory for visas, employment, education, business, and family sponsorship.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

<div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:start;">
  <!-- Left Text -->
  <div>
    <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
      <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
    </p>
    <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What is UAE MOFA Attestation?</h2>

    <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
      The official authentication of documents by the UAE Ministry of Foreign Affairs (MOFA) is known as MOFA Attestation. It is the last and most important step of document attestation in the UAE, verifying that a document is authentic, lawful, and accepted by UAE government officials.
    </p>
    <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
  Depending on their intended use, MOFA attestation is applicable to commercial, personal, and <a href="/educational-certificate-attestation-in-dubai/" style="color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;">educational certificate attestation</a> issued both inside and outside the United Arab Emirates. For over 25 years, Index has earned the trust of thousands by providing dependable and hassle-free <a href="/certificate-attestation-in-the-uae/" style="color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;">certificate attestation in the UAE</a>.
</p>

    <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;margin-top:8px;">
      <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">The Final Government Seal</h3>
      <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
        MOFA attestation acts as the final government seal, making your documents officially usable across the UAE.
      </p>
    </div>
  </div>

  <!-- Right side: image -->
  <div style="display:flex;flex-direction:column;gap:24px;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
      <img src="/images/img-16.webp" alt="UAE MOFA attestation documents" style="width:100%;height:340px;object-fit:cover;" />
      <div style="position:absolute;bottom:20px;left:-16px;background:#2D3748;color:#fff;padding:12px 18px;border-radius:12px;font-size:0.9rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
        25+ Years Experience
      </div>
    </div>
  </div>
</div>
  </div>
</section>

<!-- ════ TYPES OF DOCUMENTS ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Document Categories</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">Types of Documents Requiring UAE MOFA Attestation</h2>
      <p style="color:#6B7280;font-size:1.05rem;max-width:620px;margin:0 auto;">MOFA attestation covers educational, personal, and commercial documents, each with distinct purposes and use cases.</p>
    </div>

    <div class="doctype-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
      {documentTypes.map(d => (
        <div class="doc-type-card">
          <h3 style="font-size:1.1rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">{d.title}</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">{d.desc}</p>
          <p style="font-size:0.78rem;font-weight:700;color:#1A202C;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 8px;">Examples include:</p>
          <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:14px;">
            {d.items.map(i => (
              <div style="display:flex;align-items:center;gap:8px;font-size:0.85rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">•</span> {i}
              </div>
            ))}
          </div>
          <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:10px;padding:10px 12px;">
  <p style="font-size:0.78rem;color:#1A202C;font-weight:600;margin:0;"><span style="color:#38B2AC;">Common use:</span> <span set:html={d.use}></span></p>
</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ PROCEDURE (TABS) ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1000px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:40px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Authentication Workflow</p>
      <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">Procedure for Ministry of Foreign Affairs Attestation</h2>
      <p style="color:#4B5563;font-size:1rem;max-width:560px;margin:0 auto;line-height:1.6;">The MOFA attestation process depends on where the document was issued.</p>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:32px;">
      <button class="mofa-tab-btn active" data-tab="outside">Issued Outside UAE</button>
      <button class="mofa-tab-btn" data-tab="inside">Issued Inside UAE</button>
    </div>

    <!-- Outside UAE panel -->
    <div id="mofa-outside" style="display:block; background:#fff; border-radius:18px; padding:32px; box-shadow:0 10px 30px rgba(56,178,172,0.06); border:1px solid #B2F5EA;">
      <h3 style="font-size:1.15rem;font-weight:800;color:#1A202C;margin:0 0 20px;">For Documents Issued Outside the UAE</h3>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {outsideUAESteps.map(s => (
          <div style="display:flex;align-items:flex-start;gap:14px;padding:14px 16px;background:#F9FAFB;border-radius:10px;">
            <span style="width:30px;height:30px;border-radius:50%;background:#38B2AC;color:#fff;font-size:0.8rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</span>
            <div>
              <p style="font-size:1rem;font-weight:700;color:#1A202C;margin:0 0 2px;">{s.title}</p>
              <p style="font-size:0.88rem;color:#6B7280;margin:0;line-height:1.5;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Inside UAE panel -->
    <div id="mofa-inside" style="display:none; background:#fff; border-radius:18px; padding:32px; box-shadow:0 10px 30px rgba(56,178,172,0.06); border:1px solid #B2F5EA;">
      <h3 style="font-size:1.15rem;font-weight:800;color:#1A202C;margin:0 0 20px;">For Documents Issued Inside the UAE</h3>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {insideUAESteps.map(s => (
          <div style="display:flex;align-items:flex-start;gap:14px;padding:14px 16px;background:#F9FAFB;border-radius:10px;">
            <span style="width:30px;height:30px;border-radius:50%;background:#38B2AC;color:#fff;font-size:0.8rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</span>
            <div>
              <p style="font-size:1rem;font-weight:700;color:#1A202C;margin:0 0 2px;">{s.title}</p>
              <p style="font-size:0.88rem;color:#6B7280;margin:0;line-height:1.5;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY YOU NEED IT / IMPORTANCE ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:52px;" class="split-grid">
      <!-- Why needed -->
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Why It Matters</p>
        <h2 style="font-size:1.9rem;font-weight:900;color:#1A202C;margin:0 0 16px;">Why Do You Need UAE MOFA Attestation?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:20px;">
          MOFA attestation is mandatory when documents are submitted to UAE authorities for official, legal, or immigration purposes. Without MOFA attestation, documents are often rejected by government departments, employers, courts, and immigration authorities.
        </p>
        <p style="font-weight:700;color:#1A202C;font-size:1rem;margin-bottom:12px;text-transform:uppercase;">You need MOFA attestation for:</p>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {whyNeeded.map(w => (
            <div style="display:flex;align-items:center;gap:8px;font-size:0.98rem;color:#4B5563;background:#F8FAFF;border:1px solid #e2e8f0;padding:8px 12px;border-radius:6px;">
              <span style="color:#38B2AC;font-weight:bold;">→</span> {w}
            </div>
          ))}
        </div>
      </div>

      <!-- Importance -->
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Core Value</p>
        <h2 style="font-size:1.9rem;font-weight:900;color:#1A202C;margin:0 0 16px;">Importance of MOFA Attestation</h2>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {importancePoints.map(p => (
            <div class="check-item">
              <span style="width:20px;height:20px;border-radius:50%;background:#38B2AC;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" width="10" height="10"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              <p style="margin:0;">{p}</p>
            </div>
          ))}
        </div>
        <p style="color:#4B5563;font-size:0.95rem;line-height:1.8;margin-top:16px;">
          MOFA attestation acts as the final government seal, making your documents officially usable across the UAE.
        </p>
      </div>
    </div>
  </div>
</section>

