import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+973", label: "BH +973" },
  { code: "+91",  label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44",  label: "GB +44" },
  { code: "+1",   label: "US +1" },
]

const benefits = [
  { icon: "💼", title: "Employment", desc: "Many employers in Saudi Arabia require a PCC as part of the hiring process. It helps employers assess the reliability and trustworthiness of prospective employees, ensuring a safe work environment." },
  { icon: "✈️", title: "Immigration", desc: "When applying for immigration or a long-term visa in another country, immigration authorities often request a PCC to evaluate an individual's criminal history. It demonstrates that the applicant has a clean record." },
  { icon: "🏠", title: "Residency", desc: "Some countries require a PCC as part of the residency application process. By obtaining a PCC in Saudi Arabia, individuals can meet the requirements and expedite the residency process in their destination country." },
  { icon: "🛂", title: "Travel", desc: "Certain countries may require a PCC for travel purposes, especially for extended stays or specific visa categories. Having a PCC readily available eliminates potential delays or complications during travel arrangements." },
]

const documents = [
  { title: "Valid Passport", body: "Applicants should possess a valid passport and provide a copy of the passport's relevant pages, including personal details and visa pages." },
  { title: "Residence Permit (Iqama)", body: "A copy of the applicant's valid residence permit (Iqama) should be submitted as part of the application." },
  { title: "Application Form", body: "An application form provided by the Saudi Arabian authorities should be completed accurately and signed by the applicant." },
  { title: "Passport-Sized Photographs", body: "Two recent passport-sized photographs should be submitted along with the application." },
  { title: "Fingerprint Card", body: "Applicants need to provide their fingerprints on a fingerprint card. This can be done at designated police stations or other authorized centers." },
  { title: "Supporting Documents", body: "Additional documents may be required, such as a letter of request, proof of address, or a no-objection certificate from the employer." },
]

const whyIndex = [
  { title: "Expertise and Experience", desc: "Index has extensive experience in handling PCC applications in Saudi Arabia. With more than 25 years of experience, our team possesses in-depth knowledge of the requirements, procedures, and legal intricacies involved. We have branches in more than nine countries which makes us one of the sought-after attestation service providers in the world." },
  { title: "Efficient and Timely Service", desc: "We provide efficient and timely services, ensuring that all the necessary documentation is prepared, submitted, and followed up promptly. This minimizes delays and maximizes the chances of a successful application." },
  { title: "Document Verification", desc: "Index verifies the accuracy and completeness of all documents to ensure compliance with the Saudi Arabian authorities' requirements. This helps eliminate potential rejections or complications due to incorrect or incomplete paperwork." },
  { title: "Personalized Assistance", desc: "We offer personalized assistance, guiding applicants throughout the process. We address queries, provide updates on the application status, and offer support at every step, ensuring a smooth experience." },
  { title: "Reliable and Transparent", desc: "Index maintains transparency throughout the process. We provide clear information on the services, associated costs, and expected timelines, ensuring that applicants are well-informed and have peace of mind." },
  { title: "24/7 Customer Support", desc: "We provide 24/7/365 customer support to answer all your queries anytime, anywhere." },
]

const faqs = [
  { q: "How can Indexauh help me get a Police Clearance Certificate from Saudi Arabia if I am no longer living there?", a: "Indexauh guides applicants who have already left Saudi Arabia by assisting with the required documents, fingerprinting procedures, and coordination with the concerned authorities so the PCC can be issued without being physically present in the Kingdom." },
  { q: "Can Indexauh assist with Saudi PCC processing for applicants whose Iqama has expired?", a: "Yes. Indexauh helps former residents apply using alternative verification documents even if their Iqama has expired or is no longer accessible." },
  { q: "Does Indexauh handle fingerprinting requirements for obtaining a Saudi PCC?", a: "Indexauh assists with preparing and submitting the fingerprint card according to Saudi requirements and helps ensure it is accepted by the issuing authority." },
  { q: "How long does Saudi Police Clearance Certificate processing usually take when done through Indexauh?", a: "Processing time varies based on the applicant's situation, but Indexauh provides a clear timeline at the start and keeps clients informed throughout the process." },
  { q: "Is Indexauh able to arrange Saudi PCC for immigration purposes like Canada, UK, or Australia?", a: "Yes. Indexauh supports Saudi PCC applications required for immigration, background checks, and residency procedures for countries such as Canada, Australia, the UK, and others." },
  { q: "Can Indexauh assist with Saudi PCC if I don't have access to my Absher account anymore?", a: "Indexauh helps applicants who cannot log in to Absher by providing alternative methods to initiate and complete the PCC request." },
  { q: "Does Indexauh provide Saudi PCC services for applicants who worked in Saudi Arabia years ago?", a: "Yes. Even if your employment or residency in Saudi Arabia was many years ago, Indexauh assists in gathering the necessary proofs to start the PCC application." },
  { q: "Can Indexauh manage MOFA attestation for Saudi PCC after it is issued?", a: "Indexauh can coordinate the attestation process after the PCC is issued, including MOFA attestation if the document is intended for use outside Saudi Arabia." },
  { q: "Does Indexauh support document pickup and delivery for Saudi Police Clearance Certificate processing?", a: "Yes. Indexauh offers convenient pickup and delivery options so clients can complete the process without visiting multiple offices." },
  { q: "What documents do I need to submit to Indexauh to start the Saudi PCC application process?", a: "Documents typically include your passport details, previous Iqama information, photos, and a fingerprint card if applying from outside Saudi. Indexauh will guide you based on your specific case." },
]
---

<BaseLayout
  title="Saudi Police Clearance Certificate | Saudi PCC | Indexauh"
  description="Get your Saudi Police Clearance Certificate from the UAE with Indexauh. Trusted experts for fast and reliable Saudi PCC or Good Standing Certificate."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .benefit-card-light { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; transition: all 0.25s; }
  .benefit-card-light:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .doc-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 24px; transition: all 0.25s; }
  .doc-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 300px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-47.webp"
    alt="Police Clearance Certificate in Saudi Arabia"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      POLICE CLEARANCE<br/>CERTIFICATE IN SAUDI ARABIA
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      In Saudi Arabia, a Police Clearance Certificate (PCC) is an official document issued by the Saudi Arabian authorities that verifies an individual's criminal record or lack thereof within the country. It serves as proof that the person has not been involved in any criminal activities during their stay in Saudi Arabia.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
