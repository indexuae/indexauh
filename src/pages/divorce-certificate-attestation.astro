<BaseLayout title="Divorce Certificate Attestation UAE | Indexauh"
description="Get Divorce Certificate Attestation UAE done easily with Indexauh. Trusted, careful, and MOFA-approved attestation services across Dubai, Abu Dhabi, and the UAE."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }

  .step-card { display:flex; align-items:flex-start; gap:18px; padding:24px; background:#fff; border:1px solid #eef0f6; border-radius:16px; transition:all 0.25s; }
  .step-card:hover { border-color:#B2F5EA; box-shadow:0 12px 32px rgba(56,178,172,0.1); transform:translateY(-3px); }

  .purpose-card { padding:24px; background:#fff; border:1px solid #eef0f6; border-radius:16px; transition:all 0.25s; }
  .purpose-card:hover { border-color:#B2F5EA; box-shadow:0 12px 32px rgba(56,178,172,0.1); transform:translateY(-3px); }

  .why-card { background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:14px; padding:22px; display:flex; align-items:flex-start; gap:14px; transition:background 0.2s; }
  .why-card:hover { background:rgba(255,255,255,0.14); }

  .fact-item { display:flex; align-items:center; gap:8px; padding:10px 14px; background:#fff; border:1px solid #e0e7ef; border-radius:10px; font-size:0.98rem; color:#1A202C; font-weight:500; }
  .fact-check { width:20px; height:20px; border-radius:50%; background:#38B2AC; display:flex; align-items:center; justify-content:center; flex-shrink:0; }

  .faq-item { border:1px solid #eef0f6; border-radius:14px; padding:6px 22px; background:#fff; transition:border-color 0.2s; }
  .faq-item:hover { border-color:#B2F5EA; }
  .faq-item summary { padding:16px 0; cursor:pointer; font-weight:700; color:#1A202C; font-size:1rem; list-style:none; display:flex; justify-content:space-between; align-items:center; gap:12px; }
  .faq-item summary::-webkit-details-marker { display:none; }
  .faq-item summary::after { content:"+"; font-size:1.4rem; font-weight:400; color:#38B2AC; flex-shrink:0; transition:transform 0.2s; }
  .faq-item[open] summary::after { transform:rotate(45deg); }
  .faq-item p { color:#4B5563; font-size:0.98rem; line-height:1.75; margin:0 0 18px; }

  .idx-form input,.idx-form select,.idx-form textarea { width:100%; border:1px solid #e5e7eb; border-radius:10px; padding:11px 14px; font-size:1rem; color:#374151; outline:none; font-family:inherit; background:#fff; box-sizing:border-box; }
  .idx-form input:focus,.idx-form select:focus,.idx-form textarea:focus { border-color:#38B2AC; box-shadow:0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize:none; }
  .idx-submit { width:100%; background:#2D3748; color:#fff; font-weight:700; padding:13px; border-radius:10px; border:none; cursor:pointer; font-size:0.95rem; letter-spacing:0.04em; transition:background 0.2s; }
  .idx-submit:hover { background:#1A202C; }

  @media(max-width:900px){
    .hero-grid { flex-direction:column !important; }
    .two-col { flex-direction:column !important; }
    .two-col > div { width:100% !important; }
  }
  @media(max-width:640px){
  .steps-grid, .purpose-grid, .facts-grid { grid-template-columns:1fr !important; }
  .two-col > div { min-width:100% !important; box-sizing:border-box; }
  .sec-inner { padding-left:0 !important; padding-right:0 !important; }
}
</style>

