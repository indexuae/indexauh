---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const heroPills = ["25 Years of Trust","All Emirates","Fast Processing","Secure Handling"]

const whyNeed = [
  { title:"Remarriage Procedures", desc:"Marriage registration offices request attested divorce documents. This confirms the previous marriage legally ended." },
  { title:"Family Visa Applications", desc:"Visa authorities may request proof of marital status. An attested divorce document helps update official records." },
  { title:"Legal Matters and Court Procedures", desc:"Courts sometimes require verified documents during legal processes. Divorce Certificate Attestation proves the authenticity of the record." },
  { title:"Updating Personal Records", desc:"Some government departments ask for attested documents before updating personal details." },
  { title:"Immigration or Documentation Needs", desc:"Certain immigration procedures also request attested marital records." },
]

const processSteps = [
  { num:"01", title:"Notary Verification", desc:"The issuing country verifies the original document through a notary authority." },
  { num:"02", title:"Home Department Attestation", desc:"State authorities review the document and confirm the notary verification." },
  { num:"03", title:"Ministry of Foreign Affairs in Home Country", desc:"The foreign affairs department checks the document before it moves to embassy level." },
  { num:"04", title:"UAE Embassy Attestation", desc:"The UAE embassy in the issuing country confirms the document for UAE use." },
  { num:"05", title:"MOFA Attestation in UAE", desc:"Finally, the UAE Ministry of Foreign Affairs completes the verification. At this stage the document becomes valid for official use." },
]

const documentsRequired = [
  "Original divorce certificate",
  "Passport copy",
  "Visa copy",
  "Authorization letter when using an attestation service",
]

const timeFactors = [
  "Country that issued the divorce certificate",
  "Verification required from local authorities",
  "UAE Embassy approval in the issuing country",
  "<a href='/mofa-attestation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>MOFA attestation</a> in the UAE",
  "<a href='/legal-translation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>Legal translation</a> requirements for non-Arabic documents",
  "Public holidays in government departments",
  "Accuracy of submitted documents",
]

const costFactors = [
  "Government verification fees in the issuing country",
  "UAE Embassy attestation charges",
  "Ministry of Foreign Affairs approval in the UAE",
  "Translation fees for non-Arabic documents",
  "Courier or document handling services",
  "Urgent processing requests",
  "Number of verification stages required",
]

const challenges = [
  "Name mismatch between passport and certificate",
  "Missing verification from the issuing authority",
  "Incorrect document format",
  "Certificates issued from unrecognized institutions",
  "Translation required for foreign language documents",
  "Incomplete document submission",
  "Missing passport or visa copies",
  "Damage or unclear printing on the certificate",
]

const gettingStarted = [
  { num:"01", title:"Contact Our Team", desc:"Share your document details with our specialists." },
  { num:"02", title:"Document Review", desc:"Our team checks the certificate and confirms the required verification steps." },
  { num:"03", title:"Attestation Processing", desc:"Experts manage government and embassy approvals during the attestation process." },
  { num:"04", title:"Safe Document Delivery", desc:"After completion, the attested certificate is delivered securely to you." },
]

const whyUs = [
  { icon:"🏆", label:"More than 25 years of experience in <a href='/certificate-attestation' style='color:#fff;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>attestation services</a>." },
  { icon:"🏛️", label:"Strong knowledge of embassy and government procedures." },
  { icon:"⚡", label:"Fast document processing support." },
  { icon:"🇦🇪", label:"Assistance across all Emirates." },
  { icon:"🤝", label:"Clear communication at every stage." },
  { icon:"🔒", label:"Secure handling of important documents." },
]

const faqs = [
  { q:"What is Divorce Certificate Attestation?", a:"It is a legal verification process that confirms the authenticity of a divorce certificate for official use in the UAE." },
  { q:"Can I attest a divorce certificate issued outside the UAE?", a:"Yes. Authorities verify the document through the issuing country and UAE embassy before final approval." },
  { q:"Is MOFA attestation required in UAE?", a:"Yes. The Ministry of Foreign Affairs performs the final verification step." },
  { q:"Do I need translation for my certificate?", a:"Some documents require Arabic translation before submission to UAE authorities." },
  { q:"Can I complete the process without visiting government offices?", a:"Yes. Many applicants use professional services to handle the entire process." },
