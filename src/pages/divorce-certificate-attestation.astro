  <div class="sec-inner" style="max-width:1100px;margin:0 auto;">
    <div class="two-col" style="display:flex;gap:52px;align-items:center;flex-wrap:wrap;">

      <div style="flex:1;min-width:280px;">
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;"><span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Checklist</p>
