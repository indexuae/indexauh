        <p style="font-weight:700;color:#1A202C;margin:0 0 14px;font-size:1rem;">How Long Does It Take?</p>
        <ul style="margin:0;padding-left:18px;color:#4B5563;font-size:0.95rem;line-height:1.9;">
  {timeFactors.map(t => <li set:html={t}></li>)}
</ul>
