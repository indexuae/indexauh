      {howToIssueSteps.map(s => (
        <div class="step-card">
          <div style="width:44px;height:44px;border-radius:12px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.num}</div>
          <div>
            <p style="font-size:0.9rem;font-weight:700;color:#1A202C;margin:0 0 5px;">{s.title}</p>
            <p style="font-size:0.98rem;color:#6B7280;line-height:1.65;margin:0;" set:html={s.desc}></p>
