---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code:"+91", label:"IN +91" },{ code:"+971", label:"AE +971" },{ code:"+44", label:"GB +44" },{ code:"+1", label:"US +1" },{ code:"+973", label:"BH +973" },
]

const howToIssueSteps = [
  { num:"01", title:"Marriage Registration", desc:"Fulfill the legal requirements to get married in the UAE and submit a marriage application to the relevant marriage court or authority." },
  { num:"02", title:"Marriage Court Appointment", desc:"Once your application is processed, you will receive an appointment date from the marriage court or authority." },
  { num:"03", title:"Marriage Certificate Issuance", desc:"After the marriage ceremony, the marriage officer will issue the original marriage certificate. Ensure all information is accurate and matches the details of both partners." },
  { num:"04", title:"Translation and Notarization", desc:"If your marriage certificate is in a language other than Arabic, have it translated by a certified translator and notarized by the Notary Public or relevant authority." },
  { num:"05", title:"Attestation by UAE Embassy/Consulate", desc:"Submit the original and translated certificates, along with supporting documents, to the UAE embassy or consulate in the home country for verification and attestation." },
  { num:"06", title:"MOFA Attestation", desc:"Once attested by the UAE embassy or consulate, the marriage certificate needs to be further authenticated by the <a href='/mofa-attestation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>Ministry of Foreign Affairs</a> (MOFA) in the UAE." },
]

const howToGainSteps = [
  { num:"01", title:"Application Submission", desc:"Visit the relevant marriage court or authority in the emirate where you plan to get married and submit the necessary application form along with the required documents." },
  { num:"02", title:"Marriage Documentation", desc:"Once the application is processed, the marriage court will provide a date for the marriage ceremony. The authorized marriage officer will conduct the ceremony and prepare the marriage contract." },
  { num:"03", title:"Documentation Completion", desc:"After the ceremony, the marriage officer will issue the original marriage contract, which acts as the marriage certificate." },
  { num:"04", title:"Attestation and Registration", desc:"The translated and notarized marriage contract needs to be attested by the Ministry of Justice or the relevant department in the respective emirate, confirming the document's legal validity." },
  { num:"05", title:"Municipality Registration", desc:"After completing the attestation, register the marriage with the municipality or civil affairs department in the emirate to ensure it is officially recognized and recorded in the UAE." },
]

const whyUs = [
  { icon:"🏆", label:"More than 25 years of expertise in providing customers with effective solutions." },
  { icon:"🌍", label:"Strong presence around the globe in Qatar, Abu Dhabi, Dubai, India, and many more nations thanks to affiliate offices and business networks." },
  { icon:"📋", label:"Multinational organisation with ISO certification offering startup company advice." },
  { icon:"❤️", label:"Dedicated to having our clients' trust and happiness as our main motivator." },
  { icon:"🏢", label:"Comprehensive services for establishing businesses, incorporating them, registering them, assisting with visas and bank account establishment." },
  { icon:"⚖️", label:"PRO, legal translation, and diplomatic services under one roof." },
]
