        </div>
      ))}
    </div>

    <!-- Gain steps -->
    <div id="tab-gain" class="steps-grid" style="display:none;grid-template-columns:repeat(2,1fr);gap:16px;">
      {howToGainSteps.map(s => (
        <div class="step-card">
          <div style="width:44px;height:44px;border-radius:12px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.num}</div>
