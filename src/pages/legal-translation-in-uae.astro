---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const benefits = [
  { icon: "🌐", title: "Cross-Cultural Communication", desc: "With a multicultural population and a thriving international business scene, the UAE frequently requires legal documents to be translated from Arabic to English or vice versa. Index Office Service ensures that all parties involved understand the legal content accurately, eliminating misunderstandings." },
  { icon: "⚖️", title: "Legal Interpretation Services", desc: "In legal proceedings, precise interpretation of spoken language is just as crucial as written translations. Index Office Service provides legal interpretation services in courtrooms, during negotiations, and other legal interactions, ensuring that every word is correctly conveyed." },
  { icon: "📋", title: "Compliance and Legal Documentation", desc: "The UAE has stringent legal requirements, and any document submitted to government authorities or courts must be in compliance with local laws. Index legal translation services ensure that all documents, contracts, and agreements adhere to the UAE's legal standards." },
  { icon: "🔏", title: "Confidentiality and Accuracy", desc: "Legal documents often contain sensitive information. Index legal translation guarantees confidentiality and accuracy, safeguarding the interests of its clients and ensuring the privacy of legal matters." },
]

const whyIndex = [
  { title: "Expertise in Legal Jargon", desc: "Index legal translation services specialize in legal translations, boasting a team of experienced translators who are well-versed in legal terminology and nuances. This expertise ensures accurate and contextually sound translations." },
  { title: "Cultural Sensitivity", desc: "Understanding the cultural aspects of legal documents is vital. Index's team ensures that translations not only reflect the legal content accurately but also respect cultural nuances, maintaining the document's integrity." },
  { title: "Quick Turnaround", desc: "In the fast-paced business environment of the UAE, time is of the essence. Index Office Service is known for its efficient and timely delivery of translated documents, helping clients meet deadlines without compromising on quality." },
  { title: "Confidentiality and Accuracy", desc: "Legal documents often contain sensitive information. Index legal translation guarantees confidentiality and accuracy, safeguarding the interests of its clients and ensuring the privacy of legal matters." },
]

const faqs = [
  {
    q: "How can Index help me get MOJ-approved legal translation for UAE government submissions?",
    a: "Index works with licensed translators who follow UAE Ministry of Justice guidelines, ensuring your translated documents are accepted by courts, ministries, immigration departments, and other official authorities."
  },
  {
    q: "Does Index provide certified legal translation accepted by UAE courts and ministries?",
    a: "Yes. Index provides certified translations prepared by approved professionals so that your documents meet the standards required by UAE courts, notaries, and government institutions."
  },
  {
    q: "Can Index assist with legal translation for immigration and visa processing in the UAE?",
    a: "Index supports immigration-related requirements by translating documents such as birth certificates, marriage certificates, police clearances, and educational certificates for visa and residency submissions."
  },
  {
    q: "How does Index ensure accuracy and compliance in legal document translations?",
    a: "Every document handled by Index is translated by qualified experts and then reviewed for accuracy, legal terminology consistency, and compliance with UAE official formatting rules before delivery."
  },
  {
    q: "Does Index handle both translation and attestation of documents required in the UAE?",
    a: "Yes. Index can manage the complete process including translation, notarization, MOJ approval, and MOFA attestation — so your documents are ready for official use in the UAE."
  },
  {
    q: "Can Index translate legal documents from Arabic to English and vice versa?",
    a: "Index provides certified translation services for both Arabic-to-English and English-to-Arabic, ensuring accuracy in legal terminology across both languages."
  },
  {
    q: "What types of documents can Index translate for legal use in the UAE?",
    a: "Index can translate contracts, certificates, agreements, court documents, powers of attorney, academic records, commercial documents, and other legally sensitive paperwork."
  },
  {
    q: "Can Index review my translated documents to confirm they meet UAE legal requirements?",
    a: "Yes. If you already have a translation, Index can check it for compliance and advise whether additional certification or retranslation is required for acceptance by the UAE authorities."
  },
  {
    q: "Does Index offer urgent or same-day legal translation services in the UAE?",
    a: "Index provides fast-track translation services for urgent cases, helping clients meet tight deadlines for court submissions, visa applications, business filings, and other time-sensitive requirements."
  },
  {
    q: "Why should I choose Index for legal translation compared to other UAE translation agencies?",
    a: "Index offers end-to-end support, licensed translators, strict quality standards, and integrated services such as attestation and PRO assistance, giving clients a streamlined and professional solution."
  },
]
---

<BaseLayout
  title="Legal Translation Services in the UAE | Indexauh"
  description="Ensure accurate and reliable legal translation services in the UAE with Indexauh. Our team of professionals specializes in legal document translation"
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .svc-arrow-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px 20px; display: flex; align-items: flex-start; gap: 12px; transition: all 0.25s; }
  .svc-arrow-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .box-card { background: #fff; border: 1px solid #eef0f6; border-radius: 20px; padding: 32px; transition: all 0.25s; }
  .box-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .faq-item { border: 1px solid #eef0f6; border-radius: 14px; overflow: hidden; }
  .faq-item summary { list-style: none; cursor: pointer; padding: 18px 22px; font-size: 0.88rem; font-weight: 700; color: #1A202C; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: "+"; font-size: 1.2rem; font-weight: 900; color: #38B2AC; flex-shrink: 0; }
  .faq-item[open] summary::after { content: "−"; }
  .faq-item[open] { border-color: #B2F5EA; }
  .faq-body { padding: 0 22px 18px; font-size: 0.82rem; color: #4B5563; line-height: 1.75; }
  details summary { list-style: none; }
  details summary::-webkit-details-marker { display: none; }
  details[open] { border-color: #B2F5EA !important; }
  details[open] summary span:last-child { content: "−"; }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .two-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-75.webp"
    alt="Legal Translation Services UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      LEGAL TRANSLATION<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      In the dynamic landscape of the United Arab Emirates, navigating the legal intricacies can be a challenging endeavour. For individuals and businesses alike, clear and precise communication is vital when dealing with legal matters. Index Office Service steps in to offer impeccable legal translation assistance — bridging linguistic gaps and facilitating seamless communication across language barriers within the UAE's legal domain.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 0.9fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Overview
      </p>
