  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:0.9fr 1.4fr;gap:52px;align-items:center;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
      <img src="/images/img-8.webp" alt="Index Office Services legal translation" style="width:100%;height:440px;object-fit:cover;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
      <div style="position:absolute;bottom:20px;left:20px;right:20px;">
        <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Index Office Service</p>
        <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Trusted Legal Translation Partner in UAE</p>
      </div>
    </div>
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">The Ideal Choice</p>
