          <div style="font-size:1.5rem;flex-shrink:0;">{item.icon}</div>
          <div>
            <p style="font-size:0.92rem;font-weight:800;color:#1A202C;margin:0 0 6px;">{item.title}</p>
            <p style="font-size:0.9rem;color:#4B5563;line-height:1.65;margin:0;">{item.desc}</p>
