<script>
  document.querySelectorAll('details').forEach(details => {
    const icon = details.querySelector('summary span:last-child');
    if (!icon) return;
    details.addEventListener('toggle', () => {
      icon.textContent = details.open ? '−' : '+';
    });
  });
</script>

</BaseLayout>