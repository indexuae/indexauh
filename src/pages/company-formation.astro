---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+971", label: "AE +971" },
  { code: "+91", label: "IN +91" },
  { code: "+44", label: "GB +44" },
  { code: "+1", label: "US +1" },
  { code: "+973", label: "BH +973" },
]

const formationSteps = [
  "Determine the business activity and legal structure.",
  "Select a unique trade name.",
  "Obtain initial approvals from the relevant authorities.",
  "Draft necessary documents, such as the Memorandum of Association.",
  "Secure a tenancy contract for your business premises.",
  "Obtain any additional approvals required.",
  "Compile and submit the required documents and fees for the trade license.",
]

const procedures = [
  { title: "Choose the Business Activity and Legal Structure", desc: "Determine the nature of your business and select a suitable legal structure, such as a sole proprietorship, partnership, limited liability company (LLC), or others." },
  { title: "Reserve and Register the Trade Name", desc: "Choose a unique trade name for your company and register it with the relevant authorities." },
  { title: "Obtain Initial Approvals", desc: "Apply for initial approvals from the government authorities, ensuring compliance with legal requirements and regulations." },
  { title: "Draft Necessary Documents", desc: "Prepare the required legal documents, such as the Memorandum of Association (MOA), local service agent agreement (LSA), and any other agreements specific to the chosen legal structure." },
  { title: "Secure a Tenancy Contract", desc: "Find a suitable location for your business premises and obtain a tenancy contract or lease agreement." },
  { title: "Fulfill Additional Approvals", desc: "Depending on the business activity, you may need to obtain further approvals from government entities, such as municipalities or chambers of commerce." },
  { title: "Submit Documents and Pay Fees", desc: "Compile all necessary documents, including passport copies, educational certificates, and experience certificates. Pay the required fees to complete the company formation process." },
]

const assistanceBenefits = [
  "Expert guidance and advice throughout the entire process.",
  "Efficient handling of paperwork and documentation.",
  "Assistance in navigating complex legal and regulatory requirements.",
  "Access to a network of professional service providers.",
  "Time-saving and streamlined process.",
  "Increased likelihood of successful company formation.",
  "Compliance with all necessary procedures and regulations.",
  "Tailored solutions based on your specific business needs.",
  "Peace of mind and reduced stress during the formation process.",
  "Maximizing the chances of obtaining the desired business license.",
]

const whyChooseUs = [
  { title: "Global Presence", desc: "Index has a strong global presence, spanning the Middle East, Europe, the U.S., and Canada. This enables us to effectively coordinate services and cater to the diverse needs of our clients worldwide." },
  { title: "Unmatched Expertise", desc: "With over 25 years of experience, Index offers invaluable insights, suggestions, and recommendations to our clients. We provide comprehensive support across various service needs, ensuring the best possible assistance." },
  { title: "Quality Assurance", desc: "At Index, we prioritize exceptional quality and customer satisfaction. Our certificate attestation system is built on reliability, accuracy, and overall service excellence, ensuring reliable and trustworthy solutions." },
  { title: "Trusted Partnerships", desc: "We have established a strong network of trusted partners and specialized service providers, especially in certificate attestation. Clients can have complete confidence in our ability to efficiently deliver attestation requirements, setting new standards in speed and reliability." },
]

const faqs = [
  { q: "How can Indexauh help me set up a company in the UAE if I'm a foreign investor?", a: "Indexauh guides you through every step of UAE business setup, including choosing the right jurisdiction, preparing documents, coordinating with government authorities, and managing the entire registration process so foreign investors can establish a company smoothly." },
  { q: "Can Indexauh explain the differences between a UAE Mainland LLC and a Free Zone company?", a: "Yes. Indexauh provides clear guidance on the benefits, ownership rules, cost differences, and operational flexibility of Mainland vs Free Zone structures, helping you choose the most suitable option for your business goals." },
  { q: "Does Indexauh assist with obtaining a trade license during company formation?", a: "Indexauh handles the full trade license application process, including activity selection, approvals, document submission, and fee coordination, ensuring your company becomes operational without unnecessary delays." },
  { q: "Can Indexauh help me secure office space or a registered address for my new business?", a: "Yes. Indexauh offers support in finding office solutions—whether you need a flexi-desk, shared office, or physical workspace—based on the licensing requirements in your chosen jurisdiction." },
  { q: "How long does it typically take for Indexauh to complete the company registration process in the UAE?", a: "Timeframes depend on the business jurisdiction and approvals needed, but Indexauh streamlines all procedures so setup can be completed as quickly as possible, often within a few working days for many Free Zones." },
  { q: "Can Indexauh help me open a corporate bank account in the UAE after company formation?", a: "Yes. Indexauh assists with bank selection, document preparation, compliance requirements, and appointment scheduling to make corporate bank account opening easier for new business owners." },
  { q: "Does Indexauh offer visa and PRO services after helping to form a company?", a: "Indexauh provides complete post-setup support including investor visas, employee visas, Emirates ID processing, and ongoing PRO services for renewals, government approvals, and administrative tasks." },
  { q: "Can Indexauh manage the entire company formation process on my behalf without me being in the UAE?", a: "In many cases, yes. Indexauh can complete most procedures remotely through authorized documentation, allowing you to start your company even if you are not physically in the UAE." },
  { q: "What documents do I need to provide to Indexauh to start forming a company in the UAE?", a: "You typically need passport copies, personal information, business activity details, and any required approvals. Indexauh reviews your documents beforehand and guides you on any additional paperwork needed." },
  { q: "Why should I choose Indexauh over other business-setup consultants in the UAE?", a: "Indexauh combines professional guidance, transparent processes, end-to-end services, and consistent support throughout business setup and beyond making it easier for investors to establish and grow their companies in the UAE." },
]
---

<BaseLayout
  title="Company Formation GCC | Business Setup in GCC Countries"
  description="Index, Leading experienced company in UAE provides all assistance for company formation in GCC countries"
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-2.webp"
    alt="Company Formation in UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      COMPANY FORMATION
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Company formation refers to the process of legally establishing a new company or business entity. It involves registering the company with the appropriate government authorities, defining its legal structure, and fulfilling other legal requirements.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ BENEFITS OF COMPANY FORMATION ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Benefits of Company Formation</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:24px;">
        Company formation offers several benefits to entrepreneurs and businesses. It provides a separate legal entity for the business, which protects personal assets and limits liability. It allows for easier access to funding, enhances credibility and professionalism, provides tax advantages, facilitates business expansion, and enables partnerships and collaborations.
      </p>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">How Can Index Assist You?</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          Index is a trusted financial consultant that offers end-to-end assistance for company formation. We provide expert guidance, handle documentation and paperwork, liaise with government authorities, facilitate the approval process, and ensure compliance with legal requirements. With our in-depth knowledge and extensive network, Index ensures a smooth and efficient company formation experience. With more than 25 years of experience in the industry, we have helped more than 3500 companies to grow in the UAE. Our prices are affordable and our expert native speakers can help you navigate through all the formalities easily and efficiently.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-48.webp" alt="Company formation UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">End-to-End Company Formation</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Handled efficiently by Index Office Services</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          3500+ Companies Formed
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ HOW TO START ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-11.webp" alt="How to start company formation" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">How to Start Company Formation</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Step-by-step guidance from Index</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Getting Started</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">How to Start Company Formation</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          To start a company formation, you need to:
        </p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {formationSteps.map((step, i) => (
            <div style="display:flex;align-items:flex-start;gap:14px;background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:14px 18px;">
              <div style="width:32px;height:32px;border-radius:8px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:0.8rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{String(i+1).padStart(2,'0')}</div>
              <p style="font-size:1rem;color:#4B5563;line-height:1.6;margin:0;padding-top:5px;">{step}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ PROCEDURES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-41.webp" alt="Procedures to start company formation" style="width:100%;height:220px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Procedures to Start Company Formation</h2>
      </div>
    </div>

    <div class="two-col" style="display:grid;grid-template-columns:1fr 1fr;gap:18px;">
      {procedures.map((p, i) => (
        <div class="step-card">
          <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{String(i+1).padStart(2,'0')}</div>
          <div>
            <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{p.title}</p>
            <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ ASSISTANCE BENEFITS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1.3fr 1fr;gap:52px;align-items:center;">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Professional Support</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 14px;">Seeking Company Formation Assistance</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          Seeking professional assistance for company formation can greatly simplify the process and ensure compliance with all legal requirements. Professional consultancy firms, like Index, specialize in providing comprehensive support throughout the company formation process.
        </p>
        <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 16px;border-left:3px solid #38B2AC;padding-left:12px;">Benefits of Company Formation Assistance</h3>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {assistanceBenefits.map(b => (
            <div style="display:flex;align-items:flex-start;gap:10px;font-size:0.84rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;margin-top:1px;">→</span>{b}
            </div>
          ))}
        </div>
      </div>

      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.12);">
        <img src="/images/img-16.webp" alt="Company formation assistance" style="width:100%;height:480px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.78) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:1.05rem;font-weight:800;margin:0 0 3px;">Expert Native Speakers</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Navigating all formalities easily and efficiently</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE US ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
        <img src="/images/img-3.webp" alt="Index Office Services team" style="width:100%;height:340px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">Index Office Services</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Middle East · Europe · U.S. · Canada</p>
        </div>
      </div>
      <div>
        <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Why Choose Us</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.2;margin:0 0 16px;">WHY CHOOSE US?</h2>
        <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;">
          We have a dedicated and experienced team that has been at the forefront in ensuring effective services in Company formation and facilitated easy setup of new businesses of aspiring businessmen. The services are provided within a fixed budget and has proved to be very effective.
        </p>
      </div>
    </div>

    <div class="two-col" style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-bottom:52px;">
      {whyChooseUs.map(b => (
        <div class="benefit-card" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);">
          <h3 style="font-size:0.92rem;font-weight:800;color:#fff;margin:0 0 8px;border-bottom:1px solid rgba(56,178,172,0.3);padding-bottom:8px;">{b.title}</h3>
          <p style="font-size:0.9rem;color:#CBD5E0;line-height:1.65;margin:0;">{b.desc}</p>
        </div>
      ))}
    </div>

    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:40px;text-align:center;border-top:1px solid rgba(255,255,255,0.1);padding-top:48px;">
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">2500</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Companies Formed</p>
      </div>
