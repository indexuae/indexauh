  },
  {
    id: "australia",
    name: "Australia",
    steps: [
      "Notary public authentication",
      "DFAT authentication",
      "UAE Embassy attestation",
      "<a href='/mofa-attestation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>MOFA attestation in the UAE</a>"
    ],
    desc: "Australia Degree Attestation commonly requires notary authentication followed by DFAT authentication."
  },
  {
    id: "canada",
    name: "Canada",
    steps: [
      "Notary or provincial authentication",
      "Global Affairs Canada attestation",
      "UAE Embassy attestation",
      "MOFA attestation in the UAE"
    ],
    desc: "Canada Degree Attestation involves provincial and federal legalization procedures."
  },
]
const requiredDocs = [
  { title: "Original Degree Certificate", desc: "The original certificate is required for verification before attestation can proceed." },
  { title: "Passport Copy", desc: "A copy of the applicant's passport is required as part of the standard documentation." },
  { title: "Authorization Letter", desc: "Required when Index Office Services submits documents on the applicant's behalf." },
  { title: "Academic Transcripts (when required)", desc: "Some authorities request transcripts alongside the degree certificate for additional verification." },
  { title: "Visa Copy (in selected cases)", desc: "Required mainly for applicants already residing in the UAE or where local processing is involved." },
]

const delayReasons = [
  "Incorrect attestation route selection",
  "Incomplete document submission",
  "Laminated or damaged certificates",
  "Name mismatch issues",
  "University verification delays",
  "Missing supporting documents",
  "Incorrect embassy procedures",
]

const startSteps = [
  { step: "01", title: "Contact Our Team", desc: "Contact our team by phone or online consultation. We review your documents and explain the required attestation process." },
  { step: "02", title: "Confirm the Route", desc: "We identify the issuing country and confirm the correct verification and legalization route." },
  { step: "03", title: "Process Management", desc: "Our specialists manage university certificate attestation, embassy legalization, apostille procedures, and degree attestation from MOFA." },
  { step: "04", title: "Secure Delivery", desc: "Once the ministry of foreign affairs degree attestation is completed, we arrange secure document delivery." },
]

const whyChooseUs = [
  { title: "End-to-End Document Handling", desc: "We manage every stage of the process, from initial verification to final delivery, so you don't have to coordinate with multiple authorities." },
  { title: "Country-Specific Expertise", desc: "We provide degree attestation services for certificates issued in more than 100+ countries, each with its own verification route." },
  { title: "Clear Process Guidance", desc: "We confirm the correct attestation route before starting, helping avoid rejection, repeated submissions, and unnecessary delays." },
  { title: "Secure Document Handling", desc: "Your original certificates are handled with full responsibility and care throughout the entire attestation process." },
  { title: "Experienced Attestation Specialists", desc: "With over 25+ years of experience, our specialists understand embassy regulations and MOFA approval processes thoroughly." },
  { title: "Support for Urgent Processing Cases", desc: "We offer assistance for urgent processing cases depending on country and authority availability." },
  { title: "Free Pickup and Delivery Services", desc: "We offer free pickup and delivery services to make the process convenient for clients across the UAE." },
  { title: "Assistance with Complex Verification Cases", desc: "We assist with equivalency, primary source verification, and other complex qualification recognition procedures." },
]

const faqs = [
  { q: "Is Degree Certificate Attestation mandatory for UAE jobs?", a: "Yes, UAE authorities and employers require attested degrees to confirm authenticity." },
  { q: "Can I get a B Tech degree attestation done myself?", a: "You can, but multiple authorities are involved. Using IndexAUH saves time and avoids mistakes." },
  { q: "What is MOFA attestation for degree certificate?", a: "MOFA attestation is the final verification by the UAE Ministry of Foreign Affairs that confirms your degree is legally recognized." },
  { q: "Does the process vary for different countries?", a: "Yes. Countries like India, USA, UK, Canada, and Australia have specific steps before UAE MOFA attestation." },
  { q: "What documents are required for attestation of degree certificate?", a: "Original degree certificate, passport copy, authorization letter, and supporting transcripts if required." },
  { q: "Can someone attest a degree on my behalf?", a: "Yes, with an authorization letter. IndexAUH manages the process from start to finish." },
]
---

<BaseLayout title="Degree Certificate Attestation UAE | Attestation of Degree" 
description="Degree Certificate Attestation in UAE by Index Office Services with 25+ years experience. Trusted & secure degree attestation services in UAE.">

<style>
  .sec-inner { position: relative; z-index: 1; }

  /* pills */
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }

  /* document type card */
  .doc-type-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; transition: all 0.25s; }
  .doc-type-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.06); transform: translateY(-3px); }

  /* steps cards */
  .step-card { display: flex; align-items: flex-start; gap: 18px; padding: 20px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }

  /* tabs countries */
  .country-tab-btn { padding: 10px 22px; border-radius: 9999px; font-size: 0.85rem; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s; }
  .country-tab-btn.active { background: #2D3748; color: #fff; }
  .country-tab-btn:not(.active) { background: #F0FFFE; color: #2D3748; border: 1px solid #B2F5EA; }

  /* list items */
  .check-item { display: flex; align-items: flex-start; gap: 10px; padding: 12px 16px; background: #fff; border: 1px solid #e0e7ef; border-radius: 10px; font-size: 0.85rem; color: #1A202C; font-weight: 500; }

  /* warning item */
  .warning-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px; background: #FFF5F5; border: 1px solid #FEB2B2; border-radius: 10px; font-size: 0.82rem; color: #9B2C2C; font-weight: 500; }

  /* FAQ */
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 200px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  @media(max-width:768px){
    .about-hero-title { font-size: 2rem !important; }
    .about-hero-desc { font-size: 0.88rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .benefits-grid { grid-template-columns: 1fr !important; }
   .degree-types-grid { grid-template-columns: 1fr !important; }
    .offices-flex { flex-direction: column !important; }
    .step-sticky { position: static !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Degree Certificate Attestation UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.88) 0%,rgba(45,55,72,0.82) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">100+ Countries</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="about-hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      DEGREE CERTIFICATE ATTESTATION<br/>IN UAE
    </h1>
    <p class="about-hero-desc" style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:640px;">
      Degree Certificate Attestation is required in the UAE to confirm that your educational certificate is genuine and issued by a recognized institution. UAE authorities do not accept foreign educational documents without proper verification and legalization.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:start;">
    <!-- Left Text -->
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Degree Attestation Services — 25 Years of Trust</h2>

      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Whether you are applying for employment, higher education, professional licensing, or residency-related procedures, educational certificate attestation is an essential requirement in the UAE.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Index Office Services provides professional degree certificate attestation services across the UAE. With over 25+ years of industry experience, our team understands country-specific procedures, embassy regulations, university verification requirements, and MOFA approval processes. We support degree attestation services for employment, university admissions, licensing, equivalency procedures, and government approvals.
      </p>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;margin-bottom:16px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Why Degree Certificate Attestation Is Required in the UAE</h3>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.6;margin:0;">UAE government departments require attestation of degree certificates to verify the authenticity of foreign educational qualifications. This process protects employers, ministries, universities, and licensing authorities from false or unverified documents.</p>
      </div>

      <div style="background:#FFF5F5;border:1px solid #FEB2B2;border-radius:12px;padding:18px;margin-bottom:16px;">
        <h3 style="color:#9B2C2C;font-size:0.95rem;font-weight:700;margin:0 0 10px;">Degree Attestation is Mandatory For:</h3>
        <div style="display:flex;flex-direction:column;gap:6px;">
          {mandatoryFor.map(item => (
            <div style="font-size:0.82rem;color:#9B2C2C;display:flex;align-items:center;gap:6px;">
              <span style="font-weight:bold;">•</span> {item}
            </div>
          ))}
        </div>
      </div>

      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;">
        Without the Ministry of Foreign Affairs degree attestation, foreign degree certificates generally do not hold legal recognition in the UAE.
      </p>
    </div>

    <!-- Right side: image + stat -->
    <div style="display:flex;flex-direction:column;gap:24px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-16.webp" alt="Degree attestation documents" style="width:100%;height:340px;object-fit:cover;" />
        <div style="position:absolute;bottom:20px;left:-16px;background:#2D3748;color:#fff;padding:12px 18px;border-radius:12px;font-size:0.9rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>

      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-52.webp" alt="University degree certificates" style="width:100%;height:280px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.65) 100%);"></div>
        <div style="position:absolute;bottom:18px;left:18px;right:18px;">
          <p style="color:#fff;font-size:0.98rem;font-weight:700;margin:0;line-height:1.4;">Service support in 100+ countries</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ TYPES OF DEGREES COVERED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:48px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Coverage</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">Types of Degrees Covered</h2>
      <p style="color:#6B7280;font-size:1.05rem;max-width:620px;margin:0 auto;">We handle attestation for all types of university and college degrees.</p>
    </div>

   <div class="degree-types-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;">
      {degreeTypes.map(d => (
        <div class="doc-type-card" style="display:flex;align-items:center;gap:12px;padding:18px;">
          <span style="font-size:1.6rem;flex-shrink:0;">{d.icon}</span>
          <p style="font-size:0.92rem;font-weight:700;color:#1A202C;margin:0;line-height:1.4;">{d.title}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ STEP BY STEP PROCESS ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Authentication Workflow</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">Degree Certificate Attestation Process in UAE</h2>
      <p style="color:#6B7280;font-size:1.05rem;max-width:640px;margin:0 auto;">The Degree Attestation process in the UAE follows a structured verification procedure based on the country where the certificate was issued and the requirements of the concerned authorities.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;" class="split-grid">
      <!-- Steps list -->
     <div style="display:flex;flex-direction:column;gap:14px;">
  {steps.map(s => (
    <div class="step-card">
      <div style="width:40px;height:40px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
      <div>
        <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;" set:html={s.title}></p>
        <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
      </div>
    </div>
  ))}
</div>
      <!-- Right image -->
      <div style="position:sticky;top:100px;" class="step-sticky">
        <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.12);">
          <img src="/images/img-7.webp" alt="Degree attestation process" style="width:100%;height:460px;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(26,32,44,0.75) 100%);"></div>
          <div style="position:absolute;bottom:20px;left:20px;right:20px;">
            <p style="color:#fff;font-size:1rem;font-weight:800;margin:0 0 4px;">5-Step Verified Process</p>
            <p style="color:#B2F5EA;font-size:0.9rem;margin:0;">From university verification to MOFA final approval</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ COUNTRY-SPECIFIC ATTESTATION (TABS) ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1000px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:40px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Global Rules</p>
      <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">Country Specific Degree Certificate Attestation</h2>
      <p style="color:#4B5563;font-size:1rem;max-width:620px;margin:0 auto;line-height:1.6;">We provide degree attestation services for certificates issued in more than 100+ countries. No matter where your degree was issued, Index Office Services manages the complete process from verification to MOFA attestation.</p>
    </div>

    <!-- Country Tabs -->
    <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:32px;">
      {countriesData.map((c, idx) => (
        <button class={`country-tab-btn ${idx === 0 ? 'active' : ''}`} data-tab={c.id}>
          {c.name}
        </button>
      ))}
    </div>

    <!-- Country steps panels -->
    {countriesData.map((c, idx) => (
      <div id={`country-${c.id}`} style={`display: ${idx === 0 ? 'block' : 'none'}; background:#fff; border-radius:18px; padding:32px; box-shadow:0 10px 30px rgba(56,178,172,0.06); border:1px solid #B2F5EA;`}>
        <h3 style="font-size:1.15rem;font-weight:800;color:#1A202C;margin:0 0 8px;">Degree Attestation in {c.name}</h3>
        <p style="font-size:1rem;color:#6B7280;margin:0 0 20px;">{c.desc}</p>
        <div style="display:flex;flex-direction:column;gap:10px;">
