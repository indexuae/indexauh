---

<BaseLayout
  title="Company Registration in the UAE | Expert Business Support"
  description="Complete your company registration in the UAE with Indexauh. Our experienced team provides expert guidance for a smooth and efficient business setup."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .company-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 24px; transition: all 0.25s; }
  .company-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 300px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .steps-grid { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-9.webp"
    alt="Company Registration in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      COMPANY REGISTRATION<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      Setting up a business in the UAE is a dynamic venture that attracts entrepreneurs and investors from around the world. The UAE, with its strategic location, vibrant economy, and business-friendly environment, offers a plethora of opportunities for those looking to establish their presence in the Middle East.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ PURPOSE ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Purpose of Company Registration in the UAE</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:20px;">
        Company registration in the UAE serves multiple purposes, making it an attractive destination for businesses worldwide:
      </p>
      <div style="display:flex;flex-direction:column;gap:12px;">
        {purposes.map(p => (
          <div style="background:#F8FAFF;border:1px solid #E2E8F0;border-left:3px solid #38B2AC;border-radius:10px;padding:14px 16px;">
            <p style="font-size:1.05rem;color:#1A202C;font-weight:700;margin:0 0 4px;">{p.title}</p>
            <p style="font-size:0.98rem;color:#4B5563;line-height:1.7;margin:0;">{p.body}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/uae-flag.webp" alt="Company registration UAE" style="width:100%;height:480px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Professional Company Registration in the UAE</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">End-to-end support by Index Office Services</p>
        </div>
        <div style="position:absolute;bottom:82px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          2500+ Companies Registered
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ STEPS ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-41.webp" alt="UAE company registration steps" style="width:100%;height:220px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Starting a Company in the UAE</h2>
      </div>
    </div>

    <div class="steps-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:52px;">
      {steps.map(s => (
        <div class="company-card" style="position:relative;padding-top:32px;">
          <span style="position:absolute;top:-1px;left:24px;background:#38B2AC;color:#fff;font-size:0.7rem;font-weight:900;padding:4px 10px;border-radius:0 0 8px 8px;letter-spacing:0.06em;">{s.n}</span>
          <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:10px;">{s.title}</h3>
          <p style="font-size:0.8rem;color:#4B5563;line-height:1.7;margin:0;">{s.body}</p>
        </div>
      ))}
    </div>

    <!-- How to Form -->
    <h3 style="font-size:1.2rem;font-weight:900;color:#1A202C;margin:0 0 20px;text-align:center;">How Index Office Services Helps You Register a Company in the UAE</h3>
    <div class="two-col" style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
      {howToForm.map(h => (
        <div class="company-card">
          <h3 style="font-size:0.92rem;font-weight:800;color:#1A202C;margin:0 0 10px;border-left:3px solid #38B2AC;padding-left:10px;">{h.title}</h3>
          <p style="font-size:0.98rem;color:#4B5563;line-height:1.7;margin:0;">{h.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ BENEFITS / WHY CHOOSE US ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
        <img src="/images/img-3.webp" alt="Index Office Services team" style="width:100%;height:340px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">Index Office Services</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">9+ Countries · Global Reach</p>
        </div>
      </div>
      <div>
        <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Why Choose Us</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.2;margin:0 0 16px;">Benefits of Choosing Index Office Services</h2>
        <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin-bottom:16px;">
          Selecting the right partner for company registration in the UAE is essential for a seamless experience and long-term success. Index Office Services offers a range of benefits for entrepreneurs and businesses looking to establish themselves in the UAE.
        </p>
        <p style="color:#94A3B8;font-size:1rem;line-height:1.8;">
          Company registration in the UAE opens doors to a world of opportunities. Index Office Services simplifies the process, allowing you to focus on what matters most — growing your business in this thriving economic hub.
        </p>
      </div>
    </div>

    <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:52px;">
      {benefits.map(b => (
        <div class="benefit-card">
          <h3 style="font-size:0.92rem;font-weight:800;color:#fff;margin:0 0 8px;border-bottom:1px solid rgba(56,178,172,0.3);padding-bottom:8px;">{b.title}</h3>
          <p style="font-size:0.9rem;color:#CBD5E0;line-height:1.65;margin:0;">{b.body}</p>
        </div>
      ))}
    </div>

    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:28px;margin-bottom:52px;">
      <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin:0 0 12px;">
        Company registration in the UAE opens doors to a world of opportunities. Index Office Services simplifies the process, allowing you to focus on what matters most – growing your business in this thriving economic hub.
      </p>
      <p style="color:#94A3B8;font-size:1rem;line-height:1.8;margin:0;">
        Let us be your trusted partner on your journey to success in the UAE. We have a dedicated and experienced team that has been at the forefront in ensuring effective services in company registration and facilitated easy setup of new businesses of aspiring businessmen. The services are provided within a fixed budget and have proved to be very effective.
      </p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:40px;text-align:center;border-top:1px solid rgba(255,255,255,0.1);padding-top:48px;">
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">2500</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Companies Formed</p>
      </div>
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">25</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Years of Experience</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ FAQ ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:820px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Got Questions?</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0;">FREQUENTLY ASKED QUESTIONS</h2>
      <p style="color:#4B5563;font-size:1.05rem;margin-top:12px;">UAE Company Registration FAQs</p>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;">
      {faqs.map((f, i) => (
        <div class="faq-item">
          <button class="faq-q">
            <span>{i + 1}. {f.q}</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-a">
            <p style="color:#4B5563;font-size:0.875rem;line-height:1.75;margin:0;">{f.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════ GET IN TOUCH ════════════ -->
<section id="get-in-touch" style="background:#2D3748;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:600px;height:300px;background:radial-gradient(ellipse,rgba(56,178,172,0.12) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;gap:52px;align-items:flex-start;">

    <div style="flex:1;min-width:280px;">
      <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Free Consultation</p>
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.25;margin:0 0 18px;">Contact Us</h2>
      <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin-bottom:28px;">
