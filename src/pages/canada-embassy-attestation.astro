---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whyRequired = [
  "Employment visa",
  "Family visa",
  "Higher education",
  "Professional license",
  "Business registration",
  "Business set up in UAE",
  "Court or legal matters",
]

const personalDocs = [
  "Canada Marriage certificate attestation",
  "Canada Birth certificate attestation",
  "Divorce Certificate Attestation",
  "Death Certificate Attestation",
  "Transfer Certificate Attestation",
  "Police Clearance Certificate (PCC)",
  "Affidavit Attestation",
  "Singleness Certificate Attestation",
  "Medical Certificate Attestation",
  "Adoption Certificate Attestation",
]

const educationalDocs = [
  "Canada Degree Certificate Attestation",
  "Master Degree Certificate Attestation",
  "Engineering Degree Certificate Attestation",
  "Diploma Certificate Attestation",
  "Degree Certificate Attestation",
  "Nursing Certificate Attestation",
  "Transcripts and Mark Sheets Attestation",
  "Professional Qualification Certificates Attestation",
  "Certificate of Experience Attestation",
  "Vocational and Technical Certificates",
]

const commercialDocs = [
  "Memorandum of Association",
  "Articles of Association",
  "Certificate of Incumbency",
  "Power of Attorney",
  "Commercial Invoices",
  "Certificate of Incorporation",
  "Certificate of Good Standing",
  "Board Resolution",
  "Shareholder Resolution",
  "Agency Agreement",
]

const docTypes = [
  { category: "Personal Documents", icon: "👤", docs: personalDocs },
  { category: "Educational Certificates", icon: "🎓", docs: educationalDocs },
  { category: "Commercial Documents", icon: "⚖️", docs: commercialDocs },
]

const processSteps = [
  { step: "01", title: "Notarization in Canada", desc: "Your document must first be notarized by a recognized authority in Canada." },
  { step: "02", title: "Authentication from Global Affairs Canada", desc: "Global Affairs Canada verifies the notary seal. This is a required step before embassy submission." },
  { step: "03", title: "UAE Embassy Ottawa Attestation", desc: "The UAE Embassy in Ottawa stamps the document. This step is very important in Canada Embassy Attestation and is different from the Canadian Embassy in Dubai." },
  { step: "04", title: "UAE MOFA Attestation", desc: "After the document reaches the UAE, MOFA adds the final stamp. The document becomes legally accepted for official use." },
]

const requiredDocs = [
  "Original certificate",
  "Passport copy",
  "Visa copy",
  "Authorization letter",
]

const feeFactors = [
  "Document category",
  "Government charges in Canada",
  "UAE Embassy charges",
  "MOFA fees",
  "Service handling",
]

const commonMistakes = [
  "Skipping Global Affairs Canada authentication",
  "Sending documents to the wrong authority",
  "Confusion between UAE Embassy Ottawa attestation and Canada Embassy Dubai",
  "Submitting damaged or incomplete certificates",
]

const getStartedSteps = [
  { step: "01", title: "Contact Our Team", desc: "Reach us via phone, email, or WhatsApp. Our team will explain the requirements and guide you clearly." },
  { step: "02", title: "Share Your Document", desc: "Share a copy of your document. We review everything and guide you on the exact process needed." },
  { step: "03", title: "Submit the Original", desc: "Submit the original document. Our team checks everything before starting to reduce mistakes." },
  { step: "04", title: "We Handle Everything", desc: "We handle the full Canada Embassy Attestation process including coordination with all authorities at every stage." },
  { step: "05", title: "Receive Attested Document", desc: "You receive the attested document after UAE MOFA stamping. Your document stays safe with us throughout." },
]

const whyChoose = [
  { title: "25+ Years of Experience", desc: "More than 25 years of experience in certificate attestation services across the UAE with thousands of trusted clients served." },
  { title: "UAE Embassy Ottawa Expertise", desc: "Strong knowledge of UAE Embassy Ottawa attestation procedures and a clear understanding of UAE Embassy Canada attestation requirements." },
  { title: "Pre-Submission Document Review", desc: "Our team checks your documents before submission. This avoids delay, rejection, and the extra expense that comes with repeated submissions." },
  { title: "Transparent Fees", desc: "We explain the full cost clearly before we start. There are no hidden surprises. You know exactly what you are paying for." },
  { title: "Pickup and Delivery Across UAE", desc: "Convenient document pickup and delivery service available across the UAE for a hassle-free experience from start to finish." },
  { title: "Regular Updates at Every Stage", desc: "You receive updates at each step of the process. Your documents are handled with complete care and accuracy." },
]

const faqs = [
  { q: "Is Canada part of the Apostille for the UAE?", a: "No. Canada is not part of the Apostille system for UAE use. Full legalization through the embassy and MOFA is required." },
  { q: "Is Canada Embassy Attestation mandatory for UAE jobs?", a: "Yes. Most employers and authorities require it before they accept your certificate for employment or professional purposes." },
  { q: "Can I submit documents directly to the UAE Embassy in Canada?", a: "Yes, but the process can be confusing. Many people prefer professional guidance to avoid mistakes and delays." },
  { q: "What is the role of UAE MOFA?", a: "MOFA gives the final stamp in the UAE after embassy legalization. This is the last step that makes your document legally accepted." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Canada Embassy Attestation in UAE | 25 Years of Expertise"
  description="Canada Embassy Attestation in UAE with 25+ years of experience. We handle the UAE embassy Ottawa attestation and full legalization. Book for free consultation."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .img-first { order: -1 !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
    .get-started-grid { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Canada Embassy Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Canada Embassy Attestation</span>
      <span class="idx-pill">Canada Attestation Services</span>
      <span class="idx-pill">25 Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      CANADA EMBASSY ATTESTATION<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      Canada Embassy Attestation makes your Canadian document valid in the UAE. Canada is not part of the Apostille system for UAE use, so full legalization through the proper authorities is required. With more than 25 years of experience, our team guides you through each step in simple words.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-btns">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Why It Is Required
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Why Canada Embassy Attestation is Required in UAE?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        UAE authorities ask for Canada Embassy Attestation to confirm that your document is genuine. Without this process, your certificate has no legal value here. Many people think notarization alone is enough — it is not. UAE offices require full UAE Embassy Canada attestation before they accept the document.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:20px;">
        When documents are not attested properly, applications get delayed. Some get rejected. This creates stress and extra expense. A clear process saves time and money.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 12px;">You need it for:</h3>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
          {whyRequired.map(item => (
            <div style="display:flex;align-items:center;gap:8px;font-size:0.88rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{item}
            </div>
          ))}
        </div>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/canada-flag.avif" alt="Canada Embassy attestation UAE" style="width:100%;height:460px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Global Affairs Canada · UAE Embassy Ottawa · MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Canada Embassy attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:88px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Canada Embassy Attestation Services"
  description="We handle attestation for a wide range of document categories. Always confirm with the requesting authority what exact form of attestation they require."
  imageSrc="/images/img-1.webp"
  imageAlt="Canada attestation document types"
  docTypes={docTypes}
  country="canada"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Canada Embassy attestation process" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Canadian Embassy or Consulate Attestation Process in UAE</h2>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start;" class="split-grid">
      <!-- Steps left -->
      <div style="display:flex;flex-direction:column;gap:20px;">
        <div>
          <div style="background:#2D3748;border-radius:12px;padding:14px 20px;margin-bottom:20px;">
            <p style="color:#38B2AC;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 2px;">Attestation Flow</p>
            <p style="color:#fff;font-size:0.95rem;font-weight:800;margin:0;">Canadian Documents for UAE Use</p>
          </div>
          <div style="display:flex;flex-direction:column;gap:14px;">
            {processSteps.map(s => (
              <div class="step-card">
                <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
                <div>
                  <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
                  <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Key clarification -->
        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:20px;">
          <h3 style="font-size:0.9rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">UAE Embassy Ottawa vs Canada Embassy Dubai</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">People often get confused between these two. In most cases, the main legalization is done through the UAE Embassy Ottawa attestation — not the Canadian Embassy in Dubai. Our team explains which applies to your specific document.</p>
        </div>
      </div>

      <!-- Side panels right -->
      <div style="display:flex;flex-direction:column;gap:20px;">

        <!-- Required Documents -->
        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">The process is simple when documents are correct. Our team checks everything before starting to reduce mistakes.</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {requiredDocs.map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{d}
              </div>
            ))}
          </div>
        </div>

        <!-- Processing Time -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Processing Time</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">Processing time depends on the document type and authority clearance. Educational and commercial documents may take more time due to verification. On average, Canada Attestation takes a few weeks including Canada side authentication and UAE MOFA stamping. We give you a clear time estimate after checking your document.</p>
        </div>

        <!-- Fees -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Fees for Canada Embassy Attestation</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">We explain the full cost clearly before we start. There are no hidden surprises. Fees depend on:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {feeFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ════ COMMON MISTAKES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;" class="two-col">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What to Watch For</p>
        <h2 style="font-size:1.8rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Common Mistakes People Make</h2>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:24px;">
          Many delays happen due to simple mistakes. Our team reviews everything before submission to prevent these issues from causing setbacks.
        </p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {commonMistakes.map(c => (
            <div style="display:flex;align-items:center;gap:12px;background:#FFF5F5;border:1px solid #FED7D7;border-radius:10px;padding:12px 16px;">
              <span style="color:#E53E3E;font-weight:bold;font-size:1rem;flex-shrink:0;">!</span>
              <p style="font-size:0.88rem;color:#4B5563;line-height:1.5;margin:0;">{c}</p>
            </div>
          ))}
        </div>
      </div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-40.webp" alt="Common Canada attestation mistakes" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">Avoid Delays</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">We review everything before submission</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ GET STARTED ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;text-align:center;">
    <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Simple Process</p>
    <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">How to Get Started with Canada Embassy Attestation</h2>
    <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0 auto 44px;max-width:560px;">
      Starting is easy. IndexAUH and our support team coordinate every stage carefully. Your document stays safe with us.
    </p>

    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:18px;text-align:left;" class="get-started-grid two-col">
      {getStartedSteps.map(s => (
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;position:relative;">
          <div style="font-size:3rem;font-weight:900;color:#B2F5EA;line-height:1;margin-bottom:14px;">{s.step}</div>
          <h3 style="font-size:0.92rem;font-weight:800;color:#1A202C;margin:0 0 8px;">{s.title}</h3>
          <p style="font-size:0.82rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE INDEX ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;" class="split-grid">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
