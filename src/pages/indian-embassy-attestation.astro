---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whenNeeded = [
  "Employment approval in the UAE",
  "Family or spouse visa applications",
  "Property or legal matters in India",
  "POAs intended for personal or commercial use",
  "Business and company documentation",
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Marriage certificate attestation",
      "Death Certificate Attestation",
      "Birth certificate attestation",
      "Divorce Certificate Attestation",
      "Transfer Certificate Attestation",
      "PCC",
      "Affidavit",
      "Medical Certificate Attestation",
    ],
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Degree Attestation",
      "Diploma Certificate Attestation",
      "Master Degree Certificate Attestation",
      "Engineering Degree Certificate Attestation",
      "Medical and Nursing Degree Certificate Attestation",
      "Professional Qualification Certificate",
    ],
  },
  {
    category: "Commercial Documents",
    icon: "⚖️",
    docs: [
      "Memorandum of Association (MOA)",
      "Articles of Association (AOA)",
      "Certificate of Incorporation",
      "Certificate of Good Standing",
      "Board Resolutions",
      "Commercial Invoices",
      "Power of Attorney",
      "Commercial License",
    ],
  },
]

const processSteps = [
  { step: "01", title: "Document Verification", desc: "Check that your document is original and issued by a recognized authority in India. Ensure all details are correct and legible." },
  { step: "02", title: "Attestation in India (If Required)", desc: "Certain documents need state-level approval. Ministry of External Affairs (MEA) attestation may also be needed, confirming your document is genuine before embassy submission." },
  { step: "03", title: "Indian Embassy or Consulate Attestation in UAE", desc: "Submit your document to the Indian Embassy in Abu Dhabi or Consulate in Dubai. Embassy staff verify the authenticity and place an official stamp." },
  { step: "04", title: "UAE MOFA Attestation", desc: "The Ministry of Foreign Affairs in UAE provides final approval, making your document legally valid for use with UAE authorities." },
  { step: "05", title: "Secure Document Delivery", desc: "After all approvals, your attested document is returned safely, ready for visas, legal, property, employment, or business purposes." },
]

const marriageSteps = [
  { title: "Marriage Certificate Verification", desc: "We check that the original marriage certificate is correct and complete, confirm it is issued by the proper Indian authority, and make sure the language is readable and clear." },
  { title: "Attestation in India", desc: "Some marriage certificates need approval from the State or Home Department in India, then verification by the Ministry of External Affairs (MEA), confirming authenticity before sending to the UAE." },
  { title: "Indian Embassy or Consulate Attestation in UAE", desc: "Submit your certificate to the Indian Embassy in Abu Dhabi or the Consulate in Dubai. The embassy staff checks your certificate and places an official stamp." },
  { title: "UAE MOFA Attestation", desc: "The Ministry of Foreign Affairs in the UAE gives the final approval, making your marriage certificate legally accepted by UAE authorities." },
]

const poaSteps = [
  { title: "Draft Review", desc: "Check that the purpose of the POA is clear and the wording is correct so it works legally." },
  { title: "Signing and Notarisation", desc: "The document must be signed properly, and the identity of the signer is verified to avoid problems later." },
  { title: "Attestation in India", desc: "Some POAs need approval from local authorities in India. The Ministry of External Affairs (MEA) also verifies the document." },
  { title: "Submit for Indian Embassy/Consulate Verification in UAE", desc: "The POA must be submitted to the Indian Embassy in Abu Dhabi or the Consulate in Dubai, where officials confirm its authenticity and stamp the document." },
  { title: "UAE MOFA Attestation", desc: "The Ministry of Foreign Affairs in UAE provides final approval. Once done, the POA is legally valid for property, banking, or business use in the UAE." },
]

const docsRequired = [
  "Original document",
  "Passport copy",
  "Visa page copies",
  "Photographs",
  "Supporting letters",
]

const timingFactors = [
  "Document type",
  "Issuing authority",
  "Embassy and MOFA procedures",
  "Document completeness",
]

const feeFactors = [
  "Embassy charges",
  "MOFA fees",
  "Document category",
  "Handling requirements",
]

const challenges = [
  "Submitting documents in the wrong order",
  "Assuming notarisation is enough",
  "Missing passport or visa pages",
  "Using incorrect document formats",
]

const howWeAssist = [
  { title: "Document Review and Guidance", desc: "We check your documents for correctness and ensure they meet all embassy requirements." },
  { title: "Step by Step Process Handling", desc: "From document verification, attestation in India (if required), embassy or consulate attestation in UAE, to MOFA approval, we manage everything." },
  { title: "Secure Pickup and Delivery", desc: "We collect your documents from your location and deliver them safely once attested." },
  { title: "Avoid Delays and Rejections", desc: "Our experts prevent common mistakes like wrong document order, missing details, or incorrect formats." },
  { title: "Transparent Updates", desc: "You receive clear updates at every stage so you always know the status of your documents." },
  { title: "All Needs Under One Roof", desc: "Personal, educational, legal, and commercial documents are handled together, saving you time and effort." },
]

const whyChoose = [
  { title: "Expertise in Embassy Systems", desc: "We understand every requirement and procedure clearly." },
  { title: "Correct Attestation Order", desc: "Each document is processed in the proper sequence to avoid delays." },
  { title: "Safe Handling of Documents", desc: "Originals and copies are securely managed throughout." },
  { title: "Clear Guidance at Every Step", desc: "We explain the process so you always know what's happening." },
  { title: "Free Pickup and Delivery", desc: "We offer complimentary document pickup and secure delivery for added convenience." },
  { title: "All Needs Under One Roof", desc: "Personal, educational, legal, and commercial documents handled together." },
]

const faqs = [
  { q: "Can someone submit my documents on my behalf at the Indian Embassy?", a: "Yes. You can authorize a trusted person to submit your documents. They must carry a valid ID and a signed authorization letter. Our team at Indexauh also handles submissions on your behalf, ensuring your documents reach the embassy safely and on time." },
  { q: "Are translations required for Indian documents before attestation?", a: "Some documents, especially regional language certificates, may need certified English translations. Educational or legal documents issued in English usually do not need translation. We guide you on which documents require translation to save time and prevent delays." },
  { q: "Can attested documents be used for multiple purposes in the UAE?", a: "Yes. Once documents are attested by the Indian Embassy and UAE MOFA, they can be used for family visas, employment, property matters, or legal purposes. We make sure your documents are attested correctly so they are accepted for all intended uses." },
  { q: "What happens if a document is rejected by the embassy or MOFA?", a: "Rejection usually happens if the document is incomplete, not verified in the correct order, or contains errors. Our team reviews every document carefully before submission to prevent rejections. In case of any issue, we guide you step by step to correct it." },
  { q: "Do you provide free pickup and delivery for attestation services in UAE?", a: "Absolutely. Indexauh offers free pickup and delivery to make the process easy and convenient. Your documents are collected securely, attested, and returned safely to your doorstep." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Indian Embassy Attestation in UAE | Indexauh"
  description="Get Indian Embassy Attestation in UAE with Index Office & Services. 25 years of trusted experience in document legalization."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 280px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .four-col { display: grid !important; }
  .five-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr 1fr !important; }
    .five-col { grid-template-columns: 1fr 1fr !important; }
    .img-first { order: -1 !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
    .process-split { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Indian Embassy Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Indian Embassy Attestation</span>
      <span class="idx-pill">25+ Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      INDIAN EMBASSY ATTESTATION<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Indian embassy attestation is required when Indian documents need legal acceptance in the UAE. This process confirms that documents are genuine and approved by official authorities. With over 25+ years of experience in the UAE attestation field, our focus stays on accuracy, clarity, and smooth processing so documents move without rejection.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ WHEN DO YOU NEED ════ -->
<section id="details" style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;" class="split-grid">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/india-flag.webp" alt="When to get Indian embassy attestation" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">When You Need Attestation</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Work · Family · Property · Business</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Key Situations</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">When Do You Need Indian Embassy Attestation?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          You may need Indian embassy attestation in many real life situations, especially when dealing with UAE authorities. Common reasons include:
        </p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {whenNeeded.map(item => (
            <div style="display:flex;align-items:flex-start;gap:12px;background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:14px 18px;">
              <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:2px;">→</span>
              <p style="font-size:0.9rem;color:#374151;line-height:1.6;margin:0;">{item}</p>
            </div>
          ))}
        </div>
        <p style="color:#4B5563;font-size:0.88rem;line-height:1.7;margin-top:18px;">UAE departments only accept documents that carry proper embassy and MOFA verification.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Indian Embassy Attestation Services"
  description="We handle attestation for a wide range of document categories across personal, educational, and commercial needs."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Indian attestation"
  docTypes={docTypes}
  country="india"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Indian attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:520px;line-height:1.25;">Step by Step Embassy Attestation Process for Indian Issued Documents in UAE</h2>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;" class="split-grid">
      <div style="display:flex;flex-direction:column;gap:14px;">
        {processSteps.map(s => (
          <div class="step-card">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div style="display:flex;flex-direction:column;gap:20px;">
        <!-- Documents Required -->
        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 10px;">Usually required:</p>
          <div style="display:flex;flex-direction:column;gap:9px;margin-bottom:14px;">
            {docsRequired.slice(0,2).map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{d}
              </div>
            ))}
          </div>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 10px;">Additional requirements may include:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {docsRequired.slice(2).map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{d}
              </div>
            ))}
          </div>
          <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">Our team reviews documents before submission to prevent delays.</p>
        </div>

        <!-- Timing -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">How Long Does It Take?</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">The time required depends on several factors:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {timingFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
          <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">Indian embassy attestation moves faster when documents are correct from the start.</p>
        </div>

        <!-- Fees -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Cost of Attestation</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Pricing depends on:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {feeFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
          <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">We explain all charges clearly before starting the process.</p>
        </div>
      </div>
    </div>

    <!-- Embassy vs Consulate -->
    <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:28px;margin-top:32px;">
      <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 12px;">Indian Embassy and Indian Consulate Difference</h3>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.75;margin:0;">The Indian Embassy is located in Abu Dhabi. The Indian Consulate operates from Dubai. Indian embassy attestation is handled through the correct authority based on document type and location. We manage submissions through the right channel to avoid rejection.</p>
    </div>
  </div>
</section>

<!-- ════ SPECIFIC PROCESSES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;" class="two-col">
      <!-- Marriage -->
      <div style="background:#F8FAFF;border:1px solid #eef0f6;border-radius:16px;padding:28px;">
        <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 8px;">Indian Embassy Marriage Certificate Attestation Process</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.65;margin:0 0 18px;">Marriage certificate attestation is usually needed for family visa, spouse sponsorship, or immigration in the UAE.</p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {marriageSteps.map((s, i) => (
            <div style="display:flex;align-items:flex-start;gap:10px;">
              <span style="color:#38B2AC;font-weight:900;font-size:0.85rem;flex-shrink:0;">{i + 1}.</span>
              <div>
                <p style="font-size:0.88rem;font-weight:700;color:#1A202C;margin:0 0 3px;">{s.title}</p>
                <p style="font-size:0.82rem;color:#6B7280;line-height:1.55;margin:0;">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- POA -->
      <div style="background:#F8FAFF;border:1px solid #eef0f6;border-radius:16px;padding:28px;">
        <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 8px;">Indian Embassy Power of Attorney Attestation Process</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.65;margin:0 0 18px;">A Power of Attorney (POA) grants another person authority to act for you, and must be handled carefully to be valid in the UAE.</p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {poaSteps.map((s, i) => (
            <div style="display:flex;align-items:flex-start;gap:10px;">
              <span style="color:#38B2AC;font-weight:900;font-size:0.85rem;flex-shrink:0;">{i + 1}.</span>
              <div>
                <p style="font-size:0.88rem;font-weight:700;color:#1A202C;margin:0 0 3px;">{s.title}</p>
                <p style="font-size:0.82rem;color:#6B7280;line-height:1.55;margin:0;">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ CHALLENGES ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

