---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whoNeeds = [
  "Employment visa processing",
  "Higher education admission",
  "Family visa sponsorship",
  "Company registration",
  "Legal matters in UAE",
]

const mandatory = [
  "Many people think an apostille is enough, but Switzerland follows the Hague Convention while the UAE does not",
  "Swiss documents need full legalization to be accepted in the UAE",
]

const docTypes = [
  {
    category: "Switzerland Personal Documents Attestation",
    icon: "👤",
    docs: [
      "Switzerland Marriage certificate attestation",
      "Switzerland Birth certificate attestation",
      "Switzerland Divorce Certificate Attestation",
      "Switzerland Death Certificate Attestation",
      "Switzerland Police Clearance Certificate Attestation",
      "Medical Certificate Attestation",
      "Single Status Certificate Attestation",
      "Affidavit",
    ],
  },
  {
    category: "Switzerland Educational Certificate Attestation",
    icon: "🎓",
    docs: [
      "Switzerland Degree Certificate Attestation",
      "Diploma Certificate Attestation",
      "School Certificate Attestation",
      "Mark Sheets Attestation",
      "Technical Certificate Attestation",
      "Nursing Certificate Attestation",
      "Engineering Certificate Attestation",
      "Transcript Attestation",
    ],
  },
  {
    category: "Switzerland Commercial Documents Attestation",
    icon: "⚖️",
    docs: [
      "Power of Attorney Attestation",
      "Company Incorporation Documents Attestation",
      "Memorandum of Association Attestation",
      "Articles of Association Attestation",
      "Board Resolution Attestation",
      "Commercial Invoice Attestation",
      "Commercial License",
    ],
  },
]

const purposeGroups = [
  {
    title: "Uses of Educational Certificates",
    desc: "Employers in the UAE check your degree before issuing a work visa.",
    items: ["Employment visa approval", "Professional license", "University admission", "Equivalency certificate"],
  },
  {
    title: "Uses of Marriage Certificates",
    desc: "Marriage certificate legalization proves the relationship is valid.",
    items: ["Sponsor spouse visa", "Apply for dependent visa", "Update marital status in UAE records", "Open joint bank accounts"],
  },
  {
    title: "Uses of Birth Certificates",
    desc: "Birth certificate attestation confirms parent and child details.",
    items: ["Child visa processing", "School admission", "Passport application", "Family benefits registration"],
  },
]

const processRoutes = [
  {
    step: "01",
    title: "Notary & Swiss Authentication",
    desc: "The document gets initial verification before moving to the Canton or Federal level.",
    steps: [
      "Notary attestation in Switzerland, where the document gets initial verification",
      "Authentication from Swiss authorities, where the Canton office or Federal Department confirms the document",
    ],
  },
  {
    step: "02",
    title: "UAE Embassy & MOFA Attestation",
    desc: "Once authenticated in Switzerland, the document is stamped by the UAE Embassy and given final approval.",
    steps: [
      "UAE Embassy attestation in Switzerland, where the UAE Embassy stamps the document",
      "MOFA attestation in UAE, the final verification from the Ministry of Foreign Affairs in UAE",
    ],
  },
]

const requiredDocs = [
  "Original certificate",
  "Passport copy",
  "UAE visa copy",
  "Authorization letter",
]

const timingFactors = [
  "Type of document",
  "Verification requirements in Switzerland",
  "Embassy processing",
  "MOFA stamping schedule",
]

const challenges = [
  "Submitting laminated certificates",
  "Providing unclear copies",
  "Ignoring translation requirements",
  "Spelling mistakes in documents",
  "Missing supporting documents",
]

const getStartedSteps = [
  { step: "01", title: "Connect with IndexAUH", desc: "Call us or send a message. Share your document copy." },
  { step: "02", title: "Document Review", desc: "Our team checks your certificate and confirms the process." },
  { step: "03", title: "Secure Collection", desc: "We arrange document pickup across the UAE." },
  { step: "04", title: "Complete Legalization Process", desc: "We coordinate with Swiss authorities and UAE offices." },
  { step: "05", title: "Safe Delivery", desc: "Your attested document reaches you securely." },
]

const whyChoose = [
  { title: "25+ Years of Experience", desc: "IndexAUH is the best in UAE with over 25+ years of experience in certificate attestation services." },
  { title: "Clear Procedural Knowledge", desc: "Clear understanding of the correct attestation procedure." },
  { title: "Secure Document Handling", desc: "Secure handling of all original documents." },
  { title: "Regular Status Updates", desc: "Regular status updates throughout the process." },
  { title: "Personal & Corporate Expertise", desc: "Expertise in both personal and corporate document legalization." },
  { title: "Dedicated Support", desc: "Dedicated customer support from start to finish." },
]

const faqs = [
  { q: "Is an Apostille enough for using Swiss documents in the UAE?", a: "No. Switzerland follows the Hague Convention, but the UAE requires full legalization. After Swiss authentication, the document must go through the UAE Embassy and MOFA attestation." },
  { q: "How much does Switzerland certificate attestation cost in UAE?", a: "Cost depends on the type of document, authority fees in Switzerland, UAE Embassy charges, MOFA fees, and service handling charges. Educational, personal, and commercial documents have different pricing structures. We provide a clear quote after reviewing your document." },
  { q: "Do commercial documents from Switzerland require a different process?", a: "Commercial papers follow a structured legalization route and may require additional verification from Swiss trade authorities before UAE legalization." },
  { q: "Why do authorities ask for Switzerland Certificate Attestation?", a: "Government departments in UAE must confirm that foreign documents are genuine and legally issued before accepting them for official use." },
  { q: "Do Swiss documents need translation for UAE?", a: "Authorities may ask for certified translation in some cases. Requirements depend on the department reviewing the document." },
  { q: "Can I attest laminated certificates?", a: "Laminated documents are usually not accepted. Lamination can block official stamps. It is better to remove lamination carefully before submission." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Switzerland Certificate Attestation in UAE | 25 Years of Expertise"
  description="Need Switzerland certificate attestation in UAE? Trust IndexAUH with 25+ years of experience. Secure, hassle free service. Contact IndexAUH today."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .route-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; transition: all 0.25s; }
  .route-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  .purpose-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .five-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .five-col { grid-template-columns: 1fr !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Switzerland Certificate Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Switzerland Attestation</span>
      <span class="idx-pill">MOFA Attestation</span>
      <span class="idx-pill">25 Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      SWITZERLAND CERTIFICATE<br/>ATTESTATION IN UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Switzerland Certificate Attestation is required when you want to use a Swiss document in the UAE. UAE authorities must confirm that your certificate is genuine before they accept it for visa, job, study, or business purposes. IndexAUH is the best in UAE with over 25+ years of experience in document legalization services.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-btns">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW / WHAT IS IT ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Why Is Switzerland Certificate Attestation Required in the UAE?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:18px;">
        UAE authorities ask for attestation to confirm your document is original and legally issued. This process verifies your document through the proper authorities in Switzerland and then in the UAE.
      </p>
      <p style="color:#2D3748;font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px;">Important to know:</p>
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px;">
        {mandatory.map(item => (
          <div style="display:flex;align-items:center;gap:12px;background:#F8FAFF;border:1px solid #eef0f6;border-radius:10px;padding:10px 14px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;">→</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">{item}</p>
          </div>
        ))}
      </div>
      <p style="color:#2D3748;font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px;">You may need it for:</p>
      <div style="display:flex;flex-direction:column;gap:8px;">
        {whoNeeds.map(item => (
          <div style="display:flex;align-items:flex-start;gap:12px;background:#F0FFFE;border:1px solid #B2F5EA;border-radius:10px;padding:10px 14px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:1px;">✓</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">{item}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/switzerland-flag.webp" alt="Switzerland certificate attestation UAE" style="width:100%;height:480px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Swiss Authorities · UAE Embassy · MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Switzerland attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:90px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Switzerland Certificate Attestation Services"
  description="We handle attestation for a wide range of document categories across personal, educational, and commercial needs for use in the UAE."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Switzerland attestation"
  docTypes={docTypes}
  country="switzerland"
/>

<!-- ════ PURPOSE ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Why It Matters</p>
      <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Purpose of Obtaining Switzerland Certificate Attestation</h2>
      <p style="color:#4B5563;font-size:1rem;line-height:1.8;margin:0 auto;max-width:680px;">Different certificates serve different purposes. Below are the common uses.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;" class="three-col">
      {purposeGroups.map(g => (
        <div class="purpose-card">
          <h3 style="font-size:0.98rem;font-weight:800;color:#1A202C;margin:0 0 8px;">{g.title}</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">{g.desc}</p>
          <div style="display:flex;flex-direction:column;gap:8px;">
            {g.items.map(it => (
              <div style="display:flex;align-items:center;gap:8px;font-size:0.88rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">•</span>{it}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ PROCESS ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Switzerland certificate attestation process" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Procedure for Switzerland Certificate Attestation in the UAE</h2>
      </div>
    </div>

    <!-- Two routes side by side -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px;" class="two-col">
      {processRoutes.map(route => (
        <div class="route-card">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{route.step}</div>
            <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0;">{route.title}</h3>
          </div>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">{route.desc}</p>
          <p style="font-size:0.78rem;font-weight:700;color:#38B2AC;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 10px;">Steps Involved</p>
          <div style="display:flex;flex-direction:column;gap:8px;">
            {route.steps.map((s, idx) => (
              <div style="display:flex;align-items:flex-start;gap:10px;">
                <span style="background:#F0FFFE;border:1px solid #B2F5EA;color:#2D3748;font-weight:800;font-size:0.72rem;width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;">{idx + 1}</span>
                <p style="font-size:0.88rem;color:#4B5563;line-height:1.5;margin:0;">{s}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
    <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;text-align:center;margin:0 0 24px;">Each document type may have slight variations in the process.</p>

    <!-- Required Documents -->
    <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:16px;padding:24px;margin-bottom:24px;">
      <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required for Switzerland Certificate Attestation</h3>
      <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">You usually need:</p>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:9px;" class="two-col">
        {requiredDocs.map(f => (
          <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
            <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
          </div>
        ))}
      </div>
      <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">Our team checks everything before submission.</p>
    </div>

    <!-- Timing -->
    <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
      <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">How Long Does the Process Take?</h3>
      <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Processing time depends on:</p>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:9px;" class="two-col">
        {timingFactors.map(f => (
          <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
            <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
          </div>
        ))}
      </div>
      <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">We explain the timeline clearly after reviewing your document.</p>
    </div>
  </div>
</section>

<!-- ════ CHALLENGES ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;" class="two-col">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What to Watch For</p>
        <h2 style="font-size:1.8rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Common Mistakes That Cause Delays</h2>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:24px;">
          Many applicants face delays due to small errors. We review documents carefully to prevent rejection.
        </p>
        <div style="position:relative;border-radius:16px;overflow:hidden;box-shadow:0 12px 32px rgba(0,0,0,0.1);">
          <img
            src="/images/img-40.webp"
            alt="Common mistakes in Switzerland document attestation"
            style="width:100%;height:320px;object-fit:cover;display:block;"
          />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
          <div style="position:absolute;bottom:16px;left:16px;right:16px;">
            <p style="color:#fff;font-size:0.88rem;font-weight:700;margin:0;">Avoid these mistakes for a smooth attestation process</p>
          </div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {challenges.map(c => (
