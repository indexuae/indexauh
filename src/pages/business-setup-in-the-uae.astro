---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1",  label: "US +1" },
  { code: "+973", label: "BH +973" },
]

const purposes = [
  { icon: "🌍", title: "Strategic Location", desc: "The UAE's strategic location at the crossroads of Europe, Asia, and Africa provides easy access to a vast market, facilitating international trade and growth." },
  { icon: "💰", title: "Tax Advantages", desc: "The UAE offers favourable tax conditions, including zero corporate and income tax for most businesses, attracting companies seeking to minimize their tax burdens." },
  { icon: "📈", title: "Economic Diversification", desc: "The UAE government has been actively diversifying its economy beyond oil and gas, creating numerous opportunities across various sectors for business ventures." },
  { icon: "🏛️", title: "Stable Political Environment", desc: "The UAE is known for its political stability and robust legal framework, providing a secure environment for business operations." },
  { icon: "🏗️", title: "World-Class Infrastructure", desc: "The UAE boasts world-class infrastructure, including modern transportation networks, ports, and communication facilities essential for efficient business operations." },
]

const benefits = [
  { title: "Expert Guidelines", desc: "Index Office Services has a team of knowledgeable individuals familiar with the legal requirements, business setup procedures, and regional quirks in the UAE. Their experience guarantees a quick and easy setup." },
  { title: "Customized Solutions", desc: "We are aware of the individuality of every organization. Whether launching a small business or creating a major organization, Index offers specialized solutions that match your unique business objectives and needs." },
  { title: "Compliance & Documentation", desc: "Getting around the difficult regulatory environment in the UAE. Index Office Services assures adherence to local rules and regulations and aids with the required documentation at every step." },
  { title: "Time Efficiency", desc: "In the corporate world, time equals money. Index Office Services streamlines the setup process, saving you valuable time and enabling you to launch your business sooner." },
  { title: "Local Network", desc: "With their extensive local network and connections, Index Office Services can facilitate introductions and partnerships, helping your business thrive in the UAE market." },
]
---

<BaseLayout
  title="Business setup in the UAE | Index Office Services"
  description="Planning a Business Setup in the UAE? Indexauh offers expert assistance and end-to-end solutions to help you establish your company easily."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .purpose-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 24px; transition: all 0.25s; }
  .purpose-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .benefit-card { border-radius: 14px; padding: 22px; }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-9.webp"
    alt="Business Setup in UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 12px;">
      BUSINESS SETUP IN THE UAE
    </h1>
    <p style="color:#38B2AC;font-size:1.05rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 20px;">Company Formation · Small Business · Enterprise Setup · 25 Years of Trust</p>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      The UAE has emerged as a thriving business hub, attracting entrepreneurs and investors from around the world. Whether you're looking to form a business, start a small venture, or launch a larger enterprise, this Gulf nation offers a wealth of opportunities.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Business Setup in the UAE</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        The United Arab Emirates has emerged as a thriving business hub in recent years, attracting entrepreneurs and investors from around the world. The process of setting up a business in the UAE has become increasingly streamlined and investor-friendly, making it an attractive destination for those looking to launch their entrepreneurial ventures.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Whether you're looking to form a business in the UAE, start a small business, or launch a larger enterprise, this Gulf nation offers a wealth of opportunities across diverse sectors and markets.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:20px;">
        Partnering with a reputable consultancy like Index Office Services can significantly enhance your chances of success by providing expert guidance, customized solutions, and efficient services every step of the way.
      </p>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Start Your Business Journey in the UAE</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          From its strategic global location to zero corporate tax and world-class infrastructure, the UAE offers unmatched conditions for business success. Index Office Services is your trusted partner to navigate the setup process smoothly and compliantly.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-17.webp" alt="UAE business hub" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Company Formation · Compliance · Launch</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete business setup handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25 Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ PURPOSE ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-18.webp" alt="Purpose of business setup UAE" style="width:100%;height:480px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Why the UAE?</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Strategy · Tax · Growth · Stability</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Why UAE</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Purpose of Business Setup in the UAE</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:28px;">
          Business setup in the UAE serves various purposes, each appealing to different types of entrepreneurs and investors. From its unparalleled geographic position to its business-friendly tax environment, the UAE offers compelling reasons to establish your company here.
        </p>
        <div style="display:flex;flex-direction:column;gap:14px;">
          {purposes.map(p => (
            <div class="purpose-card" style="display:flex;align-items:flex-start;gap:16px;">
              <div style="font-size:1.8rem;flex-shrink:0;margin-top:2px;">{p.icon}</div>
              <div>
                <h3 style="font-size:0.92rem;font-weight:800;color:#1A202C;margin:0 0 5px;">{p.title}</h3>
                <p style="font-size:0.8rem;color:#4B5563;line-height:1.65;margin:0;">{p.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE INDEX ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
        <img src="/images/img-7.webp" alt="Index Office Services UAE business setup" style="width:100%;height:340px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">Index Office Services</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Abu Dhabi · Dubai · GCC Network</p>
        </div>
      </div>
      <div>
        <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Why Choose Us</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.2;margin:0 0 16px;">Benefits of Choosing Index Office Services for Business Setup in the UAE</h2>
        <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;">
          When embarking on your business setup journey in the UAE, choosing the right partner is crucial. Index Office Services, a renowned business consultancy, offers several key advantages — from expert legal guidance to a powerful local network — ensuring your business launches smoothly, compliantly, and on time.
        </p>
      </div>
    </div>

    <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:52px;">
      {benefits.map(b => (
        <div class="benefit-card" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);">
          <h3 style="font-size:0.92rem;font-weight:800;color:#fff;margin:0 0 8px;border-bottom:1px solid rgba(56,178,172,0.3);padding-bottom:8px;">{b.title}</h3>
          <p style="font-size:0.9rem;color:#CBD5E0;line-height:1.65;margin:0;">{b.desc}</p>
        </div>
      ))}
    </div>

    <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:40px;text-align:center;border-top:1px solid rgba(255,255,255,0.1);padding-top:48px;">
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">2,500+</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Companies Formed</p>
      </div>
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">25+</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Years of Experience</p>
      </div>
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">100%</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Compliance Assured</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE US CTA ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-3.webp" alt="Start your UAE business with Index" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.78) 100%);"></div>
        <div style="position:absolute;bottom:18px;left:18px;right:18px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Your Business. Our Expertise.</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">From concept to launch — we handle it all</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
          <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Why Choose Us
        </p>
        <h2 style="font-size:clamp(1.6rem,3vw,2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 20px;">Start Your Journey to Business Success in the UAE</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:20px;">
          Business setup in the UAE offers numerous advantages, from its strategic location to favourable tax conditions and political stability. Whether it's a small venture or a larger enterprise, partnering with a reputable consultancy like Index Office Services can significantly enhance your chances of success.
        </p>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:28px;">
          We provide expert guidance, customized solutions, and efficient services so you can focus on growing your business while we handle the setup process. Start your journey to business success in the UAE with the support of Index Office Services.
        </p>
        <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#2D3748;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">
          Get Free Consultation &rarr;
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ════ GET IN TOUCH ════ -->
<section id="get-in-touch" style="background:#2D3748;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:600px;height:300px;background:radial-gradient(ellipse,rgba(56,178,172,0.12) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;gap:52px;align-items:flex-start;">

    <div style="flex:1;min-width:280px;">
      <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Get In Touch</p>
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.25;margin:0 0 18px;">GET IN TOUCH WITH INDEX TODAY FOR BUSINESS SETUP IN THE UAE.</h2>
      <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin-bottom:16px;">
        Index Office Services provides complete assistance for business setup in the UAE. Our team of experts guides you through every step — from documentation and compliance to company formation and launch.
      </p>
      <p style="color:#94A3B8;font-size:1.05rem;line-height:1.8;margin-bottom:28px;">
        Reach out through WhatsApp, a quick call, or our online form. We are ready to help you start your business journey in the UAE with confidence.
      </p>
      <a href="tel:+971529300200" style="display:inline-flex;align-items:center;gap:10px;background:#38B2AC;color:#fff;font-weight:900;font-size:0.95rem;padding:14px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        CALL: (+971) 529 300 200
      </a>
    </div>

    <div style="flex:1;min-width:280px;background:#fff;border-radius:22px;padding:36px;box-shadow:0 20px 60px rgba(0,0,0,0.2);">
      <h3 style="font-size:1.2rem;font-weight:700;color:#1A202C;margin:0 0 22px;">Free Consultation</h3>
      <ContactForm />
    </div>

  </div>
</section>

</BaseLayout>