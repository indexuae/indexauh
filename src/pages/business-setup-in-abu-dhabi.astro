---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1",  label: "US +1" },
  { code: "+973", label: "BH +973" },
]

const businessTypes = [
  {
    icon: "🏙️",
    title: "Mainland Business",
    authority: "Abu Dhabi Department of Economic Development (ADDED)",
    desc: "Registered under ADDED, operates within the UAE mainland. Can engage in any type of activity and trade with any market, but requires a local partner or sponsor who owns at least 51% of the shares.",
  },
  {
    icon: "🏢",
    title: "Free Zone Business",
    authority: "ADGM / Masdar City / KIZAD / ADAFZ",
    desc: "Registered under one of the many free zones in Abu Dhabi. Enjoy 100% foreign ownership, tax exemptions, customs benefits, and other incentives. Can only trade with other free zone businesses or outside the UAE unless a special permit is obtained.",
  },
  {
    icon: "🌐",
    title: "Offshore Business",
    authority: "Abu Dhabi Global Market (ADGM)",
    desc: "Registered under offshore jurisdictions in ADGM, operates outside the UAE. Enjoy 100% foreign ownership, tax exemptions, confidentiality, and asset protection. Cannot conduct any activity or maintain physical presence within the UAE.",
  },
]

const authorities = [
  {
    name: "Abu Dhabi Department of Economic Development (ADDED)",
    desc: "Regulates all mainland businesses in Abu Dhabi. Issues trade licenses, registers trade names, approves activities and legal forms.",
  },
  {
    name: "Abu Dhabi Global Market (ADGM)",
    desc: "Regulates all free zone businesses in ADGM, an international financial center on Al Maryah Island. Issues trade licenses, registers trade names, approves activities and legal forms.",
  },
  {
    name: "Other Free Zone Authorities",
    desc: "Other free zones in Abu Dhabi — including Masdar City Free Zone, Khalifa Industrial Zone Abu Dhabi (KIZAD), and Abu Dhabi Airport Free Zone (ADAFZ) — each have their own authorities that regulate their businesses.",
  },
]

const indexServices = [
  "Identifying the best type of business setup for your needs and goals",
  "Registering the trade name and obtaining the initial approval",
  "Drafting the memorandum of association (MOA) and local service agent agreement (LSA)",
  "Finding a suitable business location and obtaining the tenancy contract",
  "Obtaining additional approvals from other government entities or agencies",
  "Submitting documents and paying fees",
  "Obtaining the trade license and other related documents",
  "Providing other services such as visa assistance, bank account opening, PRO services, etc.",
]

const formationSteps = [
  {
    icon: "🤝",
    title: "Finding A Partner",
    desc: "Every business must have a partner who is a citizen of U.A.E to set up a business in U.A.E. Index can find a suitable partner for your business in U.A.E.",
  },
  {
    icon: "🏗️",
    title: "Business Set-Up",
    desc: "Regulations and requirements of law changes as per the industry and business requirements. Index can help you understand these changes and make the best decision.",
  },
  {
    icon: "📋",
    title: "License Registration",
    desc: "Licensing is a key part of getting a business set-up and running in U.A.E. Index can help you choose the right licences from the numerous options available in U.A.E.",
  },
]
---

<BaseLayout
  title="Business Setup in Abu Dhabi | Start a Business in Abu Dhabi"
  description="Indexauh helps you with Business Setup in Abu Dhabi from start to finish. Expert guidance ensures a smooth, quick, and affordable setup process."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .biz-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 28px; transition: all 0.25s; }
  .biz-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-9.webp"
    alt="Business Setup in Abu Dhabi"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      BUSINESS SETUP IN ABU DHABI
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:700px;">
      Abu Dhabi is the capital and the largest emirate of the UAE, with a diverse and dynamic economy that offers many opportunities for entrepreneurs and investors. Abu Dhabi is home to various sectors — oil and gas, renewable energy, tourism, finance, technology, and healthcare — with a supportive government that provides various incentives and initiatives for business development and innovation.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ AUTHORITIES ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Regulatory Bodies
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Who Are the Authorities That Handle Business Formation in Abu Dhabi?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:28px;">
        Business formation in Abu Dhabi is overseen by specific regulatory authorities depending on the type and location of your business. Understanding which authority manages your setup is the first step to a smooth registration process.
      </p>
      <div style="display:flex;flex-direction:column;gap:16px;">
        {authorities.map((a, i) => (
          <div style="display:flex;align-items:flex-start;gap:14px;padding:16px;background:#F8FAFF;border:1px solid #eef0f6;border-radius:12px;">
            <div style="width:36px;height:36px;border-radius:9px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:0.8rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{String(i+1).padStart(2,'0')}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{a.name}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{a.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-2.webp" alt="Abu Dhabi business authorities" style="width:100%;height:460px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">ADDED · ADGM · Free Zones</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete business formation support in Abu Dhabi</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ BUSINESS TYPES ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:400px;background:radial-gradient(ellipse,rgba(56,178,172,0.06) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Business Structures</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Different Types of Businesses in Abu Dhabi</h2>
      <p style="color:#6B7280;font-size:1.05rem;max-width:600px;margin:0 auto;">Starting a business in Abu Dhabi is the process of establishing a legal entity that can conduct commercial activities in the UAE. Depending on the nature and scope of the business, there are different types of business setups available.</p>
    </div>

    <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
      {businessTypes.map(b => (
        <div class="biz-card">
          <div style="font-size:2rem;margin-bottom:14px;">{b.icon}</div>
          <h3 style="font-size:1.1rem;font-weight:800;color:#1A202C;margin:0 0 6px;">{b.title}</h3>
          <p style="font-size:0.75rem;font-weight:600;color:#38B2AC;margin:0 0 12px;text-transform:uppercase;letter-spacing:0.05em;">{b.authority}</p>
          <p style="font-size:0.84rem;color:#4B5563;line-height:1.75;margin:0;">{b.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ HOW INDEX ASSISTS ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.1fr;gap:52px;align-items:center;">

      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-11.webp" alt="How Index assists with business setup in Abu Dhabi" style="width:100%;height:460px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">End-to-End Business Setup Support</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">From trade name registration to license issuance</p>
        </div>
      </div>

      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
          <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Our Role
        </p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">How Can Index Office Services Assist You?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          When it comes to starting a business in the Middle East, Index is here to assist you. With Index, you can save time, money, and hassle and start your business in Abu Dhabi smoothly and efficiently.
        </p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {indexServices.map(s => (
            <div style="display:flex;align-items:flex-start;gap:10px;font-size:0.84rem;color:#4B5563;line-height:1.6;">
              <span style="color:#38B2AC;font-weight:700;flex-shrink:0;margin-top:2px;">✓</span>{s}
            </div>
          ))}
        </div>
        <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#2D3748;color:#fff;padding:13px 26px;border-radius:9999px;font-weight:700;text-decoration:none;box-shadow:0 4px 16px rgba(45,55,72,0.3);margin-top:28px;">Contact Us Today &rarr;</a>
      </div>

    </div>
  </div>
</section>

<!-- ════ COMPANY FORMATION STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-12.webp" alt="Company formation steps UAE" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Company Formation Steps in U.A.E</h2>
      </div>
    </div>

    <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
      {formationSteps.map((s, i) => (
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:32px;text-align:center;transition:all 0.25s;">
          <div style="font-size:2.4rem;margin-bottom:16px;">{s.icon}</div>
          <div style="width:36px;height:36px;border-radius:9px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:0.8rem;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">{String(i+1).padStart(2,'0')}</div>
          <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 10px;">{s.title}</h3>
          <p style="font-size:0.83rem;color:#4B5563;line-height:1.75;margin:0;">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE US ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
        <img src="/images/img-3.webp" alt="Index Office Services Abu Dhabi business setup" style="width:100%;height:340px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">Index Office Services</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Abu Dhabi · Dubai · GCC Network</p>
        </div>
      </div>
      <div>
        <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Why Choose Us</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.2;margin:0 0 16px;">WHY CHOOSE US?</h2>
        <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin-bottom:28px;">
          We have a dedicated and experienced team that has been at the forefront in ensuring effective business setup process and facilitated easy setup of new businesses of aspiring businessmen. The services are provided within a fixed budget and has proved to be very effective.
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          {[
            { label: "25 years of experience in certificate attestation" },
            { label: "Complete end-to-end document processing" },
            { label: "GCC-wide attestation and business support" },
            { label: "Clear communication at every stage" },
            { label: "Secure document handling" },
            { label: "Dedicated support team" },
          ].map(b => (
            <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:10px;">
              <span style="color:#38B2AC;font-weight:700;flex-shrink:0;">✓</span>
              <span style="font-size:0.98rem;color:#CBD5E0;line-height:1.5;">{b.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:40px;text-align:center;border-top:1px solid rgba(255,255,255,0.1);padding-top:48px;">
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">2500</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Companies Formed</p>
      </div>
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">25</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Years of Experience</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ GET IN TOUCH ════ -->
<section id="get-in-touch" style="background:#2D3748;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:600px;height:300px;background:radial-gradient(ellipse,rgba(56,178,172,0.12) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;gap:52px;align-items:flex-start;">

    <div style="flex:1;min-width:280px;">
      <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Get In Touch</p>
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.25;margin:0 0 18px;">CONTACT US TODAY AND LET US HELP YOU WITH YOUR BUSINESS SETUP IN ABU DHABI.</h2>
      <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin-bottom:16px;">
