---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whenNeeded = [
  "Employment and work visas",
  "Family or residence visas",
  "Higher education admissions",
  "Business set up in Kuwait or company registration",
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Marriage certificate attestation for Kuwait",
      "Kuwait Divorce Certificate Attestation",
      "Death Certificate Attestation",
      "Birth certificate attestation for Kuwait",
      "Transfer Certificate Attestation",
      "Kuwait PCC",
      "Affidavit",
      "Medical Certificate Attestation",
    ],
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Degree Attestation For Kuwait",
      "Diploma Certificate Attestation",
      "Master Degree Certificate Attestation",
      "Engineering Degree Certificate Attestation",
      "Medical and Nursing Degree Certificate Attestation",
      "Professional Qualification Certificate",
    ],
  },
  {
    category: "Commercial Documents",
    icon: "⚖️",
    docs: [
      "Memorandum of Association (MOA)",
      "Articles of Association (AOA)",
      "Certificate of Incorporation",
      "Certificate of Good Standing",
      "Board Resolutions",
      "Commercial Invoices",
      "Power of Attorney",
      "Commercial License",
    ],
  },
]

const processToUAE = [
  { step: "01", title: "Verify Document Authenticity", desc: "Verify the authenticity of your Kuwait-issued document." },
  { step: "02", title: "Ministry of Foreign Affairs Attestation Kuwait", desc: "The document is attested by the Kuwait Ministry of Foreign Affairs." },
  { step: "03", title: "UAE MOFA Attestation", desc: "The UAE Ministry of Foreign Affairs attests the document." },
  { step: "04", title: "Translation if Required", desc: "Translate documents into English or Arabic if required." },
  { step: "05", title: "Final Submission for Approval", desc: "The document is submitted for final approval." },
]

const processToKuwait = [
  { step: "01", title: "Notary Attestation in UAE", desc: "The document is first verified by an authorized notary in the UAE." },
  { step: "02", title: "UAE MOFA Attestation", desc: "The UAE Ministry of Foreign Affairs attests the document." },
  { step: "03", title: "Kuwait Embassy/Consulate Attestation", desc: "The Kuwait Embassy or Consulate attests the document." },
  { step: "04", title: "Optional Kuwait MOFA Attestation After Arrival", desc: "Kuwait MOFA attestation can be completed after arrival, if required." },
  { step: "05", title: "Delivery", desc: "The attested document is delivered to you." },
]

const marriageSteps = [
  "Submit your original marriage certificate",
  "UAE MOFA attestation",
  "Kuwait Embassy attestation",
  "Kuwait MOFA attestation (if required)",
  "Receive your attested certificate",
]

const degreeSteps = [
  "University or board attestation",
  "HRD/State attestation (if applicable)",
  "UAE MOFA attestation",
  "Kuwait Embassy attestation",
  "Kuwait MOFA attestation (if needed)",
  "Receive your attested degree",
]

const feeFactors = [
  "Type of document – personal, educational, commercial, or legal documents have different attestation requirements",
  "Number of documents – multiple certificates may increase the fees",
  "Document origin – UAE-issued documents may have fewer steps compared to foreign-issued documents",
  "Required attestations – some documents need notary attestation in Kuwait, MOFA attestation Kuwait, or translations",
  "Embassy or consulate regulations – different embassies may have varying service charges",
  "Urgency of service – expedited processing may affect fees",
]

const timingFactors = [
  "Type of document – personal certificates, degree certificates, and commercial documents require different steps",
  "Document origin – documents issued outside the UAE may take longer due to extra verification",
  "Number of attestations required – documents needing multiple attestations, such as embassy and MOFA, may take more time",
  "Accuracy and completeness – missing information, errors, or lack of required signatures can cause delays",
  "Embassy schedules and workload – processing may vary depending on embassy working hours or peak periods",
  "Translation requirements – documents needing certified legal translation may take extra time",
]

const challenges = [
  "Skipping notary attestation in Kuwait",
  "Name mismatch with passport",
  "Missing UAE MOFA attestation",
  "Using laminated documents",
  "Ignoring required translations",
]

const getStartedSteps = [
  { step: "01", title: "Share Document Details", desc: "Share your document details online or via WhatsApp." },
  { step: "02", title: "Expert Verification", desc: "Our experts verify the documents for Kuwait attestation services." },
  { step: "03", title: "Pickup or Submission", desc: "Arrange document pickup or submit at our UAE office." },
  { step: "04", title: "We Handle All Steps", desc: "We handle all steps of document attestation in Kuwait." },
  { step: "05", title: "Receive Attested Documents", desc: "Receive your attested documents at your address." },
]

const whyChoose = [
  { title: "25 Years of Experience", desc: "25 years of experience in attestation services in Kuwait." },
  { title: "Secure & Hassle-Free", desc: "Secure and hassle-free process from start to finish." },
  { title: "UAE-Wide Pickup & Delivery", desc: "UAE-wide pickup and door delivery for your documents." },
  { title: "Trusted by Thousands", desc: "Trusted by thousands of clients across the region." },
  { title: "Global Reach", desc: "Services across UAE, GCC, and 100+ countries." },
  { title: "Expert Guidance", desc: "Expert guidance at each step of the process." },
]

const faqs = [
  { q: "Do I need Kuwait Embassy attestation before UAE MOFA?", a: "No. Documents issued outside the UAE usually need UAE MOFA attestation first. After that, you can get the embassy attestation. We handle both steps for you." },
  { q: "Can documents from my home country be attested in UAE?", a: "Yes. Documents from other countries can be attested in the UAE. They typically need notary attestation, home country verification, and then embassy attestation." },
  { q: "How long does certificate attestation in Kuwait take?", a: "The time depends on the type of document, number of attestations needed, embassy workload, and translation requirements." },
  { q: "Is apostille accepted in Kuwait?", a: "No. Kuwait does not accept apostille. All documents must go through embassy attestation and MOFA verification." },
  { q: "Can I track my documents online?", a: "Yes. We provide updates and tracking throughout the process so you always know the status of your documents." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Kuwait Embassy Attestation | Kuwait Attestation Services"
  description="Kuwait Embassy Attestation in UAE by IndexAUH. 25 years of trusted experience, fast processing, secure handling, and expert guidance. Start today."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .four-col { display: grid !important; }
  .five-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr 1fr !important; }
    .five-col { grid-template-columns: 1fr 1fr !important; }
    .img-first { order: -1 !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
    .get-started-grid { grid-template-columns: 1fr 1fr !important; }
    .process-split { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Kuwait Embassy Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">MOFA Attestation Kuwait</span>
      <span class="idx-pill">25 Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      KUWAIT EMBASSY ATTESTATION<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      IndexAUH offers expert Kuwait Embassy Attestation services across the UAE. This process confirms that your documents are genuine and accepted for use in Kuwait. Whether it is for work, education, family visa, or business, our experts handle the entire process. With 25 years of experience, we make attestation simple, fast, and safe.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What is Kuwait Embassy Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Kuwait Embassy Attestation is the official verification of your documents. It proves that your certificates, degrees, or personal papers are authentic. This attestation is required for using documents in Kuwait for jobs, education, residence, or business.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        IndexAUH helps you complete certificate attestation in Kuwait quickly. Our team guides every step so your documents are ready for Kuwait authorities without any delays.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Key Insight — No Apostille in Kuwait</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          Documents issued in the UAE or other countries cannot be used in Kuwait without verification. Kuwait does not accept apostille for documents, which is why embassy attestation and MOFA attestation Kuwait are mandatory.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/kuwait-flag.webp" alt="Kuwait document attestation UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Notary · UAE MOFA · Kuwait Embassy · Kuwait MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Kuwait attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25 Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHEN DO YOU NEED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;" class="split-grid">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-11.webp" alt="When to get Kuwait embassy attestation" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">When You Need Attestation</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Work · Education · Family · Business</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Key Situations</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Why is the Kuwait Embassy Attestation Required?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          You need attestation for Kuwait to prove that your documents are real. It is required for:
        </p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {whenNeeded.map(item => (
            <div style="display:flex;align-items:flex-start;gap:12px;background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:14px 18px;">
              <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:2px;">→</span>
              <p style="font-size:0.9rem;color:#374151;line-height:1.6;margin:0;">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Attestation Services in Kuwait"
  description="We handle attestation for a wide range of document categories across personal, educational, and commercial needs."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Kuwait attestation"
  docTypes={docTypes}
  country="kuwait"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Kuwait attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:520px;line-height:1.25;">Kuwait Embassy Attestation Procedure</h2>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:48px;" class="process-split two-col">
      <div>
        <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 14px;">Steps for Attesting Kuwait-Issued Documents for Use in UAE</h3>
        <div style="display:flex;flex-direction:column;gap:14px;">
          {processToUAE.map(s => (
            <div class="step-card">
              <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
              <div>
                <p style="font-size:0.95rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
                <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 14px;">Steps Required for Using UAE-Issued Documents in Kuwait</h3>
        <div style="display:flex;flex-direction:column;gap:14px;">
          {processToKuwait.map(s => (
            <div class="step-card">
              <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
              <div>
                <p style="font-size:0.95rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
                <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;" class="two-col">
      <!-- Marriage Certificate -->
      <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Kuwait Marriage Certificate Attestation</h3>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {marriageSteps.map((s, i) => (
            <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">{i + 1}.</span>{s}
            </div>
          ))}
        </div>
      </div>

      <!-- Degree Certificate -->
      <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Degree Certificate Attestation for Kuwait</h3>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {degreeSteps.map((s, i) => (
            <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">{i + 1}.</span>{s}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ FEES & TIMING ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;" class="two-col">
      <!-- Fees -->
      <div style="background:#F8FAFF;border:1px solid #eef0f6;border-radius:16px;padding:28px;">
        <h3 style="font-size:1.1rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Kuwait Embassy Certificate Attestation Fees</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 16px;">Kuwait embassy attestation charges vary depending on the document and the steps involved. Several factors affect the cost, including:</p>
        <div style="display:flex;flex-direction:column;gap:11px;">
          {feeFactors.map(f => (
            <div style="display:flex;align-items:flex-start;gap:10px;font-size:0.88rem;color:#4B5563;line-height:1.6;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;margin-top:1px;">→</span>{f}
            </div>
          ))}
        </div>
      </div>

      <!-- Timing -->
      <div style="background:#F8FAFF;border:1px solid #eef0f6;border-radius:16px;padding:28px;">
        <h3 style="font-size:1.1rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Processing Time</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 16px;">The processing time for Kuwait Embassy Attestation depends on several factors:</p>
        <div style="display:flex;flex-direction:column;gap:11px;">
          {timingFactors.map(f => (
