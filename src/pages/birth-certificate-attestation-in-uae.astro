---

<BaseLayout title="Birth Certificate Attestation in UAE | Document Attestation Services"
description="Birth certificate attestation in UAE with 25+ years of trusted support. Fast processing for visa, school & immigration requirements. Call now!"
>

<style>
  .sec-inner { position: relative; z-index: 1; }

  /* pills */
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }

  /* form */
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }

  /* step list */
  .step-list-item { background: #fff; border: 1px solid #eef0f6; border-radius: 12px; padding: 16px 20px; display: flex; align-items: flex-start; gap: 14px; transition: all 0.2s; }
  .step-list-item:hover { border-color: #B2F5EA; box-shadow: 0 8px 20px rgba(56,178,172,0.06); }

  /* FAQ */
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 200px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  @media(max-width:768px){
    .about-hero-title { font-size: 2rem !important; }
    .about-hero-desc { font-size: 0.88rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
  }
</style>

<!-- ════════════ HERO — image bg, centered text ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <!-- Background image -->
  <img
    src="/images/img-16.webp"
    alt="Birth Certificate Attestation"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <!-- Dark overlay -->
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.88) 0%,rgba(45,55,72,0.82) 100%);"></div>
  <!-- Dot pattern -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="about-hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      BIRTH CERTIFICATE ATTESTATION<br/>IN UAE
    </h1>
    <p class="about-hero-desc" style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:640px;">
      Birth is a continuation, not a beginning. Make sure to have your birth certificate verified because it is the next step in your life’s journey.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>
  
  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <!-- Left Text -->
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Why Attest Your Birth Certificate?</h2>
      
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
        Index Office Service provide you a quick and effortless service with our experts and we have 25 years of experience in the field of certificate attestation. In UAE, birth certificates must undergo birth certificate attestation as a critical step in the legalisation and validation of their credibility.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
        To protect the legitimacy and integrity of all foreign papers inside the UAE, the government has made attestation essential. The attestation of birth certificates is essential for many governmental and private processes, including getting a visa, requesting admission to a school, sponsoring dependents, and conducting business in the United Arab Emirates.
      </p>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;margin-top:24px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">What is a birth certificate?</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          A birth certificate is an official record of a person’s birth information. It is often provided immediately after a child is born by a government entity, like a vital statistics office or registrar’s office. A person’s identity, age, and parentage may all be legally proven with the use of a birth certificate.
        </p>
      </div>
    </div>

    <!-- Right Image -->
    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-5.webp" alt="Attestation verification documents" style="width:100%;height:380px;object-fit:cover;" />
        <div style="position:absolute;bottom:20px;left:-16px;background:#2D3748;color:#fff;padding:12px 18px;border-radius:12px;font-size:0.9rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          Verified Globally
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ REGISTRATION PROCEDURES ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>
  
  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <!-- Image banner -->
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-6.webp" alt="Birth certificate registration process UAE" style="width:100%;height:240px;object-fit:cover;object-position:center 40%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.85) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Legal Process Guide</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:460px;line-height:1.25;">Issuing &amp; Acquiring Birth Certificates in UAE</h2>
      </div>
    </div>

    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:40px;">
      <!-- Issuing Birth Certificate -->
      <div>
        <h3 style="font-size:1.15rem;font-weight:800;color:#1A202C;margin-bottom:20px;border-left:3px solid #38B2AC;padding-left:12px;">How to Lawfully Issue a Birth Certificate in UAE</h3>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <div class="step-list-item">
            <span style="font-weight:900;color:#38B2AC;font-size:1rem;margin-top:2px;">01</span>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">Hospital Notification</p>
              <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:0;">Hospital staff notifies the relevant authorities immediately about the birth.</p>
            </div>
          </div>
          <div class="step-list-item">
            <span style="font-weight:900;color:#38B2AC;font-size:1rem;margin-top:2px;">02</span>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">Register the Birth</p>
              <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:0;">Visit Public Health or Preventive Medicine Department within 30 days. Provide original & photocopy of child's hospital birth notification.</p>
            </div>
          </div>
          <div class="step-list-item">
            <span style="font-weight:900;color:#38B2AC;font-size:1rem;margin-top:2px;">03</span>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">Pay the Fees</p>
              <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:0;">Pay required nominal registration fees at the designated counter.</p>
            </div>
          </div>
          <div class="step-list-item">
            <span style="font-weight:900;color:#38B2AC;font-size:1rem;margin-top:2px;">04</span>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">Collection</p>
              <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:0;">Once verified, the authorities issue the birth certificate. Visit the office with the receipt to collect.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Acquiring Legally Recognized Certificate -->
      <div>
        <h3 style="font-size:1.15rem;font-weight:800;color:#1A202C;margin-bottom:20px;border-left:3px solid #38B2AC;padding-left:12px;">How to Acquire a Legally Recognized Birth Certificate</h3>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <div class="step-list-item">
            <span style="font-weight:900;color:#38B2AC;font-size:1rem;margin-top:2px;">01</span>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">Medical Alert</p>
              <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:0;">Confirm hospital staff alerts appropriate UAE public health authorities regarding the baby's birth.</p>
            </div>
          </div>
          <div class="step-list-item">
            <span style="font-weight:900;color:#38B2AC;font-size:1rem;margin-top:2px;">02</span>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">Submit Required Documents</p>
              <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:0;">Provide parents' passports + Emirates ID copies, original hospital notification, and marriage licence (if necessary).</p>
            </div>
          </div>
          <div class="step-list-item">
            <span style="font-weight:900;color:#38B2AC;font-size:1rem;margin-top:2px;">03</span>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">Verification of Documents</p>
              <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:0;">Government authorities check all supplied documentation for absolute correctness and completeness.</p>
            </div>
          </div>
          <div class="step-list-item">
            <span style="font-weight:900;color:#38B2AC;font-size:1rem;margin-top:2px;">04</span>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">Biometric Verification</p>
              <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:0;">Provide biometric details such as parent fingerprints and photos for identity validation purposes.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENTS REQUIRING ATTESTATION GRID ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>
  
  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
  <div class="split-grid" style="display:grid;grid-template-columns:0.8fr 1fr;gap:48px;align-items:center;margin-bottom:52px;">
      <!-- Left image -->
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-7.webp" alt="Attestation document types UAE" style="width:100%;height:360px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">All Document Types Covered</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Personal · Commercial · Educational · Notary</p>
        </div>
      </div>
      <!-- Right text -->
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Complete Legalization Coverage</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 16px;">Documents That Require Attestation for Use in the UAE</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;">Index Office Services handles all categories of document attestation — from personal and educational certificates to commercial and notary documents. We manage every step to ensure smooth verification.</p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;">
      <!-- Personal -->
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;box-shadow:0 10px 30px rgba(0,0,0,0.02);">
        <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 16px;display:flex;align-items:center;gap:10px;">
          <span style="color:#38B2AC;font-size:1.3rem;">👤</span> Personal Certificate
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          {personalDocs.map(d => (
            <li style="font-size:0.98rem;color:#4B5563;display:flex;align-items:center;gap:8px;">
              <span style="color:#38B2AC;font-weight:bold;">•</span> {d}
            </li>
          ))}
        </ul>
      </div>

      <!-- Commercial -->
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;box-shadow:0 10px 30px rgba(0,0,0,0.02);">
        <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 16px;display:flex;align-items:center;gap:10px;">
          <span style="color:#38B2AC;font-size:1.3rem;">🏢</span> Commercial & Business
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          {commercialDocs.map(d => (
            <li style="font-size:0.98rem;color:#4B5563;display:flex;align-items:center;gap:8px;">
              <span style="color:#38B2AC;font-weight:bold;">•</span> {d}
            </li>
          ))}
        </ul>
      </div>

      <!-- Educational -->
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;box-shadow:0 10px 30px rgba(0,0,0,0.02);">
        <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 16px;display:flex;align-items:center;gap:10px;">
          <span style="color:#38B2AC;font-size:1.3rem;">🎓</span> Educational Certificate
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          {educationalDocs.map(d => (
            <li style="font-size:0.98rem;color:#4B5563;display:flex;align-items:center;gap:8px;">
              <span style="color:#38B2AC;font-weight:bold;">•</span> {d}
            </li>
          ))}
        </ul>
      </div>

      <!-- Notary -->
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;box-shadow:0 10px 30px rgba(0,0,0,0.02);">
        <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 16px;display:flex;align-items:center;gap:10px;">
          <span style="color:#38B2AC;font-size:1.3rem;">⚖️</span> Notary & Supporting
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          {notaryServices.map(d => (
            <li style="font-size:0.98rem;color:#4B5563;display:flex;align-items:center;gap:8px;">
              <span style="color:#38B2AC;font-weight:bold;">•</span> {d}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE US ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>
  
  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1fr 1.2fr;gap:52px;align-items:center;">
    <!-- Image -->
    <div>
      <img src="/images/img-8.webp" alt="Why Choose Indexauh" style="width:100%;height:360px;object-fit:cover;border-radius:20px;box-shadow:0 12px 40px rgba(0,0,0,0.1);" />
    </div>

    <!-- Text -->
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>OUR STRENGTHS
