---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1",  label: "US +1" },
  { code: "+973", label: "BH +973" },
]

const purposes = [
  { icon: "💼", title: "Employment", desc: "Companies in Qatar require attested educational and professional certificates for employment and work permit processing." },
  { icon: "🎓", title: "Education", desc: "Universities and colleges in Qatar accept only attested degrees and transcripts for enrolment and recognition." },
  { icon: "👪", title: "Family Visas", desc: "Birth, marriage, and other personal certificates must be verified and attested for family sponsorship in Qatar." },
  { icon: "🏢", title: "Business Setup", desc: "<a href='/company-formation-in-qatar/' style='color:#4B5563;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>Business set up in Qatar</a>, trade licenses, agreements, and contracts require legally attested commercial documents." },
  { icon: "📜", title: "Legal Matters", desc: "Divorce, death, and medical certificates need attestation for legal registration and official proceedings in Qatar." },
  { icon: "🛂", title: "Residency & Visa", desc: "Qatar residency and visa applications require properly attested personal and educational documents." },
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Birth certificate attestation",
      "Marriage certificate attestation",
      "Divorce certificate attestation",
      "Death certificate attestation",
      "Medical certificate attestation",
      "Transfer certificate attestation",
      "Qatar PCC (Police Clearance)",
      "Affidavit",
    ]
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Qatar degree certificate attestation",
      "Diploma certificate attestation",
      "School leaving certificates",
      "Nursing degree certificate attestation",
      "Master degree certificate attestation",
      "Engineering degree certificate attestation",
    ]
  },
  {
    category: "Commercial Documents",
    icon: "🏢",
    docs: [
      "Memorandum of Association (MOA)",
      "Articles of Association (AOA)",
      "Certificate of Incorporation",
      "Board Resolutions",
      "Commercial Invoices",
      "Power of Attorney",
      "Business contracts and invoices",
      "Commercial License",
    ]
  },
]

const steps = [
  { step: "01", title: "Verification by Issuing Authority", desc: "Certificates are checked and verified with the original issuing institution or government department." },
  { step: "02", title: "State Attestation", desc: "Required for certificates issued outside Qatar. State-level authentication is completed before embassy submission." },
  { step: "03", title: "MEA Attestation", desc: "The Ministry of External Affairs verifies your certificates to ensure they are accepted for international use." },
  { step: "04", title: "Qatar Embassy Attestation", desc: "The Qatar Embassy confirms the authenticity of your certificates, legalizing them for use in Qatar." },
  { step: "05", title: "<a href='/mofa-attestation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>MOFA Attestation</a> Qatar", desc: "Final legalization by the Qatar Ministry of Foreign Affairs completes the attestation process." },
]

const benefits = [
  { title: "25+ Years of Experience", desc: "Over two decades of handling Qatar certificate attestation in UAE, Dubai, Abu Dhabi and across the GCC with expert knowledge of all procedures." },
  { title: "Fast & Professional Service", desc: "Fast, professional <a href='/certificate-attestation/' style='color:#CBD5E0;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>certificate attestation</a> services in qatar handling with structured updates at every stage — no unnecessary delays or complications." },
  { title: "Safe & Confidential", desc: "Your documents are handled with strict confidentiality, secure physical transfer protocols, and tracked at every step." },
  { title: "Transparent Pricing", desc: "Competitive and transparent pricing with no hidden charges. Costs are clearly communicated based on your document type and requirements." },
  { title: "Pickup & Delivery Across UAE", desc: "We offer doorstep pickup and delivery options across the UAE so you never need to leave your office or home." },
  { title: "24/7 Customer Support", desc: "Our dedicated support team is available around the clock to answer queries, provide status updates, and handle urgent requests." },
]

const timingFactors = [
  "Type of document — educational, personal, or commercial certificates",
  "Number of documents submitted for attestation",
  "Steps involved — issuing authority, state, MEA, embassy, and MOFA",
  "Country of origin of the documents",
  "Choice of standard or urgent processing service",
  "Accuracy and completeness of submitted documents",
]

const mistakes = [
  "Skipping certified translations for non-English or non-Arabic certificates",
  "Using unverified or unreliable attestation services",
  "Missing steps like state or MEA attestation before embassy submission",
  "Submitting expired or incorrect ID copies",
  "Submitting incomplete documents without all required supporting papers",
]

const getStartedSteps = [
  { step: "01", title: "Contact IndexAUH", desc: "Reach out via WhatsApp, phone, or online form with your document details."},
  { step: "02", title: "Submit Documents", desc: "Upload scanned copies or arrange secure pickup from your location." },
  { step: "03", title: "Expert Verification", desc: "Documents are checked to meet Qatar attestation requirements." },
  { step: "04", title: "Processing", desc: "We handle embassy and MOFA Qatar attestation efficiently." },
  { step: "05", title: "Delivery", desc: "Receive attested documents securely at your location across the UAE." },
]

const faqs = [
  { q: "Can I use apostille services in Qatar?", a: "No. Qatar does not accept apostille services. Qatar requires full embassy and MOFA attestation for all documents. Using professional Qatar attestation services ensures your documents meet all legal requirements." },
  { q: "Can I get my documents attested after arriving in Qatar?", a: "No. Documents must be attested before arrival to be legally valid in Qatar. All attestation steps — including MEA and Qatar embassy attestation — must be completed in your home country or UAE before travelling." },
  { q: "What documents are needed for Qatar certificate attestation?", a: "You will need original certificates, photocopies of all certificates, a passport copy of the certificate holder, an authorization letter or Power of Attorney if someone else is submitting the documents, and certified legal translations for documents not in English or Arabic." },
  { q: "How long does Qatar attestation take?", a: "Standard processing usually takes 15–25 working days depending on the document type, country of origin, and steps involved. Express options are available for urgent cases. Contact us for a realistic timeline based on your specific documents." },
  { q: "What happens if my documents are incomplete?", a: "Missing documents can delay or result in rejection of the Qatar attestation process. Our team checks all documents before submission to prevent such issues and ensure a smooth process from start to finish." },
  { q: "Are marriage certificates attested differently in Qatar?", a: "The process is similar to other personal documents, including verification by the issuing authority, MEA attestation, Qatar embassy attestation, and MOFA Qatar attestation. Certified translation may be required if the document is not in Arabic or English." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Qatar Certificate Attestation Services | Indexauh"
  description="Qatar Certificate Attestation with IndexAUH. 25+ years of trusted expertise, secure embassy & MOFA handling. Ready to start? Talk to us today."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .purpose-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; transition: all 0.25s; }
  .purpose-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .step-num { width: 42px; height: 42px; border-radius: 10px; background: #2D3748; color: #38B2AC; font-weight: 900; font-size: 1rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  /* ---- Process steps section ---- */
  .steps-info-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 48px; align-items: start; }
  .steps-col { display: flex; flex-direction: column; gap: 14px; }
  .step-cards { display: flex; flex-direction: column; gap: 14px; }
  .info-col { display: flex; flex-direction: column; }
  .info-card { background: #fff; border-radius: 16px; padding: 24px; margin-bottom: 16px; }
  .info-card--teal { border: 1px solid #B2F5EA; }
  .info-card--red { border: 1px solid #FCA5A5; }
  .info-card--neutral { border: 1px solid #eef0f6; }
  .info-card-title { font-size: 0.95rem; font-weight: 800; color: #1A202C; margin: 0 0 14px; padding-left: 12px; }
  .info-card-title--teal { border-left: 3px solid #38B2AC; }
  .info-card-title--red { border-left: 3px solid #EF4444; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .get-started-grid { grid-template-columns: 1fr !important; }
  }

  /* Process steps responsive rules */
  @media (max-width: 900px) {
    .steps-info-grid { grid-template-columns: 1fr; gap: 32px; }
    .step-cards { flex-direction: row; flex-wrap: wrap; gap: 16px; }
    .step-cards .step-card { flex: 1 1 calc(50% - 8px); min-width: 260px; }
  }
  @media (max-width: 640px) {
    .step-cards { flex-direction: column; }
    .step-cards .step-card { flex: 1 1 auto; min-width: 0; padding: 16px; gap: 12px; }
    .info-card { padding: 18px; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-87.webp"
    alt="Qatar Certificate Attestation in UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 12px;">
      QATAR CERTIFICATE ATTESTATION IN UAE
    </h1>
    <p style="color:#38B2AC;font-size:1.05rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 20px;">Attestation Services For Qatar | 25 Years of Trust</p>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Make sure your documents are officially recognized in Qatar with Qatar certificate attestation services from IndexAUH. We handle the complete Qatar attestation process — including Qatar embassy attestation and MOFA attestation Qatar — for educational, personal, and commercial documents.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is Qatar Certificate Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Qatar certificate attestation is a process that confirms your certificates are authentic and legally recognized in Qatar. This process includes verification by the issuing authority, attestation from the Qatar embassy, and approval by MOFA Qatar.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Qatar does not accept apostille services. All documents must go through the full embassy and MOFA attestation process to be legally valid. Using professional attestation services in Qatar ensures your documents meet all legal requirements and are processed efficiently.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:20px;">
        At IndexAUH, we handle the complete Qatar document attestation process in UAE — from verification to final MOFA approval — with over 25 years of experience in the GCC region.
      </p>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Key Insight — No Apostille in Qatar</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          Unlike many countries, Qatar does not accept apostille certification. All documents must undergo the full attestation chain — issuing authority, MEA, Qatar embassy, and MOFA Qatar — to be legally valid.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/qatar-flag.webp" alt="Qatar document attestation" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">MEA · Qatar Embassy · MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Qatar attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY ATTESTATION IS REQUIRED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-11.webp" alt="Why Qatar attestation is required" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Why Qatar Attestation Matters</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Work · Education · Family · Business</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Core Reasons</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Why Is Attestation Required for Qatar?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          Qatar certificate attestation is necessary for a wide range of official purposes. Whether you are relocating for work, applying for a family visa, enrolling in education, or registering a business, your documents must be officially verified and attested before they are accepted by Qatari authorities.
        </p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px;">
  {purposes.map(p => (
    <div class="purpose-card">
      <div style="font-size:1.6rem;margin-bottom:10px;">{p.icon}</div>
      <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 6px;">{p.title}</h3>
      <p style="font-size:0.76rem;color:#4B5563;line-height:1.55;margin:0;" set:html={p.desc}></p>
    </div>
  ))}
</div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Qatar Attestation Services"
  description="Index AUH provides Qatar certificate attestation services for a wide range of document categories — personal, educational, and commercial. The list below covers the most commonly requested types. Always confirm the exact requirements with the requesting authority in Qatar."
  imageSrc="/images/img-16.webp"
  imageAlt="Document types for Qatar attestation"
  docTypes={docTypes}
  country="qatar"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-8.webp" alt="Qatar attestation process" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);max-width:calc(100% - 80px);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Qatar Certificate Attestation Procedure</h2>
      </div>
    </div>

    <div class="steps-info-grid">
      <div class="steps-col">
        <div class="step-cards">
          {steps.map(s => (
            <div class="step-card">
              <div class="step-num">{s.step}</div>
              <div>
                <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;" set:html={s.title}></p>
                <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="info-card info-card--neutral">
          <h3 class="info-card-title info-card-title--teal">Cost of Qatar Certificate Attestation</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">The cost depends on multiple factors. We provide transparent pricing with no hidden charges:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {[
              "Type of document (educational, personal, commercial)",
              "Number of documents to be attested",
              "Attestation steps required (state, MEA, embassy, MOFA)",
              "Service chosen (standard or urgent processing)",
              "Additional requirements such as certified translations",
            ].map(f => (
              <div style="display:flex;align-items:flex-start;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;margin-top:2px;">→</span>{f}
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="info-col">
        <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.12);margin-bottom:24px;">
          <img src="/images/img-1.webp" alt="Qatar attestation timing" style="width:100%;height:260px;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.78) 100%);"></div>
          <div style="position:absolute;bottom:18px;left:18px;right:18px;">
            <p style="color:#fff;font-size:1.05rem;font-weight:800;margin:0 0 3px;">Processing Time Varies</p>
            <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Standard: 15–25 working days · Express options available</p>
          </div>
