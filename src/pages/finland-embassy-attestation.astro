---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const heroPills = ["25 Years of Trust","Finland ⇄ UAE","MOFA Approved","Embassy Attestation"]

const purpose = [
  "Employment visa processing",
  "University admission in Finland",
  "Spouse or family residence visa",
  "Business set up in UAE",
  "Power of Attorney use",
  "Immigration formalities",
]

const serviceCategories = [
  { title:"Personal Documents Attestation", image:"/images/img-16.webp", items:["Marriage certificate attestation","Birth certificate attestation","Divorce Certificate Attestation","Death Certificate Attestation","PCC Attestation","Medical Certificate Attestation","Single Status Certificate Attestation","Affidavit"] },
  { title:"Educational Certificate Attestation", image:"/images/img-52.webp", items:["Degree Certificate Attestation","Diploma Certificate Attestation","School Certificate Attestation","Mark Sheets Attestation","Technical Certificate Attestation","Nursing Certificate Attestation","Engineering Certificate Attestation","Transcript Attestation"] },
  { title:"Commercial Documents Attestation", image:"/images/img-1.webp", items:["Power of Attorney Attestation","Company Incorporation Documents Attestation","Memorandum of Association Attestation","Articles of Association Attestation","Board Resolution Attestation","Commercial Invoice Attestation","Commercial License"] },
]

const finlandToUae = [
  { num:"01", title:"Notary Attestation in Finland", desc:"The document is first notarized in Finland to confirm its authenticity." },
  { num:"02", title:"Finland Ministry of Foreign Affairs Approval", desc:"The Finland Ministry of Foreign Affairs authenticates the document for international use." },
  { num:"03", title:"UAE Embassy Attestation in Finland", desc:"The UAE Embassy in Finland verifies and attests the document for use in the UAE." },
  { num:"04", title:"Final MOFA Attestation in UAE", desc:"Once in the UAE, the Ministry of Foreign Affairs completes the final attestation. After this, UAE authorities can legally accept the document." },
]

const uaeToFinland = [
  { num:"01", title:"UAE Notary Attestation", desc:"The document is first notarized in the UAE to confirm its authenticity." },
  { num:"02", title:"UAE Ministry of Foreign Affairs Approval", desc:"The UAE Ministry of Foreign Affairs authenticates the document for international use." },
  { num:"03", title:"Finland Embassy Attestation in Abu Dhabi", desc:"The Finland Embassy in Abu Dhabi completes verification. Once done, the document becomes valid for use in Finland." },
]

const procedureTabs = [
  { key:"finland-uae", label:"Finland → UAE", steps: finlandToUae },
  { key:"uae-finland", label:"UAE → Finland", steps: uaeToFinland },
]

const timeFactors = ["Type of document","Previous approvals completed","Embassy schedule"]
const costFactors = ["Document category","Direction of attestation","Urgent processing needs"]

const delays = ["Missing prior MOFA approval","Incorrect notarization","Damaged certificates","Signature mismatch","Submission in wrong order"]

const gettingStarted = [
  { num:"01", title:"Contact IndexAUH", desc:"Call or visit our Abu Dhabi or Dubai office." },
  { num:"02", title:"Document Review", desc:"Our team checks your certificates and confirms the required sequence." },
  { num:"03", title:"Embassy Submission", desc:"We complete the Finland Embassy Attestation process from start to finish." },
  { num:"04", title:"Safe Return", desc:"You receive your attested document securely." },
]

const whyUs = [
  { icon:"🏆", label:"25+ years of experience in UAE attestation services." },
  { icon:"🏛️", label:"Direct handling of embassy procedures in Abu Dhabi." },
  { icon:"🎯", label:"Clear guidance at every stage." },
  { icon:"⚡", label:"Fast response and status updates." },
  { icon:"🔍", label:"Careful document verification before submission." },
]

const faqs = [
  { q:"How long does the Finland Embassy Attestation take in UAE?", a:"Time varies based on document type and embassy schedule. We provide a clear estimate after review." },
  { q:"Is personal presence required?", a:"No. We can handle the submission on your behalf." },
  { q:"Can laminated certificates be attested?", a:"Laminated documents may require special handling. Our team will guide you." },
  { q:"Is translation required?", a:"Some documents need certified translation before submission. We will confirm after checking your papers." },
  { q:"Can I attest copies instead of originals?", a:"In most cases, original documents are required." },
]
---

<BaseLayout title="Embassy Attestation in UAE | Attestation Services UAE"
description="Embassy attestation in UAE by Index Office and Services with 25 years of experience. Trusted support for all documents. Call now."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }

  .step-card { display:flex; align-items:flex-start; gap:18px; padding:24px; background:#fff; border:1px solid #eef0f6; border-radius:16px; transition:all 0.25s; }
  .step-card:hover { border-color:#B2F5EA; box-shadow:0 12px 32px rgba(56,178,172,0.1); transform:translateY(-3px); }

  .purpose-card { padding:24px; background:#fff; border:1px solid #eef0f6; border-radius:16px; transition:all 0.25s; }
  .purpose-card:hover { border-color:#B2F5EA; box-shadow:0 12px 32px rgba(56,178,172,0.1); transform:translateY(-3px); }

  .why-card { background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:14px; padding:22px; display:flex; align-items:flex-start; gap:14px; transition:background 0.2s; }
  .why-card:hover { background:rgba(255,255,255,0.14); }

  .tab-btn { padding:9px 22px; border-radius:9999px; font-size:0.83rem; font-weight:600; cursor:pointer; border:none; transition:all 0.2s; }
  .tab-btn.active { background:#2D3748; color:#fff; }
  .tab-btn:not(.active) { background:#F0FFFE; color:#2D3748; border:1px solid #B2F5EA; }

  .fact-item { display:flex; align-items:center; gap:8px; padding:10px 14px; background:#fff; border:1px solid #e0e7ef; border-radius:10px; font-size:0.98rem; color:#1A202C; font-weight:500; }
  .fact-check { width:20px; height:20px; border-radius:50%; background:#38B2AC; display:flex; align-items:center; justify-content:center; flex-shrink:0; }

  .faq-item { border:1px solid #eef0f6; border-radius:14px; padding:6px 22px; background:#fff; transition:border-color 0.2s; }
  .faq-item:hover { border-color:#B2F5EA; }
  .faq-item summary { padding:16px 0; cursor:pointer; font-weight:700; color:#1A202C; font-size:1rem; list-style:none; display:flex; justify-content:space-between; align-items:center; gap:12px; }
  .faq-item summary::-webkit-details-marker { display:none; }
  .faq-item summary::after { content:"+"; font-size:1.4rem; font-weight:400; color:#38B2AC; flex-shrink:0; transition:transform 0.2s; }
  .faq-item[open] summary::after { transform:rotate(45deg); }
  .faq-item p { color:#4B5563; font-size:0.98rem; line-height:1.75; margin:0 0 18px; }

  .idx-form input,.idx-form select,.idx-form textarea { width:100%; border:1px solid #e5e7eb; border-radius:10px; padding:11px 14px; font-size:1rem; color:#374151; outline:none; font-family:inherit; background:#fff; box-sizing:border-box; }
  .idx-form input:focus,.idx-form select:focus,.idx-form textarea:focus { border-color:#38B2AC; box-shadow:0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize:none; }
  .idx-submit { width:100%; background:#2D3748; color:#fff; font-weight:700; padding:13px; border-radius:10px; border:none; cursor:pointer; font-size:0.95rem; letter-spacing:0.04em; transition:background 0.2s; }
  .idx-submit:hover { background:#1A202C; }

   @media(max-width:900px){
    .hero-grid { flex-direction:column !important; }
    .two-col { flex-direction:column !important; }
    .two-col > div { width:100% !important; }
  }
  @media(max-width:640px){
    .steps-grid, .purpose-grid, .facts-grid { grid-template-columns:1fr !important; }
  }

  @media(max-width:900px){
  .two-col { flex-direction:column !important; width:100% !important; box-sizing:border-box !important; }
  .two-col > * { width:100% !important; min-width:0 !important; box-sizing:border-box !important; overflow:hidden !important; word-break:break-word !important; }
}
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Finland Embassy Attestation UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.86) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;justify-content:center;">
      {heroPills.map(p => <span class="idx-pill">{p}</span>)}
    </div>
    <p style="color:#38B2AC;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;font-size:0.75rem;margin:0 0 14px;">MOFA Attestation | Embassy Attestation</p>
    <h1 style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      Finland Embassy Attestation<br/>in <span style="color:#38B2AC;">UAE</span>
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 16px;max-width:640px;">
      Moving to Finland or using Finnish documents in the UAE needs proper legal approval. Finland Embassy Attestation confirms your certificate is genuine and accepted by authorities.
    </p>
    <p style="color:#94A3B8;font-size:1.05rem;line-height:1.8;margin:0 auto 32px;max-width:600px;">
      IndexAUH has over 25 years of experience handling embassy procedures across the UAE. We manage both Finland issued documents for UAE use and UAE issued documents for Finland use.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:40px;">
      <a href="tel:+971529300200" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        (+971) 529 300 200
      </a>
      <a href="#contact" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">
        Get a Quote &rarr;
      </a>
    </div>
    <div style="display:flex;gap:32px;justify-content:center;flex-wrap:wrap;">
      <div style="text-align:center;">
        <p style="font-size:1.8rem;font-weight:900;color:#38B2AC;margin:0;">25+</p>
        <p style="color:#81E6D9;font-size:0.75rem;margin:2px 0 0;font-weight:500;">Years of Experience</p>
      </div>
      <div style="width:1px;background:rgba(255,255,255,0.15);"></div>
      <div style="text-align:center;">
        <p style="font-size:1.8rem;font-weight:900;color:#38B2AC;margin:0;">2-Way</p>
        <p style="color:#81E6D9;font-size:0.75rem;margin:2px 0 0;font-weight:500;">Finland ⇄ UAE Processing</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:-60px;right:-60px;width:400px;height:360px;background:radial-gradient(ellipse,rgba(56,178,172,0.08) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="two-col" style="display:flex;gap:52px;align-items:center;flex-wrap:wrap;">

      <div style="flex-shrink:0;width:420px;">
        <div style="position:relative;border-radius:20px;overflow:hidden;height:380px;">
          <img src="/images/finland-flag.webp" alt="Finland embassy attestation UAE" style="width:100%;height:100%;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(to bottom,transparent 45%,rgba(26,32,44,0.72));"></div>
          <div style="position:absolute;bottom:24px;left:24px;right:24px;">
            <p style="color:#81E6D9;font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 6px;">Legally Recognised</p>
            <p style="color:#fff;font-size:0.95rem;font-weight:700;margin:0;">Documents handled in both directions, Finland and UAE</p>
          </div>
        </div>
      </div>

      <div style="flex:1;min-width:280px;">
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;"><span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Overview</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What is Finland Embassy Attestation?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:14px;">Authorities in both countries check the authenticity of foreign documents. Attestation proves the signature and seal are valid. Without proper approval, the document will not be accepted.</p>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:20px;">IndexAUH has over 25 years of experience handling embassy procedures across the UAE. Our team handles the full process with care and clarity.</p>
        <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:16px 20px;">
          <p style="color:#1A202C;font-size:1rem;font-weight:600;margin:0 0 4px;">IndexAUH</p>
          <p style="color:#4B5563;font-size:0.98rem;line-height:1.7;margin:0;">25 Years of Trust handling Finland Embassy Attestation across the UAE.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ════ PURPOSE ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:400px;background:radial-gradient(ellipse,rgba(56,178,172,0.07) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;">
    <div class="two-col" style="display:flex;gap:52px;align-items:center;flex-wrap:wrap;">

      <div style="flex:1;min-width:280px;">
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;"><span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Why It Matters</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.1rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 16px;">Purpose of Finland Embassy Attestation</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">People request Finland Embassy Attestation for many reasons. Most cases relate to work, study, family, or business. You may need it for:</p>
        <div class="facts-grid" style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;">
          {purpose.map(item => (
            <div class="fact-item">
              <span class="fact-check">
                <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" width="10" height="10"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              {item}
            </div>
          ))}
        </div>
      </div>

      <div style="flex-shrink:0;width:380px;">
        <img src="/images/img-7.webp" alt="Purpose of Finland embassy attestation" style="width:100%;height:320px;object-fit:cover;border-radius:20px;box-shadow:0 12px 40px rgba(0,0,0,0.12);" />
      </div>

    </div>
  </div>
</section>

<!-- ════ SERVICES WE PROVIDE ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What We Cover</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Our Finland Embassy Attestation Services</h2>
      <p style="color:#6B7280;font-size:1.02rem;max-width:680px;margin:0 auto;">IndexAUH offers complete Finland embassy attestation services across personal, educational, and commercial document categories.</p>
    </div>
    <div class="purpose-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;">
      {serviceCategories.map(s => (
        <div class="purpose-card" style="padding:0;overflow:hidden;">
          <img src={s.image} alt={s.title} style="width:100%;height:150px;object-fit:cover;display:block;" />
          <div style="padding:22px;">
            <p style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 14px;">{s.title}</p>
            <ul style="margin:0;padding-left:18px;color:#6B7280;font-size:0.92rem;line-height:1.85;">
              {s.items.map(i => <li>{i}</li>)}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ PROCEDURE TABS ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;bottom:-60px;right:-60px;width:400px;height:300px;background:radial-gradient(ellipse,rgba(56,178,172,0.08) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Step by Step</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Finland Embassy Attestation Process</h2>
      <p style="color:#6B7280;font-size:1.02rem;margin:0 auto 24px;max-width:680px;">The process depends on where the document was issued. We handle both directions.</p>
      <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;" id="procTabs">
        {procedureTabs.map((t, i) => (
          <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={t.key}>{t.label}</button>
        ))}
      </div>
    </div>

    {procedureTabs.map((t, i) => (
      <div id={`tab-${t.key}`} class="steps-grid" style={`display:${i === 0 ? 'grid' : 'none'};grid-template-columns:repeat(2,1fr);gap:16px;`}>
        {t.steps.map(s => (
          <div class="step-card">
            <div style="width:44px;height:44px;border-radius:12px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.num}</div>
            <div>
              <p style="font-size:0.9rem;font-weight:700;color:#1A202C;margin:0 0 5px;">{s.title}</p>
              <p style="font-size:0.98rem;color:#6B7280;line-height:1.65;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</section>

<!-- ════ PROCESSING TIME & COST ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div class="sec-inner" style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:36px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Plan Ahead</p>
      <h2 style="font-size:2.1rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Processing Time and Cost</h2>
      <p style="color:#6B7280;font-size:1.02rem;margin:0 auto;max-width:740px;">Our team gives a clear timeline after reviewing your papers, and explains charges clearly before starting — no hidden steps.</p>
    </div>
    <div class="two-col" style="display:flex;gap:24px;flex-wrap:wrap;width:100%;box-sizing:border-box;">
      <div style="flex:1;min-width:0;background:#F0FFFE;border:1px solid #B2F5EA;border-radius:14px;padding:24px;box-sizing:border-box;overflow:hidden;">
        <p style="font-weight:700;color:#1A202C;margin:0 0 14px;font-size:1rem;">Processing Time Depends On:</p>
        <ul style="margin:0;padding-left:18px;color:#4B5563;font-size:0.95rem;line-height:1.9;word-break:break-word;">
          {timeFactors.map(t => <li>{t}</li>)}
        </ul>
      </div>
      <div style="flex:1;min-width:0;background:#F0FFFE;border:1px solid #B2F5EA;border-radius:14px;padding:24px;box-sizing:border-box;overflow:hidden;">
        <p style="font-weight:700;color:#1A202C;margin:0 0 14px;font-size:1rem;">Cost Depends On:</p>
        <ul style="margin:0;padding-left:18px;color:#4B5563;font-size:0.95rem;line-height:1.9;word-break:break-word;">
          {costFactors.map(c => <li>{c}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ════ COMMON REASONS FOR DELAY ════ -->
<section style="background:#F8FAFF;padding:64px 24px;position:relative;overflow:hidden;">
  <div class="sec-inner" style="max-width:1100px;margin:0 auto;">
    <div style="background:#fff;border:1px solid #eef0f6;border-radius:18px;padding:32px;">
