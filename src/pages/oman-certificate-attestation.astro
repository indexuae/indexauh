---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1",  label: "US +1" },
  { code: "+973", label: "BH +973" },
]

const purposes = [
  { icon: "💼", title: "Job Approval & Work Permits", desc: "Employers in Oman require attested educational and professional certificates before approving employment." },
  { icon: "👪", title: "Marriage & Family Visa", desc: "Marriage and birth certificates must be attested for family residence visa processing in Oman." },
  { icon: "🎓", title: "School & University Admission", desc: "Educational institutions in Oman accept only attested certificates and transcripts for enrollment." },
  { icon: "🏢", title: "Business Setup in Oman", desc: "Commercial documents require legal attestation for business registration and trade activities in Oman." },
  { icon: "🛂", title: "Residence & Sponsorship", desc: "Oman residence permits and family sponsorship applications require fully attested personal documents." },
  { icon: "📜", title: "Legal & Civil Matters", desc: "Divorce, death, and medical certificates need attestation for legal proceedings and official registration." },
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Marriage certificate attestation",
      "Birth certificate attestation",
      "Divorce certificate attestation",
      "Death certificate attestation",
      "Medical certificate attestation",
      "Salary certificate attestation",
      "Transfer certificate attestation",
      "Oman Police Clearance Certificate",
      "Affidavit",
    ]
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Degree certificate attestation for Oman",
      "Diploma certificate attestation",
      "School leaving certificates",
      "Nursing degree certificate attestation",
      "Master degree certificate attestation",
      "Engineering degree certificate attestation",
      "Mark sheets and transcripts",
    ]
  },
  {
    category: "Commercial Documents",
    icon: "🏢",
    docs: [
      "Memorandum of Association (MOA)",
      "Articles of Association (AOA)",
      "Certificate of Incorporation",
      "Board Resolutions",
      "Commercial Invoices",
      "Power of Attorney",
      "Business contracts",
      "Commercial License",
    ]
  },
]

const steps = [
  { step: "01", title: "Verification from the Issuing Authority", desc: "The document is verified with the department or institution that issued it, confirming the certificate is original and valid." },
  { step: "02", title: "Attestation from UAE Authorities", desc: "After initial verification, the document is attested by relevant UAE authorities, confirming it has been legally verified within the UAE." },
  { step: "03", title: "Oman Embassy Attestation (When Required)", desc: "Some documents require Oman embassy attestation based on their type and purpose. The embassy confirms the document meets Oman's legal requirements." },
  { step: "04", title: "Ministry of Foreign Affairs Oman Attestation", desc: "The final step — the<a href='/mofa-attestation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'> Ministry of Foreign Affairs </a> gives official approval for the document to be used inside Oman. Without this, the document is not legally accepted." },
]
const benefits = [
  { title: "25+ Years of Experience", desc: "Over two decades of handling Oman <a href='/certificate-attestation-in-dubai/' style='color:#CBD5E0;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>certificate attestation in Dubai</a>, UAE, Abu Dhabi and across the GCC — we understand every step of the process." },
  { title: "Complete Document Handling", desc: "We manage the entire attestation process from start to finish — issuing authority, UAE attestation, Oman embassy, and MOFA Oman." },
  { title: "Door Delivery Service", desc: "Safe and easy document return with door delivery service. Your attested certificates are returned securely to your location." },
  { title: "Transparent Pricing", desc: "Clear guidance with no hidden charges. Costs depend on document type, issuing country, and authority approvals involved." },
  { title: "Dedicated Support Team", desc: "Our support team assists you at every stage with clear timelines and regular updates throughout the attestation process." },
  { title: "100+ Countries Covered", desc: "Attestation support extending to 100+ countries makes cross-border document legalization simple and stress-free for all clients." },
]

const timingFactors = [
  "Type of document — educational, personal, or commercial",
  "Country where the document was issued",
  "Authority approvals required at each stage",
  "Educational documents usually take more time than personal certificates",
  "Whether Oman embassy attestation is required for your document type",
  "Accuracy and completeness of submitted documents",
]

const faqs = [
  { q: "Is Oman certificate attestation required for jobs?", a: "Yes. Employers in Oman require attested documents before approving employment. Educational certificates, degree certificates, and professional qualifications must all be attested before submission to Oman authorities." },
  { q: "Can I apply for Oman attestation from the UAE?", a: "Yes. Oman attestation can be completed entirely from the UAE. Index Office Services manages the complete process — including UAE authority attestation, Oman embassy attestation, and MOFA Oman — without you needing to travel to Oman." },
  { q: "Is Oman embassy attestation always needed?", a: "It depends on the document type and purpose. Some documents require Oman embassy attestation while others proceed directly to Ministry of Foreign Affairs Oman attestation. Our team confirms the correct path before starting your process." },
  { q: "How long is attested documentation valid in Oman?", a: "Attested documents remain valid unless the rules or requirements change. There is no fixed expiry for attestation, but some authorities may request re-attestation if the document is very old. Contact us to confirm validity for your specific use case." },
  { q: "What is the difference between apostille and Oman attestation?", a: "Apostille is accepted for documents used in Hague Convention countries. Oman accepts apostille for selected purposes such as education, employment, and legal use. However, some Oman authorities still require additional local verification even after an apostille. Our team checks the exact requirement before starting your process." },
  { q: "What documents are needed for Oman certificate attestation?", a: "You typically need the original certificate, passport copies, and an authorization letter if someone else submits on your behalf. Marriage certificate attestation requires passport copies of both spouses. Birth certificate attestation requires passport copies of both parents. Specific requirements may vary by document type." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Oman Certificate Attestation in UAE — Index Office Services"
  description="Complete Oman certificate attestation services in UAE. Oman embassy attestation, MOFA Oman, degree and personal document attestation from UAE. 25+ years of experience."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .purpose-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; transition: all 0.25s; }
  .purpose-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-80.webp"
    alt="Oman Certificate Attestation in UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 12px;">
      OMAN CERTIFICATE ATTESTATION IN UAE
    </h1>
    <p style="color:#38B2AC;font-size:1.05rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 20px;">Attestation Services in Muscat | 25 Years of Trust</p>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Oman certificate attestation is required when documents issued outside Oman must be used for official purposes. With over 25 years of experience, Indexauh manages the entire Oman attestation process from the UAE — ensuring each step is handled carefully, documents are processed correctly, and approvals are received without delays.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is Oman Certificate Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Oman certificate attestation is the legal confirmation of documents so they can be accepted by government and private authorities in Oman. This process confirms that the document is original, the issuing authority is approved, and the certificate is valid for use in Oman.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Without Oman attestation, documents are not accepted for any official purpose — whether employment, family visa, education, or business setup. Every document must follow a fixed legal order of verification and attestation.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:20px;">
        Indexauh has over 25 years of experience managing the complete Oman attestation process from the UAE. Our team handles each step carefully, ensuring documents are processed correctly and approvals are received smoothly.
      </p>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Key Insight — Fixed Legal Order</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          Oman attestation follows a fixed legal sequence. Each step — from issuing authority verification to UAE attestation, Oman embassy, and MOFA Oman — must be completed in the correct order. Skipping or reversing any step will result in rejection.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/oman-flag.webp" alt="Oman document attestation UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">UAE Authorities · Oman Embassy · MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Oman attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY IS OMAN ATTESTATION REQUIRED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-8.webp" alt="Why Oman attestation is required" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Why Oman Attestation Matters</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Work · Family · Education · Business</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Core Reasons</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Why Is Oman Attestation Required?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          Oman authorities require attestation to prevent document misuse and ensure that all certificates used for official purposes are genuine and legally valid. Without attestation, no document is accepted for any formal process in Oman.
        </p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px;">
          {purposes.map(p => (
            <div class="purpose-card">
              <div style="font-size:1.6rem;margin-bottom:10px;">{p.icon}</div>
              <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 6px;">{p.title}</h3>
              <p style="font-size:0.76rem;color:#4B5563;line-height:1.55;margin:0;">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Attestation Services"
  description="Index AUH provides Oman certificate attestation services for a wide range of document categories — personal, educational, and commercial. Our team confirms the correct attestation path for each document type before processing begins."
  imageSrc="/images/img-16.webp"
  imageAlt="Document types for Oman attestation"
  docTypes={docTypes}
  country="oman"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Oman attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Oman Certificate Attestation Procedure from UAE</h2>
      </div>
    </div>

    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;">
      <div style="display:flex;flex-direction:column;gap:14px;">
        {steps.map(s => (
          <div class="step-card">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;"set:html={s.desc}></p>
            </div>
          </div>
        ))}
      </div>

      <div>
        <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.12);margin-bottom:24px;">
          <img src="/images/img-1.webp" alt="Oman attestation timing" style="width:100%;height:260px;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.78) 100%);"></div>
          <div style="position:absolute;bottom:18px;left:18px;right:18px;">
            <p style="color:#fff;font-size:1.05rem;font-weight:800;margin:0 0 3px;">Processing Time Varies by Document</p>
            <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Educational docs take longer than personal certificates</p>
          </div>
        </div>

        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;margin-bottom:20px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Factors That Affect Processing Time</h3>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {timingFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.98rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>

        <div style="background:#2D3748;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#fff;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required</h3>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {[
              "Original certificate",
              "Passport copy of the certificate holder",
              "Passport copies of both spouses (marriage certificates)",
              "Passport copies of parents (birth certificates)",
              "Authorization letter (if someone else submits)",
            ].map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.98rem;color:#B2F5EA;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">✓</span>{d}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ MARRIAGE & BIRTH CERTIFICATE HIGHLIGHT ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:48px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Specific Attestation Types</p>
      <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0;">Key Personal Document Attestation for Oman</h2>
    </div>

    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:32px;">
      <!-- Marriage -->
      <div style="background:#F8FAFF;border:1px solid #eef0f6;border-radius:20px;overflow:hidden;">
        <div style="position:relative;height:200px;">
          <img src="/images/img-81.webp" alt="Marriage certificate attestation Oman" style="width:100%;height:100%;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.72) 100%);"></div>
          <div style="position:absolute;bottom:16px;left:20px;">
            <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0;">Marriage Certificate Attestation</p>
