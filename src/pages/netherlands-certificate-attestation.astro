---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whenNeeded = [
  "Employment visa processing",
  "Family visa and spouse sponsorship",
  "School or university admission",
  "Golden visa applications",
  "<a href='/business-setup-in-the-uae/' style='color:#374151;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>Business setup in UAE</a>",
  "Court or legal submissions",
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Netherlands Marriage certificate attestation",
      "Netherlands Birth certificate attestation",
      "Netherlands Divorce Certificate Attestation",
      "Netherlands Death Certificate Attestation",
      "Netherlands Police Clearance Certificate Attestation",
      "Medical Certificate Attestation",
      "Single Status Certificate Attestation",
      "Affidavit",
    ],
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Netherlands Degree Certificate Attestation",
      "Diploma Certificate Attestation",
      "School Certificate Attestation",
      "Mark Sheets Attestation",
      "Technical Certificate Attestation",
      "Nursing Certificate Attestation",
      "Engineering Certificate Attestation",
      "Transcript Attestation",
    ],
  },
  {
    category: "Commercial Documents",
    icon: "⚖️",
    docs: [
      "Power of Attorney Attestation",
      "Company Incorporation Documents Attestation",
      "Memorandum of Association Attestation",
      "Articles of Association Attestation",
      "Board Resolution Attestation",
      "Commercial Invoice Attestation",
      "Commercial License",
    ],
  },
]

const processSteps = [
  { step: "01", title: "Verification in the Netherlands", desc: "The certificate must first be verified by the issuing authority or notary in the Netherlands." },
  { step: "02", title: "Ministry of Foreign Affairs in the Netherlands", desc: "After initial verification, the Dutch Ministry confirms the authenticity of the signature and seal." },
  { step: "03", title: "UAE Embassy Attestation in the Netherlands", desc: "The UAE Embassy checks the document and places its legalization stamp." },
  { step: "04", title: "MOFA Attestation in UAE", desc: "Once the document reaches the UAE, the Ministry of Foreign Affairs gives the final approval." },
]

const docsRequired = [
  "Original certificate",
  "Passport copy",
  "Visa copy in some cases",
  "Authorization letter for agency processing",
]

const timingFactors = [
  "Type of certificate submitted",
  "Educational document verification from university or board",
  "Category of document such as personal or commercial",
  "Workload at the Ministry of Foreign Affairs in the Netherlands",
  "UAE Embassy processing schedule",
  "Final MOFA approval timeline in UAE",
  "Public holidays in the Netherlands or UAE",
  "Courier transit time between both countries",
  "Accuracy and condition of the original document",
  "Translation requirement and certification stage",
]

const feeFactors = [
  "Type of certificate",
  "Educational or commercial category",
  "Translation requirement",
  "Ministry and MOFA fees",
  "Processing speed",
]

const challenges = [
  "Laminated certificates",
  "Damaged or unclear documents",
  "Name mismatch with passport",
  "Missing supporting documents",
  "Incorrect translation",
  "Submitting photocopies instead of originals",
  "Issuing authority signature does not match ministry records",
]

const getStartedSteps = [
  { step: "01", title: "Share Your Document Copy", desc: "Send us a clear scan through WhatsApp or email. Our team responds quickly." },
  { step: "02", title: "Free Review", desc: "Our experts review the certificate and confirm the required process for Netherlands Certificate Attestation." },
  { step: "03", title: "Secure Collection", desc: "We arrange document pickup from your location in the UAE." },
  { step: "04", title: "Complete Processing", desc: "Our team handles ministry procedures, embassy legalization, and final MOFA stamping. You receive your attested document safely." },
]

const whyChoose = [
  { title: "25+ Years of Experience", desc: "We are the best in the UAE with over 25+ years of experience in certificate attestation UAE." },
  { title: "Full Dutch Process Knowledge", desc: "Clear understanding of Dutch and UAE legal procedures from start to finish." },
  { title: "Transparent Status Updates", desc: "Regular and transparent status updates at every stage of the process." },
  { title: "Safe Document Handling", desc: "Careful protection of your original documents throughout the entire process." },
  { title: "Translation & Compliance Guidance", desc: "Proper guidance on translation and legal compliance for UAE authorities." },
  { title: "Urgent Processing Support", desc: "Professional support for urgent requirements with pickup and delivery across the UAE." },
]

const faqs = [
  { q: "Is an apostille from the Netherlands accepted in the UAE?", a: "No. The Netherlands is part of the Hague Convention, but the UAE is not. That means an apostille alone is not valid for UAE visa or legal use. Full legalization including embassy and MOFA approval is required." },
  { q: "Can I use a photocopy for Netherlands document attestation?", a: "No. UAE authorities require the original certificate. Photocopies are not accepted for official stamping." },
  { q: "Do I need to attest transcripts separately from the degree certificate?", a: "In many cases, yes. Some employers and universities in the UAE request attested transcripts along with the degree. It is better to confirm the requirement before starting the process." },
  { q: "Is translation required for Dutch documents in the UAE?", a: "Most Dutch documents need English or Arabic translation. Some authorities accept English versions. Arabic translation may be required for court or government submissions. Certified translation is important." },
  { q: "Can I attest laminated certificates?", a: "No. Laminated documents are usually rejected because authorities cannot stamp on them. The lamination must be removed carefully before submission." },
  { q: "What happens if my name on the certificate does not match my passport?", a: "Name mismatch can lead to rejection. You may need a name clarification letter or supporting affidavit. It is important to review this before starting the Netherlands Certificate Attestation." },
  { q: "Can I complete Netherlands Certificate Attestation while staying in the UAE?", a: "Yes. You do not need to travel to the Netherlands. Our team manages the entire process through authorized channels." },
  { q: "Can commercial documents from the Netherlands be attested for UAE business setup?", a: "Yes. Company documents such as incorporation papers, power of attorney, and board resolutions can be legalized for use in the UAE after completing the required steps." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Netherlands Certificate Attestation Services in UAE | Indexauh"
  description="Netherlands Certificate Attestation in UAE by IndexAUH. 25+ years in document legalization with UAE Embassy Netherlands and MOFA approval. Call today."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .four-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr !important; }
    .img-first { order: -1 !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Netherlands Certificate Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">MOFA Attestation</span>
      <span class="idx-pill">Embassy Attestation</span>
      <span class="idx-pill">25 Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      NETHERLANDS CERTIFICATE ATTESTATION<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      When you bring a certificate from the Netherlands to the UAE, the government must confirm it is genuine. This process is called Netherlands Certificate Attestation. Without it, your document will not be accepted for visa, job, study, or business use. The Netherlands is part of the Hague Convention. The UAE is not. That is why an apostille alone is not enough for UAE authorities. With over 25+ years of experience in international document legalization, our team understands Dutch procedures and UAE requirements clearly.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-btns">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW / WHY NEEDED ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Purpose of Netherlands Certificate Attestation in the UAE</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:18px;">
        The UAE authorities check foreign documents before approving visas or legal applications. They need proof that your certificate is original and issued by the right authority in the Netherlands. Without correct legalization, your application can face delay or rejection.
      </p>
      <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:18px;">
  {whenNeeded.map(item => (
    <div style="display:flex;align-items:flex-start;gap:12px;background:#F8FAFF;border:1px solid #eef0f6;border-radius:12px;padding:12px 16px;">
      <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:2px;">→</span>
      <p style="font-size:0.88rem;color:#374151;line-height:1.6;margin:0;" set:html={item}></p>
    </div>
  ))}
</div>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.75;margin:0;">Missing any stage can lead to serious delays or rejection. If you are planning any of the above, this is the right time to start your attestation process.</p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/netherlands-flag.webp" alt="Netherlands document attestation UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Dutch Ministry · UAE Embassy Netherlands · MOFA UAE</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Netherlands attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Netherlands Certificate Attestation Services"
  description="We handle attestation for a wide range of document categories across personal, educational, and commercial needs."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Netherlands attestation"
  docTypes={docTypes}
  country="netherlands"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Netherlands attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">How to Get Dutch Documents Attested for the UAE?</h2>
      </div>
    </div>

    <p style="color:#4B5563;font-size:0.95rem;line-height:1.8;margin:0 0 32px;text-align:center;max-width:760px;margin-left:auto;margin-right:auto;">
      The process follows clear steps. Each step confirms your document is valid. Understanding the process clearly helps you avoid rejection and delay. Many people face problems because they skip a stage or submit incomplete documents.
    </p>

    <div style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;" class="split-grid">
      <div style="display:flex;flex-direction:column;gap:14px;">
        {processSteps.map(s => (
          <div class="step-card">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}

        <!-- Apostille vs Attestation note -->
        <div style="background:#FFF8E1;border:1px solid #F6E05E;border-radius:14px;padding:18px;margin-top:4px;">
          <p style="font-size:0.88rem;font-weight:700;color:#1A202C;margin:0 0 6px;">Attestation vs Apostille for Netherlands Documents</p>
          <p style="font-size:0.85rem;color:#4B5563;line-height:1.7;margin:0;">Many people think an apostille is enough. That works only in countries that are part of the Hague Convention. The UAE follows a different system. For UAE use, the document must go through full legalization including ministry verification and embassy stamping. An apostille stamp alone will not help for visa or government use.</p>
        </div>

        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:14px;padding:18px;">
          <p style="font-size:0.88rem;color:#4B5563;line-height:1.7;margin:0;">Every stage plays a major role in Netherlands Attestation. Missing even one step can result in rejection, which is why proper guidance is important from the beginning.</p>
        </div>
      </div>

      <div style="display:flex;flex-direction:column;gap:20px;">
        <!-- Documents Required -->
        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">What Documents Do You Need to Start the Process?</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Most applications require:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {docsRequired.map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{d}
              </div>
            ))}
          </div>
         <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">In many cases, <a href="/legal-translation-in-uae/" style="color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;">legal translation</a> must be certified. It should match the original document exactly. Translation is usually done after attestation or as required by the authority. Our Attestation services Netherlands include guidance on translation. We check your document and advise the correct step.</p>
        </div>

        <!-- Timing -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">How Long Does Netherlands Certificate Attestation Take?</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Processing time depends on several key factors:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {timingFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>

        <!-- Fees -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">How Much Does Netherlands Certificate Attestation Cost in UAE?</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Cost depends on several factors:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {feeFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ CHALLENGES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start;" class="two-col">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What to Watch For</p>
        <h2 style="font-size:1.8rem;font-weight:900;color:#1A202C;margin:0 0 14px;">What are the Common Reasons for Rejections?</h2>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:24px;">
          Rejection usually happens due to small mistakes. Many people are not aware of these issues. We check every detail before submitting your document for Dutch document attestation. This reduces risk and saves time.
        </p>
        <div style="position:relative;border-radius:16px;overflow:hidden;box-shadow:0 12px 32px rgba(0,0,0,0.1);">
          <img
            src="/images/img-40.webp"
            alt="Common rejection mistakes in Netherlands document attestation"
            style="width:100%;height:320px;object-fit:cover;display:block;"
          />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
          <div style="position:absolute;bottom:16px;left:16px;right:16px;">
            <p style="color:#fff;font-size:0.88rem;font-weight:700;margin:0;">Avoid these mistakes for a smooth attestation process</p>
          </div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {challenges.map(c => (
          <div style="display:flex;align-items:center;gap:12px;background:#FFF5F5;border:1px solid #FED7D7;border-radius:10px;padding:12px 16px;">
            <span style="color:#E53E3E;font-weight:bold;font-size:1rem;flex-shrink:0;">!</span>
            <p style="font-size:0.88rem;color:#4B5563;line-height:1.5;margin:0;">{c}</p>
          </div>
        ))}
        <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:10px;padding:14px 16px;margin-top:4px;">
          <p style="font-size:0.85rem;color:#4B5563;line-height:1.6;margin:0;">Sometimes the issuing authority signature does not match ministry records. In such cases, the document goes back for correction. Proper review at the first stage protects your application from delay.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ GET STARTED ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
