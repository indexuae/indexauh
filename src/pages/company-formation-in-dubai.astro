---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+973", label: "BH +973" },
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1", label: "US +1" },
]

const purposes = [
  {
    title: "Access to a Growing Market",
    body: "Dubai offers access to a rapidly growing market and a strategic location that serves as a bridge between the East and West, attracting entrepreneurs seeking to tap into its diverse consumer base.",
  },
  {
    title: "Global Business Hub",
    body: "Dubai's thriving business environment and status as a global business hub provide unmatched opportunities for companies looking to expand their reach across international markets.",
  },
  {
    title: "Tax Efficiency & Asset Protection",
    body: "Setting up a company in Dubai can facilitate tax efficiency and asset protection, contributing to long-term business growth and sustainability in a highly competitive environment.",
  },
  {
    title: "Enhanced Business Credibility",
    body: "A registered business entity in Dubai demonstrates professionalism and commitment, instilling trust in customers, partners, and investors, and building a solid foundation for your brand.",
  },
]

const whyIndex = [
  {
    title: "Expert Guidance",
    body: "Indexauh boasts a team of seasoned professionals well-versed in the intricacies of company formation in Dubai. Our expertise ensures that the process adheres to legal requirements and is smoothly executed.",
  },
  {
    title: "Tailored Solutions",
    body: "Indexauh understands that each business is unique. We offer personalized solutions that cater to the specific needs and preferences of individual clients, ensuring the formation aligns with the business goals and objectives.",
  },
  {
    title: "Comprehensive Services",
    body: "From initial consultations to paperwork, approvals, and licensing, Indexauh offers end-to-end assistance throughout the company formation process. This comprehensive approach streamlines the process and saves clients valuable time and effort.",
  },
  {
    title: "Network and Connections",
    body: "Indexauh has established relationships and networks within the UAE, which can be invaluable during the company formation process. These connections help expedite approvals and smooth interactions with government entities, enabling a quicker setup.",
  },
  {
    title: "Compliance and Regulations",
    body: "Staying compliant with the legal and regulatory framework in Dubai is crucial for business success. Indexauh ensures that all steps involved in company formation adhere to local laws and regulations, reducing the risk of complications or delays.",
  },
  {
    title: "Transparent Process",
    body: "Indexauh maintains transparency throughout the company formation process, keeping clients informed at every stage. Clients receive regular updates and insights, enabling them to make informed decisions regarding their business setup in Dubai.",
  },
]

const faqs = [
  { q: "How can Indexauh help me set up a mainland company in Dubai?", a: "Indexauh manages the entire process of setting up a mainland company in Dubai. This includes business activity selection, document preparation, license application, and government approvals. The team ensures a smooth registration process and compliance with local regulations." },
  { q: "Can Indexauh assist in choosing between Dubai Free Zone and mainland company formation?", a: "Yes. Indexauh evaluates your business goals, market needs, and intended trade activities to recommend the most suitable option. Free Zone companies provide international trade flexibility, while mainland companies allow unrestricted access to the UAE market." },
  { q: "Does Indexauh handle all document preparation for Dubai company registration?", a: "Indexauh prepares all necessary documents, including identity verification, Memorandum of Association, office lease agreements, and trade license applications. This ensures that every submission meets regulatory standards and avoids delays." },
  { q: "How does Indexauh guide clients through Dubai trade license approval and registration?", a: "Indexauh submits applications, communicates with government authorities, and tracks approval status. Clients receive step-by-step support, ensuring that the trade license is obtained efficiently and without unnecessary complications." },
  { q: "Can Indexauh help foreign investors understand 100% ownership rules in Dubai?", a: "Yes. Indexauh explains the sectors and business activities that allow full foreign ownership. The team guides investors through regulatory requirements, ensuring a clear understanding of rights, capital requirements, and compliance obligations." },
  { q: "Does Indexauh provide support for securing a physical office or registered address in Dubai?", a: "Yes. Indexauh assists clients in finding a suitable office or registered address that complies with Dubai regulations. This service ensures that the company meets all legal requirements for registration." },
  { q: "How can Indexauh assist with opening a corporate bank account in Dubai?", a: "Indexauh guides clients in selecting a bank, preparing required documentation, and scheduling appointments. This support helps businesses open accounts that align with their operational and regulatory needs." },
  { q: "Can Indexauh handle PRO services and visa processing after company formation?", a: "Yes. Indexauh offers full PRO services, including visa processing for investors and employees, labor approvals, and government correspondence. This ensures smooth post-registration operations for your Dubai company." },
  { q: "Does Indexauh advise on compliance and ongoing regulatory requirements in Dubai?", a: "Indexauh provides guidance on ongoing compliance such as visa renewals, license renewal, accounting obligations, and audit requirements. This helps companies maintain legal and operational compliance in Dubai." },
  { q: "How does Indexauh help startups and small businesses choose the right company structure in Dubai?", a: "Indexauh evaluates the business plan, goals, and resources to recommend the most appropriate structure, such as LLC, branch, or Free Zone entity. The team also advises on costs, licensing, and procedural steps to simplify the setup process." },
]
---

<BaseLayout
  title="Company formation in Dubai | Business Setup in Dubai"
  description="Set up your business the easy way with Indexauh. With years of experience, we make Company Formation in Dubai simple, guiding you through every step."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .company-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 24px; transition: all 0.25s; }
  .company-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 300px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .three-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-9.webp"
    alt="Company Formation in Dubai"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      COMPANY FORMATION<br/>IN DUBAI
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      Company formation in Dubai is a strategic undertaking that involves establishing a business entity within the bustling economic hub of Dubai, United Arab Emirates. This process requires careful consideration of legal, financial, and administrative aspects to ensure compliance with local regulations and optimize business operations.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ PURPOSE OF COMPANY FORMATION ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Purpose of Company Formation in Dubai</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
        The purpose of initiating a company formation in Dubai is multifaceted. Primarily, it offers access to a rapidly growing market and a strategic location that serves as a bridge between the East and West.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
        Dubai's thriving business environment attracts entrepreneurs seeking to tap into its diverse consumer base and leverage its status as a global business hub. Setting up a company in Dubai can facilitate tax efficiency, asset protection, and enhanced business credibility, contributing to long-term growth and sustainability.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          Company formation in Dubai is a strategic move for businesses aiming to capitalize on the region's economic growth and advantageous business environment. Indexauh's expertise and personalized approach make them a reliable partner in navigating the complex process of establishing a business entity in Dubai.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/uae-flag.webp" alt="Company formation Dubai" style="width:100%;height:440px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Professional Company Formation in Dubai</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">End-to-end support by Index Office Services</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          2500+ Companies Formed
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ PURPOSE CARDS ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-41.webp" alt="Purpose of company formation Dubai" style="width:100%;height:220px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Key Purposes</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Why Company Formation in Dubai Matters</h2>
      </div>
    </div>

    <div class="two-col" style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
      {purposes.map(c => (
        <div class="company-card">
          <h3 style="font-size:0.92rem;font-weight:800;color:#1A202C;margin:0 0 10px;border-left:3px solid #38B2AC;padding-left:10px;">{c.title}</h3>
          <p style="font-size:0.98rem;color:#4B5563;line-height:1.7;margin:0;">{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE INDEX ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
        <img src="/images/img-3.webp" alt="Index Office Services team" style="width:100%;height:340px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">Index Office Services</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">25+ Years · UAE & GCC Experts</p>
        </div>
      </div>
      <div>
        <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Why Choose Us</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.2;margin:0 0 16px;">Benefits of Choosing Indexauh for Company Formation in Dubai</h2>
        <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin-bottom:16px;">
          Selecting the right partner for company formation is essential for a seamless experience and long-term success. Indexauh offers a range of benefits for entrepreneurs and businesses looking to establish themselves in Dubai.
        </p>
        <p style="color:#94A3B8;font-size:1rem;line-height:1.8;">
          Indexauh's expertise and personalized approach make them a reliable partner in navigating the complex process of establishing a business entity in Dubai, ultimately setting the foundation for a successful venture.
        </p>
      </div>
    </div>

    <!-- Why Index benefit cards -->
    <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:52px;">
      {whyIndex.map(b => (
        <div class="benefit-card">
          <h3 style="font-size:0.92rem;font-weight:800;color:#fff;margin:0 0 8px;border-bottom:1px solid rgba(56,178,172,0.3);padding-bottom:8px;">{b.title}</h3>
          <p style="font-size:0.9rem;color:#CBD5E0;line-height:1.65;margin:0;">{b.body}</p>
        </div>
      ))}
    </div>

    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:28px;margin-bottom:52px;">
      <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin:0 0 12px;">
        Company formation in Dubai is a strategic move for businesses aiming to capitalize on the region's economic growth and advantageous business environment.
      </p>
      <p style="color:#94A3B8;font-size:1rem;line-height:1.8;margin:0;">
        Indexauh's expertise and personalized approach make them a reliable partner in navigating the complex process of establishing a business entity in Dubai, ultimately setting the foundation for a successful venture.
      </p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:40px;text-align:center;border-top:1px solid rgba(255,255,255,0.1);padding-top:48px;">
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">2500</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Companies Formed</p>
      </div>
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">25</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Years of Experience</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ FAQ ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:820px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Got Questions?</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0;">FREQUENTLY ASKED QUESTIONS</h2>
      <p style="color:#4B5563;font-size:1.05rem;margin-top:12px;">Dubai Business Setup FAQs</p>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;">
      {faqs.map((f, i) => (
        <div class="faq-item">
          <button class="faq-q">
            <span>{i + 1}. {f.q}</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-a">
            <p style="color:#4B5563;font-size:0.875rem;line-height:1.75;margin:0;">{f.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════ GET IN TOUCH ════════════ -->
<section id="get-in-touch" style="background:#2D3748;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:600px;height:300px;background:radial-gradient(ellipse,rgba(56,178,172,0.12) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;gap:52px;align-items:flex-start;">

    <div style="flex:1;min-width:280px;">
      <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Free Consultation</p>
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.25;margin:0 0 18px;">Contact Us</h2>
      <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin-bottom:28px;">
        If you require immediate assistance, you can also reach us using the contact numbers provided.
      </p>
      <a href="tel:+971529300200" style="display:inline-flex;align-items:center;gap:10px;background:#38B2AC;color:#fff;font-weight:900;font-size:0.95rem;padding:14px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        CALL NOW: (+971) 529 300 200
      </a>
    </div>

    <div style="flex:1;min-width:280px;background:#fff;border-radius:22px;padding:36px;box-shadow:0 20px 60px rgba(0,0,0,0.2);">
      <h3 style="font-size:1.2rem;font-weight:700;color:#1A202C;margin:0 0 22px;">Free Consultation</h3>
      <ContactForm />
    </div>

  </div>
</section>

<script>
(function(){
  document.querySelectorAll('.faq-item').forEach(item => {
    item.querySelector('.faq-q')?.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(x => {
        x.classList.remove('open');
        (x.querySelector('.faq-a') as HTMLElement).classList.remove('open');
      });
      if (!isOpen) {
        item.classList.add('open');
        (item.querySelector('.faq-a') as HTMLElement).classList.add('open');
      }
    });
  });
})();
</script>

</BaseLayout>