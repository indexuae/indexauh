  "Memorandum of Association",
  "Articles of Association",
  "Company incorporation documents",
  "Board resolutions",
  "Commercial invoices",
  "Agreements and contracts",
]

const processSteps = [
  { title: "Document Verification & Pre Check", desc: "Your document is reviewed carefully to confirm it is genuine and ready for the next stage." },
  { title: "Apostille Notary Process When Required", desc: "Some documents need notarization before they can move forward in the apostille process." },
  { title: "Submission to the Competent Authority", desc: "The document is submitted to the authority responsible for issuing the apostille." },
  { title: "Apostille Issuance", desc: "The competent authority issues the apostille certificate for your document." },
  { title: "Final Quality Check & Safe Delivery", desc: "We carry out a final check before your apostilled document is delivered safely." },
]

const timingFactors = [
  "The country where the document was issued",
  "The type of document",
  "Whether notary or additional verification is required",
