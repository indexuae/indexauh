  "Skipping mandatory notary attestation",
  "Applying for apostille when full attestation is actually required",
  "Using old or damaged certificates",
  "Missing passport copies or incorrect personal details",
]

const whyChoose = [
  "Over 25 years of experience in Attestation services",
  "Complete end to end notary and apostille services handling",
  "Clear guidance at every stage",
  "Secure document processing",
  "Support for individuals and businesses",
  "Strong coordination with local and international authorities",
