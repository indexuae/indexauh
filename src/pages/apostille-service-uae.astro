const apostilleCountries = {
  "Europe": ["Albania","Andorra","Austria","Belarus","Belgium","Netherlands","Czech Republic","Denmark","Estonia","Finland","France","Georgia","Germany","Greece","Hungary","Iceland","Ireland","Italy","Liechtenstein","Lithuania","Portugal","Spain","Switzerland","United Kingdom"],
  "Central and South America": ["Antigua and Barbuda","Argentina","Bahamas","Barbados","Belize","Bolivia","Brazil","Chile","Colombia","Costa Rica","Dominica","Dominican Republic","Ecuador","El Salvador","Guatemala","Guyana","Honduras","Mexico","Nicaragua","Panama","Paraguay","Peru","Saint Kitts and Nevis"],
  "Asia and Middle East": ["Armenia","Azerbaijan","Bahrain","Bangladesh","Brunei","China Hong Kong","China Macao","India","Indonesia","Israel","Japan","Kazakhstan","Kyrgyzstan","Oman","Pakistan","Philippines","Saudi Arabia","Singapore","South Korea","Turkey","Uzbekistan"],
  "Oceania": ["Australia","Fiji","Marshall Islands","New Zealand","Samoa","Tonga","Vanuatu"],
  "Africa": ["Botswana","Burundi","Cape Verde","Eswatini","Liberia","Malawi","Mauritius","Morocco","Namibia","Sao Tome and Principe","Seychelles","South Africa","Tunisia"],
  "North America": ["Canada","United States of America"],
}
---

<BaseLayout
  title="Apostille Services in UAE | Indexauh"
  description="Need Apostille services in Dubai? IndexAUH offers trusted apostille, notary and document attestation services with 25+ years experience."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-list-item { background: #fff; border: 1px solid #eef0f6; border-radius: 12px; padding: 16px 20px; display: flex; align-items: flex-start; gap: 14px; transition: all 0.2s; }
  .step-list-item:hover { border-color: #B2F5EA; box-shadow: 0 8px 20px rgba(56,178,172,0.06); }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  .country-pill { background: #F0FFFE; border: 1px solid #B2F5EA; color: #1A202C; font-size: 0.82rem; font-weight: 600; padding: 7px 14px; border-radius: 9999px; }

  .split-grid { display: grid !important; }
  .two-col { display: grid !important; }
  .three-col { display: grid !important; }

  @media(max-width:768px){
    .about-hero-title { font-size: 2rem !important; }
    .about-hero-desc { font-size: 0.88rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .three-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Apostille Service in UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.88) 0%,rgba(45,55,72,0.82) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="about-hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      APOSTILLE SERVICE<br/>IN THE UAE
    </h1>
    <p class="about-hero-desc" style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:640px;">
      Need an Apostille service in the UAE and not sure where to start? Index Office Services supports individuals and businesses with complete Apostille Services in UAE, handled the right way from the first step. With over 25 years of experience, our role is simple — to make sure your documents are accepted without delays or complications.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW — WHEN IS APOSTILLE REQUIRED ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">When Is Apostille Required?</h2>

      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
        An Apostille is an official confirmation placed on a document to prove it is genuine. This confirmation allows the document to be accepted in another country. Many countries follow an international system called the Hague Apostille system. Under this system, documents issued in one member country can be used in another member country after the apostille.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:18px;">
        An Apostille service helps prepare and submit your documents correctly so they are approved without delay. Some countries accept apostille alone. Other countries need additional document attestation services. IndexAUH helps you understand the correct process and handles everything for you.
      </p>

      <p style="color:#2D3748;font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px;">People usually need apostille for:</p>
      <div style="display:flex;flex-direction:column;gap:8px;">
        {whoNeeds.map(item => (
          <div style="display:flex;align-items:flex-start;gap:12px;background:#F0FFFE;border:1px solid #B2F5EA;border-radius:10px;padding:10px 14px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:1px;">✓</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">{item}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-1.webp" alt="Apostille service UAE" style="width:100%;height:380px;object-fit:cover;" />
        <div style="position:absolute;bottom:20px;left:-16px;background:#2D3748;color:#fff;padding:12px 18px;border-radius:12px;font-size:0.9rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          Verified Globally
        </div>
      </div>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;margin-top:24px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 8px;">What Documents Are Required for an Apostille?</h3>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.7;margin:0 0 10px;">To apply for an apostille, authorities need to verify that the document truly belongs to you and was officially issued. You usually need:</p>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {requiredDocs.map(d => (
            <div style="display:flex;align-items:center;gap:8px;font-size:0.85rem;color:#1A202C;">
              <span style="color:#38B2AC;font-weight:bold;">•</span>{d}
            </div>
          ))}
        </div>
        <p style="color:#4B5563;font-size:0.82rem;line-height:1.6;margin:10px 0 0;">Some documents may need additional support papers based on the issuing country or purpose. Our team reviews everything in advance so you submit only what is required.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ PROCESS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-6.webp" alt="Apostille process UAE" style="width:100%;height:240px;object-fit:cover;object-position:center 40%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.85) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:460px;line-height:1.25;">How Does the Apostille Process Work?</h2>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:52px;">
      {processSteps.map((s, idx) => (
        <div class="step-list-item">
          <span style="font-weight:900;color:#38B2AC;font-size:1rem;margin-top:2px;">{String(idx + 1).padStart(2, '0')}</span>
          <div>
            <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
            <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
      <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">How Long Does Apostille Processing Take?</h3>
      <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Processing time depends on three main factors:</p>
      <div style="display:flex;flex-direction:column;gap:9px;margin-bottom:14px;">
        {timingFactors.map(f => (
          <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
            <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
          </div>
        ))}
      </div>
      <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">Some apostille cases are completed in a few working days. Others may take longer due to government review timelines. At IndexAUH, we give you a realistic timeline after reviewing your documents. We do not give vague promises. You know what to expect from the start.</p>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.8fr 1fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-7.webp" alt="Apostille document types UAE" style="width:100%;height:360px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">All Document Types Covered</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Personal · Educational · Commercial</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Document Coverage</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 16px;">Types of Documents That Require Apostille</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;">Index Office Services handles apostille for personal, educational, and commercial documents — every category managed carefully to ensure smooth verification.</p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;" class="three-col">
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;box-shadow:0 10px 30px rgba(0,0,0,0.02);">
        <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 16px;display:flex;align-items:center;gap:10px;">
          <span style="color:#38B2AC;font-size:1.3rem;">👤</span> Personal Documents
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          {personalDocs.map(d => (
            <li style="font-size:0.95rem;color:#4B5563;display:flex;align-items:center;gap:8px;">
              <span style="color:#38B2AC;font-weight:bold;">•</span> {d}
            </li>
          ))}
        </ul>
      </div>

      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;box-shadow:0 10px 30px rgba(0,0,0,0.02);">
        <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 16px;display:flex;align-items:center;gap:10px;">
          <span style="color:#38B2AC;font-size:1.3rem;">🎓</span> Educational Documents
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          {educationalDocs.map(d => (
            <li style="font-size:0.95rem;color:#4B5563;display:flex;align-items:center;gap:8px;">
              <span style="color:#38B2AC;font-weight:bold;">•</span> {d}
            </li>
          ))}
        </ul>
      </div>

      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;box-shadow:0 10px 30px rgba(0,0,0,0.02);">
        <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 16px;display:flex;align-items:center;gap:10px;">
          <span style="color:#38B2AC;font-size:1.3rem;">🏢</span> Commercial & Business
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          {commercialDocs.map(d => (
            <li style="font-size:0.95rem;color:#4B5563;display:flex;align-items:center;gap:8px;">
              <span style="color:#38B2AC;font-weight:bold;">•</span> {d}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ════ COUNTRIES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;max-width:820px;margin-left:auto;margin-right:auto;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Hague Convention Members</p>
      <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Which Countries Require Apostille of Documents?</h2>
      <p style="color:#4B5563;font-size:0.95rem;line-height:1.8;margin:0;">
        The Hague Apostille system was introduced to make international document use easier and safer. In 1961, countries signed the Hague Convention and agreed on one standard method to verify public documents, known as Apostille. Member countries accept documents issued by other member countries without extra embassy or ministry verification. Below is the complete list of countries where apostille documents are accepted.
      </p>
    </div>

    <div style="display:flex;flex-direction:column;gap:28px;">
      {Object.entries(apostilleCountries).map(([region, countries]) => (
        <div>
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 12px;border-left:3px solid #38B2AC;padding-left:12px;">{region}</h3>
          <div style="display:flex;flex-wrap:wrap;gap:8px;">
            {countries.map(c => (
              <span class="country-pill">{c}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ E-APOSTILLE & TRANSLATION ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;" class="two-col">
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:28px;">
        <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 12px;border-left:3px solid #38B2AC;padding-left:12px;">What Is an Electronic Apostille?</h3>
        <p style="font-size:0.88rem;color:#4B5563;line-height:1.7;margin:0 0 12px;">Electronic Apostille, also called e Apostille, is a digital version of the apostille certificate. A physical stamp is replaced with a secure digital record, and authorities in some countries can verify the apostille online.</p>
        <p style="font-size:0.82rem;font-weight:700;color:#2D3748;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 10px;">E Apostille is useful when:</p>
        <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:14px;">
          {eApostilleUses.map(u => (
            <div style="display:flex;align-items:center;gap:8px;font-size:0.88rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;">•</span>{u}
            </div>
          ))}
        </div>
        <p style="font-size:0.82rem;color:#6B7280;line-height:1.6;margin:0;">Physical apostille is still needed for many countries. IndexAUH checks which option is correct for your case and manages the right process.</p>
      </div>

