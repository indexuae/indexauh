---

<BaseLayout title="Commercial Document Attestation in UAE — Index Office Services" description="Expert Commercial Document Attestation services in UAE. MOFA, Embassy, and Chamber of Commerce attestation for all business documents.">

<style>
  .sec-inner { position: relative; z-index: 1; }

  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }

  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }

  .step-card { display: flex; align-items: flex-start; gap: 18px; padding: 20px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }

  .check-item { display: flex; align-items: flex-start; gap: 10px; padding: 12px 16px; background: #fff; border: 1px solid #e0e7ef; border-radius: 10px; font-size: 0.85rem; color: #1A202C; font-weight: 500; }

  .warning-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px; background: #FFF5F5; border: 1px solid #FEB2B2; border-radius: 10px; font-size: 0.82rem; color: #9B2C2C; font-weight: 500; }

  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 200px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

@media(max-width:768px){
  .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
  .hero-title { font-size: 2rem !important; }
  .docs-cat-grid { grid-template-columns: 1fr !important; }
  .time-cost-grid { grid-template-columns: 1fr !important; }
  .why-us-grid { grid-template-columns: 1fr !important; }
  .rejection-grid { grid-template-columns: 1fr !important; }
  .stats-grid { grid-template-columns: 1fr !important; gap: 24px !important; }
  div[style*="position:sticky"] { position: static !important; }
  section { padding-left: 16px !important; padding-right: 16px !important; }
  .offices-flex { flex-direction: column !important; }
}
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <img
    src="/images/img-11.webp"
    alt="Commercial Document Attestation UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.9) 0%,rgba(45,55,72,0.82) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">MOFA Attestation</span>
      <span class="idx-pill">Embassy Attestation</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">100+ Countries</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      COMMERCIAL DOCUMENT<br/>ATTESTATION IN UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:640px;">
      Commercial Document Attestation is the process of legalizing your business documents so they can be accepted by UAE authorities. Government departments, banks, free zones, and courts ask for this verification before they approve your business activities.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

 <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Why Do You Need Commercial Document Attestation?</h2>

      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Business documents from another country are not automatically valid in the UAE. Authorities must confirm that the documents are real and properly issued before approving your business activities.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        When you plan to open a branch office, register a company, sign an international contract, or clear goods through customs, you will need Commercial Document Attestation. This confirms that your documents are genuine and issued by the right authority in your home country.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        With over 25+ years of experience in the UAE, IndexAUH handles complete Commercial Document Attestation services for companies of all sizes. Our team understands embassy rules, chamber procedures, and UAE ministry requirements.
      </p>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;margin-top:24px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">What is Commercial Document Attestation?</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          Commercial Document Attestation is the process of legalizing your business documents so they can be accepted by UAE authorities. It protects your business from rejection, delays, and legal issues — ensuring smooth approval from government offices.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-1.webp" alt="Commercial document attestation" style="width:100%;height:400px;object-fit:cover;" />
        <div style="position:absolute;bottom:20px;left:-16px;background:#2D3748;color:#fff;padding:12px 18px;border-radius:12px;font-size:0.9rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHEN YOU NEED + DOCUMENTS WE ASSIST ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1.6fr;gap:52px;align-items:center;margin-bottom:52px;" class="split-grid">
      <!-- Left image -->
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.1);">
        <img src="/images/img-7.webp" alt="Business document legalization UAE" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.6) 100%);"></div>
        <div style="position:absolute;bottom:18px;left:18px;right:18px;">
          <p style="color:#fff;font-size:0.98rem;font-weight:700;margin:0;line-height:1.4;">Corporate · Trade · Legal · Financial Documents</p>
        </div>
      </div>
      <!-- Right text -->
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">When You Need It</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 16px;">Commercial Documents We Assist With</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">Many companies also need a commercial invoice attested by the chamber of commerce for international trade. Customs departments often ask for this before clearing shipments. Below are the main document categories we handle.</p>
<div class="docs-cat-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start;">
  <!-- Left: Corporate Structure -->
  <div style="background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:18px;">
    <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 12px;border-left:3px solid #38B2AC;padding-left:10px;">Corporate Structure</h3>
    <div style="display:flex;flex-direction:column;gap:7px;">
      {corporateDocs.map(d => (
        <div style="display:flex;align-items:center;gap:7px;font-size:0.9rem;color:#4B5563;">
          <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">✔</span>{d}
        </div>
      ))}
    </div>
  </div>
  <!-- Right: Financial + Trade + Legal stacked -->
  <div style="display:flex;flex-direction:column;gap:14px;">
    <div style="background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:16px;">
      <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 10px;border-left:3px solid #38B2AC;padding-left:10px;">Financial & Banking</h3>
      <div style="display:flex;flex-direction:column;gap:6px;">
        {financialDocs.map(d => (
          <div style="display:flex;align-items:center;gap:7px;font-size:0.9rem;color:#4B5563;">
            <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">✔</span>{d}
          </div>
        ))}
      </div>
    </div>
    <div style="background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:16px;">
      <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 10px;border-left:3px solid #38B2AC;padding-left:10px;">Trade & Export</h3>
      <div style="display:flex;flex-direction:column;gap:6px;">
        {tradeDocs.map(d => (
          <div style="display:flex;align-items:center;gap:7px;font-size:0.9rem;color:#4B5563;">
            <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">✔</span>{d}
          </div>
        ))}
      </div>
    </div>
    <div style="background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:16px;">
      <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 10px;border-left:3px solid #38B2AC;padding-left:10px;">Legal & Authorization</h3>
      <div style="display:flex;flex-direction:column;gap:6px;">
        {legalDocs.map(d => (
          <div style="display:flex;align-items:center;gap:7px;font-size:0.9rem;color:#4B5563;">
            <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">✔</span>{d}
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
    </div>
  </div>
</section>

<!-- ════ STEP BY STEP PROCESS ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Authentication Workflow</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">Commercial Document Attestation Process in UAE</h2>
      <p style="color:#6B7280;font-size:1.05rem;max-width:560px;margin:0 auto;">Commercial Document Attestation involves multiple verification levels. The process depends on where the document was issued and how it will be used.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;" class="split-grid">
      <div style="display:flex;flex-direction:column;gap:14px;">
        {steps.map(s => (
          <div class="step-card">
            <div style="width:40px;height:40px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="position:sticky;top:100px;">
        <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.12);">
          <img src="/images/img-16.webp" alt="Commercial document authentication process" style="width:100%;height:520px;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(26,32,44,0.75) 100%);"></div>
          <div style="position:absolute;bottom:20px;left:20px;right:20px;">
            <p style="color:#fff;font-size:1rem;font-weight:800;margin:0 0 4px;">6-Step Verified Process</p>
            <p style="color:#B2F5EA;font-size:0.9rem;margin:0;">From notarization to UAE MOFA final approval</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENTS THAT REQUIRE + EMIRATES COVERAGE ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <!-- Top image banner -->
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-2.webp" alt="UAE business skyline" style="width:100%;height:240px;object-fit:cover;object-position:center 40%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.85) 0%,rgba(26,32,44,0.45) 60%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Nationwide Coverage</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:480px;line-height:1.25;">Commercial Attestation Across All Emirates</h2>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:52px;" class="split-grid">
      <!-- When attestation needed -->
      <div>
        <h3 style="font-size:1.3rem;font-weight:900;color:#1A202C;margin-bottom:16px;">Documents That Require Commercial Attestation</h3>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:20px;">
          Many business activities require document legalization. Companies often approach us for Commercial Document Attestation when expanding operations to UAE, appointing a local sponsor or agent, signing joint venture agreements, registering products with authorities, opening warehouse facilities, or participating in exhibitions or trade events.
        </p>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:20px;">
          You may need commercial certificate attestation for:
        </p>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {whyNeedAttestation.map(item => (
            <div style="display:flex;align-items:center;gap:8px;font-size:1rem;color:#1A202C;background:#fff;border:1px solid #e0e7ef;padding:10px 14px;border-radius:8px;font-weight:500;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{item}
            </div>
          ))}
        </div>
      </div>

