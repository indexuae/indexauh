<script>
(function(){
  const tabs = document.querySelectorAll('#procTabs .tab-btn');
  const panelIds = Array.from(tabs).map(t => (t as HTMLElement).dataset.tab);
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const target = (tab as HTMLElement).dataset.tab;
      panelIds.forEach(id => {
        const el = document.getElementById('tab-' + id) as HTMLElement;
        if (el) el.style.display = id === target ? 'grid' : 'none';
      });
    });
  });
})();
</script>

