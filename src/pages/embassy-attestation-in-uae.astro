---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const heroPills = ["25+ Years Experience","All Document Types","Embassy & MOFA Approved","UAE Compliance Experts"]

const whoNeeds = [
  "Professionals moving to the UAE for work",
  "Students applying for education or equivalency",
  "Married couples applying for family visas",
  "Parents sponsoring children",
  "Business owners submitting commercial documents",
  "Companies expanding operations in the UAE",
]

const whyRequired = [
  { title:"Employment and Work Visas" },
  { title:"Residence and Family Sponsorship" },
  { title:"Education and Equivalency Approvals" },
  { title:"Business and Legal Activities" },
  { title:"Government and Immigration Submissions" },
]

const serviceCategories = [
  { title:"Personal Documents Attestation", image:"/images/img-16.webp", items:["Birth certificate attestation","Marriage certificate attestation","Divorce certificate attestation","Death certificate attestation","Police Clearance Certificate Attestation UAE","Medical Certificate Attestation","Affidavits and declarations"] },
  { title:"Educational Certificate Attestation", image:"/images/img-52.webp", items:["Degree certificate attestation","Diploma certificate attestation","Master's and PhD certificates","Academic transcripts","School leaving certificates"] },
  { title:"Commercial Documents Attestation", image:"/images/img-1.webp", items:["Power of Attorney","Memorandum and Articles of Association","Board resolutions","Commercial invoices","Company registration documents","Business agreements"] },
]

const generalProcedure = [
  { num:"01", title:"Local Verification or Notarization", desc:"This may involve Notary Public verification, solicitor certification, local government authentication, or issuing authority verification, confirming the document is genuine and legally valid at the initial level." },
  { num:"02", title:"Regional, State, or Relevant Department Authentication", desc:"The document is submitted to the responsible authority within the issuing country, such as education departments, home or civil departments, chambers of commerce, or state authorities." },
  { num:"03", title:"National Foreign Affairs Authentication", desc:"The document moves to the national foreign affairs authority, such as the Ministry of Foreign Affairs, Ministry of External Affairs, Department of Foreign Affairs, or Foreign Office." },
  { num:"04", title:"UAE Embassy or UAE Consulate Attestation", desc:"The document is submitted to the UAE Embassy or UAE Consulate in the issuing country, where UAE authorities verify the previous attestations." },
  { num:"05", title:"MOFA Attestation in the UAE", desc:"The final step is attestation from the UAE Ministry of Foreign Affairs, confirming official acceptance of the document inside the UAE." },
]

const indiaProcedure = [
  { num:"01", title:"Document Verification in India", desc:"The document is first checked for clarity, originality, and issuing authority details to ensure it is eligible for attestation." },
  { num:"02", title:"State Level Attestation in India", desc:"Educational documents go to the education department of the issuing state, and personal documents go to the home department." },
  { num:"03", title:"MEA Attestation in India", desc:"After state approval, the document is submitted to the Ministry of External Affairs in India for national level authentication." },
  { num:"04", title:"UAE Embassy Attestation in India", desc:"Once MEA approval is completed, the document is submitted to the UAE Embassy in India, which verifies and stamps it for use in the UAE." },
  { num:"05", title:"MOFA Attestation in the UAE", desc:"After reaching the UAE, the document is submitted to the Ministry of Foreign Affairs, confirming acceptance by UAE authorities." },
]

const procedureTabs = [
  { key:"general", label:"General Procedure", steps: generalProcedure },
  { key:"india", label:"Procedure for India", steps: indiaProcedure },
]

const feeFactors = ["Type of document","Country where the document was issued","Embassy charges","MOFA requirements","Processing urgency"]
const timeFactors = ["Document category","Embassy workload","Required verification steps","MOFA approval timelines"]

const digitalCapabilities = ["Online submission","QR code verification","Digitally signed approvals","Status tracking through official portals"]
const digitalBenefits = ["Faster processing","Less physical paperwork","Reduced risk of document loss","Fraud prevention via QR verification","Greater transparency","Environment friendly system"]

const mistakes = ["Submitting laminated documents","Skipping required prior attestations","Choosing the wrong authority","Incorrect document order","Incomplete supporting papers"]

const gettingStarted = [
  { num:"01", title:"Contact Us", desc:"Reach out to Index office and services by phone, email, or our website. Tell us about your documents and what you need." },
  { num:"02", title:"Share Your Documents", desc:"Send copies or details of your documents. We check they are complete and ready for attestation." },
  { num:"03", title:"We Plan the Attestation Route", desc:"We decide the correct steps for your document, including notarization, state or home department verification, embassy attestation, and MOFA approval." },
  { num:"04", title:"Embassy and MOFA Coordination", desc:"We submit your documents and follow up with the UAE embassy and MOFA. You get updates at every stage." },
  { num:"05", title:"Get Your Attested Documents", desc:"Your documents are returned to you fully stamped and ready for use in the UAE, for work, study, family visas, or business." },
  { num:"06", title:"Ongoing Support", desc:"We continue to help after the documents are delivered. You can ask questions and get advice for future attestations." },
]

const whyUs = [
  { icon:"🎯", label:"Clear guidance." },
  { icon:"📋", label:"Correct documentation flow." },
  { icon:"🇦🇪", label:"UAE compliance knowledge." },
  { icon:"🔒", label:"Secure handling of certificates." },
  { icon:"🤝", label:"Dedicated support from start to finish." },
]

const faqs = [
  { q:"Do all UAE visas require embassy attestation?", a:"Embassy attestation is mainly required for employment, family sponsorship, and higher studies. Tourist and short visit visas usually do not need it. The requirement connects to the purpose of your document in the UAE." },
  { q:"How should you proceed after a document rejection?", a:"Most rejections happen due to missing stamps or incorrect formatting. Correct the issue first, then submit the document again for approval. A careful review before submission helps avoid repeat problems." },
  { q:"Why does the issuing country affect the process?", a:"Each country follows its own verification pattern before the UAE Embassy stamp. Authorities check documents based on their origin, which is why the steps vary from one country to another." },
  { q:"Are unclear or damaged certificates accepted for attestation?", a:"Authorities expect clean and readable documents. Torn edges, faded prints, or overwritten details often lead to rejection. Submitting a fresh and clear copy improves approval chances." },
  { q:"For which type of stay is embassy attestation commonly required?", a:"Long term residence, employment, and legal procedures usually require attestation. Short visits for tourism rarely need this process." },
  { q:"Which business documents usually need embassy attestation?", a:"Power of Attorney, board resolutions, and company agreements often require attestation before business setup or expansion in the UAE. Authorities verify these papers carefully." },
  { q:"At what stage should the attestation process begin?", a:"Start early in your planning stage. Visa processing and official approvals take time. Early preparation reduces stress and keeps everything on track." },
  { q:"How does expert support make the process easier?", a:"Attestation rules differ across countries. Expert guidance ensures every step is completed correctly, preventing delays and unnecessary rejection." },
]

const embassyCountries = [
  { name: "Spain", href: "/spain-embassy-attestation/" },
  { name: "Qatar", href: "/qatar-embassy-attestation-in-uae/" },
  { name: "Oman", href: "/oman-embassy-attestation/" },
  { name: "Saudi Arabia", href: "/saudi-embassy-attestation/" },
  { name: "Kuwait", href: "/kuwait-embassy-attestation/" },
  { name: "Bahrain", href: "/bahrain-embassy-attestation/" },
  { name: "Portugal", href: "/portugal-embassy-attestation/" },
  { name: "Morocco", href: "/morocco-embassy-attestation/" },
  { name: "Canada", href: "/canada-embassy-attestation/" },
  { name: "Greece", href: "/greece-embassy-attestation/" },
  { name: "Finland", href: "/finland-embassy-attestation/" },
  { name: "Turkey", href: "/turkish-embassy-attestation-in-uae/" },
  { name: "India", href: "/indian-embassy-attestation/" },
  { name: "Philippines", href: "/philippines-embassy-attestation-in-uae/" },
]
---

<BaseLayout title="Embassy Attestation in UAE | Attestation Services UAE"
description="Embassy attestation in UAE by Index Office and Services with 25 years of experience. Trusted support for all documents. Call now."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }

  .step-card { display:flex; align-items:flex-start; gap:18px; padding:24px; background:#fff; border:1px solid #eef0f6; border-radius:16px; transition:all 0.25s; }
  .step-card:hover { border-color:#B2F5EA; box-shadow:0 12px 32px rgba(56,178,172,0.1); transform:translateY(-3px); }

  .purpose-card { padding:24px; background:#fff; border:1px solid #eef0f6; border-radius:16px; transition:all 0.25s; }
  .purpose-card:hover { border-color:#B2F5EA; box-shadow:0 12px 32px rgba(56,178,172,0.1); transform:translateY(-3px); }

  .why-card { background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:14px; padding:22px; display:flex; align-items:flex-start; gap:14px; transition:background 0.2s; }
  .why-card:hover { background:rgba(255,255,255,0.14); }

  .tab-btn { padding:9px 22px; border-radius:9999px; font-size:0.83rem; font-weight:600; cursor:pointer; border:none; transition:all 0.2s; }
  .tab-btn.active { background:#2D3748; color:#fff; }
  .tab-btn:not(.active) { background:#F0FFFE; color:#2D3748; border:1px solid #B2F5EA; }

  .fact-item { display:flex; align-items:center; gap:8px; padding:10px 14px; background:#fff; border:1px solid #e0e7ef; border-radius:10px; font-size:0.98rem; color:#1A202C; font-weight:500; }
  .fact-check { width:20px; height:20px; border-radius:50%; background:#38B2AC; display:flex; align-items:center; justify-content:center; flex-shrink:0; }

  .faq-item { border:1px solid #eef0f6; border-radius:14px; padding:6px 22px; background:#fff; transition:border-color 0.2s; }
  .faq-item:hover { border-color:#B2F5EA; }
  .faq-item summary { padding:16px 0; cursor:pointer; font-weight:700; color:#1A202C; font-size:1rem; list-style:none; display:flex; justify-content:space-between; align-items:center; gap:12px; }
  .faq-item summary::-webkit-details-marker { display:none; }
  .faq-item summary::after { content:"+"; font-size:1.4rem; font-weight:400; color:#38B2AC; flex-shrink:0; transition:transform 0.2s; }
  .faq-item[open] summary::after { transform:rotate(45deg); }
  .faq-item p { color:#4B5563; font-size:0.98rem; line-height:1.75; margin:0 0 18px; }

  .idx-form input,.idx-form select,.idx-form textarea { width:100%; border:1px solid #e5e7eb; border-radius:10px; padding:11px 14px; font-size:1rem; color:#374151; outline:none; font-family:inherit; background:#fff; box-sizing:border-box; }
  .idx-form input:focus,.idx-form select:focus,.idx-form textarea:focus { border-color:#38B2AC; box-shadow:0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize:none; }
  .idx-submit { width:100%; background:#2D3748; color:#fff; font-weight:700; padding:13px; border-radius:10px; border:none; cursor:pointer; font-size:0.95rem; letter-spacing:0.04em; transition:background 0.2s; }
  .idx-submit:hover { background:#1A202C; }

@media(max-width:900px){
  .hero-grid { flex-direction:column !important; }
  .two-col { flex-direction:column !important; }
  .two-col > div { width:100% !important; box-sizing:border-box; }
}
 @media(max-width:640px){
    .steps-grid, .purpose-grid, .facts-grid { grid-template-columns:1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Embassy Attestation UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.86) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;justify-content:center;">
      {heroPills.map(p => <span class="idx-pill">{p}</span>)}
    </div>
    <p style="color:#38B2AC;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;font-size:0.75rem;margin:0 0 14px;">Attestation Services</p>
    <h1 style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      Embassy Attestation<br/>in <span style="color:#38B2AC;">UAE</span>
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 16px;max-width:640px;">
      Embassy attestation in UAE confirms that a document issued in another country is genuine and acceptable for use in the UAE — required before visas, employment, education, family sponsorship, or business activities are approved.
    </p>
    <p style="color:#94A3B8;font-size:1.05rem;line-height:1.8;margin:0 auto 32px;max-width:600px;">
      With over 25+ years of experience, Index Office and Services handles the process clearly and correctly from the start, so your documents move without confusion.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:40px;">
      <a href="tel:+971529300200" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        (+971) 529 300 200
      </a>
      <a href="#contact" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">
        Start Attestation &rarr;
      </a>
    </div>
    <div style="display:flex;gap:32px;justify-content:center;flex-wrap:wrap;">
      <div style="text-align:center;">
        <p style="font-size:1.8rem;font-weight:900;color:#38B2AC;margin:0;">25+</p>
        <p style="color:#81E6D9;font-size:0.75rem;margin:2px 0 0;font-weight:500;">Years of Experience</p>
      </div>
      <div style="width:1px;background:rgba(255,255,255,0.15);"></div>
      <div style="text-align:center;">
        <p style="font-size:1.8rem;font-weight:900;color:#38B2AC;margin:0;">3</p>
        <p style="color:#81E6D9;font-size:0.75rem;margin:2px 0 0;font-weight:500;">Document Categories Covered</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:-60px;right:-60px;width:400px;height:360px;background:radial-gradient(ellipse,rgba(56,178,172,0.08) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="two-col" style="display:flex;gap:52px;align-items:center;flex-wrap:wrap;">

      <div style="flex-shrink:0;width:420px;">
        <div style="position:relative;border-radius:20px;overflow:hidden;height:380px;">
          <img src="/images/uae-flag.webp" alt="Embassy attestation UAE" style="width:100%;height:100%;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(to bottom,transparent 45%,rgba(26,32,44,0.72));"></div>
          <div style="position:absolute;bottom:24px;left:24px;right:24px;">
            <p style="color:#81E6D9;font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 6px;">Legally Recognised</p>
            <p style="color:#fff;font-size:0.95rem;font-weight:700;margin:0;">Full legalization chain handled end-to-end</p>
          </div>
        </div>
      </div>

      <div style="flex:1;min-width:280px;">
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;"><span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Overview</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What is Embassy Attestation?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:14px;">Many people struggle with this process because every document follows a fixed order and embassy rules are strict. A small mistake can delay the entire application.</p>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:20px;">Index office and services helps. Our team understands embassy requirements, document flow, and UAE compliance rules, so your documents move without confusion.</p>
        <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:16px 20px;">
          <p style="color:#1A202C;font-size:1rem;font-weight:600;margin:0 0 4px;">Index Office and Services</p>
          <p style="color:#4B5563;font-size:0.98rem;line-height:1.7;margin:0;">Over 25+ years of experience in the UAE attestation field, handled clearly and correctly from the start.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ════ WHO NEEDS IT ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:400px;background:radial-gradient(ellipse,rgba(56,178,172,0.07) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;">
    <div class="two-col" style="display:flex;gap:52px;align-items:center;flex-wrap:wrap;">

      <div style="flex:1;min-width:280px;">
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;"><span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Who It's For</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.1rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 16px;">Who Needs UAE Embassy Attestation?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">Embassy attestation in UAE is required for many people and businesses, including:</p>
        <div class="facts-grid" style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;">
          {whoNeeds.map(item => (
            <div class="fact-item">
              <span class="fact-check">
                <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" width="10" height="10"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              {item}
            </div>
          ))}
        </div>
      </div>

      <div style="flex-shrink:0;width:380px;">
        <img src="/images/img-7.webp" alt="People who need UAE embassy attestation" style="width:100%;height:320px;object-fit:cover;border-radius:20px;box-shadow:0 12px 40px rgba(0,0,0,0.12);" />
      </div>

    </div>
  </div>
</section>

<!-- ════ WHY REQUIRED ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Why It Matters</p>
      <h2 style="font-size:2.1rem;font-weight:900;color:#1A202C;margin:0;">Why Embassy Attestation Is Required in the UAE?</h2>
      <p style="color:#6B7280;font-size:1.02rem;margin:14px auto 0;max-width:680px;">UAE authorities will not approve foreign documents unless they are properly verified. Embassy attestation proves that your certificate is real and approved by official authorities. This requirement applies to:</p>
    </div>
    <div class="purpose-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;">
      {whyRequired.map(p => (
        <div class="purpose-card" style="text-align:center;">
          <p style="font-size:1rem;font-weight:700;color:#1A202C;margin:0;">{p.title}</p>
        </div>
      ))}
    </div>
    <p style="color:#6B7280;font-size:0.95rem;text-align:center;margin:28px 0 0;">Without embassy attestation, documents are rejected even when they are original.</p>
  </div>
</section>

<!-- ════ SERVICES WE PROVIDE ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What We Cover</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">UAE Embassy Attestation Services We Provide</h2>
      <p style="color:#6B7280;font-size:1.02rem;max-width:680px;margin:0 auto;">IndexAUH offers complete UAE embassy attestation services for all document categories.</p>
    </div>
    <div class="purpose-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;">
      {serviceCategories.map(s => (
        <div class="purpose-card" style="padding:0;overflow:hidden;">
          <img src={s.image} alt={s.title} style="width:100%;height:150px;object-fit:cover;display:block;" />
          <div style="padding:22px;">
            <p style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 14px;">{s.title}</p>
            <ul style="margin:0;padding-left:18px;color:#6B7280;font-size:0.92rem;line-height:1.85;">
              {s.items.map(i => <li>{i}</li>)}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ PROCEDURE TABS ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
