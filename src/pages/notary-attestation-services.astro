---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+973", label: "BH +973" },
  { code: "+91",  label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44",  label: "GB +44" },
  { code: "+1",   label: "US +1" },
]

const ourServices = [
  "Immigration Document Attestation (Canada – United Kingdom – Australia – Dominica, etc)",
  "Certified True Copy Attestation services (Passport, utility bills, tenancy contracts etc)",
  "Property Sale & Purchase Document Drafting & Legalization",
  "Wills Drafting & Wills attestation",
  "Legal consultation",
  "Arbitration",
  "Company incorporation",
  "Construction claims consultancy",
  "Dispute resolution",
  "Litigation and Counseling",
  "Business formation",
  "Contracts, Agreement, Memorandum of Understanding, Memorandum of association, and Legal drafting",
]

const willTypes = [
  "Guardianship Will — for children under 21",
  "Property Will — for up to five UAE properties",
  "Business Owners Will — for up to five free zone and offshore firm shares",
  "Financial Assets Will — up to 10 bank or brokerage accounts",
  "Full Will — covers all types of assets",
]
---

<BaseLayout
  title="Notary Attestation Services UAE | Certified True Copy Attestation UAE"
  description="Index provides best assistance for Notary Attestation Services or Certified True Copy Attestation UAE. Fast and Secure, Call Now"
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .svc-arrow-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px 20px; display: flex; align-items: flex-start; gap: 12px; transition: all 0.25s; }
  .svc-arrow-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .box-card { background: #fff; border: 1px solid #eef0f6; border-radius: 20px; padding: 32px; transition: all 0.25s; }
  .box-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Notary Assistance UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      NOTARY ASSISTANCE<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      Notary public applications include memorandum of association, power of attorney, contracts &amp; agreements, declarations, acknowledgements, and local service agent contracts. Index makes it simple to prepare and notarize all documents through the UAE Judicial Department portal in a very short amount of time.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
    </div>
  </div>
</section>

<!-- ════ NOTARY ASSISTANCE ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 0.9fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>What We Do
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Notary Assistance</h2>
      <p style="color:#4B5563;font-size:0.95rem;line-height:1.8;margin:0 0 16px;">
        In order to achieve this, our special services, which include all online notary public applications, make it simpler for you to draft a special power of attorney and a general power of attorney. Writing, translating, and notarizing a memorandum of association, articles of association, or local service agency contract are additional requirements for forming a company. Our team of experts is ready to help you.
      </p>
      <p style="color:#4B5563;font-size:0.95rem;line-height:1.8;margin:0;">
        In order to make it simple for all clients to prepare and notarize all of their documents in a very short amount of time, Index has developed its specialization in providing all notary public services through the portal of the Judicial Department and other governmental entities in the UAE.
      </p>
    </div>

    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
      <img src="/images/img-55.webp" alt="Notary Assistance UAE" style="width:100%;height:400px;object-fit:cover;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
      <div style="position:absolute;bottom:20px;left:20px;right:20px;">
        <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Professional Notary Public Assistance</p>
        <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">POA · Company Docs · Attestation · Wills</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ OUR SERVICES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-41.webp" alt="Notary document services UAE" style="width:100%;height:220px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">What We Cover</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">OUR SERVICES</h2>
      </div>
    </div>

    <p style="color:#4B5563;font-size:0.95rem;line-height:1.8;margin:0 0 28px;">We provide legal services at the highest professional level, capable of rendering effective solutions mainly in the following areas:</p>

    <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
      {ourServices.map(item => (
        <div class="svc-arrow-card">
          <span style="color:#38B2AC;font-weight:900;font-size:1rem;flex-shrink:0;margin-top:2px;">→</span>
          <p style="font-size:0.9rem;color:#4B5563;line-height:1.65;margin:0;">{item}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ CERTIFIED TRUE COPY ATTESTATION ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:0.9fr 1.4fr;gap:52px;align-items:center;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
      <img src="/images/img-8.webp" alt="Certified True Copy Attestation UAE" style="width:100%;height:440px;object-fit:cover;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
      <div style="position:absolute;bottom:20px;left:20px;right:20px;">
        <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Certified True Copy Attestation</p>
        <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Passports · Certificates · Business Docs</p>
      </div>
    </div>
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Document Attestation</p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">CERTIFIED TRUE COPY ATTESTATION</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0 0 16px;">
        Document legalization and verification are becoming more and more necessary for a variety of foreign documents when used internationally. Any company or any individual may need document authentication, legalization, and certification services in connection with a business agreement, the registration of a certificate or degree, establishing residency, or any other transactions in a foreign country.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0 0 16px;">
        We offer consultation on expediting Certified true copy attestation and Notary services in UAE for business and personal documents. Certificate, diploma, transcripts attestation. We ensure our service that each document attested meets the internationally specified requirements. Certification and legalization of documents for international use could be a painful and time-consuming process, and a lot of wastage of money if it is not done in the correct manner.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">CERTIFIED TRUE COPY OF PASSPORTS</h3>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.75;margin:0;">
          Copies of passports are very significant personal documents that require certification and legality. The certified true copy attestation is approved to confirm the originality of a document. We offer one of the fast and reliable Passport true copy attestations in UAE — same day and same time service available.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ════ CREDIT CARD SETTLEMENT ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.4fr 0.9fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Debt Services
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">CREDIT CARD SETTLEMENT</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0 0 16px;">
        Index is aware that individuals who are mired in credit card debt or other types of bank debt require debt counseling and expert assistance in order to settle their debts amicably with banks and prevent legal action, a travel ban, and adverse effects on their credit score. As a result, Index has established a dedicated department to assist all bank and credit card creditors in paying off their obligations and leading debt-free lives.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0 0 16px;">
        Each client's financial situation and needs are assessed by the debt reduction specialists at Index. Debtors can acquire debt-free counsel by getting the penal interest, delay charges, legal fees, and other charges waived off under the direction of Index's bank debt negotiation experts.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0;">
        We provide debt consolidation, repayment modification, and settlement negotiation services. We also assist debtors returning to the UAE who are facing legal action or police cases in successfully resolving cheque bounce situations with the police, criminal court, or civil cases.
      </p>
    </div>
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
      <img src="/images/img-7.webp" alt="Credit Card Settlement UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
      <div style="position:absolute;bottom:20px;left:20px;right:20px;">
        <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Credit Card &amp; Debt Settlement</p>
        <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Expert negotiation with banks on your behalf</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ DEBT COLLECTION ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:0.9fr 1.4fr;gap:52px;align-items:center;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
      <img src="/images/img-55.webp" alt="Debt Collection UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
      <div style="position:absolute;bottom:20px;left:20px;right:20px;">
        <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Debt Collection Services</p>
        <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Cost-effective · AI-powered · Legal expertise</p>
      </div>
    </div>
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Recovery Services</p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">DEBT COLLECTION</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0 0 16px;">
        Debt collection is a cost-effective way to settle a debt before taking legal action. The legal debt recovery process through courts takes time, costs a lot of money, and permanently damages the connection between the business and the defaulter. Therefore, debt collection, rather than starting with legal action, is the preferable course of action.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0 0 16px;">
        After assessing the debtors' reputations in the market, the debt amount involved, the age of the debts, and commercial documents, our skilled team ensures to streamline the current collection procedure. Index leverages cutting-edge automation technologies, artificial intelligence, and other innovations to improve the efficiency of debt collection services while strictly adhering to the law.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0;">
        Before sending legal letters created by our own legal experts, our debt collection service first makes pleasant reminder calls to the defaulters. Index's debt solution specialists assist clients in turning all bad debts into credits without resorting to expensive legal action, enabling them to proceed with better cash flow.
      </p>
    </div>
  </div>
</section>

<!-- ════ WILLS & PROBATES + CHEQUE BOUNCING ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner two-col" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:32px;">

    <div class="box-card">
      <h2 style="font-size:1.3rem;font-weight:900;color:#1A202C;border-left:4px solid #38B2AC;padding-left:14px;margin:0 0 18px;">WILLS &amp; PROBATES</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0 0 14px;">
        One of the most popular services we offer in the UAE is wills and probate. Numerous expats have already received will registration services from our specialists, who hold a DIFC WPR license. It is crucial to get a properly designed will registered, especially when you are abroad. Our team of professionals will help you create and register your will, or start the probate process, whether it is a Mainland Will or a DIFC Will.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0 0 14px;">There are five different will types to choose from depending on your needs:</p>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;">
        {willTypes.map(item => (
          <li style="display:flex;align-items:flex-start;gap:10px;font-size:0.88rem;color:#4B5563;line-height:1.65;">
            <span style="color:#38B2AC;font-weight:900;flex-shrink:0;">→</span>{item}
          </li>
        ))}
      </ul>
    </div>

    <div class="box-card">
      <h2 style="font-size:1.3rem;font-weight:900;color:#1A202C;border-left:4px solid #38B2AC;padding-left:14px;margin:0 0 18px;">CHEQUE BOUNCING</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0 0 14px;">
        Cheque bounce problems, complaints, and litigation are seen as long-term problems by people in the UAE. It is regarded as a crime and carries potentially serious and intimidating legal repercussions and penalties. Cheque bounce issues can arise in a number of circumstances, including private and personal transactions, business transactions, purchases, real estate rentals, bank loans, and so on.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin:0;">
        As well as offering helpful guidance on all issues and outcomes, we can assist you in situations where a cheque bounces. We offer guidance and support to businesses, organizations, banks, financial institutions, and private citizens. We create the ideal strategies and consistently make the necessary advancements to resolve your cheque bounce issues efficiently.
      </p>
    </div>

  </div>
</section>

<!-- ════ WHY CHOOSE US ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;">
