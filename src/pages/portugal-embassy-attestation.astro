---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whenNeeded = [
  { title: "Employment and Work Purposes", desc: "Attested educational or professional documents are required during job offers, work visa processing, and professional licensing." },
  { title: "Education and Higher Studies", desc: "Universities and training institutes ask for verified academic records before granting admission." },
  { title: "Immigration and Residency", desc: "Personal documents are needed when applying for residence permits or family visas." },
  { title: "Family and Legal Matters", desc: "Marriage, birth, and other personal certificates must be validated for legal acceptance." },
  { title: "Business and Commercial Use", desc: "Companies expanding operations or signing agreements may need verified commercial documents." },
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Birth Certificate Attestation in Portugal",
      "Marriage Certificate Attestation in Portugal",
      "Divorce Certificate Attestation",
      "Death Certificate Attestation",
      "Transfer Certificate Attestation",
      "Medical Certificate Attestation",
      "Police Clearance Certificate PCC from Portugal",
      "Affidavit Attestation",
      "Experience Certificate Attestation",
      "Single Status Certificate",
      "Passport copy attestation",
    ],
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Degree Certificate Attestation for Portugal",
      "Diploma Certificate Attestation",
      "Master Degree Certificate Attestation",
      "Engineering Degree Certificate Attestation",
      "Nursing Degree Certificate Attestation",
      "Professional Qualification Certificate Attestation",
      "Academic Transcripts Attestation",
      "Mark Sheets Attestation",
      "School Leaving Certificate Attestation",
      "Provisional Certificate Attestation",
    ],
  },
  {
    category: "Commercial Documents",
    icon: "⚖️",
    docs: [
      "Memorandum of Association (MOA)",
      "Articles of Association (AOA)",
      "Certificate of Incorporation",
      "Commercial License Attestation",
      "Board Resolution Attestation",
      "Power of Attorney for business use",
      "Commercial Invoice Attestation",
      "Company Profile Attestation",
      "Shareholder Resolution",
      "Partnership Deed Attestation",
    ],
  },
]

const processRoutes = [
  {
    step: "01",
    title: "Documents Issued in the UAE — Used in Portugal",
    steps: [
      "Verification from the issuing authority in the UAE",
      "Authentication from relevant UAE departments",
      "Attestation by the UAE Ministry of Foreign Affairs",
      "Legalization through the Portuguese embassy",
    ],
    notes: [
      "Documents must be original and clearly readable",
      "Some certificates may require supporting documents",
      "Commercial documents may need chamber of commerce approval",
      "Processing time varies based on document type",
    ],
  },
  {
    step: "02",
    title: "Documents Issued in Portugal — Used in the UAE",
    steps: [
      "Verification from competent authorities in Portugal",
      "Legalization through official Portuguese government channels",
      "Embassy level authentication",
      "Mandatory MOFA attestation for legal acceptance in the UAE",
    ],
    notes: [
      "Certain documents require prior registration",
      "Certified translation may be required before UAE submission",
      "Educational and personal documents follow different procedures",
    ],
  },
  {
    step: "03",
    title: "Documents Used in Other Countries",
    steps: [
      "Authorities check the destination country's document acceptance rules",
      "Some countries accept apostille",
      "Other countries require embassy legalization",
      "The correct process must be followed based on document usage",
    ],
    notes: [
      "Choosing the wrong method often leads to rejection or delays",
      "Understanding the destination requirement is important before starting",
    ],
  },
]

const timingFactors = [
  "Type of document",
  "Country of issuance",
  "Embassy workload",
  "Ministry approvals",
  "Translation requirements",
  "Completeness of documents",
]

const feeFactors = [
  "Document category",
  "Country of issue",
  "Number of certificates",
  "Embassy charges",
  "Ministry approvals",
  "Urgency of service",
]

const challenges = [
  { title: "Incorrect Document Format", desc: "Using an incorrect document format that does not meet authority standards." },
  { title: "Missing Stamps or Signatures", desc: "Missing official stamps or signatures on certificates can cause immediate rejection." },
  { title: "Poor Quality Copies", desc: "Submitting unclear or poor quality copies is one of the most common causes of delay." },
  { title: "Wrong Authority", desc: "Approaching the wrong authority for verification restarts the entire process." },
  { title: "Apostille vs Embassy Confusion", desc: "Portugal follows different legalization rules depending on usage. Choosing the wrong method leads to rejection." },
  { title: "Translation Requirements", desc: "Certain documents must be submitted in a specific language with certified legal translation completed first." },
]

const getStartedSteps = [
  { step: "01", title: "Connect with IndexAUH", desc: "Share your document details and intended country of use with our specialists." },
  { step: "02", title: "Document Assessment", desc: "We review the document type, origin, and legalization requirement." },
  { step: "03", title: "Process Planning", desc: "Our team identifies the correct approval route and estimated timeline." },
  { step: "04", title: "Embassy and Authority Handling", desc: "We manage submissions, follow ups, and approvals with the Portuguese embassy Abu Dhabi and UAE authorities." },
  { step: "05", title: "Secure Document Return", desc: "Once completed, documents are returned safely to you." },
]

const whyChoose = [
  { title: "25+ Years of Experience", desc: "More than 25 years of experience in certificate attestation and document legalization in the UAE." },
  { title: "Expert Embassy Knowledge", desc: "Strong knowledge of embassy procedures, MOFA requirements, and country specific rules." },
  { title: "Reduce Delays & Resubmissions", desc: "Helps reduce delays, re-submissions, and unnecessary complications with proper document review." },
  { title: "Trusted by Thousands", desc: "Trusted by thousands of clients across the UAE for accurate and smooth attestation." },
  { title: "Free Pickup & Delivery", desc: "Free document pickup and delivery for added convenience across the UAE." },
  { title: "Full Process Management", desc: "Full assistance across all stages with clear communication and regular updates throughout." },
]

const faqs = [
  { q: "Is embassy attestation mandatory for UAE use?", a: "Yes. UAE authorities require legalized documents for official acceptance. Without proper attestation, documents will not be accepted by government departments." },
  { q: "Do Portugal issued documents need UAE approval?", a: "Yes. Final approval from the UAE Ministry of Foreign Affairs is required for any document issued in Portugal to be used in the UAE." },
  { q: "Can apostille be used instead of embassy attestation?", a: "This depends on the destination country and purpose of the document. Our team confirms the correct method before starting the process to avoid rejection." },
  { q: "Is there a Portuguese Embassy in Dubai?", a: "Many people search for the Portuguese Embassy in Dubai, but embassy legalization services are officially managed through the Embassy of Portugal in Abu Dhabi. Understanding this avoids delays and incorrect submissions." },
  { q: "Do you handle attestation for other countries?", a: "Yes. IndexAUH manages document legalization for over 100 countries. Contact our team for guidance on your specific country requirements." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Portugal Embassy Attestation Services in UAE | Indexauh"
  description="Portugal Embassy Attestation in UAE with 25+ years’ experience. Fast, accurate document legalization via Portuguese Embassy Abu Dhabi. Contact IndexAUH today."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .route-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; }
  .route-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .five-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .five-col { grid-template-columns: 1fr !important; }
    .img-first { order: -1 !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Portugal Embassy Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Portugal Attestation</span>
      <span class="idx-pill">Embassy Attestation</span>
      <span class="idx-pill">25 Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      PORTUGAL EMBASSY ATTESTATION<br/>SERVICES IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      When documents need to be used between Portugal and the UAE, authorities ask for official verification. This confirms that a certificate is genuine and legally accepted for government and institutional use. IndexAUH provides complete support for Portugal-related embassy attestation across the UAE. With over 25 years of experience, we understand embassy procedures, document requirements, and approval timelines.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-btns">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW / WHO NEEDS IT ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Who Needs Portugal Embassy Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:18px;">
        People approach us for this service in many situations. Our team manages the entire process so clients do not have to deal with multiple offices or unclear instructions.
      </p>
      <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:18px;">
        {whenNeeded.map(item => (
          <div style="display:flex;align-items:flex-start;gap:12px;background:#F8FAFF;border:1px solid #eef0f6;border-radius:12px;padding:12px 16px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:2px;">→</span>
            <div>
              <p style="font-size:0.88rem;font-weight:700;color:#1A202C;margin:0 0 2px;">{item.title}</p>
              <p style="font-size:0.83rem;color:#6B7280;line-height:1.5;margin:0;">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/portugal-flag.webp" alt="Portugal embassy attestation UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Portuguese Embassy Abu Dhabi · UAE MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Portugal attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Documents That Can Be Attested for Portugal"
  description="We handle attestation for a wide range of document categories across personal, educational, and commercial needs."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Portugal attestation"
  docTypes={docTypes}
  country="portugal"
/>

<!-- ════ PROCESS ROUTES ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Portugal attestation process routes" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Portugal Embassy Attestation Process</h2>
      </div>
    </div>

    <p style="color:#4B5563;font-size:0.95rem;line-height:1.8;margin:0 0 36px;text-align:center;max-width:760px;margin-left:auto;margin-right:auto;">
      The embassy attestation process depends on two factors: where the document was issued and where it will be used. Based on this, authorities follow a specific legalization route to confirm document authenticity.
    </p>

    <div style="display:flex;flex-direction:column;gap:24px;">
      {processRoutes.map(route => (
        <div class="route-card">
          <div>
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
              <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{route.step}</div>
              <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0;">{route.title}</h3>
            </div>
            <div style="flex:1;">
              <div style="display:flex;flex-direction:column;gap:16px;">
                <div>
                  <p style="font-size:0.78rem;font-weight:700;color:#38B2AC;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 10px;">Step by Step Process</p>
                  <div style="display:flex;flex-direction:column;gap:8px;">
                    {route.steps.map((s, idx) => (
                      <div style="display:flex;align-items:flex-start;gap:10px;">
                        <span style="background:#F0FFFE;border:1px solid #B2F5EA;color:#2D3748;font-weight:800;font-size:0.72rem;width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;">{idx + 1}</span>
                        <p style="font-size:0.88rem;color:#4B5563;line-height:1.5;margin:0;">{s}</p>
                      </div>
                    ))}
                  </div>
                </div>
                <div>
                  <p style="font-size:0.78rem;font-weight:700;color:#E53E3E;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 10px;">Important Points</p>
                  <div style="display:flex;flex-direction:column;gap:8px;">
                    {route.notes.map(n => (
                      <div style="display:flex;align-items:flex-start;gap:10px;background:#FFF5F5;border:1px solid #FED7D7;border-radius:8px;padding:8px 10px;">
                        <span style="color:#E53E3E;font-weight:bold;font-size:0.9rem;flex-shrink:0;">!</span>
                        <p style="font-size:0.85rem;color:#4B5563;line-height:1.5;margin:0;">{n}</p>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Embassy Note -->
    <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:28px;margin-top:32px;">
      <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Portuguese Embassy Locations — Important Clarification</h3>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;" class="three-col">
        <div style="background:#F8FAFF;border-radius:10px;padding:16px;">
          <p style="font-size:0.88rem;font-weight:700;color:#1A202C;margin:0 0 6px;">Embassy of Portugal — Abu Dhabi</p>
          <p style="font-size:0.83rem;color:#6B7280;line-height:1.6;margin:0;">The Embassy of Portugal in Abu Dhabi handles official legalization matters for documents related to the UAE.</p>
        </div>
        <div style="background:#F8FAFF;border-radius:10px;padding:16px;">
          <p style="font-size:0.88rem;font-weight:700;color:#1A202C;margin:0 0 6px;">Portuguese Embassy Dubai</p>
          <p style="font-size:0.83rem;color:#6B7280;line-height:1.6;margin:0;">Many people search for the Portuguese Embassy in Dubai, but embassy legalization services are officially managed through Abu Dhabi.</p>
        </div>
        <div style="background:#FFF5F5;border:1px solid #FED7D7;border-radius:10px;padding:16px;">
          <p style="font-size:0.88rem;font-weight:700;color:#E53E3E;margin:0 0 6px;">! Avoid This Mistake</p>
          <p style="font-size:0.83rem;color:#6B7280;line-height:1.6;margin:0;">There is no separate legalization authority in Dubai for Portugal. Understanding this avoids delays and incorrect submissions.</p>
        </div>
      </div>
    </div>

    <!-- Timing & Fees -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px;" class="two-col">
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Portugal Attestation Processing Time</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Processing time varies based on document type and authority involvement. What affects the timeline:</p>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {timingFactors.map(f => (
            <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
            </div>
          ))}
        </div>
        <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">IndexAUH reviews timelines in advance and keeps clients informed at every stage.</p>
      </div>
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Portugal Embassy Attestation Fees</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">The cost of attestation depends on several practical factors:</p>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {feeFactors.map(f => (
            <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
            </div>
          ))}
        </div>
        <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">Exact charges are shared after document review. Our team explains the cost clearly before starting the process.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ CHALLENGES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;" class="two-col">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What to Watch For</p>
