---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1",  label: "US +1" },
  { code: "+973", label: "BH +973" },
]

const purposes = [
  { icon: "🛂", title: "Visa & Immigration", desc: "Many countries require attested documents for visa and immigration purposes to verify the authenticity of the applicant's credentials." },
  { icon: "💼", title: "Employment Abroad", desc: "Employers in foreign countries demand attested educational and professional documents to verify qualifications and experience of job applicants." },
  { icon: "🎓", title: "Higher Education", desc: "Students seeking admission to universities abroad need to submit attested educational documents recognized by the institution." },
  { icon: "🏢", title: "Business & Commerce", desc: "International business transactions may require attested documents to establish credibility of company registrations, agreements, and financial statements." },
  { icon: "👪", title: "Family & Personal", desc: "Personal milestones such as marriage, birth registration, or family visa applications require properly attested civil documents." },
  { icon: "📋", title: "Legal Proceedings", desc: "Affidavits, power of attorney, and other legal documents used abroad must be attested to be legally recognized by foreign authorities." },
]

const docTypes = [
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Degree certificate attestation in India",
      "Mark sheet attestation",
      "Diploma certificate attestation",
      "Academic transcripts attestation",
      "School leaving certificate attestation",
      "Engineering degree certificate attestation",
      "Nursing degree certificate attestation",
    ]
  },
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Birth certificate attestation in India",
      "Marriage certificate attestation in India",
      "Death certificate attestation in India",
      "Divorce certificate attestation in India",
      "Affidavit attestation",
      "Police Clearance Certificate (PCC)",
      "Medical certificate attestation",
    ]
  },
  {
    category: "Commercial Documents",
    icon: "🏢",
    docs: [
      "Company registration attestation",
      "Memorandum of Association (MOA)",
      "Articles of Association (AOA)",
      "Power of Attorney attestation",
      "Commercial invoice attestation",
      "Certificate of Origin attestation",
      "Board Resolutions",
    ]
  },
]

const steps = [
  { step: "01", title: "Notary Attestation", desc: "The document is notarized by a notary public to authenticate its content and signature as the first step of the attestation process." },
  { step: "02", title: "Home Department Authentication", desc: "The document is submitted to the respective State Home Department or General Administration Department for state-level authentication." },
  { step: "03", title: "Ministry of External Affairs (MEA) Attestation", desc: "After state-level authentication, the document is sent to the MEA for further attestation. The MEA verifies the signature and seal of the state authorities." },
  { step: "04", title: "Embassy or Consulate Attestation", desc: "The document is submitted to the embassy or consulate of the concerned country in India. They verify the MEA stamp and authenticate the document for use abroad." },
  { step: "05", title: "Delivery of Attested Documents", desc: "Once all attestation steps are completed, your attested documents are securely delivered to you and are ready for use in the destination country." },
]

const benefits = [
  { title: "25+ Years of Experience", desc: "Index has a strong track record with over 25 years of experience in certificate attestation, ensuring a smooth and efficient process." },
  { title: "Branches in 9+ Countries", desc: "With branches in more than 9 countries, Index has a global presence to provide comprehensive support for attestation requirements worldwide." },
  { title: "Native Professionals", desc: "Our native professionals have years of industry experience and deep knowledge of local processes, regulations, and language for accurate document handling." },
  { title: "24/7 Customer Support", desc: "Index offers round-the-clock customer support, ensuring prompt responses to your queries and concerns at any time during the attestation process." },
  { title: "Affordable & Customized", desc: "We provide cost-effective services without compromising on quality, with customized solutions tailored to your specific attestation requirements." },
  { title: "End-to-End Processing", desc: "We handle the complete attestation process from start to finish, coordinating with all relevant authorities to avoid delays and document rejections." },
]

const timingFactors = [
  "Type of document — educational, personal, or commercial",
  "Workload of the state and central authorities involved",
  "Specific requirements of the destination country",
  "Educational certificates generally take longer than personal documents",
  "Incomplete paperwork or incorrect formats can cause delays",
  "Whether embassy or consulate has a backlog at the time of submission",
]

const faqs = [
  { q: "How long does certificate attestation in India take?", a: "The duration can vary depending on the type of document, the workload of the authorities involved, and the specific requirements of the destination country. Generally, the attestation process can take anywhere from a few days to a few weeks. Index can help expedite the process." },
  { q: "What is the process for certificate attestation in India?", a: "The process involves four main steps: Notary attestation, Home Department authentication at the state level, Ministry of External Affairs (MEA) attestation at the national level, and finally Embassy or Consulate attestation for use in the destination country." },
  { q: "What types of documents can be attested in India?", a: "Educational documents (degrees, mark sheets, diplomas, transcripts), personal documents (birth, marriage, death, divorce certificates, affidavits), and commercial documents (company registrations, MOA, AOA, power of attorney) can all be attested in India." },
  { q: "Can attestation be done without visiting the offices in person?", a: "Yes. Index manages the complete attestation process on your behalf. Documents can be sent securely through courier or direct submission. Our team handles all coordination with the relevant authorities without you needing to visit multiple offices." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Indian Certificate Attestation in UAE | Indian Documents Attestation"
  description="Get Indian Certificate Attestation in UAE with Indexauh. Embassy-approved experts handle education, marriage, and birth certificate attestations."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .purpose-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; transition: all 0.25s; }
  .purpose-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-26.webp"
    alt="Certificate Attestation in India"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 12px;">
      CERTIFICATE ATTESTATION IN INDIA
    </h1>
    <p style="color:#38B2AC;font-size:1.05rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 20px;">MEA Attestation | Embassy Attestation | Degree & Personal Document Attestation | 25 Years of Trust</p>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Certificate attestation in India is the process of verifying the authenticity of documents issued in India for use in a foreign country. It involves obtaining an official stamp or signature from designated authorities to certify that the documents are genuine and meet the requirements of the destination country.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is Certificate Attestation in India?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Certificate attestation in India is the official process of verifying the authenticity and validity of documents issued in India so they can be legally used in a foreign country. It involves obtaining an official stamp or signature from designated authorities to certify that the documents are genuine.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        This process ensures that the documents are legally recognized and accepted abroad. The attestation process in India involves multiple levels of verification — from state authorities to the Ministry of External Affairs (MEA), and finally to the embassy or consulate of the destination country.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:20px;">
        Attested documents from India are commonly required for employment visas, residence permits, higher education admissions, family sponsorship, and international business transactions.
      </p>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Key Insight — Multi-Level Authentication Required</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          Certificate attestation in India requires authentication at multiple levels: notary, state Home Department, MEA, and finally the embassy of the destination country. Each step is mandatory and must be completed in order. Skipping any step can result in rejection of the documents abroad.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/india-flag.webp" alt="Certificate attestation India" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Notary · Home Dept · MEA · Embassy</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete India attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25 Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY IS ATTESTATION REQUIRED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-8.webp" alt="Why certificate attestation India is required" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Why India Attestation Matters</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Visa · Work · Education · Business</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Core Reasons</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Why Is Certificate Attestation Required?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          Certificate attestation from India is required to provide assurance to foreign authorities regarding the authenticity of your credentials. Without proper attestation, documents issued in India are not legally recognized abroad and may lead to visa rejections, employment denials, or admission refusals.
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          {purposes.map(p => (
            <div class="purpose-card">
              <div style="font-size:1.6rem;margin-bottom:10px;">{p.icon}</div>
              <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 6px;">{p.title}</h3>
              <p style="font-size:0.76rem;color:#4B5563;line-height:1.55;margin:0;">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Types of Documents Permitted for Attestation"
  description="Index handles certificate attestation in India for educational, personal, and commercial documents. Our team confirms the correct attestation path for each document type before processing begins to avoid delays or rejection by foreign authorities."
  imageSrc="/images/img-16.webp"
  imageAlt="Document types for India attestation"
  docTypes={docTypes}
  country="india"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="India attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">How to Get Certificate Attestation in India?</h2>
      </div>
    </div>

    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;">
      <div style="display:flex;flex-direction:column;gap:14px;">
        {steps.map(s => (
          <div class="step-card">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div>
        <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.12);margin-bottom:24px;">
          <img src="/images/img-1.webp" alt="India attestation timing" style="width:100%;height:260px;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.78) 100%);"></div>
          <div style="position:absolute;bottom:18px;left:18px;right:18px;">
            <p style="color:#fff;font-size:1.05rem;font-weight:800;margin:0 0 3px;">Processing Time Varies by Document</p>
            <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Can range from a few days to a few weeks</p>
          </div>
        </div>

        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;margin-bottom:20px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Factors That Affect Processing Time</h3>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {timingFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.98rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>

        <div style="background:#2D3748;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#fff;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required</h3>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {[
              "Original certificate",
              "Passport copy of the applicant",
              "Authorization letter",
              "Supporting documents based on document type",
            ].map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.98rem;color:#B2F5EA;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">✓</span>{d}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ HOW TO GET STARTED ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-3.webp" alt="Getting started with India attestation" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.78) 100%);"></div>
        <div style="position:absolute;bottom:18px;left:18px;right:18px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Simple 4-Step Process</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Contact · Submit · Process · Receive</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
          <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Getting Started
        </p>
        <h2 style="font-size:clamp(1.6rem,3vw,2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 20px;">How to Get Started with Certificate Attestation in India?</h2>
        <div style="display:flex;flex-direction:column;gap:14px;">
          {[
