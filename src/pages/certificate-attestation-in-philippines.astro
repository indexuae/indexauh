---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1",  label: "US +1" },
  { code: "+973", label: "BH +973" },
]

const purposes = [
  { icon: "💼", title: "Employment Visa Processing", desc: "Employment visas for Philippines require attested educational and professional certificates from the issuing country." },
  { icon: "👪", title: "Family & Dependent Visa", desc: "Family or dependent visa applications require attested personal certificates such as birth and marriage documents." },
  { icon: "🎓", title: "University Admissions", desc: "Higher education institutions in Philippines accept only attested degree certificates and transcripts." },
  { icon: "🪪", title: "Professional Licensing", desc: "Professional licensing bodies in Philippines require attested qualifications before approving practitioners." },
  { icon: "🏢", title: "Business Registration", desc: "Business registration and trade activities in Philippines require legally attested commercial documents." },
  { icon: "🛂", title: "Residence & Migration", desc: "Residence permit and migration applications require fully attested personal and civil status documents." },
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Marriage certificate attestation for Philippines",
      "Birth certificate attestation for Philippines",
      "Divorce certificate attestation for Philippines",
      "Death certificate attestation for Philippines",
      "Transfer certificate attestation",
      "Police Clearance Certificate (PCC)",
      "Medical certificate attestation",
      "Affidavit attestation",
    ]
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Degree attestation for Philippines",
      "School leaving certificates",
      "Diploma certificate attestation for Philippines",
      "Master degree certificate attestation",
      "Engineering degree certificate attestation",
      "Nursing degree certificate attestation",
    ]
  },
  {
    category: "Commercial Documents",
    icon: "🏢",
    docs: [
      "Memorandum of Association (MOA)",
      "Articles of Association (AOA)",
      "Certificate of Incorporation",
      "Commercial License",
      "Power of Attorney",
      "Commercial Invoices",
      "Bills of Lading",
      "Certificates of Origin",
    ]
  },
]

const steps = [
  { step: "01", title: "Initial Verification", desc: "Documents are reviewed for accuracy and format. In some cases, notary attestation or in the issuing country is required as an initial step." },
  { step: "02", title: "State or Department Attestation", desc: "Educational certificates are verified by education authorities. Personal documents are attested by home or administrative departments." },
  { step: "03", title: "Ministry of External Affairs Attestation", desc: "The Ministry of External Affairs authenticates the document at the national level for international use." },
  { step: "04", title: "Philippines Embassy Attestation", desc: "Philippines embassy attestation is a crucial step. The embassy confirms the document for official use in Philippines." },
  { step: "05", title: "Additional Verification (if required)", desc: "Certain cases require further verification after arrival in Philippines, depending on the purpose of use." },
]

const benefits = [
  { title: "25 Years of Experience", desc: "25 years of experience in certificate attestation handling all types of attestation for Philippines with accuracy and compliance." },
  { title: "Complete End-to-End Processing", desc: "We handle the complete document attestation process from start to finish, including coordination with the Philippines Embassy and government agencies." },
  { title: "GCC-Wide Attestation Support", desc: "Attestation support across all GCC countries and the UAE, making cross-border document legalization simple and efficient." },
  { title: "Clear Communication", desc: "Clear communication at every stage so you always know the status of your documents and what comes next." },
  { title: "Secure Document Handling", desc: "Strict confidentiality and secure physical transfer protocols ensure your documents are safe throughout the entire process." },
  { title: "Personalized Packages", desc: "Index provides packages that are customized as per client's request. This way you pay only for the services we provide." },
]

const timingFactors = [
  "Type of document — educational, personal, or commercial",
  "Issuing country of the document",
  "Workload at the relevant attestation authorities",
  "Educational certificates generally take longer than personal documents",
  "Incomplete paperwork or incorrect document formats can cause delays",
  "Whether additional verification is required after arrival in Philippines",
]

const faqs = [
  { q: "Is apostille accepted for Philippines?", a: "No. The Philippines is not a member of the Hague Apostille Convention. Apostille alone is not accepted for use in the Philippines. Philippines embassy attestation is mandatory for all documents intended for official use in the Philippines." },
  { q: "Is certificate attestation mandatory for the Philippines?", a: "Yes, it is mandatory to get certificate attestation for Philippines if you want to use your documents in the Philippines for any reason. You need to get your documents attested by the relevant authorities in your country and then by the Philippine embassy or consulate." },
  { q: "Can marriage certificate attestation for Philippines be done from abroad?", a: "Yes. The Philippines certificate attestation process can be completed remotely through authorized attestation services. Index manages the complete process on your behalf without you needing to travel to the Philippines." },
  { q: "Do commercial documents require chamber verification?", a: "Yes. Many business documents require additional chamber or trade body verification as part of the commercial document attestation process. Our team confirms the exact requirements for your specific commercial documents before starting." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Certificate Attestation for Philippines — Index Office Services"
  description="Complete Philippines certificate attestation services in UAE. Embassy attestation, MOFA attestation, degree and personal document attestation. 25 years of experience."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .purpose-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; transition: all 0.25s; }
  .purpose-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-28.webp"
    alt="Philippines Certificate Attestation"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 12px;">
      PHILIPPINES CERTIFICATE ATTESTATION
    </h1>
    <p style="color:#38B2AC;font-size:1.05rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 20px;">MOFA Attestation | Embassy Attestation | PCC | Degree Certificate Attestation | 25 Years of Trust</p>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Philippines certificate attestation is required when documents need legal acceptance in the Philippines. People moving for employment, family residence, education, or business purposes must complete this process. Attestation confirms that certificates issued in another country are genuine and officially recognized by Philippine authorities.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is Philippines Certificate Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Philippines certificate attestation is the official process of verifying the authenticity and validity of documents so they can be used legally in the Philippines. It confirms that certificates such as educational, personal, and commercial documents are genuine and issued by a competent authority.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        The Philippines is not a member of the Hague Apostille Convention. For this reason, apostille alone is not accepted. Philippines embassy attestation is mandatory for all documents intended for use in the Philippines.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:20px;">
        Attested documents are commonly required for employment visas, residence permits, higher education, family sponsorship, and business-related matters. Attestation for Philippines involves verification from multiple departments, including authorities in the issuing country and the Philippine Embassy.
      </p>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Key Insight — Apostille Not Accepted in Philippines</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          The Philippines is not a Hague Convention member. Apostille alone is not valid for the Philippines. Philippine embassy attestation is mandatory for all documents. Without proper attestation, documents often face rejection during visa or legal procedures.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-29.webp" alt="Philippines document attestation" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">MEA · Philippine Embassy · MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Philippines attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25 Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY IS PHILIPPINES ATTESTATION REQUIRED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-8.webp" alt="Why Philippines attestation is required" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Why Philippines Attestation Matters</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Work · Family · Education · Business</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Core Reasons</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Why Is Attestation Required for Philippines?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          Attestation for Philippines is necessary to prove that your documents are genuine and issued by a competent authority in your country of origin. It ensures that documents are recognized and accepted by the Philippine government and other institutions. Without proper certificate attestation, applications may face delays or rejection.
        </p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px;">
          {purposes.map(p => (
            <div class="purpose-card">
              <div style="font-size:1.6rem;margin-bottom:10px;">{p.icon}</div>
              <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 6px;">{p.title}</h3>
              <p style="font-size:0.76rem;color:#4B5563;line-height:1.55;margin:0;">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Attestation Services For Philippines"
  description="Index provides Philippines certificate attestation services for personal, educational, and commercial documents. Our team confirms the correct attestation path for each document type before processing begins to avoid delays or rejection."
  imageSrc="/images/img-16.webp"
  imageAlt="Document types for Philippines attestation"
  docTypes={docTypes}
  country="philippines"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Philippines attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Philippines Certificate Attestation Procedure</h2>
      </div>
    </div>

    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;">
      <div style="display:flex;flex-direction:column;gap:14px;">
        {steps.map(s => (
          <div class="step-card">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div>
        <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.12);margin-bottom:24px;">
          <img src="/images/img-1.webp" alt="Philippines attestation timing" style="width:100%;height:260px;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.78) 100%);"></div>
          <div style="position:absolute;bottom:18px;left:18px;right:18px;">
            <p style="color:#fff;font-size:1.05rem;font-weight:800;margin:0 0 3px;">Processing Time Varies by Document</p>
            <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Educational certificates take longer than personal documents</p>
          </div>
        </div>

        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;margin-bottom:20px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Factors That Affect Processing Time</h3>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {timingFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.98rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>

        <div style="background:#2D3748;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#fff;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required</h3>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {[
              "Original certificate",
              "Passport copy of the applicant",
              "Authorization letter",
              "Supporting documents based on document type",
            ].map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.98rem;color:#B2F5EA;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">✓</span>{d}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ HOW TO GET STARTED ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-3.webp" alt="Getting started with Philippines attestation" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.78) 100%);"></div>
        <div style="position:absolute;bottom:18px;left:18px;right:18px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Simple 4-Step Process</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Contact · Submit · Process · Receive</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
          <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Getting Started
        </p>
        <h2 style="font-size:clamp(1.6rem,3vw,2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 20px;">How to Get Started with Philippines Certificate Attestation?</h2>
        <div style="display:flex;flex-direction:column;gap:14px;">
          {[
            { step: "01", title: "Contact Index", desc: "Reach out to Index through phone or email. Our team reviews the requirements and provides clear guidance on the attestation process." },
            { step: "02", title: "Share Your Documents", desc: "Documents can be sent securely through courier or direct submission. Our team checks everything before proceeding to avoid any delays." },
            { step: "03", title: "Attestation Process Begins", desc: "We take care of everything, including coordinating with the Philippine Embassy and other relevant government agencies." },
            { step: "04", title: "Receive Your Attested Documents", desc: "Once completed, the attested documents are delivered safely and are ready for use in the Philippines." },
