---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whenNeeded = [
  "Employment visa processing",
  "Family visa sponsorship",
  "Higher education admission",
  "Professional license approval",
  "Company Formation",
  "Court or legal matters",
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Marriage certificate attestation",
      "Birth certificate attestation",
      "Divorce Certificate Attestation",
      "Police Clearance Certificate Attestation",
      "Death Certificate Attestation",
      "Salary Certificate Attestation",
      "Affidavit",
    ],
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Spain Degree Certificate Attestation",
      "Diploma certificate Attestation",
      "PhD Certificate Attestation",
      "Engineering Certificate Attestation",
      "Nursing Certificate Attestation",
      "Medical Certificate Attestation",
      "School Leaving Certificate Attestation",
      "Higher Secondary Certificate Attestation",
    ],
  },
  {
    category: "Commercial Documents",
    icon: "⚖️",
    docs: [
      "Power of Attorney Attestation",
      "Memorandum of Association Attestation",
      "Articles of Association Attestation",
      "Board Resolution Attestation",
      "Certificate of Incorporation Attestation",
      "Commercial Invoice Attestation",
      "Trade License Attestation",
      "Commercial License",
    ],
  },
]

const processSteps = [
  { step: "01", title: "Verification in Spain", desc: "Authorities in Spain confirm the document is genuine. This is the first approval stage." },
  { step: "02", title: "Apostille from Spanish Authority", desc: "Spain is part of the Hague Convention. An apostille confirms international validity. Still, the UAE requires additional legalisation." },
  { step: "03", title: "UAE Embassy Attestation", desc: "The UAE diplomatic mission in Spain verifies the document for use inside the Emirates." },
  { step: "04", title: "MOFA Attestation in UAE", desc: "The Ministry of Foreign Affairs in the UAE gives the final stamp. After this stage, the document becomes legally valid." },
]

const docsRequired = [
  "Original certificate",
  "Passport copy",
  "Visa copy if available",
  "Authorization letter in some cases",
]

const timingFactors = [
  "Type of document",
  "Current authority workload",
  "Translation requirements",
  "Completeness of paperwork",
]

const feeFactors = [
  "Type of document",
  "Number of certificates",
  "Translation requirement",
  "Urgency of processing",
  "Authority fees",
]

const challenges = [
  "Submitting unclear copies",
  "Sending laminated originals",
  "Skipping translation when required",
  "Using incomplete documents",
  "Not confirming employer requirements",
]

const emirates = [
  { name: "Abu Dhabi", desc: "Many government approvals happen in the capital. We coordinate submissions and complete MOFA stamping smoothly." },
  { name: "Dubai", desc: "High demand for employment and business approvals. We assist professionals and companies with complete documentation." },
  { name: "Sharjah", desc: "Family visa and education cases are common here. Our support team manages quick coordination and delivery." },
]

const getStartedSteps = [
  { step: "01", title: "Contact IndexAUH", desc: "Call or send a message. Share a copy of your document." },
  { step: "02", title: "Free Review", desc: "Our team checks requirements and confirms timeline and cost." },
  { step: "03", title: "Secure Collection", desc: "We arrange safe document pickup anywhere in the UAE." },
  { step: "04", title: "Complete Processing", desc: "We manage verification in Spain, embassy approval, and final UAE stamping." },
  { step: "05", title: "Safe Return", desc: "Your completed document is delivered back to you." },
]

const whyChoose = [
  { title: "Fast Document Review", desc: "We review your documents quickly and confirm requirements, timeline, and cost before starting." },
  { title: "Strong Knowledge of Spain Attestation", desc: "Deep expertise in Spain documents attestation rules and every required authority stage." },
  { title: "Dedicated Customer Support", desc: "A dedicated team is assigned to your case and available to answer your queries at every step." },
  { title: "Safe Handling of Originals", desc: "Strict protocols ensure your original documents are handled and tracked securely throughout the process." },
  { title: "No Hidden Charges", desc: "Clear pricing is provided before starting. Proper planning helps avoid extra expenses." },
  { title: "UAE-Wide Service", desc: "Full support across all emirates with safe pickup and delivery from your home or office." },
]

const faqs = [
  { q: "Is apostille enough for UAE use?", a: "No. UAE requires full Spain Certificate Attestation including MOFA approval." },
  { q: "Is translation required?", a: "Some documents must be translated into English or Arabic before submission." },
  { q: "Can someone submit on my behalf?", a: "Yes. Our team handles the complete process for you." },
  { q: "Do I need to visit Spain?", a: "No. We coordinate the entire procedure through authorised channels." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Spain Certificate Attestation Services in the UAE | Indexauh"
  description="Start your Spain Certificate Attestation with IndexAUH. 25+ years of UAE experience. Quick support, clear process, safe handling. Contact us today."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .get-started-grid { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .get-started-grid { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-101.webp"
    alt="Spain Certificate Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Spain Attestation</span>
      <span class="idx-pill">25 Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      SPAIN CERTIFICATE ATTESTATION<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Spain Certificate Attestation makes your Spanish document legally valid in the UAE. With over 25 years of experience, IndexAUH guides you from document review to final MOFA stamping — no travel, no queues.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What is Spain Certificate Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Spain Certificate Attestation is required when you want to use a certificate issued in Spain inside the UAE. UAE authorities must confirm that your document is genuine before they accept it for visa, job, education, or business purposes.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        With over 25 years of experience in the UAE, IndexAUH has handled a large number of attestation cases. Our team understands each stage clearly. You do not need to travel or stand in queues. We manage the full process carefully and return your document safely.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Key Insight — Apostille Is Not Enough for UAE</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          Spain is part of the Hague Convention, but the UAE requires additional legalisation beyond the apostille. UAE Embassy attestation and final MOFA approval are both mandatory.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/spain-flag.webp" alt="Spain document attestation UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Verification · Apostille · UAE Embassy · MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Spain attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHEN DO YOU NEED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-11.webp" alt="Purpose of Spain certificate attestation" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">When You Need Attestation</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Visa · Business · Education · Legal</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Key Situations</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Purpose of Spain Certificate Attestation in the UAE</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:16px;">
          UAE government departments accept only verified foreign documents. A Spanish certificate must pass official authentication before it becomes valid here. Without proper verification, authorities may reject the application — leading to delays and stress.
        </p>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:24px;">
          For example, a degree from Barcelona must be attested before your employer can apply for your work visa. A Spanish marriage certificate must be verified before sponsoring your spouse. You may need Spain Certificate Attestation for:
        </p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {whenNeeded.map(item => (
            <div style="display:flex;align-items:flex-start;gap:12px;background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:14px 18px;">
              <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:2px;">→</span>
              <p style="font-size:0.9rem;color:#374151;line-height:1.6;margin:0;">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our Spain Certificate Attestation Services"
  description="We handle attestation for a wide range of document categories. Always check with the requesting authority to confirm exactly what form of attestation they require."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Spain attestation"
  docTypes={docTypes}
  country="spain"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Spain attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Spain Certificate Attestation Process</h2>
      </div>
    </div>

    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;">
      <div style="display:flex;flex-direction:column;gap:14px;">
        {processSteps.map(s => (
          <div class="step-card">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}
        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:14px;padding:18px;margin-top:4px;">
          <p style="font-size:0.88rem;color:#4B5563;line-height:1.7;margin:0;">After the final MOFA stage, your Spanish document becomes legally valid in the UAE and is accepted by all government departments and institutions.</p>
        </div>
      </div>

      <div style="display:flex;flex-direction:column;gap:20px;">
        <!-- Documents Required -->
        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required for Spain Certificate Attestation</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Do not laminate certificates — damaged documents may face delay. Our team checks everything before submission. You normally need:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {docsRequired.map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{d}
              </div>
            ))}
          </div>
        </div>

        <!-- Timing -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">How Long Does Spain Certificate Attestation Take?</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Standard processing usually takes a few working weeks. Express options may be available in urgent cases. We review your documents first to avoid delays. Processing time depends on:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {timingFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>

        <!-- Fees -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Spain Certificate Attestation Cost in UAE</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">We provide clear pricing before starting — no hidden charges. Proper planning helps avoid extra expenses. The cost depends on:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {feeFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ UAE COVERAGE ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1.3fr 1fr;gap:48px;align-items:center;">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Coverage Area</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Spain Certificate Attestation Services in UAE</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:28px;">
          We provide full support across all emirates. Our team handles submission, follow-up, and final delivery. No matter where you are located, expert support is always available.
        </p>
        <div style="display:flex;flex-direction:column;gap:14px;">
          {emirates.map(e => (
            <div style="background:#F8FAFF;border:1px solid #eef0f6;border-radius:12px;padding:16px 20px;">
              <p style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 4px;">Spain Certificate Attestation in {e.name}</p>
              <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">{e.desc}</p>
            </div>
          ))}
        </div>
      </div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-34.webp" alt="Spain attestation services across UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">UAE-Wide Coverage</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Abu Dhabi · Dubai · Sharjah & beyond</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ CHALLENGES ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

