<!-- ════ SCRIPTS ════ -->
<script>
(function(){
  // ── Document tabs ──
  const tabs = document.querySelectorAll('.doc-tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const target = (tab as HTMLElement).dataset.tab;
      ['personal','educational','commercial'].forEach(t => {
        const el = document.getElementById('tab-' + t) as HTMLElement;
        el.style.display = t === target ? 'grid' : 'none';
      });
    });
  });

  // ── FAQ accordion ──
  document.querySelectorAll('.faq-item').forEach(item => {
    item.querySelector('.faq-q')?.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(x => {
        x.classList.remove('open');
        (x.querySelector('.faq-a') as HTMLElement).classList.remove('open');
      });
      if (!isOpen) {
        item.classList.add('open');
        (item.querySelector('.faq-a') as HTMLElement).classList.add('open');
      }
    });
  });
})();
</script>

