---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const personalDocs = [
  "Marriage Certificate Attestation","Birth Certificate Attestation","Divorce Certificate Attestation",
  "Death Certificate Attestation","Police Clearance Certificate Attestation","Medical Certificate Attestation",
  "Affidavit",
]
const educationalDocs = [
  "Degree Certificate Attestation","Diploma Certificate Attestation","School Certificate",
  "Mark Sheets Attestation","Transfer Certificate Attestation","Engineering Certificate","Transcript Attestation",
]
const commercialDocs = [
  "Commercial License","Commercial Invoices","Memorandum of Association","Power of Attorney",
  "Board Resolutions","Company Agreements","Certificate of Incorporation",
]

const steps = [
  { num:"01", title:"Notary Attestation", desc:"A notary or issuing authority verifies the document. This confirms basic authenticity." },
  { num:"02", title:"Home Country Attestation", desc:"Government departments check the document at a national level. This step validates its origin." },
  { num:"03", title:"Embassy Attestation", desc:"The embassy of the destination country approves the document for use abroad." },
  { num:"04", title:"Final Attestation by Authorities", desc:"The final approval is completed by the relevant foreign affairs authority in the destination country." },
]

const majorCountries = [
  { name: "UK", href: "/certificate-attestation-in-uk/" },
  { name: "USA", href: "/usa-certificate-attestation-in-the-uae/" },
  { name: "Canada", href: "/canada-certificate-attestation/" },
  { name: "France", href: "/france-certificate-attestation/" },
  { name: "Spain", href: "/spain-certificate-attestation/" },
  { name: "Australia", href: "/australia-certificate-attestation/" },
  { name: "Malaysia", href: "/malaysia-certificate-attestation/" },
  { name: "Germany", href: "/germany-certificate-attestation/" },
  { name: "Philippines", href: "/certificate-attestation-in-philippines/" },
  { name: "Italy", href: "/italy-certificate-attestation/" },
  { name: "Singapore", href: "/singapore-certificate-attestation/" },
  { name: "Switzerland", href: "/switzerland-certificate-attestation/" },
  { name: "Netherlands", href: "/netherlands-certificate-attestation/" },
  { name: "Poland", href: "/poland-certificate-attestation/" },
  { name: "Nigeria", href: "/nigerian-certificate-attestation/" },
  { name: "Lebanon", href: "/lebanon-certificate-attestation/" },
  { name: "China", href: "/china-attestation-services/" },
  { name: "Austria", href: "/austria-certificate-attestation/" },
]

const gccCountries = [
  { name: "Kuwait", href: "/kuwait-certificate-attestation/" },
  { name: "Oman", href: "/oman-certificate-attestation/" },
  { name: "Bahrain", href: "/bahrain-certificate-attestation/" },
  { name: "Saudi Arabia", href: "/saudi-certificate-attestation/" },
  { name: "UAE", href: "/certificate-attestation-in-the-uae/" },
  { name: "Qatar", href: "/qatar-certificate-attestation/" },
]

const faqs = [
  { q:"How can Index Office Services help me complete document attestation for the UAE?", a:"Indexauh manages every stage of attestation, coordinating with the required authorities so your documents are processed accurately and delivered on time." },
  { q:"What makes Index Office Services a preferred choice for handling certificate attestation procedures?", a:"Index Office Services streamlines the entire process, ensuring each step is handled correctly while keeping clients informed from start to finish." },
  { q:"How long does document attestation take when processed through Index Office Services?", a:"Processing time depends on the issuing country and document type. Index Office Services provides clear timelines at the start and updates you if any authority requires additional verification." },
  { q:"Can Index Office Services assist with MOFA attestation after completing the initial attestation steps?", a:"Yes. We handle MOFA attestation as part of the complete service, ensuring your document is ready for official use in the UAE." },
  { q:"Does Index Office Services provide updates throughout the attestation process?", a:"Clients receive regular updates so they always know the status of their attestation and the upcoming steps." },
  { q:"Is document pickup and delivery available through Index Office Services?", a:"We offer convenient pickup and delivery options so clients can complete the attestation process without visiting multiple offices." },
  { q:"Does Indexauh manage attestation for certificates issued outside the UAE?", a:"Indexauh supports attestation for documents issued in various countries by coordinating with foreign ministries, embassies, and UAE authorities as required." },
  { q:"What fees should I expect when getting certificate attestation through Index Office Services?", a:"Costs vary depending on the document type, issuing country, and number of authorities involved. We provide a clear estimate before starting the process." },
]

const countryCodes = [
  { code:"+91", label:"IN +91" },{ code:"+971", label:"AE +971" },{ code:"+44", label:"GB +44" },{ code:"+1", label:"US +1" },{ code:"+973", label:"BH +973" },
]
---

<BaseLayout
  title="Certificate Attestation Services | Attestation For 100+ Countries"
  description="Index offers best certificate attestation services with 25 years experience. Birth, marriage, educational attestation & more. Call now !"
>

<style>
  .sec-inner { position: relative; z-index: 1; }

  /* pills */
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }

  /* form */
  .idx-form input,.idx-form select,.idx-form textarea { width:100%; border:1px solid #e5e7eb; border-radius:10px; padding:11px 14px; font-size:1rem; color:#374151; outline:none; font-family:inherit; background:#fff; box-sizing:border-box; }
  .idx-form input:focus,.idx-form select:focus,.idx-form textarea:focus { border-color:#38B2AC; box-shadow:0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize:none; }
  .idx-submit { width:100%; background:#2D3748; color:#fff; font-weight:700; padding:13px; border-radius:10px; border:none; cursor:pointer; font-size:0.95rem; letter-spacing:0.04em; transition:background 0.2s; }
  .idx-submit:hover { background:#1A202C; }

  /* doc category tabs */
  .doc-tab { padding:9px 20px; border-radius:9999px; font-size:0.98rem; font-weight:600; cursor:pointer; border:none; transition:all 0.2s; }
  .doc-tab.active { background:#2D3748; color:#fff; }
  .doc-tab:not(.active) { background:#F0FFFE; color:#2D3748; border:1px solid #B2F5EA; }

  /* steps */
  .step-card { display:flex; align-items:flex-start; gap:18px; padding:24px; background:#fff; border:1px solid #eef0f6; border-radius:16px; transition:all 0.25s; }
  .step-card:hover { border-color:#B2F5EA; box-shadow:0 12px 32px rgba(56,178,172,0.1); transform:translateY(-3px); }

  /* chip */
  .country-chip { background:#F0FFFE; border:1px solid #B2F5EA; border-radius:8px; padding:8px 14px; font-size:0.98rem; color:#1A202C; font-weight:500; text-align:center; }
  .gcc-chip { background:#2D3748; border:1px solid rgba(56,178,172,0.3); border-radius:8px; padding:8px 14px; font-size:0.98rem; color:#81E6D9; font-weight:500; text-align:center; }

  /* FAQ */
  .faq-item { border:1px solid #e5e7eb; border-radius:12px; overflow:hidden; }
  .faq-q { width:100%; background:#fff; border:none; text-align:left; padding:18px 20px; font-size:0.9rem; font-weight:600; color:#1A202C; cursor:pointer; display:flex; justify-content:space-between; align-items:center; gap:12px; }
  .faq-a { padding:0 20px; max-height:0; overflow:hidden; transition:max-height 0.35s ease,padding 0.2s; }
  .faq-a.open { max-height:200px; padding:0 20px 16px; }
  .faq-icon { font-size:1.1rem; transition:transform 0.3s; flex-shrink:0; }
  .faq-item.open .faq-icon { transform:rotate(45deg); }

  /* who needs grid */
  .who-card { background:#fff; border:1px solid #eef0f6; border-radius:14px; padding:20px 22px; display:flex; align-items:flex-start; gap:12px; transition:all 0.25s; }
  .who-card:hover { border-color:#B2F5EA; box-shadow:0 8px 24px rgba(56,178,172,0.1); }

  /* how-to steps */
  .how-card { background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:14px; padding:24px; text-align:center; transition:background 0.2s; }
  .how-card:hover { background:rgba(255,255,255,0.14); }

  @media(max-width:768px){
    .about-hero-title { font-size: 2rem !important; }
    .about-hero-desc { font-size: 0.88rem !important; }
  }
  @media(max-width:640px) {
    .steps-grid { grid-template-columns:1fr !important; }
    .who-grid { grid-template-columns:1fr !important; }
    .how-grid { grid-template-columns:repeat(1,1fr) !important; }
  }

  /* Image hover effects */
.img-hover-wrap {
  transition: transform 0.35s ease, box-shadow 0.35s ease;
}
.img-hover-wrap:hover {
  transform: translateY(-6px);
  box-shadow: 0 24px 56px rgba(56,178,172,0.18) !important;
}
.img-hover-wrap img {
  transition: transform 0.45s ease;
}
.img-hover-wrap:hover img {
  transform: scale(1.04);
}

/* Fix mobile image overflow */
@media(max-width:768px) {
  .img-side-wrap {
    width: 100% !important;
    flex-shrink: unset !important;
  }
  .img-side-wrap img {
    width: 100% !important;
    height: 260px !important;
  }
}
</style>

<!-- ════════════ HERO — image bg, centered text ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <!-- Background image -->
  <img
    src="/images/img-16.webp"
    alt="Certificate Attestation Services"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <!-- Dark overlay -->
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.88) 0%,rgba(45,55,72,0.82) 100%);"></div>
  <!-- Dot pattern -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <p style="color:#38B2AC;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;font-size:0.75rem;margin:0 0 16px;">Attestation Services</p>
    <h1 class="about-hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      Certificate Attestation<br/>Services For <span style="color:#38B2AC;">100+ Countries</span>
    </h1>
    <p class="about-hero-desc" style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:640px;">
      Index Office Services brings over 25 years of experience handling document attestation and MOFA approvals worldwide. We ensure your certificates are verified and accepted by authorities with speed and reliability.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="/contact/" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#docTabs" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Our Services</a>
    </div>
  </div>
</section>

<!-- ════ WHY REQUIRED ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:-80px;right:-80px;width:360px;height:360px;background:radial-gradient(circle,rgba(56,178,172,0.12) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;display:flex;flex-wrap:wrap;gap:52px;align-items:center;">

    <div style="flex:1;min-width:280px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;"><span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Mandatory Requirement</p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 16px;">Why Certificate Attestation Is Required?</h2>
      <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:20px;">Attestation is a mandatory step when you plan to use documents outside the country where they were issued. Authorities need proof that every document is valid and verified.</p>
      <p style="font-weight:700;color:#1A202C;font-size:1.05rem;margin-bottom:12px;">You will need attested documents for:</p>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {["Employment visa approvals","Family visa applications","Higher education admissions","Business setup and corporate work","Legal procedures and official approvals"].map(item => (
          <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;background:#fff;border:1px solid #e0e7ef;border-radius:10px;font-size:1rem;color:#1A202C;font-weight:500;">
            <span style="width:24px;height:24px;border-radius:50%;background:#38B2AC;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" width="12" height="12"><path d="M20 6L9 17l-5-5"/></svg>
            </span>
            {item}
          </div>
        ))}
      </div>
      <p style="color:#6B7280;font-size:0.98rem;line-height:1.7;margin-top:16px;padding:12px 16px;background:#FFF9F0;border:1px solid #FCD34D;border-radius:10px;">
        ⚠ Without attestation, documents are not accepted. Therefore, applications may face rejection or delay.
      </p>
    </div>

    <div class="img-side-wrap" style="flex-shrink:0;width:420px;">
  <div class="img-hover-wrap" style="position:relative;border-radius:20px;overflow:hidden;height:380px;">
        <img src="/images/img-36.webp" alt="Certificate attestation documents" style="width:100%;height:100%;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,rgba(26,32,44,0.7));"></div>
        <div style="position:absolute;bottom:24px;left:24px;right:24px;">
          <p style="color:#81E6D9;font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 6px;">Trusted by 400K+ clients</p>
          <p style="color:#fff;font-size:0.95rem;font-weight:700;margin:0;">End-to-end attestation for 100+ countries with 25 years of experience</p>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ════ WHO NEEDS ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Different Needs, One Solution</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0;">WHO NEEDS DOCUMENT ATTESTATION?</h2>
    </div>
    <div class="who-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
      {[
        { icon:"💼", title:"Professionals", desc:"Applying for jobs abroad requiring verified credentials and experience certificates." },
        { icon:"👨‍👩‍👧", title:"Families", desc:"Sponsoring spouse or children and needing attested personal documents." },
        { icon:"🎓", title:"Students", desc:"Planning higher education in another country and needing degree or transcript attestation." },
        { icon:"🏢", title:"Business Owners", desc:"Expanding operations internationally and requiring commercial document attestation." },
        { icon:"⚖️", title:"Legal Matters", desc:"Individuals handling power of attorney and other legal procedures abroad." },
        { icon:"🌍", title:"Anyone Using Documents Abroad", desc:"Each case follows a different path. The document type decides the process." },
      ].map(w => (
        <div class="who-card">
          <span style="font-size:1.6rem;flex-shrink:0;">{w.icon}</span>
          <div>
            <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{w.title}</p>
            <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:0;">{w.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ OUR DOCUMENT ATTESTATION SERVICES ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:400px;background:radial-gradient(ellipse,rgba(56,178,172,0.07) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Complete Coverage</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">OUR DOCUMENT ATTESTATION SERVICES</h2>
    </div>

    <!-- Tab buttons -->
    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:32px;" id="docTabs">
      <button class="doc-tab active" data-tab="personal">Personal Documents</button>
      <button class="doc-tab" data-tab="educational">Educational Documents</button>
      <button class="doc-tab" data-tab="commercial">Commercial Documents</button>
    </div>

    <!-- Personal -->
    <div id="tab-personal" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;">
      {personalDocs.map(d => (
        <a href="#" style="display:flex;align-items:center;gap:10px;background:#fff;border:1px solid #e0e7ef;border-radius:12px;padding:14px 18px;font-size:1rem;color:#1A202C;font-weight:500;text-decoration:none;transition:all 0.2s;">
          <span style="width:28px;height:28px;border-radius:50%;background:#2D3748;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg viewBox="0 0 24 24" fill="none" stroke="#38B2AC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </span>
          {d}
          <span style="margin-left:auto;color:#38B2AC;font-size:0.75rem;">→</span>
        </a>
      ))}
    </div>

    <!-- Educational -->
    <div id="tab-educational" style="display:none;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;">
      {educationalDocs.map(d => (
        <a href="#" style="display:flex;align-items:center;gap:10px;background:#fff;border:1px solid #e0e7ef;border-radius:12px;padding:14px 18px;font-size:1rem;color:#1A202C;font-weight:500;text-decoration:none;transition:all 0.2s;">
          <span style="width:28px;height:28px;border-radius:50%;background:#2D3748;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg viewBox="0 0 24 24" fill="none" stroke="#38B2AC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0112 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
          </span>
          {d}
          <span style="margin-left:auto;color:#38B2AC;font-size:0.75rem;">→</span>
        </a>
      ))}
    </div>

    <!-- Commercial -->
    <div id="tab-commercial" style="display:none;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;">
      {commercialDocs.map(d => (
        <a href="#" style="display:flex;align-items:center;gap:10px;background:#fff;border:1px solid #e0e7ef;border-radius:12px;padding:14px 18px;font-size:1rem;color:#1A202C;font-weight:500;text-decoration:none;transition:all 0.2s;">
          <span style="width:28px;height:28px;border-radius:50%;background:#2D3748;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg viewBox="0 0 24 24" fill="none" stroke="#38B2AC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </span>
          {d}
          <span style="margin-left:auto;color:#38B2AC;font-size:0.75rem;">→</span>
        </a>
      ))}
    </div>

  </div>
</section>

<!-- ════ STEP BY STEP ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;bottom:-60px;right:-60px;width:400px;height:300px;background:radial-gradient(ellipse,rgba(56,178,172,0.08) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Clear Process</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">STEP BY STEP PROCESS FOR DOCUMENT ATTESTATION</h2>
      <p style="color:#6B7280;font-size:1.05rem;max-width:560px;margin:0 auto;">The process follows a fixed order. Each stage confirms the document before moving ahead.</p>
    </div>
    <div class="steps-grid" style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px;">
