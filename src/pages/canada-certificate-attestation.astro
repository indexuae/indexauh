  { step: "05", title: "Embassy and MOFA Processing", desc: "Our team manages the legalization and UAE attestation stages." },
  { step: "06", title: "Safe Delivery", desc: "The attested document is delivered securely within the UAE." },
]

const whyChoose = [
  { title: "Proper Document Verification", desc: "We verify your documents thoroughly before submission to confirm compliance with UAE and Canadian authority requirements." },
  { title: "Clear Procedural Guidance", desc: "We explain the exact legalization steps required for your specific document type — no confusion, no surprises." },
