---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whenNeeded = [
  "Employment and work visa applications",
  "Higher education and university admissions",
  "Family visa and residency applications",
  "Marriage registration and spouse visa processing",
  "<a href='/business-setup-in-the-uae/' style='color:#374151;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>Business setup in the UAE</a> or Bahrain",
  "Legal transactions",
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Marriage certificate attestation in Bahrain",
      "Divorce Certificate attestation in Bahrain",
      "Birth certificate attestation",
      "Death Certificate Attestation in Bahrain",
      "Transfer Certificate Attestation",
      "Bahrain PCC",
      "Salary certificate attestation in Bahrain",
      "Medical Certificate Attestation",
      "Affidavit",
    ],
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Degree certificates attestation for Bahrain",
      "School leaving certificates",
      "Bahrain Diploma Certificate Attestation",
      "Master Degree Certificate Attestation",
      "Engineering Degree Certificate Attestation",
      "Nursing Degree Certificate Attestation in Bahrain",
    ],
  },
  {
    category: "Commercial Documents",
    icon: "⚖️",
    docs: [
      "Memorandum of Association (MOA)",
      "Articles of Association (AOA)",
      "Power of Attorney",
      "Certificate of Incorporation",
      "Commercial License",
      "Board Resolutions",
      "Commercial Invoices",
    ],
  },
]
const processSteps = [
  { step: "01", title: "Initial Notary Verification", desc: "The process starts with initial verification from the issuing authority or a registered notary. This confirms that your certificate is genuine and officially issued." },
  { step: "02", title: "Home Country Government Attestation", desc: "If required, the document is attested by the relevant government departments in the issuing country. This step is common for educational and personal certificates issued outside the UAE." },
  { step: "03", title: "Bahrain Embassy Attestation", desc: "After home country verification, the certificate is submitted for Bahrain Embassy attestation. The embassy checks the document and approves it for legal use in Bahrain." },
  { step: "04", title: "<a href='/mofa-attestation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>MOFA Attestation</a> Bahrain", desc: "The final step is MOFA attestation Bahrain. The Ministry of Foreign Affairs provides the last level of approval, making the certificate fully valid for submission in Bahrain." },
  { step: "05", title: "Delivery of Attested Certificate", desc: "Our experts handle each stage carefully to ensure the process is smooth and to reduce the chances of delays or rejection." },
]

const docsRequired = [
  "Original certificate",
  "Passport copy of the certificate holder",
  "Authorization letter",
  "Supporting documents if required",
]

const timingFactors = [
  "Type of document",
  "Issuing country",
  "Embassy and MOFA workload",
  "Translation requirements",
]

const challenges = [
  "Submitting incomplete documents",
  "Following the wrong attestation order",
  "Missing Ministry of Foreign Affairs Bahrain attestation",
  "Using non-certified translations",
]

const getStartedSteps = [
  { step: "01", title: "Contact Us for a Free Quote", desc: "Reach out to Indexauh. Our team will explain the requirements and guide you clearly." },
  { step: "02", title: "Submit Your Documents", desc: "Send your certificates safely. We ensure secure handling at every stage." },
  { step: "03", title: "We Process Your Documents", desc: "Our experts manage all steps with UAE authorities, the Bahrain Embassy, and MOFA Bahrain attestation offices." },
  { step: "04", title: "Receive Attested Certificates", desc: "Your fully attested documents are delivered to your doorstep." },
]

const whyChoose = [
  { title: "Experienced Attestation Specialists", desc: "Our team brings deep expertise in Bahrain certificate attestation procedures across all document types." },
  { title: "Best Service in Dubai & Abu Dhabi", desc: "Trusted name for the best <a href='/certificate-attestation-in-dubai/' style='color:#CBD5E0;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>certificate attestation in Dubai</a> and Abu Dhabi with proven results." },
  { title: "Secure Document Handling", desc: "Strict protocols ensure your certificates are handled and tracked securely throughout the entire process." },
  { title: "Transparent Communication", desc: "We keep you informed at every stage so you are never left wondering about the status of your documents." },
  { title: "Embassy and MOFA Coordination", desc: "We coordinate directly with the Bahrain Embassy and MOFA Bahrain attestation offices on your behalf." },
  { title: "Dedicated Customer Support", desc: "A dedicated support team is available to answer your queries and guide you clearly from start to finish." },
]

const faqs = [
  { q: "How long does Bahrain certificate attestation take?", a: "Processing time depends on the document and issuing country, but most cases are completed within a few working days." },
  { q: "Is MOFA attestation Bahrain mandatory?", a: "Yes, Ministry of Foreign Affairs Bahrain attestation is a key step for document acceptance." },
  { q: "Do Indian certificates need attestation for Bahrain?", a: "Yes, Indian certificate attestation in Bahrain is required for employment, education, and residency purposes." },
  { q: "Can I track my attestation status?", a: "Yes, Indexauh provides regular updates during the process." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Bahrain Certificate Attestation Services | Indexauh"
  description="Bahrain Certificate Attestation by Indexauh with 25 years of experience. Secure, accurate processing in the UAE. Avoid delays. Contact us today to get started."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .img-first { order: -1 !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
    .get-started-grid { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Bahrain Certificate Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Bahrain Attestation</span>
      <span class="idx-pill">25+ Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      BAHRAIN CERTIFICATE ATTESTATION<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      If you plan to work, study, get married, or do business in Bahrain, your documents must be legally verified. At IndexAUH, we manage Bahrain certificate attestation with careful document handling, clear procedures, and dedicated coordination at every stage.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-btns">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is Bahrain Certificate Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Bahrain certificate attestation is the process of verifying documents so they are legally valid for use in Bahrain. This verification confirms that the certificate was issued by a recognized authority and is authentic.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Verification from the issuing authority, the Bahrain Embassy, and the Ministry of Foreign Affairs Bahrain attestation stage are typically included in the attestation procedure. Your completed document is accepted by Bahraini government agencies, businesses, academic institutions, and other institutions.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        All significant documents, including birth certificates, marriage licences, educational credentials, and business paperwork, must go through this procedure.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Key Insight — Translation Requirements</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          Some documents may need certified translation before attestation in Bahrain. Translation is usually required if the certificate is not in English or Arabic. We assist with approved translation services to ensure full compliance with Bahrain authorities.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/bahrain-flag.webp" alt="Bahrain document attestation UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Notary · Embassy · MOFA Bahrain</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Bahrain attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHEN DO YOU NEED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;" class="split-grid">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-11.webp" alt="Why Bahrain certificate attestation is required" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">When You Need Attestation</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Visa · Business · Education · Family</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Key Situations</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Why Is Bahrain Certificate Attestation Required?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          Attestation in Bahrain is mandatory for many official purposes. Without proper attestation, authorities may reject your documents. You need Bahrain certificate attestation for:
        </p>
       <div style="display:flex;flex-direction:column;gap:12px;">
  {whenNeeded.map(item => (
    <div style="display:flex;align-items:flex-start;gap:12px;background:#fff;border:1px solid #eef0f6;border-radius:12px;padding:14px 18px;">
      <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:2px;">→</span>
      <p style="font-size:0.9rem;color:#374151;line-height:1.6;margin:0;" set:html={item}></p>
    </div>
  ))}
</div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Types of Certificates We Attest for Bahrain"
  description="We handle attestation for a wide range of document categories. Always check with the requesting authority to confirm exactly what form of attestation they require."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Bahrain attestation"
  docTypes={docTypes}
  country="bahrain"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Bahrain attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Step by Step Bahrain Certificate Attestation Process</h2>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;" class="split-grid">
      <div style="display:flex;flex-direction:column;gap:14px;">
  {processSteps.map(s => (
    <div class="step-card">
      <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
      <div>
        <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;" set:html={s.title}></p>
        <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
      </div>
    </div>
  ))}
</div>
      <div style="display:flex;flex-direction:column;gap:20px;">
        <!-- Documents Required -->
        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required for Bahrain Certificate Attestation</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Requirements may vary based on the certificate and purpose. To begin the attestation process, you usually need:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {docsRequired.map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{d}
              </div>
            ))}
          </div>
        </div>

        <!-- Timing -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Processing Time for Bahrain Certificate Attestation</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Most cases are completed within a few working days. Contact Indexauh for accurate guidance on your specific case. Processing time depends on:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {timingFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>

        <!-- Benefits -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Benefits of Bahrain Certificate Attestation</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Attestation services in Bahrain offer many advantages for individuals and businesses alike:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {[
              "Legal recognition of documents",
              "Faster visa and employment processing",
              "Reduced risk of document rejection",
              "Smooth academic and business procedures",
            ].map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ CHALLENGES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;" class="two-col">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What to Watch For</p>
        <h2 style="font-size:1.8rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Common Mistakes to Avoid During Bahrain Attestation</h2>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:24px;">
          Delays often happen because of small mistakes that can easily be avoided. Our professional support helps prevent these issues and makes the process smooth.
        </p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {challenges.map(c => (
            <div style="display:flex;align-items:center;gap:12px;background:#FFF5F5;border:1px solid #FED7D7;border-radius:10px;padding:12px 16px;">
              <span style="color:#E53E3E;font-weight:bold;font-size:1rem;flex-shrink:0;">!</span>
              <p style="font-size:0.88rem;color:#4B5563;line-height:1.5;margin:0;">{c}</p>
            </div>
          ))}
        </div>
      </div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-40.webp" alt="Common mistakes in Bahrain attestation" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">Avoid Delays</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">We check everything before submission</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ GET STARTED ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
