---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const purposePoints = [
  { title: "Confirms Work Record is Genuine", desc: "It proves that the document issued by the company is genuine. It helps authorities trust the details written in the certificate." },
  { title: "Protects Companies from False Claims", desc: "A verified experience certificate UAE helps employers confirm work history. This protects companies from false employment claims." },
  { title: "Supports Authentic Career Records", desc: "It also helps professionals present authentic career records. Many HR teams ask for an employment certificate UAE with proper attestation during background checks." },
]

const steps = [
  { step: "01", title: "Issuing Authority Verification", desc: "The process begins with verification from the organisation that issued the certificate. The company seal and authorised signature confirm that the document belongs to the employee." },
  { step: "02", title: "Home Country Attestation", desc: "Authorities in the issuing country verify the document through government departments. This stage confirms the authenticity of the certificate before international use." },
  { step: "03", title: "UAE Embassy Attestation", desc: "The UAE embassy checks the document after home country verification. This stage allows the certificate to be used in the UAE." },
  { step: "04", title: "MOFA Attestation in UAE", desc: "The Ministry of Foreign Affairs completes the final stage. After this step the Experience Certificate Attestation process becomes valid for official use in the UAE." },
]

const commonPurposes = [
  "Job change inside the UAE",
  "Employment verification by HR departments",
  "Visa or immigration procedures",
  "Professional documentation for certain sectors",
  "Government related document submissions",
]

const whenNeeded = [
  "Applying for jobs outside the UAE",
  "Immigration related procedures",
  "Professional licensing applications",
  "Verification for government documentation",
  "Company background checks",
]

const commonMistakes = [
  "Missing company seal or authorised signature",
  "Incorrect employee name in the certificate",
  "Damaged or unclear document copies",
  "Certificates printed without official company letterhead",
]

const gettingStartedSteps = [
  { step: "01", title: "Contact Our Team", desc: "Contact our team and share details about your certificate and requirements." },
  { step: "02", title: "Submit Documents", desc: "Submit the required documents for verification through secure pickup or drop off." },
  { step: "03", title: "Expert Processing", desc: "Our experts begin the attestation procedure with the relevant authorities." },
  { step: "04", title: "Receive Attested Certificate", desc: "Receive your attested certificate after completion at your address." },
]

const whyChooseUs = [
  "More than 25 years of experience in <a href='/certificate-attestation-in-the-uae/' style='color:#fff;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>certificate attestation UAE</a>",
  "Strong understanding of government procedures",
  "Dedicated team handling each document carefully",
  "Support for individuals and corporate clients across the UAE",
  "Clear guidance from submission to final attestation",
]

const faqs = [
  { q: "Is Experience Certificate Attestation required for job change in the UAE?", a: "Some employers request attestation during background verification. An attested uae experience certificate helps confirm the authenticity of the candidate's work history and supports smooth hiring procedures." },
  { q: "How long does Experience Certificate Attestation take?", a: "Processing time depends on the country where the certificate was issued. Documents may require verification from different authorities before final approval from the Ministry of Foreign Affairs in the UAE." },
  { q: "Can I submit a copy of my experience certificate for attestation?", a: "Authorities usually request the original certificate issued by the company. A clear copy of the passport and other supporting documents may also be required during the attestation process." },
  { q: "What happens after the attestation process is completed?", a: "After the process is completed, the certificate becomes officially verified for use in the UAE. Employers and government departments can accept the document as proof of previous employment." },
  { q: "Can someone apply for Experience Certificate Attestation on my behalf?", a: "Yes. Many professionals use attestation service providers to handle the procedure. The applicant may provide an authorisation letter along with the required documents to begin the process." },
  { q: "Do all companies require attested employment certificates in the UAE?", a: "Requirements depend on the organisation and the purpose of verification. Some companies ask for an attested employment certificate UAE during recruitment or internal documentation procedures." },
]
---

<BaseLayout
  title="Experience Certificate Attestation in UAE | Indexauh"
  description="Get professional assistance for experience certificate attestation in UAE. With 25+ years of experience, IndexAUH is ready to support you."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .doc-type-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; transition: all 0.25s; }
  .doc-type-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.06); transform: translateY(-3px); }
  .step-card { display: flex; align-items: flex-start; gap: 18px; padding: 20px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .warning-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px; background: #FFF5F5; border: 1px solid #FEB2B2; border-radius: 10px; font-size: 0.88rem; color: #9B2C2C; font-weight: 500; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .benefits-grid { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .benefits-grid { grid-template-columns: 1fr !important; }
    .offices-flex { flex-direction: column !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Experience Certificate Attestation in UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.88) 0%,rgba(45,55,72,0.82) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Document Attestation</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">UAE MOFA Approved</span>
      <span class="idx-pill">Trusted by Professionals</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      EXPERIENCE CERTIFICATE<br/>ATTESTATION IN UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:640px;">
      Many professionals face document verification during job change or visa processing. In such cases an attested experience certificate becomes important. Experience Certificate Attestation confirms that your work record is genuine and accepted by authorities in the UAE.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-btns">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ PURPOSE / OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:start;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Purpose of Experience Certificate Attestation</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        An experience certificate shows the work history of an employee. Many organisations and authorities in the UAE ask for this document to confirm previous employment. Index Attestation Services has supported individuals and companies with document attestation for more than 25 years. Our team understands the requirements followed by government departments and employers across the country.
      </p>
      <p style="color:#2D3748;font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin:20px 0 10px;">Common purposes include:</p>
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px;">
        {commonPurposes.map(item => (
          <div style="display:flex;align-items:center;gap:12px;background:#F8FAFF;border:1px solid #eef0f6;border-radius:10px;padding:10px 14px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;">→</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">{item}</p>
          </div>
        ))}
      </div>
      <div style="display:flex;flex-direction:column;gap:14px;margin-top:8px;">
        {purposePoints.map(p => (
          <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
            <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">{p.title}</h3>
            <p style="color:#4B5563;font-size:0.88rem;line-height:1.75;margin:0;">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:24px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-16.webp" alt="Experience certificate attestation documents" style="width:100%;height:340px;object-fit:cover;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">UAE MOFA · Embassy · Home Country</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:82px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
      <div style="background:#FFF5F5;border:1px solid #FEB2B2;border-radius:12px;padding:18px;">
        <h3 style="color:#9B2C2C;font-size:0.95rem;font-weight:700;margin:0 0 8px;">⚠ Without verification the document may not be accepted</h3>
        <p style="color:#9B2C2C;font-size:0.82rem;line-height:1.6;margin:0;">Without verification the document may not be accepted for official procedures. Many HR teams ask for an employment certificate UAE with proper attestation during background checks.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ STEP BY STEP PROCESS ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Authentication Workflow</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">Experience Certificate Attestation Process</h2>
      <p style="color:#6B7280;font-size:1.05rem;max-width:620px;margin:0 auto;">The attestation procedure follows several verification stages. Each stage confirms the authenticity of the certificate before it receives final approval in the UAE.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;" class="split-grid">
      <div style="display:flex;flex-direction:column;gap:14px;">
        {steps.map(s => (
          <div class="step-card">
            <div style="width:40px;height:40px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}
        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:14px;padding:18px;margin-top:4px;">
          <p style="font-size:0.88rem;color:#4B5563;line-height:1.7;margin:0;">Professional assistance helps complete the attestation process faster because experts understand the required steps and document checks.</p>
        </div>
      </div>
      <div style="position:sticky;top:100px;">
        <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.12);">
          <img src="/images/img-7.webp" alt="Experience certificate attestation process" style="width:100%;height:480px;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(26,32,44,0.75) 100%);"></div>
          <div style="position:absolute;bottom:20px;left:20px;right:20px;">
            <p style="color:#fff;font-size:1rem;font-weight:800;margin:0 0 4px;">4-Step Verified Process</p>
            <p style="color:#B2F5EA;font-size:0.9rem;margin:0;">From issuing authority to MOFA final approval</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHEN DO YOU NEED IT ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:0.9fr 1.3fr;gap:48px;align-items:center;" class="split-grid">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-52.webp" alt="Professional needing experience certificate attestation" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.6) 100%);"></div>
        <div style="position:absolute;bottom:18px;left:18px;right:18px;">
          <p style="color:#fff;font-size:0.98rem;font-weight:700;margin:0;line-height:1.4;">Job Change · Immigration · Licensing · Verification</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Eligibility</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 16px;">When Do You Need Experience Certificate Attestation in UAE?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:20px;">Professionals usually think about attestation after an employer or authority requests the document. One common situation happens during a job change. A new company may request an attested UAE experience certificate to confirm the candidate's previous role.</p>
        <p style="font-weight:700;color:#1A202C;font-size:1rem;margin-bottom:12px;text-transform:uppercase;">Other situations include:</p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {whenNeeded.map(s => (
            <div style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:#fff;border-radius:8px;font-size:1rem;color:#1A202C;font-weight:500;border:1px solid #B2F5EA;">
              <span style="width:24px;height:24px;border-radius:50%;background:#38B2AC;color:#fff;font-size:0.75rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;">✓</span>
              {s}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ TIMELINE & COMMON MISTAKES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-54.webp" alt="Processing time and common mistakes" style="width:100%;height:240px;object-fit:cover;object-position:center 30%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 60%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Timeline &amp; Accuracy</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:480px;line-height:1.25;">How Long it Takes &amp; Common Mistakes to Avoid</h2>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:52px;" class="split-grid">
      <div>
        <h3 style="font-size:1.4rem;font-weight:900;color:#1A202C;margin-bottom:16px;">How Long Does Experience Certificate Attestation Take?</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.8;margin-bottom:16px;">
          Processing time depends on the country where the certificate was issued. Documents from some countries require additional verification steps.
        </p>
        <p style="color:#4B5563;font-size:1rem;line-height:1.8;margin-bottom:16px;">
          Standard processing may take several working days. Some cases take longer when additional verification becomes necessary.
        </p>
        <p style="color:#4B5563;font-size:1rem;line-height:1.8;margin:0;">
          Professional assistance helps complete the attestation process faster because experts understand the required steps and document checks.
        </p>
      </div>

      <div>
        <h3 style="font-size:1.4rem;font-weight:900;color:#9B2C2C;margin-bottom:16px;">Common Mistakes That Delay Attestation</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.8;margin-bottom:16px;">Small mistakes in documents can delay the attestation process. Many applicants face issues because of missing information. Correct documents help complete Experience Certificate Attestation smoothly.</p>
        <p style="font-weight:700;color:#9B2C2C;font-size:0.9rem;margin-bottom:12px;text-transform:uppercase;">Common problems include:</p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {commonMistakes.map(m => (
            <div class="warning-item">
              <span style="color:#E53E3E;font-weight:bold;margin-top:2px;">⚠</span>
              <p style="margin:0;line-height:1.5;">{m}</p>
            </div>
          ))}
        </div>
        <p style="color:#9B2C2C;font-size:0.88rem;line-height:1.7;margin-top:14px;">Checking these details before submission saves time and prevents rejection.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ HOW TO GET STARTED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Get Started</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">How to Get Started with Experience Certificate Attestation?</h2>
      <p style="color:#6B7280;font-size:1.05rem;max-width:560px;margin:0 auto;">Starting the process becomes simple with professional guidance. Index Attestation Services supports individuals and companies through each stage of <a href="/" style="color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;">certificate attestation</a>.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;" class="benefits-grid">
      {gettingStartedSteps.map(s => (
        <div class="doc-type-card" style="text-align:center;">
          <div style="width:48px;height:48px;border-radius:12px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1.1rem;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">{s.step}</div>
          <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 8px;">{s.title}</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
        </div>
      ))}
    </div>
