---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const faqs = [
  {
    q: "How does Index help me get my UAE Equivalency Certificate approved faster?",
    a: "Index streamlines each stage of the process by reviewing your documents, preparing required attestations, and guiding you through ministry submissions. This organised approach reduces delays and helps you receive your equivalency certificate in a shorter timeframe."
  },
  {
    q: "Can Index assist if my equivalency application was previously rejected?",
    a: "Yes. Index can assess the reason for rejection, identify missing or incorrect documents, and help you reapply with the proper requirements so your application aligns with ministry expectations."
  },
  {
    q: "Does Index handle attestation and verification needed before applying for equivalency?",
    a: "Index manages the entire preparation phase, including attestation, legalization, and verification steps that must be completed before the certificate can be submitted to the ministry."
  },
  {
    q: "What documents should I prepare before contacting Index for equivalency services?",
    a: "You can keep your degree certificate, transcript, passport copy, and any prior attestations ready. Index will review these documents and inform you if anything additional is required."
  },
  {
    q: "Can Index manage both academic attestation and UAE Equivalency Certificate submission?",
    a: "Yes. Index can take care of academic attestation from the issuing country and continue with the equivalency submission in the UAE, providing full-service support from start to finish."
  },
  {
    q: "Does Index support equivalency processing for degrees from non-accredited universities?",
    a: "Index evaluates each case individually. If your institution is not recognised, they will guide you on what alternatives or supporting documents may be needed to complete the process."
  },
  {
    q: "How does Index ensure my documents meet UAE Ministry of Education requirements?",
    a: "Index checks authenticity, formatting, attestations, and supporting documentation to ensure everything aligns with ministry standards before submitting your file."
  },
  {
    q: "Can Index guide me on DataFlow or verification steps required for equivalency?",
    a: "Yes. Index can help you understand the verification procedures that the ministry may request and assist you in completing them correctly."
  },
  {
    q: "What makes Index a trusted choice for UAE degree equivalency services?",
    a: "Index offers years of experience, process knowledge, and personalised support. Their team handles complex cases and ensures each step is completed accurately to avoid unnecessary delays."
  },
  {
    q: "Does Index offer consultation to check if my degree qualifies for UAE equivalency?",
    a: "Yes. You can request a consultation, and Index will review your degree details, issuing country, and accreditation status to confirm your eligibility before starting the process."
  },
]
---

<BaseLayout
  title="Equivalency Certificate Service in Dubai & Abu Dhabi | Indexauh"
  description="Indexauh provides best Equivalency Certificate Service in Dubai & Abu Dhabi. Contact us now for fast and Equivalency Certificate Service."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  details summary { list-style: none; }
  details summary::-webkit-details-marker { display: none; }
  details[open] { border-color: #B2F5EA !important; }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Equivalency Certificate UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      EQUIVALENCY CERTIFICATE<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      The ministry of education certifies a degree as being equivalent to UAE standards through the certificate equivalency process. It often involves two or three levels of attestations from various government departments in both countries, as well as a review by an equivalence committee, after which the letter of equivalency is provided from the UAE Ministry of Education.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
    </div>
  </div>
</section>

<!-- ════ BENEFITS ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 0.9fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Why You Need It
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What are the benefits of Equivalency Certificate?</h2>
      <p style="color:#4B5563;font-size:0.95rem;line-height:1.8;margin:0;">
        Professionals hired in the UAE must get a certificate of equivalency for their educational degrees obtained outside of the UAE from the Ministry of Education (MOE). Among other professions, civil engineers must show the legitimacy of their academic qualifications. When acquiring an engineering card in Abu Dhabi, the equivalency certificate is also a necessity (Engineer Registration System).
      </p>
    </div>

    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
      <img src="/images/img-7.webp" alt="Benefits of Equivalency Certificate UAE" style="width:100%;height:400px;object-fit:cover;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
      <div style="position:absolute;bottom:20px;left:20px;right:20px;">
        <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Benefits of Equivalency Certificate</p>
        <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Employment · Licensing · Compliance · Recognition</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE US ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;">
    <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Why Choose Us</p>
    <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.2;margin:0 0 18px;">WHY CHOOSE US?</h2>
    <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin-bottom:16px;">
      By availing the services of Index, you can get the Equivalency Certificate, save time and effort, and ensure that your documents meet the necessary legal requirements for UAE. However, it's always recommended to check the specific requirements and regulations of UAE's authorities and consult with the relevant institutions for accurate information.
    </p>
    <p style="color:#94A3B8;font-size:1rem;line-height:1.8;margin-bottom:48px;">Call us today to book a free consultation…!!!</p>

    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:40px;text-align:center;border-top:1px solid rgba(255,255,255,0.1);padding-top:48px;">
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">25000</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Happy Customers</p>
      </div>
      <div>
        <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">25</p>
        <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Years of Experience</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ FAQ ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;">
    <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;text-align:center;margin-bottom:10px;">Have Questions?</p>
    <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;text-align:center;margin:0 0 40px;">Frequently Asked Questions on Equivalency Certificate</h2>
    <div style="display:flex;flex-direction:column;gap:12px;">
      {faqs.map((f, i) => (
        <details style="border:1px solid #eef0f6;border-radius:14px;overflow:hidden;background:#fff;">
          <summary style="list-style:none;cursor:pointer;padding:18px 22px;font-size:0.88rem;font-weight:700;color:#1A202C;display:flex;justify-content:space-between;align-items:center;gap:12px;user-select:none;">
            <span>{i + 1}. {f.q}</span>
            <span style="color:#38B2AC;font-size:1.3rem;font-weight:900;flex-shrink:0;line-height:1;">+</span>
          </summary>
          <div style="padding:0 22px 18px;font-size:0.88rem;color:#4B5563;line-height:1.75;">{f.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- ════ GET IN TOUCH ════ -->
<section id="get-in-touch" style="background:#2D3748;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:600px;height:300px;background:radial-gradient(ellipse,rgba(56,178,172,0.12) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;gap:52px;align-items:flex-start;">

    <div style="flex:1;min-width:280px;">
      <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Free Consultation</p>
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.25;margin:0 0 18px;">CONSULT AND GET YOUR CERTIFICATE ON TIME</h2>
      <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin-bottom:16px;">
        Index is a specialist service provider, focusing on equivalency certificates and other international individual and business services.
      </p>
      <p style="color:#94A3B8;font-size:1.05rem;line-height:1.8;margin-bottom:28px;">
        With 25+ years of expertise in this industry, we have gained considerable knowledge and insight on delivering professional and timely results authorised by the concerned authorities in various countries, as per your requirements. Call us today to book a free consultation.
      </p>
      <a href="tel:+971529300200" style="display:inline-flex;align-items:center;gap:10px;background:#38B2AC;color:#fff;font-weight:900;font-size:0.95rem;padding:14px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        CALL NOW: (+971) 529 300 200
      </a>
    </div>

    <div style="flex:1;min-width:280px;background:#fff;border-radius:22px;padding:36px;box-shadow:0 20px 60px rgba(0,0,0,0.2);">
      <h3 style="font-size:1.2rem;font-weight:700;color:#1A202C;margin:0 0 22px;">Free Consultation</h3>
      <ContactForm />
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('details').forEach(details => {
    const icon = details.querySelector('summary span:last-child');
    if (!icon) return;
    details.addEventListener('toggle', () => {
      icon.textContent = details.open ? '−' : '+';
    });
  });
</script>

</BaseLayout>