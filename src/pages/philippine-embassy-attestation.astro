---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const whoNeeds = [
  "Applying for a job that requires attested educational or experience certificates in UAE",
  "Sending birth and marriage certificates to sponsor family visas",
  "Submitting attested academic records for university admissions or transfer credits",
  "Registering a company, trading, or closing a business deal",
  "Getting a Power of Attorney accepted in another nation",
  "Submitting affidavits, court documents, or other legal papers",
  "Applying for a visa or residency without delays",
]

const mandatory = [
  "Educational certificates",
  "Personal documents like birth and marriage certificates",
  "Commercial records like contracts and company papers",
]

const docTypes = [
  {
    category: "Educational Certificate Attestation",
    icon: "🎓",
    docs: [
      "Degree certificate attestation",
      "Diploma certificate attestation",
      "Master's and PhD certificates",
      "Academic transcripts",
      "School leaving certificates",
      "Transcript",
      "Transfer Certificate Attestation",
    ],
  },
  {
    category: "Personal Documents Attestation",
    icon: "👤",
    docs: [
      "Birth certificate attestation",
      "Marriage certificate attestation",
      "Divorce certificate attestation",
      "Death certificate attestation",
      "Police Clearance Certificate Attestation US",
      "Medical Certificate Attestation",
      "Affidavits and declarations",
    ],
  },
  {
    category: "Commercial Documents Attestation",
    icon: "⚖️",
    docs: [
      "Power of Attorney",
      "Certificate of Incorporation",
      "Memorandum of Association",
      "Articles of Association",
      "Board Resolution",
      "Commercial Invoice",
      "Business License",
    ],
  },
]

const processRoutes = [
  {
    step: "01",
    title: "Philippines Documents for Use in UAE",
    desc: "This applies to documents issued in the Philippines and required for official use in the UAE.",
    steps: [
      "Prepare your original document and check that names, dates, and other details match your passport and supporting documents",
      "Get authentication from the Philippine Department of Foreign Affairs (DFA). As the Philippines is part of the Apostille Convention, eligible documents receive an Apostille Philippines certificate",
      "Submit the document to the UAE Embassy in the Philippines for attestation",
      "Send the document for MOFA attestation in UAE, the final verification step before UAE authorities can accept it",
    ],
  },
  {
    step: "02",
    title: "UAE Documents for Use in the Philippines",
    desc: "This applies to documents issued in the UAE and required for official use in the Philippines.",
    steps: [
      "Prepare your original document and any supporting documents, verifying names and dates before submission",
      "Get notary attestation where required for legal, commercial, or privately issued documents",
      "Submit the document to the Ministry of Foreign Affairs (MOFA) in UAE for attestation",
      "Get Philippine Embassy attestation in UAE through the Embassy of the Philippines in Abu Dhabi or the Philippine Consulate in Dubai",
    ],
  },
]

const timingFactors = [
  "Processing time depends on the type of document being attested",
  "It also depends on the country where the document was originally issued",
  "The number and type of approvals needed can add to the overall timeline",
]

const feeFactors = [
  "The type of document and the attestation process required",
  "Government fees",
  "Embassy fees",
  "MOFA fee",
  "Notary fee",
  "Translation fee and service charge",
]

const challenges = [
  "Sending damaged, incomplete, or confusing documents",
  "Inconsistencies in name and date among your documents and passport",
  "Not going through DFA authentication for Philippine issued documents",
  "Failure to attach your passport copy, visa copy, and other required documents",
  "Supplying wrong information",
  "Delaying the process until the last minute",
]

const requiredDocs = [
  "Original Document",
  "Copy of Passport",
  "Copy of Emirates ID (if required)",
  "Copy of UAE visa (if required)",
  "Authorization letter in case of submission by a third person",
  "Supporting documents required by the concerned authority",
]

const getStartedSteps = [
  { step: "01", title: "Contact Index Office Services", desc: "Share a copy of your document or tell us what you need it for. We check where it was issued, where it will be used, and the process it requires." },
  { step: "02", title: "Receive a Clear Assessment", desc: "We explain the attestation steps, documents you need, estimated processing time, and government and embassy requirements." },
  { step: "03", title: "We Handle the Attestation Process", desc: "Once you decide to proceed, our team manages the required submissions with the concerned authorities and keeps you updated." },
  { step: "04", title: "Receive Your Attested Documents", desc: "After all required attestations are completed, we return your documents, ready for official use in the UAE or the Philippines." },
]

const whyChoose = [
  { title: "25+ Years of Experience", desc: "More than 25 years of experience in the attestation industry." },
  { title: "Global Coverage", desc: "Assistance for documents of more than 100 countries." },
  { title: "200+ Expert Services", desc: "200+ expert attestation services for personal, academic, and commercial documents." },
  { title: "Professional Consultation", desc: "Professional consultation before starting the process, so you know what comes next." },
  { title: "Constant Feedback", desc: "Constant updates through every step of the process." },
  { title: "Two-Way Attestation", desc: "Attestation for both Philippines to UAE and UAE to Philippines documents, with cautious handling of your originals." },
]

const faqs = [
  { q: "What Is Philippine Embassy Attestation?", a: "Philippine Embassy attestation is the process of authentication of a document from the appropriate authorities to make it valid in other countries." },
  { q: "How Long Does Philippine Embassy Attestation Take?", a: "This process is time-dependent upon the type of document, the country where it was issued, and the approvals needed." },
  { q: "What Are the Philippine Embassy Attestation Charges?", a: "The charges depend on the type of document and the attestation process. Fees include government fees, embassy fees, MOFA fee, notary fee, translation fee, and service charge." },
  { q: "Is DFA authentication required?", a: "Yes. Philippine-issued documents usually need authentication from the Philippine Department of Foreign Affairs (DFA) before UAE Embassy Philippines attestation." },
  { q: "Can someone submit my documents on my behalf?", a: "Yes. An authorised representative or an attestation service provider can usually handle the process for you. Some cases may require an authorisation letter." },
  { q: "Do commercial documents follow the same process?", a: "The main steps are similar, but commercial documents often require additional verification before embassy attestation." },
  { q: "Do I need an appointment for the Philippine Consulate in Dubai?", a: "Some consular services require an appointment. Check the latest Philippine Consulate Dubai attestation appointment requirements before your visit." },
  { q: "Can Index Office Services handle the complete process?", a: "Yes. Index Office Services manages the complete attestation process for Philippine documents used in the UAE and UAE documents used in the Philippines." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Philippine Embassy Attestation in UAE | 25 Years of Trust"
  description="Philippine Embassy Attestation for personal, educational, and commercial documents. Trust Index Office Services and our 25+ years of experience."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .route-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; transition: all 0.25s; }
  .route-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .four-col { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Philippine Embassy Attestation in the UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Philippine Attestation</span>
      <span class="idx-pill">Embassy Attestation</span>
      <span class="idx-pill">25 Years of Trust</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      PHILIPPINE EMBASSY ATTESTATION<br/>IN UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Philippine Embassy Attestation is required whenever you have to use a document from one country as an official document in another. For over 25 years, our services have helped people and organizations with their Philippine certificate attestation needs, whether documents move from the Philippines to the UAE or from the UAE to the Philippines.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-btns">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW / WHAT IS IT ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is Philippine Embassy Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:18px;">
        Philippine Embassy attestation means the document has been certified for use and has undergone all necessary certification procedures. In the case of documents from the Philippines, attestation from the Philippine Embassy is required for the UAE, while documents from the UAE require attestation before being used in the Philippines. We guide you through both directions with the right procedure, documents, and timelines.
      </p>
      <p style="color:#2D3748;font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px;">This is needed for:</p>
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px;">
        {mandatory.map(item => (
          <div style="display:flex;align-items:center;gap:12px;background:#F8FAFF;border:1px solid #eef0f6;border-radius:10px;padding:10px 14px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;">→</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">{item}</p>
          </div>
        ))}
      </div>
      <p style="color:#2D3748;font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px;">When you need this service:</p>
      <div style="display:flex;flex-direction:column;gap:8px;">
        {whoNeeds.map(item => (
          <div style="display:flex;align-items:flex-start;gap:12px;background:#F0FFFE;border:1px solid #B2F5EA;border-radius:10px;padding:10px 14px;">
            <span style="color:#38B2AC;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:1px;">✓</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">{item}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/philippines-flag.webp" alt="Philippine embassy attestation UAE" style="width:100%;height:480px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Philippine Embassy · DFA · UAE Embassy · MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Philippine attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:90px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Which Documents Can Be Attested?"
  description="The documents accepted for Philippine embassy attestation depend on your purpose. They generally fall into three categories: educational, personal, and commercial documents."
  imageSrc="/images/img-1.webp"
  imageAlt="Document types for Philippine attestation"
  docTypes={docTypes}
  country="philippines"
/>

<!-- ════ PROCESS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-7.webp" alt="Philippine embassy attestation process" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Philippine Embassy Attestation Procedure</h2>
      </div>
    </div>

    <!-- Two routes side by side -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px;" class="two-col">
      {processRoutes.map(route => (
        <div class="route-card">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{route.step}</div>
            <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0;">{route.title}</h3>
          </div>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">{route.desc}</p>
          <p style="font-size:0.78rem;font-weight:700;color:#38B2AC;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 10px;">Steps Involved</p>
          <div style="display:flex;flex-direction:column;gap:8px;">
            {route.steps.map((s, idx) => (
              <div style="display:flex;align-items:flex-start;gap:10px;">
                <span style="background:#F0FFFE;border:1px solid #B2F5EA;color:#2D3748;font-weight:800;font-size:0.72rem;width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;">{idx + 1}</span>
                <p style="font-size:0.88rem;color:#4B5563;line-height:1.5;margin:0;">{s}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Required Documents -->
    <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;margin-bottom:24px;">
      <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required for Philippine Embassy Attestation</h3>
      <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">To avoid delays, you need:</p>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:9px;" class="two-col">
        {requiredDocs.map(f => (
          <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
            <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
          </div>
        ))}
      </div>
    </div>

    <!-- Timing & Fees -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;" class="two-col">
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Philippine Embassy Attestation Time</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">The time it takes to complete Philippine embassy attestation depends on several factors:</p>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {timingFactors.map(f => (
            <div style="display:flex;align-items:flex-start;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
            </div>
          ))}
        </div>
      </div>
      <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
        <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Philippine Embassy Attestation Charges</h3>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">The cost of Philippine attestation depends on the type of document and process, and includes:</p>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {feeFactors.map(f => (
            <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
              <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
            </div>
          ))}
        </div>
        <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">At Index Office Services, we give you a clear cost breakdown before you start. You know exactly how much you will pay. There are no surprises, and you can choose the services you need.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ CHALLENGES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;" class="two-col">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What to Watch For</p>
        <h2 style="font-size:1.8rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Mistakes That Will Result in Delay</h2>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:24px;">
          Just a few minor mistakes may result in delays with your application. By taking time to verify your documents before submission, you can prevent extra trips and repeated visits.
        </p>
        <div style="position:relative;border-radius:16px;overflow:hidden;box-shadow:0 12px 32px rgba(0,0,0,0.1);">
          <img
            src="/images/img-40.webp"
            alt="Common mistakes in Philippine document attestation"
            style="width:100%;height:320px;object-fit:cover;display:block;"
          />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
          <div style="position:absolute;bottom:16px;left:16px;right:16px;">
            <p style="color:#fff;font-size:0.88rem;font-weight:700;margin:0;">Avoid these mistakes for a smooth attestation process</p>
          </div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {challenges.map(c => (
          <div style="display:flex;align-items:center;gap:12px;background:#FFF5F5;border:1px solid #FED7D7;border-radius:10px;padding:14px 16px;">
            <span style="color:#E53E3E;font-weight:bold;font-size:1rem;flex-shrink:0;">!</span>
            <p style="font-size:0.9rem;color:#4B5563;line-height:1.5;margin:0;">{c}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ════ GET STARTED ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;text-align:center;">
    <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Simple Process</p>
    <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">How to Get Started with Philippine Embassy Attestation?</h2>
    <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0 auto 44px;max-width:560px;">
      Start the process in four simple steps.
    </p>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;text-align:left;" class="four-col">
      {getStartedSteps.map(s => (
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:22px;position:relative;">
          <div style="font-size:2.8rem;font-weight:900;color:#B2F5EA;line-height:1;margin-bottom:12px;">{s.step}</div>
          <h3 style="font-size:0.88rem;font-weight:800;color:#1A202C;margin:0 0 8px;">{s.title}</h3>
          <p style="font-size:0.8rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE INDEX ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
