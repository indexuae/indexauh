---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const docTypes = [
  {
    title: "Sick Leave Certificates",
    desc: "Companies request verification for a sick leave certificate when an employee takes medical leave. Many employers also ask for sick leave attestation UAE to confirm the leave is genuine.",
  },
  {
    title: "Medical Fitness Certificates",
    desc: "Hospitals issue these certificates to show a person is medically fit for work, travel, or residency procedures.",
  },
  {
    title: "Hospital Medical Reports",
    desc: "Medical reports from clinics or hospitals sometimes require medical certificate attestation before submission to authorities or insurance providers.",
  },
  {
    title: "Health Insurance Medical Documents",
    desc: "Insurance companies review medical documents carefully. Attestation confirms that the report comes from a recognized medical provider.",
  },
  {
    title: "Doctor Issued Medical Certificates",
    desc: "Doctors issue many certificates such as medical certificate for sick leave or treatment confirmation. Authorities may request attestation before accepting these documents.",
  },
]

const uaeSteps = [
  { step: "01", title: "Hospital or Clinic Verification", desc: "The clinic confirms the details on the certificate. Many hospitals in Dubai issue documents like medical certificate Dubai for treatment or sick leave." },
  { step: "02", title: "MOHAP Sick Leave Attestation", desc: "Health authorities review certificates that support employee leave. This process helps companies verify sick leave with medical certificate submissions." },
  { step: "03", title: "MOFA Attestation", desc: "Some organizations still request MOFA verification. The final stamp confirms the authenticity of the certificate." },
]

const foreignSteps = [
  { step: "01", title: "<a href='/notary-attestation-services/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>Notary Attestation</a> in the Home Country", desc: "A notary confirms the document's authenticity before proceeding to the next verification stage." },
  { step: "02", title: "Health Department Verification", desc: "The health department validates the medical report issued by the hospital in the issuing country." },
  { step: "03", title: "Home Country Foreign Affairs Verification", desc: "The foreign affairs department confirms the certificate before embassy submission." },
  { step: "04", title: "UAE Embassy Attestation", desc: "The UAE embassy verifies the document for use inside the country." },
  { step: "05", title: "<a href='/mofa-attestation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>MOFA Attestation in UAE</a>", desc: "The final stage completes the attestation process and makes the document valid for official use in the UAE." },
]

const challenges = [
  { title: "Missing Hospital Stamp", desc: "Some hospitals forget to include the official seal. Our team checks every document before submission." },
  { title: "Incorrect Certificate Format", desc: "Authorities expect specific formats for certificates such as sick leave certificate in Dubai. We review the document and guide clients before processing." },
  { title: "Rejection by Health Authorities", desc: "A certificate may face rejection during MOH sick leave attestation. Our specialists identify the issue and arrange corrections." },
  { title: "Delays in Embassy Attestation", desc: "Embassy procedures sometimes take time. Our experience helps speed up document movement between departments." },
]

const gettingStartedSteps = [
  { step: "01", title: "Contact Our Team", desc: "Reach our office through phone or email. Our specialists explain the requirements." },
  { step: "02", title: "Share Your Certificate", desc: "Send a copy of your document — sick leave certificate, medical certificates, or other medical documents." },
  { step: "03", title: "Document Review", desc: "Our team checks the certificate and confirms the required attestation steps before processing." },
  { step: "04", title: "Attestation Process Begins", desc: "We handle submission to authorities and keep you informed about progress at every stage." },
  { step: "05", title: "Receive Your Attested Certificate", desc: "After completion, your document becomes ready for official use in the UAE." },
]

const whyChooseUs = [
  "25+ years of experience in <a href='/certificate-attestation-in-the-uae/' style='color:#fff;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>UAE attestation services</a>",
  "Expert support for medical certificate attestation",
  "Free document pick up and delivery across UAE",
  "Fast and smooth processing support",
  "Guidance for MOH and MOFA procedures",
  "Support for UAE and foreign medical certificates",
  "Secure handling of all documents",
  "Clear updates during every stage",
  "Offices in Abu Dhabi and Dubai",
  "Trusted by thousands of clients across the UAE",
]

const faqs = [
  { q: "What Documents Are Needed for MOHAP Attestation?", a: "Authorities usually request the original medical certificate for sick leave, passport copy, and hospital details." },
  { q: "What Happens With Handwritten Certificates?", a: "Authorities review handwritten medical documents carefully. In many cases, hospitals issue a typed version to complete the attestation process." },
  { q: "Do Companies Accept Medical Certificates Without Attestation?", a: "Some employers accept hospital issued certificates directly. However, many organizations request verification or sick leave validation from health authorities." },
  { q: "What Details Should a Valid Medical Certificate Include?", a: "A valid certificate normally includes the patient name, treatment date, doctor signature, hospital stamp, and the period of recommended rest." },
  { q: "Can I apply without visiting an office?", a: "Many service providers allow document submission through online or courier support. Contact our team and we will guide you through the process remotely." },
]
---

<BaseLayout
  title="Medical Certificate Attestation Services UAE | Indexauh"
  description="Medical certificate attestation in UAE for sick leave, MOHAP and MOFA approval. Trust Indexauh for your attestation process. Call now!"
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .doc-type-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; transition: all 0.25s; }
  .doc-type-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.06); transform: translateY(-3px); }
  .step-card { display: flex; align-items: flex-start; gap: 18px; padding: 20px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .warning-item { display: flex; align-items: flex-start; gap: 10px; padding: 14px 16px; background: #FFF5F5; border: 1px solid #FEB2B2; border-radius: 10px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .benefits-grid { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .benefits-grid { grid-template-columns: 1fr !important; }
    .offices-flex { flex-direction: column !important; }
    .hero-btns { flex-direction: column !important; align-items: stretch !important; }
    .hero-btns a { text-align: center; justify-content: center; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <img
    src="/images/img-16.webp"
    alt="Medical Certificate Attestation in UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.88) 0%,rgba(45,55,72,0.82) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Attestation Services</span>
      <span class="idx-pill">MOHAP Approved</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">UAE MOFA</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      MEDICAL CERTIFICATE<br/>ATTESTATION IN UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:640px;">
      Medical certificate attestation confirms that a medical document is genuine and accepted by UAE authorities. Hospitals, employers, and government departments request it for official use. IndexAUH supports individuals across the UAE with this process. With over 25 years of experience, our team handles medical certificate attestation quickly and smoothly.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-btns">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;margin-bottom:52px;" class="split-grid">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
          <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
        </p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Types of Medical Certificates We Attest</h2>
        <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:0;">
          Different medical documents need verification before use in the UAE. Attestation confirms the authenticity of the certificate and the issuing authority.
        </p>
      </div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-16.webp" alt="Medical certificate attestation documents" style="width:100%;height:280px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">MOHAP · MOFA · UAE Embassy</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete medical attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:78px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;" class="benefits-grid">
      {docTypes.map(d => (
        <div class="doc-type-card">
          <div style="width:40px;height:40px;border-radius:10px;background:#F0FFFE;border:1px solid #B2F5EA;display:flex;align-items:center;justify-content:center;margin-bottom:14px;">
            <span style="color:#38B2AC;font-size:1.2rem;">🏥</span>
          </div>
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;">{d.title}</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.65;margin:0;">{d.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ STEP BY STEP PROCESS ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Authentication Workflow</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">Step by Step Medical Certificate Attestation Process in UAE</h2>
      <p style="color:#6B7280;font-size:1.05rem;max-width:680px;margin:0 auto;">The process differs depending on whether the certificate was issued in the UAE or abroad. Each stage confirms the authenticity of the document.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;" class="split-grid">
      <!-- UAE Issued -->
      <div>
        <div style="background:#2D3748;border-radius:14px;padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;">
          <span style="background:#38B2AC;color:#fff;font-size:0.75rem;font-weight:800;padding:4px 10px;border-radius:9999px;white-space:nowrap;">Route A</span>
          <h3 style="color:#fff;font-size:0.95rem;font-weight:800;margin:0;">For UAE Issued Medical Certificates</h3>
        </div>
        <p style="color:#4B5563;font-size:0.88rem;line-height:1.7;margin:0 0 16px;">A UAE medical certificate follows a simpler process since the document already comes from a local hospital.</p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {uaeSteps.map(s => (
            <div class="step-card">
              <div style="width:40px;height:40px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
              <div>
                <p style="font-size:0.95rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
                <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Foreign Issued -->
      <div>
        <div style="background:#2D3748;border-radius:14px;padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;">
          <span style="background:#E53E3E;color:#fff;font-size:0.75rem;font-weight:800;padding:4px 10px;border-radius:9999px;white-space:nowrap;">Route B</span>
          <h3 style="color:#fff;font-size:0.95rem;font-weight:800;margin:0;">For Foreign Issued Medical Certificates</h3>
        </div>
        <p style="color:#4B5563;font-size:0.88rem;line-height:1.7;margin:0 0 16px;">People moving to the UAE sometimes bring medical documents issued abroad. These documents require several verification stages.</p>
       <div style="display:flex;flex-direction:column;gap:12px;">
  {foreignSteps.map(s => (
    <div class="step-card">
      <div style="width:40px;height:40px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
      <div>
        <p style="font-size:0.95rem;font-weight:700;color:#1A202C;margin:0 0 4px;" set:html={s.title}></p>
        <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
      </div>
    </div>
  ))}
</div>
      </div>
    </div>
  </div>
</section>

<!-- ════ MOHAP SICK LEAVE ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:0.9fr 1.3fr;gap:48px;align-items:center;" class="split-grid">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-52.webp" alt="MOHAP sick leave attestation UAE" style="width:100%;height:400px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.65) 100%);"></div>
        <div style="position:absolute;bottom:18px;left:18px;right:18px;">
          <p style="color:#fff;font-size:0.98rem;font-weight:700;margin:0;line-height:1.4;">MOHAP · Sick Leave Validation · UAE</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Official Process</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 16px;">MOHAP Attestation for Sick Leave Certificates</h2>
        <p style="color:#4B5563;font-size:1rem;line-height:1.8;margin-bottom:16px;">Many companies ask employees to verify medical leave certificates through MOHAP. This step supports proper sick leave validation.</p>
        <p style="color:#4B5563;font-size:1rem;line-height:1.8;margin-bottom:16px;">A doctor may issue a medical certificate for sick leave after treatment. However, organizations sometimes request verification from health authorities. Therefore, employees submit the certificate through the official MOHAP system.</p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <div style="display:flex;align-items:flex-start;gap:12px;background:#fff;border:1px solid #B2F5EA;border-radius:10px;padding:12px 16px;">
            <span style="width:24px;height:24px;border-radius:50%;background:#38B2AC;color:#fff;font-size:0.75rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;">✓</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">The authority checks the hospital details, doctor license, and treatment date.</p>
          </div>
          <div style="display:flex;align-items:flex-start;gap:12px;background:#fff;border:1px solid #B2F5EA;border-radius:10px;padding:12px 16px;">
            <span style="width:24px;height:24px;border-radius:50%;background:#38B2AC;color:#fff;font-size:0.75rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;">✓</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">After approval, the certificate becomes valid for employer records.</p>
          </div>
          <div style="display:flex;align-items:flex-start;gap:12px;background:#fff;border:1px solid #B2F5EA;border-radius:10px;padding:12px 16px;">
            <span style="width:24px;height:24px;border-radius:50%;background:#38B2AC;color:#fff;font-size:0.75rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;">✓</span>
            <p style="font-size:0.88rem;color:#374151;line-height:1.5;margin:0;">This step protects organizations from false medical claims and ensures accurate verification.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ COMMON CHALLENGES ════ -->
<section style="background:#FFF5F5;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(229,62,62,0.01) 1px,transparent 1px),linear-gradient(90deg,rgba(229,62,62,0.01) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;" class="split-grid">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-40.webp" alt="Common challenges in medical certificate attestation" style="width:100%;height:400px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(154,44,44,0.65) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Avoid Costly Mistakes</p>
          <p style="color:#FEB2B2;font-size:0.75rem;margin:0;">Small errors cause major delays</p>
        </div>
      </div>
      <div>
        <p style="color:#C53030;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Verification Warning</p>
        <h2 style="font-size:2rem;font-weight:900;color:#9B2C2C;margin:0 0 16px;">Common Challenges and How We Solve Them</h2>
        <p style="color:#9B2C2C;font-size:0.95rem;line-height:1.7;margin-bottom:24px;">Medical document verification can confuse many people. Several issues appear during the attestation process. Our team is experienced in resolving each of these challenges quickly.</p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {challenges.map(c => (
            <div class="warning-item">
              <span style="color:#E53E3E;font-weight:bold;font-size:1rem;flex-shrink:0;margin-top:1px;">⚠</span>
              <div>
                <p style="font-size:0.88rem;font-weight:700;color:#9B2C2C;margin:0 0 3px;">{c.title}</p>
                <p style="font-size:0.83rem;color:#9B2C2C;line-height:1.5;margin:0;">{c.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ HOW TO GET STARTED ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
