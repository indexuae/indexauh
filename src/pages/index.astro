<BaseLayout title="Certificate Attestation Services in UAE — 25 Years of Trust">
<style>
  .idx-pill{background:rgba(255,255,255,0.14);border:1px solid rgba(255,255,255,0.28);color:#fff;font-size:0.9rem;padding:5px 14px;border-radius:9999px;font-weight:500;white-space:nowrap;}
  .idx-form input,.idx-form select,.idx-form textarea{width:100%;border:1px solid #e5e7eb;border-radius:10px;padding:11px 14px;font-size:1rem;color:#374151;outline:none;font-family:inherit;background:#fff;box-sizing:border-box;}
  .idx-form input:focus,.idx-form select:focus,.idx-form textarea:focus{border-color:#38B2AC;box-shadow:0 0 0 3px rgba(56,178,172,0.15);}
  .idx-form textarea{resize:none;}
  .idx-submit{width:100%;background:#2D3748;color:#fff;font-weight:700;padding:13px;border-radius:10px;border:none;cursor:pointer;font-size:0.95rem;letter-spacing:0.04em;transition:background 0.2s;}
  .idx-submit:hover{background:#1A202C;}

  /* ── Infinite loop slider ── */
  #slideTrack{display:flex;will-change:transform;}
  .hero-slide{min-width:100%;box-sizing:border-box;}

  /* ── Hero image wrapper — padding contains the overflow badges ── */
  .hero-fixed-img{
  flex-shrink:0;
  width:420px;
  position:relative;
  align-self:center;
}
.hero-fixed-img img{
  width:100%;
  height:420px;
  object-fit:cover;
  display:block;
  /* no border-radius, no box-shadow — blends into the section background */
}
  .sdot{width:8px;height:8px;border-radius:9999px;background:rgba(255,255,255,0.35);border:none;cursor:pointer;padding:0;transition:background 0.3s,width 0.3s;display:inline-block;}
  .sdot.on{background:#38B2AC;width:24px;}
  .sarr{width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.28);color:#fff;font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.2s;flex-shrink:0;}
  .sarr:hover{background:rgba(255,255,255,0.25);}

  /* ── Hero diagonal (desktop only) ── */
  .hero-diagonal{display:none;}
  @media(min-width:768px){.hero-diagonal{display:block;}}

  /* ── Hero image responsive ── */
 @media(max-width:767px){
  .hero-fixed-img{
    width:100% !important;
    max-width:360px;
    margin:0 auto;
  }
 .hero-fixed-img img{
  height:auto !important;
  object-fit:contain;
  object-position:center;
}
}

  /* ── Service cards ── */
  .svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
  @media(max-width:1024px){.svc-grid{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:600px){.svc-grid{grid-template-columns:1fr;}}
  .svc-card{border:1px solid #eef0f6;border-radius:16px;overflow:hidden;background:#fff;transition:box-shadow 0.25s,transform 0.25s,border-color 0.25s;}
  .svc-card:hover{box-shadow:0 16px 48px rgba(45,55,72,0.13);transform:translateY(-5px);border-color:#B2F5EA;}
  .svc-card-img{width:100%;height:180px;object-fit:cover;display:block;}
  .svc-card-body{padding:20px 22px 22px;}
  .svc-card-img-wrap{position:relative;overflow:hidden;}
  .svc-card-img-wrap::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,transparent 50%,rgba(26,32,44,0.55));}

  /* ── Attestation card grid ── */
  .att-card{display:flex;flex-direction:column;align-items:center;text-align:center;background:#fff;border:1px solid #e0e7ef;border-radius:16px;padding:28px 16px 20px;text-decoration:none;transition:all 0.25s;}
  .att-card:hover{background:#fff;border-color:#38B2AC;transform:translateY(-4px);box-shadow:0 12px 32px rgba(56,178,172,0.15);}
  .att-card:hover .att-card-icon svg{stroke:#38B2AC;}

  .att-card-icon{width:80px;height:80px;background:#F0FFFE;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:16px;transition:background 0.25s;flex-shrink:0;}
  .att-card:hover .att-card-icon{background:rgba(56,178,172,0.15);}
  .att-card-label{font-size:0.8rem;font-weight:600;color:#1A202C;line-height:1.4;}
  .att-card-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:20px;}
  @media(max-width:1024px){.att-card-grid{grid-template-columns:repeat(4,1fr);}}
  @media(max-width:768px){.att-card-grid{grid-template-columns:repeat(3,1fr);}}
  @media(max-width:480px){.att-card-grid{grid-template-columns:repeat(2,1fr);}}

  /* ── Country grid ── */
  .country-chip{background:#F0FFFE;border:1px solid #B2F5EA;border-radius:8px;padding:8px 14px;font-size:0.98rem;color:#1A202C;font-weight:500;text-align:center;}

  /* ── FAQ ── */
  .faq-item{border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;}
  .faq-q{width:100%;background:#fff;border:none;text-align:left;padding:18px 20px;font-size:0.9rem;font-weight:600;color:#1A202C;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:12px;}
  .faq-a{padding:0 20px;max-height:0;overflow:hidden;transition:max-height 0.35s ease,padding 0.2s;}
  .faq-a.open{max-height:200px;padding:0 20px 16px;}
  .faq-icon{font-size:1.1rem;transition:transform 0.3s;flex-shrink:0;}
  .faq-item.open .faq-icon{transform:rotate(45deg);}

  /* ── Why us ── */
  .why-card{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:14px;padding:22px;display:flex;align-items:flex-start;gap:14px;}
  .why-card:hover{background:rgba(255,255,255,0.14);}

  /* ── Responsive flex image panels ── */
  .panel-img{
    flex-shrink:0;
    width:min(420px, 100%);
    max-width:100%;
  }
  .panel-img img{
    width:100%;
    object-fit:cover;
    border-radius:20px;
    display:block;
  }
  .panel-img-sm{
    flex-shrink:0;
    width:min(380px, 100%);
    max-width:100%;
  }
  .panel-img-sm img{
    width:100%;
    object-fit:cover;
    border-radius:20px;
    display:block;
  }

  /* ── About stat box ── */
  .about-stat-box{
    flex-shrink:0;
    width:min(340px, 100%);
    max-width:100%;
    height:260px;
    position:relative;
  }

  /* ── Social icons branded hover ── */
  .soc-icon{width:38px;height:38px;border-radius:10px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;color:#fff;text-decoration:none;transition:background 0.25s,border-color 0.25s,color 0.25s;flex-shrink:0;}
  .soc-instagram:hover{background:linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);border-color:transparent;color:#fff;}
  .soc-whatsapp:hover{background:#25D366;border-color:#25D366;color:#fff;}
  .soc-facebook:hover{background:#1877F2;border-color:#1877F2;color:#fff;}
  .soc-youtube:hover{background:#FF0000;border-color:#FF0000;color:#fff;}
  .soc-x:hover{background:#000;border-color:#000;color:#fff;}
  .soc-linkedin:hover{background:#0A66C2;border-color:#0A66C2;color:#fff;}
  .sec-inner{position:relative;z-index:1;}

  /* ── Formation / PCC link cards hover ── */
  .link-card{display:flex;align-items:center;gap:12px;border:1px solid #e0e7ef;border-radius:12px;padding:14px 18px;font-size:1rem;color:#1A202C;font-weight:500;text-decoration:none;transition:all 0.2s;}
  .link-card:hover{border-color:#38B2AC;box-shadow:0 4px 16px rgba(56,178,172,0.12);}
  .link-card-pcc{background:#F8FAFF;}
  .link-card-formation{background:#fff;}
</style>

