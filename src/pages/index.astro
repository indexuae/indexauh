<script>
(function(){
  // ── Infinite loop slider ──
  const track = document.getElementById('slideTrack') as HTMLElement
  const dots  = Array.from(document.querySelectorAll('.sdot')) as HTMLElement[]
  const total = dots.length
  if(!track || total===0) return

  const origSlides = Array.from(track.children) as HTMLElement[]
  const firstClone = origSlides[0].cloneNode(true) as HTMLElement
  const lastClone  = origSlides[total-1].cloneNode(true) as HTMLElement
  track.appendChild(firstClone)
  track.insertBefore(lastClone, origSlides[0])

  let cur = 1
  let transitioning = false
  let timer: ReturnType<typeof setInterval>

  function setPos(idx: number, animate: boolean){
    track.style.transition = animate ? 'transform 0.6s cubic-bezier(0.4,0,0.2,1)' : 'none'
    track.style.transform  = `translateX(-${idx * 100}%)`
  }

  function updateDots(realIdx: number){
    dots.forEach(d => d.classList.remove('on'))
    dots[realIdx].classList.add('on')
  }

  function go(direction: number){
    if(transitioning) return
    transitioning = true
    cur += direction
    setPos(cur, true)
    updateDots((cur - 1 + total) % total)
  }

  track.addEventListener('transitionend', ()=>{
    if(cur === total + 1){ cur = 1; setPos(cur, false) }
    if(cur === 0)        { cur = total; setPos(cur, false) }
    transitioning = false
  })

  function goTo(realIdx: number){
    if(transitioning) return
    transitioning = true
    cur = realIdx + 1
    setPos(cur, true)
    updateDots(realIdx)
  }

  function resetTimer(){
    clearInterval(timer)
    timer = setInterval(()=> go(1), 4500)
  }

  setPos(cur, false)
  resetTimer()

  document.getElementById('sNext')?.addEventListener('click',()=>{ go(1); resetTimer() })
  document.getElementById('sPrev')?.addEventListener('click',()=>{ go(-1); resetTimer() })
  dots.forEach((d,i)=> d.addEventListener('click',()=>{ goTo(i); resetTimer() }))

  // ── FAQ accordion ──
  document.querySelectorAll('.faq-item').forEach(item=>{
    item.querySelector('.faq-q')?.addEventListener('click',()=>{
      const isOpen = item.classList.contains('open')
      document.querySelectorAll('.faq-item').forEach(x=>{ x.classList.remove('open'); (x.querySelector('.faq-a') as HTMLElement).classList.remove('open') })
      if(!isOpen){ item.classList.add('open'); (item.querySelector('.faq-a') as HTMLElement).classList.add('open') }
    })
  })
})()
</script>

