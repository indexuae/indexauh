// Strapi Testimonials Fetch
let strapiTestimonials = [];
try {
  const strapiUrl = import.meta.env.STRAPI_URL || process.env.STRAPI_URL || "http://localhost:1337";
  if (strapiUrl) {
    const res = await fetch(`${strapiUrl}/api/testimonials?populate=img`);
    if (res.ok) {
      const data = await res.json();
      let fetched = data.data.map((item: any) => ({
        text: item.text,
        by: item.by,
        role: item.role,
        img: item.img?.url ? `${strapiUrl}${item.img.url}` : '/images/img-66.webp'
      }));
      if (fetched.length > 0 && fetched.length < 5) {
        while (fetched.length < 5) {
          fetched = [...fetched, ...fetched];
        }
      }
      strapiTestimonials = fetched;
    }
  }
} catch (e) {
  console.warn("Could not fetch testimonials from Strapi. Falling back to static data.");
}

