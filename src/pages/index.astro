<script define:vars={{ strapiTestimonials }}>
(function(){
  const testimonials = strapiTestimonials && strapiTestimonials.length > 0 ? strapiTestimonials : [
    { text: "Index Office Services made our attestation process seamless. Got everything done in record time without any hassle.", by: "Arjun Menon", role: "Business Owner, Dubai", img: "/images/img-66.webp" },
    { text: "Professional team, excellent communication. They handled our embassy attestation perfectly from start to finish.", by: "Sarah Al-Rashid", role: "HR Manager, Abu Dhabi", img: "/images/img-67.webp" },
    { text: "I needed a Police Clearance Certificate urgently. Index Office Services delivered faster than I expected. Highly recommend!", by: "Rajesh Kumar", role: "IT Professional, Sharjah", img: "/images/img-68.webp" },
    { text: "We used their company formation service for our Dubai mainland setup. The team guided us through every step with clarity.", by: "Mohammed Al-Farsi", role: "Entrepreneur, Dubai", img: "/images/img-69.webp" },
    { text: "MOFA attestation done without me having to step out of my office even once. Truly doorstep service!", by: "Priya Nair", role: "Finance Executive, Dubai", img: "/images/img-70.webp" },
    { text: "Reliable, honest and efficient. 25 years of experience really shows in how they handle even complex cases.", by: "Thomas George", role: "Legal Consultant, UAE", img: "/images/img-71.webp" },
    { text: "The apostille service was handled perfectly. Very professional team with great attention to detail.", by: "Amina Khalid", role: "Educator, Abu Dhabi", img: "/images/img-72.webp" },
    { text: "I've referred 5 colleagues already. Best attestation service in UAE, no question.", by: "Vikram Sharma", role: "Project Manager, Ajman", img: "/images/img-73.webp" },
  ];

  const stage = document.getElementById('testimonialStage');
  const prevBtn = document.getElementById('tPrev');
  const nextBtn = document.getElementById('tNext');
  if (!stage) return;

  let current = 0;
  const CARD_W = window.innerWidth >= 640 ? 320 : 260;

  function getPosition(idx) {
    let pos = idx - current;
    const half = Math.floor(testimonials.length / 2);
    if (pos > half) pos -= testimonials.length;
    if (pos < -half) pos += testimonials.length;
    return pos;
  }

  function renderCards() {
    stage.innerHTML = '';
    for (let i = 0; i < testimonials.length; i++) {
      const pos = getPosition(i);
      if (Math.abs(pos) > 2) continue;
      const t = testimonials[i];
      const isCenter = pos === 0;
      const xOffset = pos * (CARD_W * 0.72);
      const yOffset = isCenter ? -30 : (pos % 2 !== 0 ? 10 : -10);
      const rotate = isCenter ? 0 : pos * 2;
      const scale = isCenter ? 1 : 1 - Math.abs(pos) * 0.08;
      const zIndex = 10 - Math.abs(pos);
      const opacity = 1 - Math.abs(pos) * 0.25;

      const card = document.createElement('div');
      card.style.cssText = `
        position:absolute;
        left:50%; top:50%;
        width:${CARD_W}px;
        transform: translate(-50%,-50%) translateX(${xOffset}px) translateY(${yOffset}px) rotate(${rotate}deg) scale(${scale});
        z-index:${zIndex};
        opacity:${opacity};
        transition: all 0.2s cubic-bezier(0.4,0,0.2,1);
        cursor:${isCenter ? 'default' : 'pointer'};
        background:${isCenter ? '#2D3748' : '#fff'};
        border:2px solid ${isCenter ? '#38B2AC' : '#e0e7ef'};
        border-radius:20px;
        padding:28px;
        box-shadow:${isCenter ? '0 20px 48px rgba(45,55,72,0.25)' : '0 4px 16px rgba(45,55,72,0.08)'};
        box-sizing:border-box;
      `;

      card.innerHTML = `
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:18px;">
          <img src="${t.img}" alt="${t.by}" style="width:48px;height:48px;border-radius:50%;object-fit:cover;border:2px solid ${isCenter ? '#38B2AC' : '#e0e7ef'};" />
          <div>
            <p style="font-weight:700;font-size:1.05rem;color:${isCenter ? '#fff' : '#1A202C'};margin:0;">${t.by}</p>
            <p style="font-size:0.75rem;color:${isCenter ? '#81E6D9' : '#6B7280'};margin:0;">${t.role}</p>
          </div>
        </div>
        <div style="color:#38B2AC;font-size:1.8rem;line-height:1;margin-bottom:8px;">"</div>
        <p style="font-size:1.05rem;line-height:1.75;color:${isCenter ? '#B2F5EA' : '#4B5563'};margin:0 0 16px;">${t.text}</p>
        <div style="display:flex;gap:3px;">
          ${[1,2,3,4,5].map(() => `<svg width="14" height="14" viewBox="0 0 24 24" fill="${isCenter ? '#38B2AC' : '#F59E0B'}" style="flex-shrink:0;"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`).join('')}
        </div>
      `;

      if (!isCenter) {
        card.addEventListener('click', () => { current = i; renderCards(); });
      }
      stage.appendChild(card);
    }
  }

  prevBtn?.addEventListener('click', () => { current = (current - 1 + testimonials.length) % testimonials.length; renderCards(); });
  nextBtn?.addEventListener('click', () => { current = (current + 1) % testimonials.length; renderCards(); });

  prevBtn?.addEventListener('mouseenter', () => { if(prevBtn) { prevBtn.style.background='#2D3748'; prevBtn.style.borderColor='#2D3748'; prevBtn.style.color='#fff'; }});
  prevBtn?.addEventListener('mouseleave', () => { if(prevBtn) { prevBtn.style.background='#fff'; prevBtn.style.borderColor='#e0e7ef'; prevBtn.style.color='#2D3748'; }});
  nextBtn?.addEventListener('mouseenter', () => { if(nextBtn) { nextBtn.style.background='#2D3748'; nextBtn.style.borderColor='#2D3748'; }});
  nextBtn?.addEventListener('mouseleave', () => { if(nextBtn) { nextBtn.style.background='#38B2AC'; nextBtn.style.borderColor='#38B2AC'; }});

  let autoplay = setInterval(() => { current = (current + 1) % testimonials.length; renderCards(); }, 2500);
  stage.addEventListener('mouseenter', () => clearInterval(autoplay));
  stage.addEventListener('mouseleave', () => {
    autoplay = setInterval(() => { current = (current + 1) % testimonials.length; renderCards(); }, 2500);
  });

  renderCards();
})();
</script>

