---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1",  label: "US +1" },
  { code: "+973", label: "BH +973" },
]

const purposes = [
  { icon: "💼", title: "Employment in UAE/GCC", desc: "UAE and GCC employers require attested US educational and professional certificates before approving employment." },
  { icon: "🎓", title: "Education & Licensing", desc: "Universities and professional licensing bodies require attested US degrees and qualifications for recognition." },
  { icon: "👪", title: "Family & Residency Visa", desc: "Birth and marriage certificates issued in the USA must be attested for family visa and residency applications in UAE." },
  { icon: "🏢", title: "Business Setup in UAE", desc: "US commercial documents require attestation for company registration and business activities in the UAE and GCC." },
  { icon: "🛂", title: "Immigration & Relocation", desc: "Anyone relocating from the USA to the UAE or GCC needs attested personal documents for legal immigration purposes." },
  { icon: "📜", title: "Legal & Civil Matters", desc: "US-issued legal documents — powers of attorney, affidavits, divorce decrees — require attestation for use in the UAE." },
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Birth certificate attestation",
      "Marriage certificate attestation",
      "Divorce certificate / decree attestation",
      "Death certificate attestation",
      "Police clearance / FBI background check",
      "Affidavit attestation",
      "Medical certificate attestation",
      "Power of Attorney",
    ]
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "US degree certificate attestation",
      "Diploma certificate attestation",
      "Transcripts and mark sheets",
      "Professional qualification certificates",
      "Nursing degree certificate attestation",
      "Engineering degree certificate attestation",
      "School leaving certificates",
    ]
  },
  {
    category: "Commercial Documents",
    icon: "🏢",
    docs: [
      "Certificate of Incorporation",
      "Memorandum of Association (MOA)",
      "Articles of Association (AOA)",
      "Board Resolutions",
      "Commercial Invoices",
      "Business contracts",
      "Commercial License",
      "Company authorization letters",
    ]
  },
]

const steps = [
  { step: "01", title: "Notarization (US Notary Public)", desc: "The document is certified by a US notary public. This is the first step that confirms the document's legitimacy before further processing." },
  { step: "02", title: "Secretary of State Certification", desc: "For state-issued documents, certification is obtained from the Secretary of State in the state where the document was issued." },
  { step: "03", title: "US Department of State Authentication", desc: "The document is submitted to the US Department of State in Washington D.C. for authentication, confirming the state-level certification is genuine." },
  { step: "04", title: "<a href='/embassy-attestation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>UAE Embassy Attestation</a> (Washington D.C.)", desc: "The UAE Embassy in Washington D.C. affixes an official UAE government sticker and seal, confirming the document's authenticity and compliance with UAE regulations." },
  { step: "05", title: "<a href='/mofa-attestation-in-uae/' style='color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>UAE MOFA Attestation</a>", desc: "Upon arrival in the UAE, the document is attested by the Ministry of Foreign Affairs (MOFA) for final legal acceptance and use within the UAE." },
]
const benefits = [
  { title: "25+ Years of Experience", desc: "Over two decades of handling USA certificate attestation for the UAE, with deep knowledge of US Department of State and UAE Embassy procedures." },
  { title: "End-to-End Remote Handling", desc: "We manage the entire USA attestation process remotely — from US notarization and State Department authentication to UAE Embassy and MOFA attestation." },
  { title: "Safe & Confidential", desc: "Your documents are handled with strict confidentiality, secure physical transfer protocols, and tracked at every stage of the international process." },
  { title: "Competitive Pricing", desc: "Transparent, affordable pricing with no hidden charges. Costs depend on document type, state of issuance, urgency and embassy charges." },
  { title: "Doorstep Pickup & Delivery", desc: "We offer doorstep collection and delivery options across the UAE so you never have to leave your office or home to complete the process." },
  { title: "Arabic Translation Available", desc: "If your US documents need certified Arabic translation for UAE submission, we coordinate translation alongside attestation as a single seamless service." },
]

const timingFactors = [
  "Type of document — state-issued, federal, or commercial",
  "State of origin — processing times vary by US state",
  "US Department of State workload and authentication queue",
  "UAE Embassy in Washington D.C. processing timelines",
  "Whether certified Arabic translation is required",
  "Choice of standard (2–3 weeks) or express processing",
]

const faqs = [
  { q: "Can the UAE accept a US apostille instead of full attestation?", a: "No. The UAE is not a member of the Hague Apostille Convention. A US apostille alone is not accepted in the UAE. All US documents must go through the full attestation process — notarization, Secretary of State certification, US Department of State authentication, UAE Embassy attestation, and UAE MOFA attestation." },
  { q: "Do I need to be present in the USA for the attestation process?", a: "No. Index Office Services can handle the complete USA attestation process on your behalf without you being present in the USA. We coordinate with US notary and authentication offices and manage all embassy and MOFA steps remotely." },
  { q: "What is the difference between state documents and federal documents for USA attestation?", a: "State documents — such as birth certificates, marriage certificates, and divorce decrees — require certification from the Secretary of State of the issuing state before US Department of State authentication. Federal documents — such as FBI results and federal licenses — go directly to the US Department of State without the state-level step." },
  { q: "How long does USA certificate attestation for UAE take?", a: "Standard processing typically takes 2–3 weeks depending on document type, state of origin, and embassy workload. Express service options are available for urgent cases. Contact us for a realistic timeline based on your specific documents." },
  { q: "Does my US document need Arabic translation?", a: "If your document is in English and will be submitted to Arabic-speaking UAE authorities, a certified Arabic translation may be required. Our team confirms whether translation is necessary based on your document and the requesting authority's requirements, and we coordinate translation alongside attestation." },
  { q: "What documents are required for USA certificate attestation?", a: "You typically need the original certificate or notarized copy, a copy of your passport, and an authorization letter if submitting through a representative. Additional supporting documents may be required depending on the document type and the authority requesting attestation." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="US Certificate Attestation in UAE | 25+ Years of Expertise"
  description="Get US Certificate Attestation in UAE for degree, marriage, birth & commercial documents. Trusted support backed by 25+ years of experience."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .purpose-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; transition: all 0.25s; }
  .purpose-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 260px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-91.webp"
    alt="USA Certificate Attestation in UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 12px;">
      USA CERTIFICATE ATTESTATION IN UAE
    </h1>
    <p style="color:#38B2AC;font-size:1.05rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 20px;">US Document Attestation for UAE | 25 Years of Trust</p>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      If you have documents issued in the USA that need to be used in the UAE or GCC, you must complete the full USA certificate attestation process. Index Office Services handles every step — from US Department of State authentication to UAE Embassy attestation and MOFA — quickly, securely and completely remotely.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is USA Certificate Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        USA certificate attestation is the process of verifying and legalizing documents issued in the United States so they are officially accepted in the UAE and GCC countries. The process involves multiple stages of authentication — from US state and federal authorities to the UAE Embassy in Washington D.C. and UAE MOFA.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        The UAE is not a member of the Hague Apostille Convention. This means a US apostille alone is not sufficient for use in the UAE. All US documents must complete the full embassy attestation and MOFA process before they are legally accepted by UAE authorities.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:20px;">
        With over 25 years of experience, Index Office Services manages the complete USA attestation process from the UAE — without you needing to be physically present in the United States at any stage.
      </p>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Key Insight — Apostille Not Accepted in UAE</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          The UAE is NOT a Hague Convention member. A US apostille is not valid for UAE use. Every US document must go through notarization, Secretary of State certification, US Department of State authentication, UAE Embassy attestation in Washington D.C., and final UAE MOFA attestation.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/usa-flag.webp" alt="USA document attestation UAE" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">State Dept · UAE Embassy · MOFA UAE</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete USA attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY IS USA ATTESTATION REQUIRED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-11.webp" alt="Why USA attestation is required for UAE" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Why USA Attestation Matters</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Work · Family · Education · Business</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Core Reasons</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Why Is USA Certificate Attestation Required?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          UAE and GCC authorities do not accept unattested US documents for any official purpose. Whether you are seeking employment, enrolling in education, sponsoring family members, or registering a business in the UAE, your US documents must be officially verified and attested before they are accepted.
        </p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px;">
          {purposes.map(p => (
            <div class="purpose-card">
              <div style="font-size:1.6rem;margin-bottom:10px;">{p.icon}</div>
              <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 6px;">{p.title}</h3>
              <p style="font-size:0.76rem;color:#4B5563;line-height:1.55;margin:0;">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Our USA Attestation Services"
  description="Index AUH provides USA certificate attestation services for all document categories — personal, educational, and commercial. Each document type follows a specific path depending on whether it is state-issued or federally issued. Our team confirms the correct attestation process before starting."
  imageSrc="/images/img-16.webp"
  imageAlt="Document types for USA attestation"
  docTypes={docTypes}
  country="uae"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-1.webp" alt="USA attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">USA Certificate Attestation Process for UAE</h2>
      </div>
    </div>

    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;">
      <div style="display:flex;flex-direction:column;gap:14px;">
  {steps.map(s => (
    <div class="step-card">
      <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
      <div>
        <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;" set:html={s.title}></p>
        <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
      </div>
    </div>
  ))}
</div>

      <div>
        <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.12);margin-bottom:24px;">
          <img src="/images/img-8.webp" alt="USA attestation timing" style="width:100%;height:260px;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.78) 100%);"></div>
          <div style="position:absolute;bottom:18px;left:18px;right:18px;">
            <p style="color:#fff;font-size:1.05rem;font-weight:800;margin:0 0 3px;">Standard: 2–3 Weeks</p>
            <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Express service available for urgent cases</p>
          </div>
        </div>

        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;margin-bottom:20px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Factors That Affect Processing Time</h3>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {timingFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.98rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>

        <div style="background:#2D3748;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#fff;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required</h3>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {[
              "Original certificate or notarized copy",
              "Passport copy of the certificate holder",
              "Authorization letter (if submitting through a representative)",
              "Supporting documents as required by document type",
              "Certified Arabic translation (if required by UAE authority)",
            ].map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.98rem;color:#B2F5EA;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">✓</span>{d}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ STATE vs FEDERAL DOCUMENTS ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:48px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Document Types</p>
      <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0;">State vs Federal Documents — Understanding the Difference</h2>
    </div>

    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:32px;">
      <!-- State Documents -->
      <div style="background:#F8FAFF;border:1px solid #eef0f6;border-radius:20px;overflow:hidden;">
        <div style="position:relative;height:200px;">
