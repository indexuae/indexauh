---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro'

const purposes = [
  { icon: "💼", title: "Employment Visas", desc: "Saudi employment visas and work permits require attested educational and personal documents for processing." },
  { icon: "👪", title: "Family & Dependent Visa", desc: "Attested birth and marriage certificates are required for family and dependent visa applications in Saudi Arabia." },
  { icon: "🎓", title: "Education & Licensing", desc: "Degree attestation is mandatory for professionals seeking educational qualification recognition in Saudi Arabia." },
  { icon: "🏢", title: "Business Registration", desc: "Commercial documents must be attested for business registration and commercial activities in Saudi Arabia." },
  { icon: "🛂", title: "Government Ministries", desc: "Saudi government ministries require attested documents to confirm legal validity and prevent fraud." },
  { icon: "📜", title: "Legal & Civil Matters", desc: "Divorce, death, and medical certificates need attestation for legal registration and official proceedings." },
]

const docTypes = [
  {
    category: "Personal Documents",
    icon: "👤",
    docs: [
      "Birth certificate attestation",
      "Marriage certificate attestation",
      "Divorce certificate attestation",
      "Death certificate attestation",
      "Medical certificate attestation",
      "Salary certificate attestation",
      "Transfer certificate attestation",
      "Saudi Police Clearance Certificate",
      "Affidavit",
    ]
  },
  {
    category: "Educational Documents",
    icon: "🎓",
    docs: [
      "Saudi degree certificates",
      "Diploma certificates",
      "School leaving certificates",
      "Mark sheets and transcripts",
      "Professional qualification certificates",
    ]
  },
  {
    category: "Commercial Documents",
    icon: "🏢",
    docs: [
      "Memorandum of Association (MOA)",
      "Articles of Association (AOA)",
      "Certificate of Incorporation",
      "Board Resolutions",
      "Commercial Invoices",
      "Power of Attorney",
      "Business contracts",
      "Commercial License",
    ]
  },
]

const steps = [
  { step: "01", title: "Verification & Translation", desc: "Your documents are checked for authenticity. Arabic translation is completed if required before any further processing." },
  { step: "02", title: "Issuing Authority Attestation", desc: "The issuing authority or department verifies the original document to confirm it is genuine and complete." },
  { step: "03", title: "Ministry of External Affairs (MEA)", desc: "The document is attested by the relevant ministry to confirm it is valid for international use." },
  { step: "04", title: "Saudi Embassy / Saudi MOFA Attestation", desc: "The Saudi Embassy in UAE or the Saudi Ministry of Foreign Affairs attests the document for final legalization." },
  { step: "05", title: "UAE MOFA Attestation (if needed)", desc: "If your document will be used in the UAE after Saudi attestation, UAE MOFA attestation is completed as a final step." },
]

const timingFactors = [
  "Document type — degrees and educational certificates take longer than personal documents",
  "Issuing authority verification — some authorities take more time to confirm authenticity",
  "Arabic translation — documents not in Arabic must be translated and certified first",
  "Ministry and embassy workload — Saudi MOFA or embassy may take longer during busy periods",
  "Correct submission — incomplete documents or missing copies can cause delays",
  "Urgency requests — express services can shorten timelines but may involve additional charges",
]

const docsRequired = [
  "Original certificate",
  "Passport copy",
  "Supporting documents (like visa or employment offer)",
  "Authorization letter (if applicable)",
]

const feeFactors = [
  "Document type",
  "Translation needs",
  "Urgency",
  "Embassy and ministry charges",
]

const mistakes = [
  "Wrong attestation order",
  "Missing <a href='/legal-translation-in-uae/' style='color:#4B5563;font-weight:700;text-decoration:underline;text-decoration-color:#E53E3E;text-underline-offset:3px;'>legal translation</a>",
  "Name mismatches between passport and certificate",
  "Submitting incomplete documents",
]

const getStartedSteps = [
  { step: "01", title: "Contact IndexAUH", desc: "Send us the details of your documents. Our team will review them and advise the correct attestation path." },
  { step: "02", title: "Document Verification & Guidance", desc: "We check the documents, confirm translation needs, and verify which ministries and authorities are involved." },
  { step: "03", title: "Submission and Processing", desc: "Submit your original or copy as instructed. We manage all interactions with ministries and the embassy." },
  { step: "04", title: "Attestation Completion & Delivery", desc: "Once attested, your documents are safely returned to you, ready for use in Saudi Arabia." },
]

const benefits = [
  { title: "25+ Years of Experience", desc: "Over two decades of handling Saudi <a href='/certificate-attestation-in-dubai/' style='color:#CBD5E0;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;'>certificate attestation in Dubai</a>, UAE, Abu Dhabi and across the GCC with deep knowledge of all procedures." },
  { title: "End-to-End Handling", desc: "We manage everything from document verification and Arabic translation to ministry and Saudi embassy attestation — all under one roof." },
  { title: "Safe & Confidential", desc: "Your documents are handled with strict confidentiality, secure physical transfer protocols, and tracked at every stage of the process." },
  { title: "Competitive Pricing", desc: "Transparent, affordable pricing with no hidden fees. Costs depend on document type, translation needs, urgency and embassy charges." },
  { title: "Doorstep Collection & Delivery", desc: "We offer doorstep pickup and delivery options available across the UAE so you never have to leave your office or home." },
  { title: "Expert Compliance Team", desc: "Dedicated compliance experts with real-time process updates ensure your Saudi attestation is smooth and hassle-free from start to finish." },
]

const faqs = [
  { q: "How long does Saudi certificate attestation take?", a: "The time depends on the document type, issuing country, and embassy processing. Educational and degree certificates usually take longer than personal documents. Some cases may take more time due to verification checks. Contact us for a realistic timeline based on your specific documents." },
  { q: "What documents are required for Saudi attestation?", a: "The basic documents required are the original certificate, a passport copy of the applicant, and an authorization letter. Educational documents may also need mark sheets or transcripts. Commercial documents require company authorization and supporting papers." },
  { q: "Is MOFA attestation mandatory for Saudi Arabia?", a: "Yes. MOFA attestation is a required step in the Saudi attestation process. Documents cannot move to Saudi embassy attestation without prior MOFA approval. This applies to both educational and personal documents." },
  { q: "Can Saudi attestation be done in UAE?", a: "Yes. Saudi attestation can be completed entirely in the UAE. The complete process, including MOFA and Saudi embassy attestation in UAE, can be handled without travelling to Saudi Arabia. Index Office Services manages everything on your behalf." },
  { q: "What are the common mistakes to avoid in Saudi attestation?", a: "The most common mistakes include following the wrong attestation order, missing legal Arabic translation, name mismatches between documents, and submitting incomplete documents. Our team guides you to avoid all these issues from the start." },
]
import DocumentCoverage from '../components/DocumentCoverage.astro';
---

<BaseLayout
  title="Saudi Certificate Attestation in UAE | Indexauh"
  description="Saudi Certificate Attestation in UAE by IndexAUH. 25+ years of trusted experience, end-to-end handling, fast service. Contact us today."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .split-grid { display: grid !important; }
  .three-col { display: grid !important; }
  .two-col { display: grid !important; }
  .get-started-grid { display: grid !important; }

  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .get-started-grid { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-47.webp"
    alt="Saudi Certificate Attestation in UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 12px;">
      SAUDI CERTIFICATE ATTESTATION IN UAE
    </h1>
    <p style="color:#38B2AC;font-size:1.05rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 20px;">MOFA Attestation KSA | Degree Attestation | 25 Years of Trust</p>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      Getting your documents attested for Saudi Arabia is essential for employment, family visas, education, and business purposes. At IndexAUH, we provide complete Saudi document attestation services in UAE — handling all steps from document verification to embassy attestation.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is Saudi Certificate Attestation?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Saudi certificate attestation is the process of verifying and legalizing documents to make them acceptable in Saudi Arabia. This includes educational certificates, personal documents like birth or marriage certificates, and commercial papers.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        The process is recognized by Saudi authorities and involves multiple steps, including ministry verification, embassy attestation, and sometimes <a href="/mofa-attestation-in-uae/" style="color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;">UAE MOFA attestation</a>. Completing this process ensures your documents are officially valid in Saudi Arabia.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:20px;">
        With over 25 years of experience, Index Office Services ensures your documents are processed quickly and securely — handling everything from start to finish on your behalf.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Key Insight — Saudi MOFA Attestation</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          Saudi attestation typically requires MOFA approval before Saudi embassy attestation can be completed. Documents cannot move to the Saudi embassy stage without prior Ministry of Foreign Affairs verification.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/saudi-flag.webp" alt="Saudi Arabia document attestation" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">MEA · Saudi Embassy · MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete Saudi attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY IS SAUDI ATTESTATION REQUIRED ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-7.webp" alt="Why Saudi attestation is required" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Why Saudi Attestation Matters</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Work · Family · Education · Business</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Core Reasons</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Why Is Saudi Attestation Required?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          Saudi certificate attestation is necessary for a wide range of official purposes. Whether you are relocating for work, applying for a family visa, registering a business, or studying in Saudi Arabia, your documents must be officially verified before they are accepted by Saudi authorities.
        </p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px;">
          {purposes.map(p => (
            <div style="background:#fff;border:1px solid #eef0f6;border-radius:14px;padding:18px;">
              <div style="font-size:1.6rem;margin-bottom:10px;">{p.icon}</div>
              <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0 0 6px;">{p.title}</h3>
              <p style="font-size:0.76rem;color:#4B5563;line-height:1.55;margin:0;">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<DocumentCoverage
  title="Attestation Services Offered by Index AUH"
  description="Index AUH provides Saudi certificate attestation services for a wide range of document categories — personal, educational, and commercial. Always check with the requesting authority to confirm exactly what form of attestation is required."
  imageSrc="/images/img-16.webp"
  imageAlt="Document types for Saudi attestation"
  docTypes={docTypes}
  country="saudi"
/>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-8.webp" alt="Saudi attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Saudi Certificate Attestation Process in UAE</h2>
      </div>
    </div>

    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;">
      <div style="display:flex;flex-direction:column;gap:14px;">
        {steps.map(s => (
          <div class="step-card">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div style="display:flex;flex-direction:column;gap:20px;">
        <!-- Documents Required -->
        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Documents Required for Saudi Certificate Attestation</h3>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {docsRequired.map(d => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{d}
              </div>
            ))}
          </div>
        </div>

<!-- Timing -->
<div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
  <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Factors That Affect Processing Time</h3>
  <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">Educational and degree certificates usually take longer than personal documents like birth or marriage certificates. Processing time depends on:</p>
  <div style="display:flex;flex-direction:column;gap:9px;">
    {timingFactors.map(f => (
      <div style="display:flex;align-items:flex-start;gap:10px;font-size:0.88rem;color:#4B5563;">
        <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;margin-top:2px;">→</span>{f}
      </div>
    ))}
  </div>
  <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:14px 0 0;">At <a href="/" style="color:#1A202C;font-weight:700;text-decoration:underline;text-decoration-color:#38B2AC;text-underline-offset:3px;">Index attestation</a>, we guide you through all steps and provide realistic timelines based on your document type and requirements, ensuring your Saudi attestation process is smooth and hassle free.</p>
</div>

        <!-- Cost -->
        <div style="background:#fff;border:1px solid #eef0f6;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:12px;">Cost of Saudi Certificate Attestation</h3>
          <p style="font-size:0.85rem;color:#6B7280;line-height:1.6;margin:0 0 14px;">We provide transparent pricing with no hidden charges. The cost depends on:</p>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {feeFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DEGREE ATTESTATION HIGHLIGHT ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-90.webp" alt="Saudi degree certificate attestation" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.78) 100%);"></div>
