---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="section-badge">Kerala's #1 Digital Academy</div>
      <h1 class="hero-title">
        Build a Career in the <span class="highlight">Digital Economy</span>
      </h1>
      <p class="hero-desc">
        Practical, job-oriented training in Digital Marketing, AI Tools, and Tech skills. 
        Join 1500+ students who are already building real careers.
      </p>
      <div class="hero-actions">
        <a href="/courses" class="btn btn-primary">Explore Courses →</a>
        <a href="/about" class="btn btn-outline">Learn More</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <strong>1500+</strong>
          <span>Students</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <strong>20+</strong>
          <span>Courses</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <strong>95%</strong>
          <span>Placement Rate</span>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-card">
        <div class="card-header">
          <span class="card-dot green"></span>
          <span class="card-dot yellow"></span>
          <span class="card-dot red"></span>
        </div>
        <div class="card-content">
          <div class="course-item">
            <div class="course-icon" style="background:#E0F2F1">📊</div>
            <div>
              <div class="course-name">Digital Marketing</div>
              <div class="course-meta">48 lessons · Beginner</div>
            </div>
            <span class="badge">Popular</span>
          </div>
          <div class="course-item">
            <div class="course-icon" style="background:#FFF3E0">🤖</div>
            <div>
              <div class="course-name">AI Tools Mastery</div>
              <div class="course-meta">32 lessons · All levels</div>
            </div>
            <span class="badge new">New</span>
          </div>
          <div class="course-item">
            <div class="course-icon" style="background:#F3E5F5">💻</div>
            <div>
              <div class="course-name">Web Development</div>
              <div class="course-meta">64 lessons · Intermediate</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 100px 0 80px;
    background: linear-gradient(135deg, #F0FFF9 0%, #FFFFFF 60%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .hero-title {
    font-size: 52px;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -1px;
    margin-bottom: 20px;
    color: var(--text-main);
  }

  .highlight {
    color: var(--primary);
    position: relative;
  }

  .hero-desc {
    font-size: 17px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .stat strong {
    display: block;
    font-size: 24px;
    font-weight: 800;
    color: var(--text-main);
    line-height: 1;
  }

  .stat span {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 4px;
    display: block;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--border-color);
  }

  /* Hero card */
  .hero-card {
    background: white;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    border: 1px solid var(--border-color);
  }

  .card-header {
    background: var(--bg-light);
    padding: 14px 20px;
    display: flex;
    gap: 8px;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
  }

  .card-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .card-dot.green { background: #34C759; }
  .card-dot.yellow { background: #FFCC00; }
  .card-dot.red { background: #FF3B30; }

  .card-content {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .course-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    transition: all 0.2s;
  }

  .course-item:hover {
    border-color: var(--primary);
    background: var(--primary-light);
  }

  .course-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }

  .course-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-main);
  }

  .course-meta {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .badge {
    margin-left: auto;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 100px;
    background: var(--primary-light);
    color: var(--primary-dark);
    white-space: nowrap;
  }

  .badge.new {
    background: #FFF3E0;
    color: #E65100;
  }

  @media (max-width: 992px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero-title { font-size: 40px; }
  }

  @media (max-width: 768px) {
    .hero { padding: 60px 0; }
    .hero-title { font-size: 32px; }
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { justify-content: center; }
  }
</style>
