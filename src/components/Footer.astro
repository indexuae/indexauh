<script>
  function updateFooterLayout() {
    const main = document.getElementById('fmain');
    const brand = document.getElementById('fbrand');
    const cols = main ? main.querySelectorAll('.fcol') : [];
    const bar = document.getElementById('fbar');
    const w = window.innerWidth;

    if (!main) return;

    if (w < 640) {
      // Mobile: single column for everything
      main.style.flexDirection = 'column';
      main.style.padding = '36px 20px 32px 20px';
      if (brand) {
        brand.style.flex = '0 0 auto';
        brand.style.width = '100%';
        brand.style.minWidth = '0';
      }
      cols.forEach(col => {
        col.style.flex = '0 0 auto';
        col.style.width = '100%';
        col.style.minWidth = '0';
      });
      // Larger text on mobile
      main.querySelectorAll('a[href]').forEach(a => {
        a.style.fontSize = '15px';
      });
      if (bar) {
        bar.style.flexDirection = 'column';
        bar.style.alignItems = 'center';
        bar.style.textAlign = 'center';
        bar.style.padding = '16px 20px';
      }
    } else if (w < 1024) {
      // Tablet: brand full width on top, then 2-column links
      main.style.flexDirection = 'row';
      main.style.padding = '48px 28px 36px 28px';
      if (brand) {
        brand.style.flex = '0 0 100%';
        brand.style.width = '100%';
        brand.style.minWidth = '0';
      }
      cols.forEach(col => {
        col.style.flex = '0 0 calc(50% - 14px)';
        col.style.width = 'calc(50% - 14px)';
        col.style.minWidth = '0';
      });
      main.querySelectorAll('a[href]').forEach(a => {
        a.style.fontSize = '13.5px';
      });
      if (bar) {
        bar.style.flexDirection = 'row';
        bar.style.alignItems = 'center';
        bar.style.textAlign = 'left';
        bar.style.padding = '18px 28px';
      }
    } else {
      // Desktop: brand + all 4 link cols in one row
      main.style.flexDirection = 'row';
      main.style.padding = '56px 32px 40px 32px';
      if (brand) {
        brand.style.flex = '0 0 220px';
        brand.style.width = 'auto';
        brand.style.minWidth = '180px';
      }
      cols.forEach(col => {
        col.style.flex = '1';
        col.style.width = 'auto';
        col.style.minWidth = '160px';
      });
      main.querySelectorAll('a[href]').forEach(a => {
        a.style.fontSize = '13.5px';
      });
      if (bar) {
        bar.style.flexDirection = 'row';
        bar.style.alignItems = 'center';
        bar.style.textAlign = 'left';
        bar.style.padding = '18px 32px';
      }
    }
  }

  updateFooterLayout();
  window.addEventListener('resize', updateFooterLayout);
</script>

<style is:global>
  footer a:hover { color: #38B2AC !important; }
</style>